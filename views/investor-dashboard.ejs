<%- include("partials/header") %>

<style>
  .invd-page { max-width: 480px; margin: 2rem auto; padding: 0 1rem 3rem; }
  .invd-card {
    background: linear-gradient(135deg, #0f0c29 0%, #1a1a4e 60%, #0d1b2a 100%);
    border-radius: 24px;
    padding: 2.5rem 2rem;
    color: #fff;
    text-align: center;
    box-shadow: 0 24px 64px rgba(0,0,0,0.45);
    position: relative;
    overflow: hidden;
  }
  .invd-card::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 200px; height: 200px;
    background: rgba(99,102,241,0.15);
    border-radius: 50%;
    pointer-events: none;
  }
  .invd-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(22,163,74,0.2);
    border: 1px solid rgba(22,163,74,0.4);
    color: #4ade80;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 99px;
    margin-bottom: 1.5rem;
  }
  .invd-status::before { content: '●'; font-size: 0.6rem; }
  .invd-avatar {
    width: 90px; height: 90px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(255,255,255,0.2);
    margin: 0 auto 1rem;
    display: block;
  }
  .invd-avatar-placeholder {
    width: 90px; height: 90px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem; font-weight: 800; color: #fff;
    margin: 0 auto 1rem;
  }
  .invd-name { font-size: 1.5rem; font-weight: 800; margin: 0 0 0.2rem; }
  .invd-designation {
    font-size: 0.82rem;
    color: #94a3b8;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }
  .invd-divider { border: none; border-top: 1px solid rgba(255,255,255,0.1); margin: 0 0 2rem; }
  .invd-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
  .invd-stat {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1rem 0.75rem;
  }
  .invd-stat-val { font-size: 1.25rem; font-weight: 800; color: #fbbf24; }
  .invd-stat-lbl { font-size: 0.68rem; color: #94a3b8; margin-top: 0.25rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .invd-stat-full {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1rem 0.75rem;
    margin-bottom: 1rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    text-align: left;
  }
  .invd-dt { font-size: 0.72rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.15rem; }
  .invd-dd { font-size: 0.95rem; font-weight: 600; color: #e2e8f0; }
  .invd-actions { display: flex; gap: 0.75rem; margin-top: 1.5rem; }
  .invd-btn {
    flex: 1; padding: 0.75rem;
    border: none; border-radius: 10px;
    font-size: 0.85rem; font-weight: 600;
    cursor: pointer; text-decoration: none;
    text-align: center; display: block;
    transition: opacity 0.2s;
  }
  .invd-btn:hover { opacity: 0.85; }
  .invd-btn-primary { background: #6366f1; color: #fff; }
  .invd-btn-secondary { background: rgba(255,255,255,0.1); color: #e2e8f0; }
  .invd-back { display: block; text-align: center; margin-top: 1.5rem; color: #6b7280; font-size: 0.85rem; text-decoration: none; }
  .invd-back:hover { color: #374151; }
</style>

<main>
<div class="invd-page">
  <div class="invd-card">
    <div class="invd-status">Active Investor</div>

    <% if (profileImageUrl) { %>
      <img src="<%= profileImageUrl %>" alt="<%= investment.name %>" class="invd-avatar">
    <% } else { %>
      <div class="invd-avatar-placeholder"><%= investment.name.charAt(0).toUpperCase() %></div>
    <% } %>

    <div class="invd-name"><%= investment.name %></div>
    <div class="invd-designation">Investor · SmrAI Studio</div>
    <hr class="invd-divider">

    <div class="invd-stats">
      <div class="invd-stat">
        <div class="invd-stat-val">₹<%= Number(investment.amount).toLocaleString('en-IN') %></div>
        <div class="invd-stat-lbl">Invested Amount</div>
      </div>
      <div class="invd-stat">
        <div class="invd-stat-val"><%= investment.equity_percent %>%</div>
        <div class="invd-stat-lbl">Equity Ownership</div>
      </div>
    </div>

    <div class="invd-stat" style="margin-bottom:1rem;padding:1rem 0.75rem;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:12px">
      <div class="invd-stat-val" style="font-size:1.1rem">₹<%= Number(investment.valuation).toLocaleString('en-IN') %></div>
      <div class="invd-stat-lbl">Company Valuation</div>
    </div>

    <div class="invd-stat-full">
      <div>
        <div class="invd-dt">Investment Date</div>
        <div class="invd-dd"><%= new Date(investment.created_at).toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'}) %></div>
      </div>
      <div>
        <div class="invd-dt">Investment Time</div>
        <div class="invd-dd"><%= new Date(investment.created_at).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit',hour12:true}) %></div>
      </div>
    </div>

    <div class="invd-actions">
      <a href="/investor/history" class="invd-btn invd-btn-secondary">View History</a>
      <a href="/admin" class="invd-btn invd-btn-primary">Admin Panel</a>
    </div>
  </div>
  <a href="/admin" class="invd-back">← Back to Admin Panel</a>
</div>
</main>

<%- include("partials/footer") %>
