// ── Load templates list ──────────────────────────────────────────────────────
async function loadTemplates() {
  try {
    const r = await fetch("/admin/api/templates");
    const d = await r.json();
    if (d.success) {
      tplList = d.templates;
      renderTplTable();
      tplLoaded = true;
    }
  } catch (err) { console.error("loadTemplates:", err); }
}

function renderTplTable() {
  const tbody = document.getElementById("admTplTableBody");
  const total = tplList.length;
  const pub   = tplList.filter(t => t.is_published).length;
  document.getElementById("admTplTotal").textContent     = total;
  document.getElementById("admTplPublished").textContent = pub;
  document.getElementById("admTplDraft").textContent     = total - pub;

  if (!total) {
    tbody.innerHTML = `<tr id="admTplEmptyRow"><td colspan="7" style="text-align:center;color:#6b7280;padding:2rem;">No templates yet. Click <strong>Create Template</strong> to get started.</td></tr>`;
    return;
  }
  tbody.innerHTML = tplList.map(t => `
    <tr>
      <td>
        ${t.thumbnail_url
          ? `<img src="${escHtml(t.thumbnail_url)}" style="width:60px;height:40px;object-fit:cover;border-radius:4px;border:1px solid #e5e7eb;">`
          : `<div style="width:60px;height:40px;background:#f1f5f9;border-radius:4px;border:1px solid #e5e7eb;display:flex;align-items:center;justify-content:center;color:#9ca3af;font-size:0.65rem;">No img</div>`
        }
      </td>
      <td>
        <strong>${escHtml(t.title)}</strong>
        ${t.badge ? `<span class="adm-tpl-badge-chip">${escHtml(t.badge)}</span>` : ""}
      </td>
      <td style="text-transform:capitalize;">${escHtml(t.category)}</td>
      <td style="font-size:0.78rem;color:#6b7280;">${escHtml(t.layout_type || '')}</td>
      <td style="font-size:0.8rem;">${t.enabled_sections ?? '—'}</td>
      <td>
        <span class="adm-tpl-status-pill ${t.is_published ? 'adm-tpl-status-pub' : 'adm-tpl-status-draft'}">
          ${t.is_published ? 'Published' : 'Draft'}
        </span>
      </td>
      <td>
        <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
          <button class="adm-tbl-action-btn" onclick="openBuilder(${t.id})" title="Edit">
            <i class="fas fa-edit"></i>
          </button>
          <button class="adm-tbl-action-btn ${t.is_published ? 'adm-tbl-btn-orange' : 'adm-tbl-btn-green'}"
            onclick="togglePublish(${t.id})" title="${t.is_published ? 'Unpublish' : 'Publish'}">
            <i class="fas fa-${t.is_published ? 'eye-slash' : 'globe'}"></i>
          </button>
          <button class="adm-tbl-action-btn adm-tbl-btn-red" onclick="deleteTemplate(${t.id})" title="Delete">
            <i class="fas fa-trash-alt"></i>
          </button>
        </div>
      </td>
    </tr>
  `).join("");
}

function escHtml(s) {
  return String(s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}

function showAdmToast(msg, type) {
  var t = document.createElement('div');
  t.textContent = msg;
  t.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;'
    + 'padding:0.7rem 1.25rem;border-radius:10px;font-size:0.85rem;font-weight:600;'
    + 'color:#fff;box-shadow:0 4px 16px rgba(0,0,0,0.35);pointer-events:none;transition:opacity 0.4s;'
    + (type === 'error' ? 'background:#dc2626;' : 'background:#16a34a;');
  document.body.appendChild(t);
  setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 400); }, 2500);
}

// ── Builder panel open / close ───────────────────────────────────────────────
document.getElementById("admTplCreateBtn").addEventListener("click", () => openBuilder(null));
document.getElementById("admTplBuilderClose").addEventListener("click", closeBuilder);

// Click on the dark backdrop (outside inner panel) to close
document.getElementById("admTplBuilder").addEventListener("click", function(e) {
  if (e.target === this) closeBuilder();
});

// ESC key closes the builder
document.addEventListener("keydown", function(e) {
  if (e.key === "Escape" && !document.getElementById("admTplBuilder").hidden) closeBuilder();
});

function openBuilder(id) {
  builderTplId = id;
  const tpl    = id ? tplList.find(t => t.id === id) : null;
  document.getElementById("admTplBuilderTitle").textContent = id ? "Edit Template" : "Create Template";

  // Reset form
  document.getElementById("admTplTitle").value    = tpl?.title       || "";
  document.getElementById("admTplDesc").value     = tpl?.description || "";
  document.getElementById("admTplCategory").value = tpl?.category    || "experienced";
  document.getElementById("admTplBadge").value    = tpl?.badge       || "New";

  const cs = tpl?.color_scheme || {};
  document.getElementById("admTplColorPrimary").value   = cs.primary   || "#1e3a5f";
  document.getElementById("admTplColorSecondary").value = cs.secondary || "#f3f4f6";
  document.getElementById("admTplColorAccent").value    = cs.accent    || "#3b82f6";
  document.getElementById("admTplColorText").value      = cs.text      || "#1f2937";

  // Layout radio
  const layoutVal = tpl?.layout_type || "two-column-left";
  document.querySelectorAll("input[name='admTplLayout']").forEach(r => {
    r.checked = r.value === layoutVal;
  });

  // Pricing
  document.getElementById("admTplIsPaid").checked = tpl ? tpl.is_paid : true;
  document.getElementById("admTplPrice").value    = tpl?.price_inr || CATEGORY_PRICE[document.getElementById("admTplCategory").value] || 49;
  document.getElementById("admTplPriceWrap").style.display = tpl ? (tpl.is_paid ? "" : "none") : "";

  // Thumbnail
  const thumbBox = document.getElementById("admTplThumbBox");
  const thumbImg = document.getElementById("admTplThumb");
  if (tpl?.thumbnail_url) {
    thumbImg.src   = tpl.thumbnail_url;
    thumbBox.hidden = false;
  } else {
    thumbBox.hidden = true;
  }

  // Reset thumbnail status
  document.getElementById("admTplThumbStatus").textContent = "";

  // Background image
  setAdmBgPreview(tpl?.background_image_url || null);
  document.getElementById("admTplBgStatus").textContent = "";

  // Design settings
  const ds = tpl?.design_settings || {};
  document.getElementById("dsFont").value              = ds.fontFamily        || "segoe";
  document.getElementById("dsHeadingWeight").value     = ds.headingWeight     || "800";
  document.getElementById("dsBodySize").value          = ds.bodySize          || "medium";
  document.getElementById("dsBorderRadius").value      = ds.borderRadius      || "soft";
  document.getElementById("dsShadow").value            = ds.shadow            || "none";
  document.getElementById("dsSectionTitleStyle").value = ds.sectionTitleStyle || "underline";
  document.getElementById("dsHeaderStyle").value       = ds.headerStyle       || "classic";
  document.getElementById("dsPillShape").value         = ds.pillShape         || "rounded";

  // Sections
  renderSectionsList(tpl ? null : null); // load from API if editing
  if (id) {
    fetch(`/admin/api/templates/${id}/sections`)
      .then(r => r.json())
      .then(d => d.success && renderSectionsList(d.sections))
      .catch(() => {});
  }

  // Switch to first tab
  switchTplTab("basic");
  document.getElementById("admTplBuilderError").hidden = true;
  document.getElementById("admTplBuilder").hidden = false;
  document.getElementById("admTplBuilder").scrollTop = 0;

  // Enable preview links if editing existing template
  if (id) updatePreviewLinks();
}

function closeBuilder() {
  document.getElementById("admTplBuilder").hidden = true;
  builderTplId = null;
}

// ── Tab switching ────────────────────────────────────────────────────────────
const TAB_ORDER = ["basic", "layout", "sections", "design", "pricing", "preview"];

document.querySelectorAll(".adm-tpl-tab").forEach(tab => {
  tab.addEventListener("click", () => switchTplTab(tab.dataset.tab));
});

document.getElementById("admTplNextBtn").addEventListener("click", () => {
  const cur = TAB_ORDER.indexOf(currentTab());
  if (cur < TAB_ORDER.length - 1) switchTplTab(TAB_ORDER[cur + 1]);
});
document.getElementById("admTplBackBtn").addEventListener("click", () => {
  const cur = TAB_ORDER.indexOf(currentTab());
  if (cur > 0) switchTplTab(TAB_ORDER[cur - 1]);
});

function currentTab() {
  const active = document.querySelector(".adm-tpl-tab.active");
  return active ? active.dataset.tab : "basic";
}

function switchTplTab(name) {
  document.querySelectorAll(".adm-tpl-tab").forEach(t => t.classList.toggle("active", t.dataset.tab === name));
  document.querySelectorAll(".adm-tpl-tab-content").forEach(c => c.classList.toggle("active", c.dataset.tabContent === name));
  if (name === "preview" && builderTplId) updatePreviewLinks();
  // Update Back / Next buttons
  const idx = TAB_ORDER.indexOf(name);
  document.getElementById("admTplBackBtn").hidden = idx <= 0;
  document.getElementById("admTplNextBtn").hidden = idx >= TAB_ORDER.length - 1;
}

// ── Preview tab helpers ───────────────────────────────────────────────────────
function updatePreviewLinks() {
  if (!builderTplId) return;
  const tpl = tplList.find(t => t.id === builderTplId);
  if (!tpl) return;
  const previewUrl = `/admin/preview/${tpl.slug}`;

  // Footer preview button
  const footerBtn = document.getElementById("admTplPreviewBtn");
  footerBtn.href = previewUrl;
  footerBtn.style.display = "";

  // Preview tab
  document.getElementById("admPreviewHint").hidden = true;
  document.getElementById("admPreviewFrame").hidden = false;
  document.getElementById("admPreviewOpenBtn").href = previewUrl;
  const iframe = document.getElementById("admPreviewIframe");
  if (!iframe.src || iframe.src === window.location.href) {
    iframe.src = previewUrl + "?compact=1";
  }
}

document.getElementById("admPreviewRefreshBtn").addEventListener("click", async () => {
  await saveTemplate(false, true);
  const tpl = tplList.find(t => t.id === builderTplId);
  if (tpl) {
    document.getElementById("admPreviewIframe").src = `/admin/preview/${tpl.slug}?compact=1&t=${Date.now()}`;
  }
});

// ── Paid toggle ──────────────────────────────────────────────────────────────
document.getElementById("admTplIsPaid").addEventListener("change", function() {
  document.getElementById("admTplPriceWrap").style.display = this.checked ? "" : "none";
});

// ── Category → default price ──────────────────────────────────────────────────
const CATEGORY_PRICE = { experienced: 49, fresher: 29, developer: 59, "ats-friendly": 69 };
document.getElementById("admTplCategory").addEventListener("change", function() {
  const priceInput = document.getElementById("admTplPrice");
  // Only auto-fill if admin hasn't manually changed the price from any category default
  const currentDefault = Object.values(CATEGORY_PRICE);
  if (currentDefault.includes(+priceInput.value) || priceInput.value === "") {
    priceInput.value = CATEGORY_PRICE[this.value] ?? 49;
  }
});

// ── Sections list renderer ───────────────────────────────────────────────────
let sectionStates = {}; // { key: { enabled, order } }

function renderSectionsList(apiSections) {
  // Build state from API or defaults
  sectionStates = {};
  SECTION_DEFS.forEach((s, i) => {
    const api = apiSections ? apiSections.find(a => a.section_key === s.key) : null;
    sectionStates[s.key] = {
      enabled:        api ? api.is_enabled      : !s.defaultDisabled,
      order:          api ? api.sort_order      : i,
      placement:      api ? (api.placement      || s.defaultPlacement) : s.defaultPlacement,
      display_type:   api ? (api.display_type   || s.defaultDisplay)   : s.defaultDisplay,
      label_override: api ? (api.label_override || null)               : null,
    };
  });

  const container = document.getElementById("admTplSectionsList");
  container.innerHTML = SECTION_DEFS
    .slice()
    .sort((a, b) => sectionStates[a.key].order - sectionStates[b.key].order)
    .map(s => {
      const st = sectionStates[s.key];
      return `
      <div class="adm-tpl-section-row" draggable="true" data-sec="${s.key}">
        <i class="fas fa-grip-vertical adm-tpl-drag-handle"></i>
        <span class="adm-tpl-sec-label">${st.label_override || s.label}${s.defaultDisabled ? ' <span class="adm-sec-badge-new">NEW</span>' : ''}</span>
        <div class="adm-tpl-sec-actions">
          <button type="button" class="adm-tpl-sec-settings-btn" data-sec-key="${s.key}" title="Section settings">
            <i class="fas fa-cog"></i>
          </button>
          <label class="adm-tpl-toggle">
            <input type="checkbox" data-sec-key="${s.key}" ${st.enabled ? "checked" : ""} />
            <span class="adm-tpl-toggle-slider"></span>
          </label>
        </div>
      </div>
      <div class="adm-tpl-sec-settings-panel" data-sec-panel="${s.key}" hidden>
        <div class="adm-tpl-sec-settings-row">
          <div class="adm-tpl-sec-setting">
            <label>Placement</label>
            <select data-sec-placement="${s.key}">
              <option value="auto"    ${st.placement === 'auto'    ? 'selected' : ''}>Auto</option>
              <option value="sidebar" ${st.placement === 'sidebar' ? 'selected' : ''}>Sidebar</option>
              <option value="main"    ${st.placement === 'main'    ? 'selected' : ''}>Main</option>
            </select>
          </div>
          <div class="adm-tpl-sec-setting">
            <label>Display Style</label>
            <select data-sec-display="${s.key}">
              <option value="bullets"  ${st.display_type === 'bullets'  ? 'selected' : ''}>Bullets</option>
              <option value="pills"    ${st.display_type === 'pills'    ? 'selected' : ''}>Pills / Tags</option>
              <option value="plain"    ${st.display_type === 'plain'    ? 'selected' : ''}>Plain text</option>
              <option value="timeline" ${st.display_type === 'timeline' ? 'selected' : ''}>Timeline</option>
            </select>
          </div>
          <div class="adm-tpl-sec-setting adm-tpl-sec-setting-wide">
            <label>Label Override</label>
            <input type="text" data-sec-label="${s.key}" value="${st.label_override || ''}" placeholder="${s.label}" />
          </div>
        </div>
      </div>`;
    }).join("");

  // Sync checkbox changes to state
  container.querySelectorAll("input[data-sec-key]").forEach(cb => {
    cb.addEventListener("change", () => {
      sectionStates[cb.dataset.secKey].enabled = cb.checked;
    });
  });

  // Settings button toggle
  container.querySelectorAll(".adm-tpl-sec-settings-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const key = btn.dataset.secKey;
      const panel = container.querySelector(`[data-sec-panel="${key}"]`);
      if (panel) panel.hidden = !panel.hidden;
    });
  });

  // Sync placement / display / label changes to state
  container.querySelectorAll("[data-sec-placement]").forEach(sel => {
    sel.addEventListener("change", () => { sectionStates[sel.dataset.secPlacement].placement = sel.value; });
  });
  container.querySelectorAll("[data-sec-display]").forEach(sel => {
    sel.addEventListener("change", () => { sectionStates[sel.dataset.secDisplay].display_type = sel.value; });
  });
  container.querySelectorAll("[data-sec-label]").forEach(inp => {
    inp.addEventListener("input", () => {
      const key = inp.dataset.secLabel;
      sectionStates[key].label_override = inp.value.trim() || null;
      // Update visible label in row
      const row = container.querySelector(`[data-sec="${key}"] .adm-tpl-sec-label`);
      if (row) {
        const def = SECTION_DEFS.find(d => d.key === key);
        const badge = def && def.defaultDisabled ? ' <span class="adm-sec-badge-new">NEW</span>' : '';
        row.innerHTML = (inp.value.trim() || (def && def.label) || key) + badge;
      }
    });
  });

  // Drag-and-drop reordering
  let dragSrc = null;
  container.querySelectorAll(".adm-tpl-section-row").forEach(row => {
    row.addEventListener("dragstart", () => { dragSrc = row; row.style.opacity = "0.4"; });
    row.addEventListener("dragend",   () => { dragSrc = null; row.style.opacity = ""; });
    row.addEventListener("dragover",  e  => { e.preventDefault(); row.style.background = "#eff6ff"; });
    row.addEventListener("dragleave", () => { row.style.background = ""; });
    row.addEventListener("drop", e => {
      e.preventDefault();
      row.style.background = "";
      if (dragSrc && dragSrc !== row) {
        container.insertBefore(dragSrc, row);
        // Update order in state
        container.querySelectorAll(".adm-tpl-section-row").forEach((r, i) => {
          sectionStates[r.dataset.sec].order = i;
        });
      }
    });
  });
}

// ── Save Draft / Save & Publish ──────────────────────────────────────────────
document.getElementById("admTplSaveDraft").addEventListener("click", () => saveTemplate(false));
document.getElementById("admTplSavePublish").addEventListener("click", () => saveTemplate(true));

async function saveTemplate(publish, keepOpen) {
  const title = document.getElementById("admTplTitle").value.trim();
  if (!title) {
    showTplError("Title is required.");
    switchTplTab("basic");
    return;
  }

  const color_scheme = {
    primary:   document.getElementById("admTplColorPrimary").value,
    secondary: document.getElementById("admTplColorSecondary").value,
    accent:    document.getElementById("admTplColorAccent").value,
    text:      document.getElementById("admTplColorText").value,
  };
  const layout_type = document.querySelector("input[name='admTplLayout']:checked")?.value || "two-column-left";

  const design_settings = {
    fontFamily:        document.getElementById("dsFont").value,
    headingWeight:     document.getElementById("dsHeadingWeight").value,
    bodySize:          document.getElementById("dsBodySize").value,
    borderRadius:      document.getElementById("dsBorderRadius").value,
    shadow:            document.getElementById("dsShadow").value,
    sectionTitleStyle: document.getElementById("dsSectionTitleStyle").value,
    headerStyle:       document.getElementById("dsHeaderStyle").value,
    pillShape:         document.getElementById("dsPillShape").value,
  };

  const body = {
    title,
    description: document.getElementById("admTplDesc").value.trim(),
    category:    document.getElementById("admTplCategory").value,
    badge:       document.getElementById("admTplBadge").value.trim(),
    layout_type,
    color_scheme,
    design_settings,
    is_paid:   document.getElementById("admTplIsPaid").checked,
    price_inr: parseInt(document.getElementById("admTplPrice").value) || 49,
  };

  try {
    let tplId = builderTplId;
    if (!tplId) {
      // Create
      const r = await fetch("/admin/api/templates", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      const d = await r.json();
      if (!d.success) { showTplError(d.error || "Create failed."); return; }
      tplId      = d.template.id;
      builderTplId = tplId;
      document.getElementById("admTplThumbStatus").textContent = "";
    } else {
      // Update
      const r = await fetch(`/admin/api/templates/${tplId}`, {
        method: "PUT", headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      const d = await r.json();
      if (!d.success) { showTplError(d.error || "Update failed."); return; }
    }

    // Save sections
    const sections = SECTION_DEFS.map(s => ({
      section_key:    s.key,
      is_enabled:     sectionStates[s.key]?.enabled !== false,
      sort_order:     sectionStates[s.key]?.order   || 0,
      placement:      sectionStates[s.key]?.placement     || s.defaultPlacement || 'auto',
      display_type:   sectionStates[s.key]?.display_type  || s.defaultDisplay   || 'bullets',
      label_override: sectionStates[s.key]?.label_override || null,
    }));
    await fetch(`/admin/api/templates/${tplId}/sections`, {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ sections }),
    });

    // Toggle publish if needed
    const existingTpl = tplList.find(t => t.id === tplId);
    if (publish && !(existingTpl?.is_published)) {
      await fetch(`/admin/api/templates/${tplId}/publish`, { method: "POST" });
    }

    // Reload list
    tplLoaded = false;
    await loadTemplates();
    updatePreviewLinks();
    if (!keepOpen) closeBuilder();
  } catch (err) {
    showTplError("Network error: " + err.message);
  }
}

function showTplError(msg) {
  const el = document.getElementById("admTplBuilderError");
  el.textContent = msg;
  el.hidden = false;
}

// ── Toggle publish from table ────────────────────────────────────────────────
async function togglePublish(id) {
  try {
    const r = await fetch(`/admin/api/templates/${id}/publish`, { method: "POST" });
    const d = await r.json();
    if (d.success) { tplLoaded = false; await loadTemplates(); }
  } catch (err) { console.error("togglePublish:", err); }
}

// ── Delete template modal ────────────────────────────────────────────────────
let pendingDeleteTplId = null;

function deleteTemplate(id) {
  const tpl = tplList.find(t => t.id === id);
  pendingDeleteTplId = id;
  document.getElementById("tplDeleteMsg").textContent =
    `Are you sure you want to delete "${tpl?.title || 'this template'}"? This cannot be undone.`;
  document.getElementById("tplDeleteModal").hidden = false;
}

document.getElementById("tplDeleteCancel").addEventListener("click", () => {
  document.getElementById("tplDeleteModal").hidden = true;
  pendingDeleteTplId = null;
});
document.getElementById("tplDeleteConfirm").addEventListener("click", async () => {
  if (!pendingDeleteTplId) return;
  document.getElementById("tplDeleteModal").hidden = true;
  try {
    await fetch(`/admin/api/templates/${pendingDeleteTplId}`, { method: "DELETE" });
    tplLoaded = false;
    await loadTemplates();
  } catch (err) { console.error("deleteTemplate:", err); }
  pendingDeleteTplId = null;
});

// ── Thumbnail file upload ─────────────────────────────────────────────────────
async function uploadThumbnailFile(file) {
  if (!builderTplId) { alert("Save a draft first before uploading a thumbnail."); return; }
  const statusEl = document.getElementById("admTplThumbStatus");
  if (file.size > 5 * 1024 * 1024) { statusEl.textContent = "File too large (max 5 MB)."; return; }
  statusEl.textContent = "Uploading…";
  const fd = new FormData();
  fd.append("image", file);
  try {
    const r = await fetch(`/admin/api/templates/${builderTplId}/image`, { method: "POST", body: fd });
    const d = await r.json();
    if (!d.success) { statusEl.textContent = "Upload failed."; return; }
    document.getElementById("admTplThumb").src = d.imageUrl;
    document.getElementById("admTplThumbBox").hidden = false;
    statusEl.textContent = "Thumbnail saved!";
    tplLoaded = false;
    loadTemplates();
  } catch (err) {
    statusEl.textContent = "Error: " + err.message;
  }
}

document.getElementById("admTplThumbFile").addEventListener("change", function() {
  if (this.files[0]) uploadThumbnailFile(this.files[0]);
});

// Drag & drop on the upload zone
const uploadZone = document.getElementById("admTplUploadZone");
uploadZone.addEventListener("dragover", e => { e.preventDefault(); uploadZone.classList.add("adm-tpl-upload-zone--over"); });
