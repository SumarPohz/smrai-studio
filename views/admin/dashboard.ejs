let psLoaded = false;
let _psTxnPage = 1;
let _psRefundId = null, _psRefundType = null, _psRefundAmt = 0, _psRefundUser = '';
let _psPinUserId = null;
let _psBillerEditId = null;

const CAT_ICONS_ADMIN = { electricity:'⚡', water:'💧', gas:'🔥', broadband:'🌐', dth:'📺', other:'⚙️' };

async function loadPsStats() {
  try {
    const d = await fetch('/admin/api/paysetu/stats').then(r => r.json());
    if (!d.success) return;
    document.getElementById('psStatRcTotal').textContent = d.recharge.total.toLocaleString('en-IN');
    document.getElementById('psStatRcVol').textContent   = '₹' + d.recharge.volume.toLocaleString('en-IN');
    document.getElementById('psStatBbTotal').textContent = d.bbps.total.toLocaleString('en-IN');
    document.getElementById('psStatBbVol').textContent   = '₹' + d.bbps.volume.toLocaleString('en-IN');
    document.getElementById('psStatFailed').textContent  = (d.recharge.failed + d.bbps.failed).toLocaleString('en-IN');
    document.getElementById('psStatBillers').textContent = d.billers.toLocaleString('en-IN');
  } catch(_) {}
}

async function loadPsTxns(page) {
  if (page) _psTxnPage = page;
  const filter = document.getElementById('psTxnFilter').value;
  const search = document.getElementById('psTxnSearch').value;
  const el = document.getElementById('psTxnTable');
  el.innerHTML = '<p style="color:#9ca3af;text-align:center;padding:1rem">Loading…</p>';
  try {
    const d = await fetch(`/admin/api/paysetu/transactions?page=${_psTxnPage}&limit=20&filter=${filter}&search=${encodeURIComponent(search)}`).then(r => r.json());
    if (!d.success || !d.rows.length) {
      el.innerHTML = '<p style="color:#9ca3af;text-align:center;padding:1.5rem">No transactions found.</p>';
      document.getElementById('psTxnPager').innerHTML = '';
      return;
    }
    const rows = d.rows.map(t => {
      const isRc = t.txn_type === 'recharge';
      const desc = isRc ? (t.operator + ' · ' + t.mobile) : (t.biller_name + ' · ' + t.customer_number);
      const typeLabel = isRc ? '📱 Recharge' : '🧾 Bill';
      const statusColor = t.status === 'success' ? '#16a34a' : t.status === 'failed' ? '#dc2626' : '#f59e0b';
      const date = new Date(t.created_at).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'2-digit'});
      const refundBtn = t.status === 'failed'
        ? `<button onclick="openPsRefundModal(${t.id},'${t.txn_type}',${t.amount},'${(t.user_name||'').replace(/'/g,"\\'")} (${t.user_email||''})')" style="padding:0.25rem 0.55rem;background:#f97316;color:#fff;border:none;border-radius:5px;font-size:0.72rem;cursor:pointer;margin-right:0.3rem">Refund</button>`
        : (t.status === 'pending' && t.txn_type === 'recharge')
        ? `<button onclick="checkRechargeTxnStatus(${t.id},this)" style="padding:0.25rem 0.55rem;background:#0891b2;color:#fff;border:none;border-radius:5px;font-size:0.72rem;cursor:pointer;margin-right:0.3rem">Check Status</button><button onclick="openComplainModal(${t.id})" style="padding:0.25rem 0.55rem;background:#f59e0b;color:#fff;border:none;border-radius:5px;font-size:0.72rem;cursor:pointer;margin-right:0.3rem">Complain</button><button onclick="forceRefundPending(${t.id})" style="padding:0.25rem 0.55rem;background:#dc2626;color:#fff;border:none;border-radius:5px;font-size:0.72rem;cursor:pointer;margin-right:0.3rem">Force Refund</button>` : '';
      const pinBtn = `<button onclick="openPsPinModal(${t.user_id},'${(t.user_name||'User').replace(/'/g,"\\'")} (${t.user_email||''})')" style="padding:0.25rem 0.55rem;background:#6366f1;color:#fff;border:none;border-radius:5px;font-size:0.72rem;cursor:pointer">Reset PIN</button>`;
      return `<tr style="border-bottom:1px solid #f3f4f6">
        <td style="padding:0.5rem 0.45rem;white-space:nowrap">${typeLabel}</td>
        <td style="padding:0.5rem 0.45rem">
          <div style="font-weight:600;font-size:0.82rem">${t.user_name||'—'}</div>
          <div style="font-size:0.72rem;color:#9ca3af">${t.user_email||''}</div>
        </td>
        <td style="padding:0.5rem 0.45rem;font-size:0.8rem">${desc}</td>
        <td style="padding:0.5rem 0.45rem;font-weight:700;color:#1e293b">₹${Number(t.amount).toFixed(0)}</td>
        <td style="padding:0.5rem 0.45rem"><span style="font-size:0.72rem;font-weight:700;color:${statusColor};text-transform:uppercase">${t.status}</span></td>
        <td style="padding:0.5rem 0.45rem;font-size:0.75rem;color:#9ca3af">${date}</td>
        <td style="padding:0.5rem 0.45rem">${refundBtn}${pinBtn}</td>
      </tr>`;
    }).join('');
    el.innerHTML = `<table style="width:100%;border-collapse:collapse;font-size:0.83rem">
      <thead><tr style="border-bottom:2px solid #f3f4f6">
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">TYPE</th>
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">USER</th>
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">DETAIL</th>
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">AMOUNT</th>
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">STATUS</th>
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">DATE</th>
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">ACTIONS</th>
      </tr></thead><tbody>${rows}</tbody></table>`;
    // Pagination
    const totalPages = Math.ceil(d.total / 20);
    const pager = document.getElementById('psTxnPager');
    pager.innerHTML = '';
    for (let p = 1; p <= Math.min(totalPages, 10); p++) {
      const btn = document.createElement('button');
      btn.textContent = p;
      btn.style.cssText = `padding:0.3rem 0.6rem;border:1px solid #d1d5db;border-radius:6px;cursor:pointer;font-size:0.78rem;background:${p===_psTxnPage?'#0891b2':'#fff'};color:${p===_psTxnPage?'#fff':'#374151'}`;
      btn.onclick = () => loadPsTxns(p);
      pager.appendChild(btn);
    }
  } catch(e) { el.innerHTML = `<p style="color:#dc2626">Error: ${e.message}</p>`; }
}

// Check live status of a pending recharge via femoney24
async function checkRechargeTxnStatus(id, btn) {
  const orig = btn.textContent;
  btn.disabled = true; btn.textContent = 'Checking…';
  try {
    const d = await fetch(`/admin/api/recharge-transactions/${id}/check-status`, { method: 'POST' }).then(r => r.json());
    if (d.success) {
      const color = d.rechargeStatus === 'success' ? 'success' : d.rechargeStatus === 'failed' ? 'error' : '';
      showAdmToast(d.message, color);
      if (d.rechargeStatus !== 'pending') loadPsTxns();
    } else {
      showAdmToast(d.message || 'Status check failed', 'error');
    }
  } catch(e) { showAdmToast(e.message, 'error'); }
  btn.disabled = false; btn.textContent = orig;
}

