async function loadTrackingScripts() {
  try {
    const r = await fetch("/admin/api/settings");
    const d = await r.json();
    if (d.settings) {
      document.getElementById("adsensePublisherId").value = d.settings.adsense_publisher_id || "";
      document.getElementById("facebookPixelId").value    = d.settings.facebook_pixel_id    || "";
      document.getElementById("homepageAdSlot").value     = d.settings.homepage_ad_slot     || "";
      document.getElementById("footerAdSlot").value       = d.settings.footer_ad_slot       || "";
