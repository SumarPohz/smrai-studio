}

// ── Wallet admin ─────────────────────────────────────────────────────────────
var _walPage = 1;
var _walAdjustUserId = null;

async function loadWalletUsers(page) {
  if (page) _walPage = page;
  var search = (document.getElementById("walSearchInput") || {}).value || "";
  var url = "/admin/api/wallet/users?page=" + _walPage + "&limit=20" + (search ? "&search=" + encodeURIComponent(search) : "");
  var tbody = document.getElementById("walUsersTable");
  if (!tbody) return;
  try {
    var d = await fetch(url).then(function(r){ return r.json(); });
    if (!d.success) { tbody.innerHTML = '<p style="color:#dc2626">Failed to load</p>'; return; }

    // Update stats
    var totalBal = d.users.reduce(function(s,u){ return s + parseFloat(u.wallet_balance||0); }, 0);
    var usersWithBal = d.users.filter(function(u){ return parseFloat(u.wallet_balance||0) > 0; }).length;
    var totalRef = d.users.reduce(function(s,u){ return s + parseInt(u.referral_count||0); }, 0);
    if (page === 1 || !page) {
      var el1 = document.getElementById("walStatTotal"); if (el1) el1.textContent = "₹" + totalBal.toFixed(0);
      var el2 = document.getElementById("walStatUsers"); if (el2) el2.textContent = usersWithBal;
      var el3 = document.getElementById("walStatReferrals"); if (el3) el3.textContent = totalRef;
    }

    if (!d.users.length) { tbody.innerHTML = '<p style="color:#9ca3af;text-align:center;padding:1rem">No users found</p>'; return; }

    var rows = d.users.map(function(u){
      var bal = parseFloat(u.wallet_balance||0);
      return '<tr>' +
        '<td style="padding:0.55rem 0.5rem">' + (u.name || '—') + '<br><span style="font-size:0.72rem;color:#9ca3af">' + (u.email||'') + '</span></td>' +
        '<td style="padding:0.55rem 0.5rem;font-weight:700;color:' + (bal > 0 ? '#0f766e' : '#9ca3af') + '">₹' + bal.toFixed(0) + '</td>' +
        '<td style="padding:0.55rem 0.5rem;color:#6b7280">' + (u.referral_count||0) + '</td>' +
        '<td style="padding:0.55rem 0.5rem">' +
          '<button onclick="openWalletAdjust(' + u.id + ',\'' + (u.name||'').replace(/'/g,"\\'") + '\')" style="padding:0.3rem 0.6rem;background:#0891b2;color:#fff;border:none;border-radius:6px;font-size:0.76rem;cursor:pointer;margin-right:0.35rem">Adjust</button>' +
          '<button onclick="openWalTxnModal(' + u.id + ')" style="padding:0.3rem 0.6rem;background:#f3f4f6;color:#374151;border:none;border-radius:6px;font-size:0.76rem;cursor:pointer">History</button>' +
        '</td>' +
      '</tr>';
    }).join('');

    tbody.innerHTML = '<table style="width:100%;border-collapse:collapse">' +
      '<thead><tr style="border-bottom:1px solid #f3f4f6">' +
      '<th style="text-align:left;padding:0.4rem 0.5rem;font-size:0.72rem;color:#9ca3af;font-weight:600">USER</th>' +
      '<th style="text-align:left;padding:0.4rem 0.5rem;font-size:0.72rem;color:#9ca3af;font-weight:600">BALANCE</th>' +
      '<th style="text-align:left;padding:0.4rem 0.5rem;font-size:0.72rem;color:#9ca3af;font-weight:600">REFERRALS</th>' +
      '<th style="text-align:left;padding:0.4rem 0.5rem;font-size:0.72rem;color:#9ca3af;font-weight:600">ACTIONS</th>' +
      '</tr></thead><tbody>' + rows + '</tbody></table>';

    // Pagination
    var totalPages = Math.ceil(d.total / d.limit);
    var pgEl = document.getElementById("walPagination");
    if (pgEl) {
      pgEl.innerHTML = '';
      for (var p = 1; p <= Math.min(totalPages, 10); p++) {
        var btn = document.createElement("button");
        btn.textContent = p;
        btn.style.cssText = "padding:0.3rem 0.6rem;border:1px solid #d1d5db;border-radius:6px;cursor:pointer;font-size:0.8rem;background:" + (p === _walPage ? "#0891b2" : "#fff") + ";color:" + (p === _walPage ? "#fff" : "#374151");
        btn.onclick = (function(pp){ return function(){ loadWalletUsers(pp); }; })(p);
        pgEl.appendChild(btn);
      }
    }
  } catch(e) { tbody.innerHTML = '<p style="color:#dc2626">Error: ' + e.message + '</p>'; }
}

