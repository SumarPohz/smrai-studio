        </td>
        <td style="padding:0.6rem 0.75rem">
          <span style="padding:0.2rem 0.6rem;border-radius:99px;font-size:0.72rem;font-weight:700;background:${r.status==='approved'?'#dcfce7':r.status==='rejected'?'#fee2e2':'#fef3c7'};color:${r.status==='approved'?'#16a34a':r.status==='rejected'?'#dc2626':'#d97706'}">${r.status}</span>
