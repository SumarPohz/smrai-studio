function setBgrProviderUI(provider) {
  const isFree = provider === 'free';
  const toggle = document.getElementById('bgrProviderToggle');
  const slider = document.getElementById('bgrProviderSlider');
  const knob   = document.getElementById('bgrProviderKnob');
  const label  = document.getElementById('bgrProviderLabel');
  const desc   = document.getElementById('bgrProviderDesc');
  if (!toggle) return;
  toggle.checked           = isFree;
  slider.style.background  = isFree ? '#06b6d4' : '#374151';
  knob.style.transform     = isFree ? 'translateX(20px)' : 'translateX(0)';
  label.textContent = isFree ? 'AI Free (Local)' : 'remove.bg';
  desc.textContent  = isFree
    ? 'Free · Unlimited · AI-powered, runs on server · No API key needed'
    : 'Paid · 50 free calls/month · remove.bg API';
