          <button onclick="clearInvReq(${r.id},this)" style="padding:0.25rem 0.65rem;background:#f3f4f6;color:#6b7280;border:1px solid #e5e7eb;border-radius:5px;font-size:0.75rem;font-weight:600;cursor:pointer">Clear</button>
