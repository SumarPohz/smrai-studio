  var modal = document.getElementById("walAdjustModal");
  if (modal) modal.style.display = "none";
}

async function submitWalletAdjust() {
  var btn = document.getElementById("walAdjustBtn");
  var errEl = document.getElementById("walAdjustErr");
  var amount = parseFloat((document.getElementById("walAdjustAmount")||{}).value);
  var type = (document.querySelector("input[name=walAdjustType]:checked")||{}).value;
  var reason = ((document.getElementById("walAdjustReason")||{}).value || "").trim() || "admin_adjustment";
  if (!amount || amount <= 0) { if (errEl) errEl.textContent = "Enter a valid amount"; return; }
  if (btn) { btn.disabled = true; btn.textContent = "Saving…"; }
  try {
    var r = await fetch("/admin/api/wallet/adjust", {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ userId: _walAdjustUserId, amount, type, reason })
    });
    var d = await r.json();
    if (d.success) {
      showAdmToast("Wallet updated. New balance: ₹" + d.newBalance.toFixed(0), "success");
      closeWalletModal();
      loadWalletUsers(_walPage);
    } else {
      if (errEl) errEl.textContent = d.message || "Failed";
    }
  } catch(e) {
    if (errEl) errEl.textContent = "Error: " + e.message;
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = "Apply"; }
  }
}

async function openWalTxnModal(userId) {
  var modal = document.getElementById("walTxnModal");
  var list = document.getElementById("walTxnList");
  if (!modal || !list) return;
  modal.style.display = "flex";
  list.innerHTML = "Loading…";
  try {
    var d = await fetch("/admin/api/wallet/transactions/" + userId).then(function(r){ return r.json(); });
    if (!d.success || !d.transactions.length) { list.innerHTML = '<p style="text-align:center;color:#9ca3af;padding:1rem">No transactions yet</p>'; return; }
    list.innerHTML = d.transactions.map(function(tx){
      var isCredit = tx.type === "credit";
