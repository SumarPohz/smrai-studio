document.getElementById("bgr_img_input") && document.getElementById("bgr_img_input").addEventListener("change", async function() {
  if (bgrImagesList.length >= 20) { alert("Maximum 20 images allowed"); this.value = ""; return; }
  const file = this.files[0]; if (!file) return;
  const fd = new FormData(); fd.append("image", file);
  const r = await fetch("/admin/api/homepage/upload-image", { method: "POST", body: fd });
  const d = await r.json();
  if (!d.success) { alert("Upload failed"); return; }
  bgrImagesList.push(d.imageUrl);
  renderBgrImages(bgrImagesList);
  this.value = "";
});

function renderBgrImages(images) {
  const list = document.getElementById("bgr_images_list");
  if (!list) return;
  list.innerHTML = "";
  if (!images.length) {
    list.innerHTML = '<span style="color:#6b7280;font-size:0.82rem;">No images yet. Click Add Image to upload.</span>';
    return;
  }
  images.forEach(function(url, i) {
    const wrap = document.createElement("div");
    wrap.style.cssText = "position:relative;width:90px;height:64px;border-radius:10px;overflow:hidden;border:1px solid #374151;flex-shrink:0;";
    wrap.innerHTML = `<img src="${url}" style="width:100%;height:100%;object-fit:cover;">
      <button type="button" onclick="removeBgrImage(${i})"
        style="position:absolute;top:3px;right:3px;background:rgba(0,0,0,0.75);border:none;border-radius:50%;width:20px;height:20px;color:#fff;font-size:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;">✕</button>`;
    list.appendChild(wrap);
  });
}

function removeBgrImage(idx) { bgrImagesList.splice(idx, 1); renderBgrImages(bgrImagesList); }

async function saveBgrBackgrounds() {
  const r = await fetch("/admin/api/bgremover/backgrounds", {
    method: "PUT",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ images: bgrImagesList })
  });
  const d = await r.json();
  if (d.success) {
    const msg = document.getElementById("bgr_save_msg");
    if (msg) { msg.style.display = "inline"; setTimeout(function() { msg.style.display = "none"; }, 2500); }
