// ════════════════════════════════════════════════════════════════════════════
//  STATIC TEMPLATE MANAGEMENT
// ════════════════════════════════════════════════════════════════════════════
let staticTplList = [];
let staticTplLoaded = false;

async function loadStaticTemplates() {
  if (staticTplLoaded) return;
  const r = await fetch("/admin/api/static-templates");
  const d = await r.json();
  if (!d.success) return;
  staticTplList = d.templates;
  renderStaticTplTable();
  staticTplLoaded = true;
}

function renderStaticTplTable() {
  const tbody      = document.getElementById("staticTplTableBody");
  const search     = (document.getElementById("staticTplSearch")?.value     || "").toLowerCase().trim();
  const catFilter  = (document.getElementById("staticTplCatFilter")?.value  || "");
  const statusFilter = (document.getElementById("staticTplStatusFilter")?.value || "");

  const filtered = staticTplList.filter(t => {
    if (search     && !t.title.toLowerCase().includes(search))       return false;
    if (catFilter  && t.category !== catFilter)                      return false;
    if (statusFilter === "live"        && !t.isAvailable)            return false;
    if (statusFilter === "coming-soon" &&  t.isAvailable)            return false;
    return true;
  });

  if (!filtered.length) {
    tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;color:#6b7280;padding:2rem;">No templates match your filters.</td></tr>`;
    return;
  }
  tbody.innerHTML = filtered.map(t => `
    <tr>
      <td><img src="${escHtml(t.previewImage)}" alt="" style="width:56px;height:40px;object-fit:cover;border-radius:4px;border:1px solid #e5e7eb;" onerror="this.src='/images/templates/SmrAI-Studio-Resume-A4.jpg'"></td>
      <td><strong>${escHtml(t.title)}</strong></td>
      <td><span style="text-transform:capitalize;">${escHtml(t.category)}</span></td>
      <td>${escHtml(t.badge || '')}</td>
      <td><span class="adm-tpl-status-pill ${t.isAvailable ? 'adm-tpl-status-live' : 'adm-tpl-status-draft'}">${t.isAvailable ? 'Live' : 'Coming Soon'}</span></td>
      <td>
        <button class="adm-btn-icon" title="Edit" onclick="openStaticTplModal('${escHtml(t.id)}')">
          <i class="fas fa-pencil-alt"></i>
        </button>
      </td>
    </tr>
  `).join("");
}

// Wire up filter controls
["staticTplSearch","staticTplCatFilter","staticTplStatusFilter"].forEach(id => {
  document.getElementById(id)?.addEventListener("input", renderStaticTplTable);
});

function setStaticTplStatus(isLive) {
  document.getElementById("staticTplAvailable").value = isLive ? "true" : "false";
  document.getElementById("staticTplStatusLive").classList.toggle("adm-stpl-vis-btn--active", isLive);
  document.getElementById("staticTplStatusSoon").classList.toggle("adm-stpl-vis-btn--active", !isLive);
}

function openStaticTplModal(id) {
  const t = staticTplList.find(x => x.id === id);
  if (!t) return;
  document.getElementById("staticTplId").value        = t.id;
  document.getElementById("staticTplSubtitle").textContent = t.category.charAt(0).toUpperCase() + t.category.slice(1).replace(/-/g," ");
  document.getElementById("staticTplTitle").value     = t.title;
  document.getElementById("staticTplDesc").value      = t.description || "";
  document.getElementById("staticTplBadge").value     = t.badge || "";
  document.getElementById("staticTplPreviewImg").src  = t.previewImage || "";
  document.getElementById("staticTplImageFile").value = "";
  setStaticTplStatus(t.isAvailable !== false);
  document.getElementById("staticTplModal").hidden    = false;
  document.body.style.overflow = "hidden";
}

function closeStaticTplModal() {
  document.getElementById("staticTplModal").hidden = true;
  document.body.style.overflow = "";
}

// Visibility toggle buttons
document.getElementById("staticTplStatusLive").addEventListener("click", () => setStaticTplStatus(true));
document.getElementById("staticTplStatusSoon").addEventListener("click", () => setStaticTplStatus(false));

// Image zone click → trigger hidden file input
document.getElementById("staticTplImgZone").addEventListener("click", () => {
  document.getElementById("staticTplImageFile").click();
});
// Preview selected image immediately
document.getElementById("staticTplImageFile").addEventListener("change", function() {
  if (!this.files.length) return;
  const url = URL.createObjectURL(this.files[0]);
  document.getElementById("staticTplPreviewImg").src = url;
});

document.getElementById("staticTplModalClose").addEventListener("click", closeStaticTplModal);
document.getElementById("staticTplCancelBtn").addEventListener("click",  closeStaticTplModal);
document.getElementById("staticTplModal").addEventListener("click", function(e) {
  if (e.target === this) closeStaticTplModal();
});
document.addEventListener("keydown", function(e) {
  if (e.key === "Escape" && !document.getElementById("staticTplModal").hidden) closeStaticTplModal();
});

document.getElementById("staticTplSaveBtn").addEventListener("click", async () => {
  const id    = document.getElementById("staticTplId").value;
  const title = document.getElementById("staticTplTitle").value.trim();
  if (!title) { alert("Title is required."); return; }

  const btn = document.getElementById("staticTplSaveBtn");
  btn.disabled = true; btn.textContent = "Saving…";

  try {
    // 1. Save text fields
    const r = await fetch(`/admin/api/static-templates/${encodeURIComponent(id)}`, {
      method: "PUT", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        title,
        description: document.getElementById("staticTplDesc").value.trim() || null,
        badge:       document.getElementById("staticTplBadge").value.trim() || null,
        isAvailable: document.getElementById("staticTplAvailable").value === "true",
      }),
    });
    if (!(await r.json()).success) throw new Error("Save failed");

    // 2. Upload image if selected
    const fileInput = document.getElementById("staticTplImageFile");
    if (fileInput.files.length) {
      const fd = new FormData();
      fd.append("image", fileInput.files[0]);
      const ir = await fetch(`/admin/api/static-templates/${encodeURIComponent(id)}/image`, { method: "POST", body: fd });
      const id2 = await ir.json();
      if (id2.success && id2.imageUrl) {
        document.getElementById("staticTplPreviewImg").src = id2.imageUrl;
      }
    }

    closeStaticTplModal();
    staticTplLoaded = false;
    await loadStaticTemplates();
    showAdmToast("Template updated successfully.", "success");
  } catch (err) {
    showAdmToast("Error: " + err.message, "error");
  } finally {
    btn.disabled = false; btn.textContent = "Save Changes";
  }
});

