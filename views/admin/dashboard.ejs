// ── Sub-admin page-load enforcement ─────────────────────────────────────────
if (isSubAdmin && myPerms) {
(function() {
  const perms = myPerms;
  const sections = ["overview","users","activity","requests","pricing","templates","homepage","ads","coupons","apikeys","investors"];

  sections.forEach(function(sec) {
    const level = perms[sec] || "none";

    // Hide nav link + section panel if no access
    if (level === "none") {
      const navLink = document.querySelector(`.adm-nav-link[data-section="${sec}"]`);
      if (navLink) navLink.style.display = "none";
      const panel = document.getElementById(sec);
      if (panel) panel.style.display = "none";
      return;
    }

    // View-only: lock all inputs/buttons now and watch for dynamically loaded content
    if (level === "view") {
      const panel = document.getElementById(sec);
      if (!panel) return;
      panel.classList.add("adm-view-only");

      function _lockPanel() {
        panel.querySelectorAll("input, select, textarea").forEach(function(el) {
          el.disabled = true;
          el.setAttribute("readonly", "");
        });
        panel.querySelectorAll("button, [type='submit']").forEach(function(el) {
          el.disabled = true;
        });
      }

      // Lock immediately and re-lock whenever new content is injected
      _lockPanel();
      new MutationObserver(_lockPanel).observe(panel, { childList: true, subtree: true });

      // Block all form submissions in this panel (capture phase so it runs before handlers)
      panel.addEventListener("submit", function(e) { e.preventDefault(); e.stopImmediatePropagation(); }, true);
      // Block all button/click events
      panel.addEventListener("click", function(e) {
        const t = e.target.closest("button, [type='submit'], [role='button']");
        if (t) { e.preventDefault(); e.stopImmediatePropagation(); }
      }, true);
    }
  });

  // Navigate to first allowed section if overview is not accessible
  const firstAllowed = sections.find(function(s) { return (perms[s] || "none") !== "none"; });
  if (firstAllowed && (perms["overview"] || "none") === "none") {
    showSection(firstAllowed);
  }
})();
}

