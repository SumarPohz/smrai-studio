async function saveSubPlan() {
  const id = document.getElementById("subPlanModalId").value;
  const payload = {
    name: document.getElementById("subPlanName").value.trim(),
    duration_days: parseInt(document.getElementById("subPlanDuration").value),
    price: parseFloat(document.getElementById("subPlanPrice").value),
    description: document.getElementById("subPlanDesc").value.trim(),
    is_active: document.getElementById("subPlanActive").checked
  };
  const errEl = document.getElementById("subPlanModalErr");
  if (!payload.name || !payload.duration_days || isNaN(payload.price)) {
    errEl.textContent = "Name, duration and price are required."; return;
  }
  const btn = document.getElementById("subPlanSaveBtn");
  btn.disabled = true; btn.textContent = "Saving…";
  try {
    const url = id ? "/admin/api/subscription-plans/" + id : "/admin/api/subscription-plans";
    const method = id ? "PATCH" : "POST";
    const d = await fetch(url, { method, headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) }).then(r => r.json());
    if (d.success) {
      closeSubPlanModal();
      loadSubPlans();
      showAdmToast("Plan saved");
    } else { errEl.textContent = d.error || "Save failed"; }
  } catch(e) { errEl.textContent = "Error: " + e.message; }
  btn.disabled = false; btn.textContent = "Save Plan";
}

async function toggleSubPlan(id, active) {
  try {
    const d = await fetch("/admin/api/subscription-plans/" + id, {
      method: "PATCH", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ is_active: active })
    }).then(r => r.json());
    if (d.success) { loadSubPlans(); showAdmToast(active ? "Plan enabled" : "Plan disabled"); }
    else alert("Failed: " + (d.error || "unknown"));
  } catch(e) { alert("Error: " + e.message); }
}

async function loadSubList() {
  const el = document.getElementById("subListTable");
  const pagEl = document.getElementById("subListPagination");
  if (!el) return;
  el.innerHTML = "Loading…";
  const status = document.getElementById("subFilterStatus").value;
  const q = document.getElementById("subSearchInput").value.trim();
  try {
    let url = `/admin/api/subscriptions?page=${subCurrentPage}&limit=20`;
    if (status) url += "&status=" + status;
    if (q) url += "&q=" + encodeURIComponent(q);
    const d = await fetch(url).then(r => r.json());
    if (!d.success || !d.subscriptions.length) {
      el.innerHTML = '<p style="color:#9ca3af;text-align:center;padding:1rem">No subscribers found.</p>';
      pagEl.innerHTML = ""; return;
    }
    el.innerHTML = '<table style="width:100%;border-collapse:collapse;font-size:0.82rem">' +
      '<thead><tr style="border-bottom:2px solid #e5e7eb">' +
      '<th style="text-align:left;padding:0.5rem 0.6rem;color:#6b7280;font-weight:600">User</th>' +
      '<th style="text-align:left;padding:0.5rem 0.6rem;color:#6b7280;font-weight:600">Plan</th>' +
      '<th style="text-align:left;padding:0.5rem 0.6rem;color:#6b7280;font-weight:600">Start</th>' +
      '<th style="text-align:left;padding:0.5rem 0.6rem;color:#6b7280;font-weight:600">Expires</th>' +
      '<th style="text-align:left;padding:0.5rem 0.6rem;color:#6b7280;font-weight:600">Amount</th>' +
      '<th style="text-align:left;padding:0.5rem 0.6rem;color:#6b7280;font-weight:600">Status</th>' +
      '<th style="text-align:left;padding:0.5rem 0.6rem;color:#6b7280;font-weight:600">Action</th>' +
      '</tr></thead><tbody>' +
      d.subscriptions.map(s => {
        const statusColor = s.status === 'active' ? '#dcfce7;color:#16a34a' : s.status === 'cancelled' ? '#fee2e2;color:#dc2626' : '#f3f4f6;color:#6b7280';
        return '<tr style="border-bottom:1px solid #f3f4f6">' +
          '<td style="padding:0.55rem 0.6rem"><div style="font-weight:600">' + s.user_name + '</div><div style="font-size:0.72rem;color:#9ca3af">' + s.user_email + '</div></td>' +
          '<td style="padding:0.55rem 0.6rem">' + s.plan_name + '</td>' +
          '<td style="padding:0.55rem 0.6rem">' + new Date(s.start_date).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) + '</td>' +
          '<td style="padding:0.55rem 0.6rem">' + new Date(s.end_date).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) + '</td>' +
          '<td style="padding:0.55rem 0.6rem">' + (s.granted_by_admin ? '<span style="color:#7c3aed;font-weight:600">Free</span>' : '₹' + parseFloat(s.amount).toFixed(0)) + '</td>' +
          '<td style="padding:0.55rem 0.6rem"><span style="display:inline-block;padding:0.15rem 0.5rem;border-radius:20px;font-size:0.72rem;font-weight:700;background:' + statusColor + '">' + s.status + '</span></td>' +
          '<td style="padding:0.55rem 0.6rem"><button onclick="openSubGrantModal(' + s.user_id + ',\'' + s.user_name.replace(/'/g,'') + '\')" style="padding:0.2rem 0.6rem;background:#7c3aed;color:#fff;border:none;border-radius:6px;font-size:0.72rem;font-weight:600;cursor:pointer">Grant</button></td>' +
          '</tr>';
      }).join('') + '</tbody></table>';

    // Pagination
    const total = d.total || 0;
    const totalPages = Math.ceil(total / 20);
    pagEl.innerHTML = Array.from({length: totalPages}, (_,i) =>
      '<button onclick="subCurrentPage=' + (i+1) + ';loadSubList()" style="padding:0.3rem 0.65rem;border:1px solid ' +
      (subCurrentPage === i+1 ? '#7c3aed;background:#7c3aed;color:#fff' : '#e5e7eb;background:#fff;color:#374151') +
      ';border-radius:6px;font-size:0.8rem;cursor:pointer">' + (i+1) + '</button>'
    ).join('');
  } catch(e) { el.innerHTML = '<p style="color:#dc2626">Error: ' + e.message + '</p>'; }
}

async function openSubGrantModal(userId, userName) {
  document.getElementById("subGrantUserId").value = userId;
  document.getElementById("subGrantUserLabel").textContent = "Granting free subscription to: " + userName;
  document.getElementById("subGrantErr").textContent = "";
  // Populate plan select from cache
  const sel = document.getElementById("subGrantPlanId");
  if (subPlansCache.length) {
    sel.innerHTML = subPlansCache.map(p => '<option value="' + p.id + '">' + p.name + ' (' + p.duration_days + ' days)</option>').join('');
  } else {
    const d = await fetch("/admin/api/subscription-plans").then(r => r.json());
    sel.innerHTML = (d.plans || []).map(p => '<option value="' + p.id + '">' + p.name + ' (' + p.duration_days + ' days)</option>').join('');
  }
  document.getElementById("subGrantModal").style.display = "flex";
}

function closeSubGrantModal() {
  document.getElementById("subGrantModal").style.display = "none";
}

async function submitSubGrant() {
  const userId = document.getElementById("subGrantUserId").value;
  const planId = document.getElementById("subGrantPlanId").value;
  const errEl = document.getElementById("subGrantErr");
  const btn = document.getElementById("subGrantBtn");
  btn.disabled = true; btn.textContent = "Granting…";
  try {
    const d = await fetch("/admin/api/subscriptions/grant", {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ userId, planId })
    }).then(r => r.json());
    if (d.success) {
      closeSubGrantModal();
      loadSubList();
      loadSubStats();
      showAdmToast("Free subscription granted!");
    } else { errEl.textContent = d.error || "Failed to grant"; }
  } catch(e) { errEl.textContent = "Error: " + e.message; }
  btn.disabled = false; btn.textContent = "Grant Access";
}

