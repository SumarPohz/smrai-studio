        <div style="font-size:0.78rem;color:#6b7280;margin-bottom:0.75rem">Should this user also be recorded as an investor?</div>
        <div style="display:flex;gap:0.6rem;margin-bottom:0.85rem">
          <button id="promoteInvYes" style="flex:1;padding:0.5rem;border:1.5px solid #6366f1;border-radius:8px;background:#fff;color:#6366f1;font-size:0.82rem;font-weight:700;cursor:pointer">Yes, also investor</button>
          <button id="promoteInvNo"  style="flex:1;padding:0.5rem;border:1.5px solid #d1d5db;border-radius:8px;background:#fff;color:#374151;font-size:0.82rem;font-weight:600;cursor:pointer">No, sub-admin only</button>
        </div>
        <div id="promoteInvFields" style="display:none">
          <div style="margin-bottom:0.65rem">
            <label style="font-size:0.72rem;font-weight:600;color:#6b7280;display:block;margin-bottom:0.25rem">Investment Amount (₹)</label>
            <input type="number" id="promoteInvAmount" min="1" placeholder="e.g. 25000"
              style="width:100%;border:1.5px solid #d1d5db;border-radius:7px;padding:0.5rem 0.65rem;font-size:0.9rem;font-weight:700;outline:none;box-sizing:border-box"
              oninput="promoteInvCalc()" />
          </div>
          <div style="margin-bottom:0.65rem">
            <label style="font-size:0.72rem;font-weight:600;color:#6b7280;display:block;margin-bottom:0.25rem">Company Valuation (₹)</label>
            <input type="number" id="promoteInvValuation" min="1" placeholder="e.g. 125000"
              style="width:100%;border:1.5px solid #d1d5db;border-radius:7px;padding:0.5rem 0.65rem;font-size:0.9rem;font-weight:700;outline:none;box-sizing:border-box"
              oninput="promoteInvCalc()" />
          </div>
          <div id="promoteInvEquity" style="font-size:0.78rem;color:#16a34a;font-weight:700;margin-bottom:0.65rem;min-height:1em"></div>
          <div id="promoteInvErr" style="font-size:0.75rem;color:#dc2626;margin-bottom:0.5rem;min-height:1em"></div>
          <div style="display:flex;gap:0.6rem">
            <button data-cancel style="flex:1;padding:0.5rem;border:1.5px solid #d1d5db;border-radius:8px;background:#fff;color:#6b7280;font-size:0.82rem;cursor:pointer">Cancel</button>
            <button id="promoteInvConfirmBtn" style="flex:2;padding:0.5rem;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:0.82rem;font-weight:700;cursor:pointer">Confirm &amp; Promote</button>
          </div>
        </div>
      </div>

      <!-- Permissions grid (shown for subadmin users) -->
      <div id="permsGridWrap" style="margin-top:1rem"></div>
