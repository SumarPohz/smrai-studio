// ── Sections list renderer ───────────────────────────────────────────────────
let sectionStates = {}; // { key: { enabled, order } }

function renderSectionsList(apiSections) {
  // Build state from API or defaults
  sectionStates = {};
  SECTION_DEFS.forEach((s, i) => {
    const api = apiSections ? apiSections.find(a => a.section_key === s.key) : null;
    sectionStates[s.key] = {
      enabled:        api ? api.is_enabled      : !s.defaultDisabled,
      order:          api ? api.sort_order      : i,
      placement:      api ? (api.placement      || s.defaultPlacement) : s.defaultPlacement,
      display_type:   api ? (api.display_type   || s.defaultDisplay)   : s.defaultDisplay,
      label_override: api ? (api.label_override || null)               : null,
    };
  });

  const container = document.getElementById("admTplSectionsList");
  container.innerHTML = SECTION_DEFS
    .slice()
    .sort((a, b) => sectionStates[a.key].order - sectionStates[b.key].order)
    .map(s => {
      const st = sectionStates[s.key];
      return `
      <div class="adm-tpl-section-row" draggable="true" data-sec="${s.key}">
        <i class="fas fa-grip-vertical adm-tpl-drag-handle"></i>
        <span class="adm-tpl-sec-label">${st.label_override || s.label}${s.defaultDisabled ? ' <span class="adm-sec-badge-new">NEW</span>' : ''}</span>
        <div class="adm-tpl-sec-actions">
          <button type="button" class="adm-tpl-sec-settings-btn" data-sec-key="${s.key}" title="Section settings">
            <i class="fas fa-cog"></i>
          </button>
          <label class="adm-tpl-toggle">
            <input type="checkbox" data-sec-key="${s.key}" ${st.enabled ? "checked" : ""} />
            <span class="adm-tpl-toggle-slider"></span>
          </label>
        </div>
      </div>
      <div class="adm-tpl-sec-settings-panel" data-sec-panel="${s.key}" hidden>
        <div class="adm-tpl-sec-settings-row">
          <div class="adm-tpl-sec-setting">
            <label>Placement</label>
            <select data-sec-placement="${s.key}">
              <option value="auto"    ${st.placement === 'auto'    ? 'selected' : ''}>Auto</option>
              <option value="sidebar" ${st.placement === 'sidebar' ? 'selected' : ''}>Sidebar</option>
              <option value="main"    ${st.placement === 'main'    ? 'selected' : ''}>Main</option>
            </select>
          </div>
          <div class="adm-tpl-sec-setting">
            <label>Display Style</label>
            <select data-sec-display="${s.key}">
              <option value="bullets"  ${st.display_type === 'bullets'  ? 'selected' : ''}>Bullets</option>
              <option value="pills"    ${st.display_type === 'pills'    ? 'selected' : ''}>Pills / Tags</option>
              <option value="plain"    ${st.display_type === 'plain'    ? 'selected' : ''}>Plain text</option>
              <option value="timeline" ${st.display_type === 'timeline' ? 'selected' : ''}>Timeline</option>
            </select>
          </div>
          <div class="adm-tpl-sec-setting adm-tpl-sec-setting-wide">
            <label>Label Override</label>
            <input type="text" data-sec-label="${s.key}" value="${st.label_override || ''}" placeholder="${s.label}" />
          </div>
        </div>
      </div>`;
    }).join("");

  // Sync checkbox changes to state
  container.querySelectorAll("input[data-sec-key]").forEach(cb => {
    cb.addEventListener("change", () => {
      sectionStates[cb.dataset.secKey].enabled = cb.checked;
    });
  });

  // Settings button toggle
  container.querySelectorAll(".adm-tpl-sec-settings-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const key = btn.dataset.secKey;
      const panel = container.querySelector(`[data-sec-panel="${key}"]`);
      if (panel) panel.hidden = !panel.hidden;
    });
  });

  // Sync placement / display / label changes to state
  container.querySelectorAll("[data-sec-placement]").forEach(sel => {
    sel.addEventListener("change", () => { sectionStates[sel.dataset.secPlacement].placement = sel.value; });
  });
  container.querySelectorAll("[data-sec-display]").forEach(sel => {
    sel.addEventListener("change", () => { sectionStates[sel.dataset.secDisplay].display_type = sel.value; });
  });
  container.querySelectorAll("[data-sec-label]").forEach(inp => {
    inp.addEventListener("input", () => {
      const key = inp.dataset.secLabel;
      sectionStates[key].label_override = inp.value.trim() || null;
      // Update visible label in row
      const row = container.querySelector(`[data-sec="${key}"] .adm-tpl-sec-label`);
      if (row) {
        const def = SECTION_DEFS.find(d => d.key === key);
        const badge = def && def.defaultDisabled ? ' <span class="adm-sec-badge-new">NEW</span>' : '';
        row.innerHTML = (inp.value.trim() || (def && def.label) || key) + badge;
      }
    });
  });

  // Drag-and-drop reordering
  let dragSrc = null;
  container.querySelectorAll(".adm-tpl-section-row").forEach(row => {
    row.addEventListener("dragstart", () => { dragSrc = row; row.style.opacity = "0.4"; });
    row.addEventListener("dragend",   () => { dragSrc = null; row.style.opacity = ""; });
    row.addEventListener("dragover",  e  => { e.preventDefault(); row.style.background = "#eff6ff"; });
    row.addEventListener("dragleave", () => { row.style.background = ""; });
    row.addEventListener("drop", e => {
      e.preventDefault();
      row.style.background = "";
      if (dragSrc && dragSrc !== row) {
        container.insertBefore(dragSrc, row);
        // Update order in state
        container.querySelectorAll(".adm-tpl-section-row").forEach((r, i) => {
          sectionStates[r.dataset.sec].order = i;
        });
      }
    });
  });
}

// ── Save Draft / Save & Publish ──────────────────────────────────────────────
document.getElementById("admTplSaveDraft").addEventListener("click", () => saveTemplate(false));
document.getElementById("admTplSavePublish").addEventListener("click", () => saveTemplate(true));

async function saveTemplate(publish, keepOpen) {
  const title = document.getElementById("admTplTitle").value.trim();
  if (!title) {
    showTplError("Title is required.");
    switchTplTab("basic");
    return;
  }

  const color_scheme = {
    primary:   document.getElementById("admTplColorPrimary").value,
    secondary: document.getElementById("admTplColorSecondary").value,
    accent:    document.getElementById("admTplColorAccent").value,
    text:      document.getElementById("admTplColorText").value,
  };
  const layout_type = document.querySelector("input[name='admTplLayout']:checked")?.value || "two-column-left";

  const design_settings = {
    fontFamily:        document.getElementById("dsFont").value,
    headingWeight:     document.getElementById("dsHeadingWeight").value,
    bodySize:          document.getElementById("dsBodySize").value,
    borderRadius:      document.getElementById("dsBorderRadius").value,
    shadow:            document.getElementById("dsShadow").value,
    sectionTitleStyle: document.getElementById("dsSectionTitleStyle").value,
    headerStyle:       document.getElementById("dsHeaderStyle").value,
    pillShape:         document.getElementById("dsPillShape").value,
  };

  const body = {
    title,
    description: document.getElementById("admTplDesc").value.trim(),
    category:    document.getElementById("admTplCategory").value,
    badge:       document.getElementById("admTplBadge").value.trim(),
    layout_type,
    color_scheme,
    design_settings,
    is_paid:   document.getElementById("admTplIsPaid").checked,
    price_inr: parseInt(document.getElementById("admTplPrice").value) || 49,
  };

  try {
    let tplId = builderTplId;
    if (!tplId) {
      // Create
      const r = await fetch("/admin/api/templates", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      const d = await r.json();
      if (!d.success) { showTplError(d.error || "Create failed."); return; }
      tplId      = d.template.id;
      builderTplId = tplId;
      document.getElementById("admTplThumbStatus").textContent = "";
    } else {
      // Update
      const r = await fetch(`/admin/api/templates/${tplId}`, {
        method: "PUT", headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      const d = await r.json();
      if (!d.success) { showTplError(d.error || "Update failed."); return; }
    }

    // Save sections
    const sections = SECTION_DEFS.map(s => ({
      section_key:    s.key,
      is_enabled:     sectionStates[s.key]?.enabled !== false,
      sort_order:     sectionStates[s.key]?.order   || 0,
      placement:      sectionStates[s.key]?.placement     || s.defaultPlacement || 'auto',
      display_type:   sectionStates[s.key]?.display_type  || s.defaultDisplay   || 'bullets',
      label_override: sectionStates[s.key]?.label_override || null,
    }));
    await fetch(`/admin/api/templates/${tplId}/sections`, {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ sections }),
    });

    // Toggle publish if needed
    const existingTpl = tplList.find(t => t.id === tplId);
    if (publish && !(existingTpl?.is_published)) {
      await fetch(`/admin/api/templates/${tplId}/publish`, { method: "POST" });
    }

    // Reload list
    tplLoaded = false;
    await loadTemplates();
    updatePreviewLinks();
    if (!keepOpen) closeBuilder();
  } catch (err) {
    showTplError("Network error: " + err.message);
  }
}

function showTplError(msg) {
  const el = document.getElementById("admTplBuilderError");
  el.textContent = msg;
  el.hidden = false;
}

// ── Toggle publish from table ────────────────────────────────────────────────
async function togglePublish(id) {
  try {
    const r = await fetch(`/admin/api/templates/${id}/publish`, { method: "POST" });
    const d = await r.json();
    if (d.success) { tplLoaded = false; await loadTemplates(); }
  } catch (err) { console.error("togglePublish:", err); }
}

// ── Delete template modal ────────────────────────────────────────────────────
let pendingDeleteTplId = null;

function deleteTemplate(id) {
  const tpl = tplList.find(t => t.id === id);
  pendingDeleteTplId = id;
  document.getElementById("tplDeleteMsg").textContent =
    `Are you sure you want to delete "${tpl?.title || 'this template'}"? This cannot be undone.`;
  document.getElementById("tplDeleteModal").hidden = false;
}

document.getElementById("tplDeleteCancel").addEventListener("click", () => {
  document.getElementById("tplDeleteModal").hidden = true;
  pendingDeleteTplId = null;
});
document.getElementById("tplDeleteConfirm").addEventListener("click", async () => {
  if (!pendingDeleteTplId) return;
  document.getElementById("tplDeleteModal").hidden = true;
  try {
    await fetch(`/admin/api/templates/${pendingDeleteTplId}`, { method: "DELETE" });
