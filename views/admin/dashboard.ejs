async function submitComplain() {
  const btn = document.getElementById('psComplainBtn');
  btn.disabled = true; btn.textContent = 'Submitting…';
  document.getElementById('psComplainErr').textContent = '';
  try {
    const d = await fetch(`/admin/api/recharge-transactions/${_psComplainId}/complain`, {
