  document.getElementById('psBillerModalTitle').textContent = 'Add Biller';
  document.getElementById('psBillerId').value = '';
  document.getElementById('psBillerId').disabled = false;
  document.getElementById('psBillerName').value = '';
  document.getElementById('psBillerCat').value = 'electricity';
  document.getElementById('psBillerErr').textContent = '';
  document.getElementById('psBillerModal').style.display = 'flex';
}
function openPsBillerEditModal(id, billerId, name, cat) {
  _psBillerEditId = id;
  document.getElementById('psBillerModalTitle').textContent = 'Edit Biller';
  document.getElementById('psBillerId').value = billerId;
  document.getElementById('psBillerId').disabled = true;
  document.getElementById('psBillerName').value = name;
  document.getElementById('psBillerCat').value = cat;
  document.getElementById('psBillerErr').textContent = '';
  document.getElementById('psBillerModal').style.display = 'flex';
}
async function submitPsBiller() {
  const btn = document.getElementById('psBillerBtn');
  btn.disabled = true; btn.textContent = 'Saving…';
  document.getElementById('psBillerErr').textContent = '';
  try {
    const isEdit = !!_psBillerEditId;
    const url = isEdit ? `/admin/api/paysetu/billers/${_psBillerEditId}` : '/admin/api/paysetu/billers';
    const method = isEdit ? 'PUT' : 'POST';
    const body = {
      biller_id: document.getElementById('psBillerId').value.trim(),
      name: document.getElementById('psBillerName').value.trim(),
      category: document.getElementById('psBillerCat').value,
    };
    const d = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) }).then(r => r.json());
    if (d.success) {
      showAdmToast(isEdit ? '✅ Biller updated' : '✅ Biller added', 'success');
      document.getElementById('psBillerModal').style.display = 'none';
      loadPsBillers(); loadPsStats();
    } else { document.getElementById('psBillerErr').textContent = d.message || 'Failed'; }
  } catch(e) { document.getElementById('psBillerErr').textContent = e.message; }
  finally { btn.disabled = false; btn.textContent = 'Save'; }
}
async function togglePsBiller(id) {
  try {
    const d = await fetch(`/admin/api/paysetu/billers/${id}/toggle`, { method:'PATCH' }).then(r => r.json());
    if (d.success) { showAdmToast('✅ Biller status updated'); loadPsBillers(); loadPsStats(); }
    else showAdmToast('Failed: ' + d.message, 'error');
  } catch(e) { showAdmToast(e.message, 'error'); }
}
async function deletePsBiller(id, name) {
  if (!confirm(`Delete biller "${name}"? This cannot be undone.`)) return;
  try {
    const d = await fetch(`/admin/api/paysetu/billers/${id}`, { method:'DELETE' }).then(r => r.json());
    if (d.success) { showAdmToast('🗑️ Biller deleted'); loadPsBillers(); loadPsStats(); }
    else showAdmToast('Failed: ' + d.message, 'error');
  } catch(e) { showAdmToast(e.message, 'error'); }
}

// ── Recharge API Providers ────────────────────────────────────────────────────

async function loadPsProviders() {
  const el = document.getElementById('psProviderTable');

  // Auto-fetch callback URL and show it
  fetch('/admin/api/paysetu/callback-url').then(r => r.json()).then(d => {
    const box = document.getElementById('psCallbackUrlBox');
    document.getElementById('psCallbackUrlText').textContent = d.url;
    document.getElementById('psCallbackSecretWarn').style.display = d.secretSet ? 'none' : 'block';
    box.style.display = 'block';
  }).catch(() => {});

  // Auto-check balance for low-balance alert (silently)
  fetch('/admin/api/paysetu/provider-balance').then(r => r.json()).then(d => {
    if (d.success) {
      const LOW_THRESHOLD = 500;
      const bal = parseFloat(String(d.balance).replace(/,/g, ''));
      const alert = document.getElementById('psLowBalAlert');
      if (!isNaN(bal) && bal < LOW_THRESHOLD) {
        document.getElementById('psLowBalMsg').textContent =
          `Provider wallet balance is low: ₹${d.balance}. Top up your femoney24 account to avoid recharge failures.`;
        alert.style.display = 'block';
      } else {
        alert.style.display = 'none';
      }
    }
  }).catch(() => {});

  try {
    const d = await fetch('/admin/api/paysetu/providers').then(r => r.json());
    if (!d.success) { el.innerHTML = '<p style="color:#dc2626">Failed to load providers.</p>'; return; }
    const rows = d.providers.map(p => {
      const activeBadge = p.is_active
        ? `<span style="background:#dcfce7;color:#16a34a;padding:0.2rem 0.55rem;border-radius:20px;font-size:0.72rem;font-weight:700">● Active</span>`
        : `<span style="background:#f3f4f6;color:#9ca3af;padding:0.2rem 0.55rem;border-radius:20px;font-size:0.72rem;font-weight:600">○ Inactive</span>`;
      const keyDisplay = p.has_key
        ? `<span style="font-family:monospace;font-size:0.78rem;color:#374151">${p.api_key_masked}</span>`
        : `<span style="color:#d1d5db;font-size:0.78rem;font-style:italic">Not set</span>`;
      const toggleBtn = p.is_active
        ? `<button onclick="togglePsProvider(${p.id},false)" style="padding:0.25rem 0.55rem;background:#f59e0b;color:#fff;border:none;border-radius:5px;font-size:0.72rem;cursor:pointer">Deactivate</button>`
        : `<button onclick="togglePsProvider(${p.id},true)" style="padding:0.25rem 0.55rem;background:#16a34a;color:#fff;border:none;border-radius:5px;font-size:0.72rem;cursor:pointer${p.has_key ? '' : ';opacity:0.45;cursor:not-allowed'}" ${p.has_key ? '' : 'disabled title="Set API key first"'}>Activate</button>`;
      return `<tr style="border-bottom:1px solid #f3f4f6">
        <td style="padding:0.55rem 0.45rem;font-weight:600;color:#1a2b6b">${p.display_name}</td>
        <td style="padding:0.55rem 0.45rem">${keyDisplay}</td>
        <td style="padding:0.55rem 0.45rem">${activeBadge}</td>
        <td style="padding:0.55rem 0.45rem;white-space:nowrap">
          <button onclick="openPsProviderModal(${p.id},'${p.display_name}')" style="padding:0.25rem 0.55rem;background:#6366f1;color:#fff;border:none;border-radius:5px;font-size:0.72rem;cursor:pointer;margin-right:0.3rem">Configure</button>
          ${toggleBtn}
        </td>
      </tr>`;
    }).join('');
    el.innerHTML = `<table style="width:100%;border-collapse:collapse;font-size:0.83rem">
      <thead><tr style="border-bottom:2px solid #f3f4f6">
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">PROVIDER</th>
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">API KEY</th>
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">STATUS</th>
        <th style="text-align:left;padding:0.4rem 0.45rem;font-size:0.72rem;color:#9ca3af;font-weight:600">ACTIONS</th>
      </tr></thead><tbody>${rows}</tbody></table>`;
  } catch(e) { el.innerHTML = `<p style="color:#dc2626">Error: ${e.message}</p>`; }
}

function openPsProviderModal(id, name) {
  document.getElementById('psProviderModalId').value = id;
  document.getElementById('psProviderModalName').textContent = `Provider: ${name}`;
  document.getElementById('psProviderKey').value = '';
  document.getElementById('psProviderSecret').value = '';
  document.getElementById('psProviderErr').textContent = '';
  document.getElementById('psProviderModal').style.display = 'flex';
  setTimeout(() => document.getElementById('psProviderKey').focus(), 100);
}

async function submitPsProvider() {
  const btn = document.getElementById('psProviderSaveBtn');
  const id  = document.getElementById('psProviderModalId').value;
  const api_key    = document.getElementById('psProviderKey').value.trim();
  const api_secret = document.getElementById('psProviderSecret').value.trim();
  document.getElementById('psProviderErr').textContent = '';
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const d = await fetch(`/admin/api/paysetu/providers/${id}`, {
      method: 'PUT',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ api_key: api_key || null, api_secret: api_secret || null })
    }).then(r => r.json());
    if (d.success) {
      showAdmToast('✅ API keys saved');
      document.getElementById('psProviderModal').style.display = 'none';
      loadPsProviders();
    } else { document.getElementById('psProviderErr').textContent = d.message || 'Failed to save'; }
  } catch(e) { document.getElementById('psProviderErr').textContent = e.message; }
  finally { btn.disabled = false; btn.textContent = 'Save Keys'; }
}

function copyCallbackUrl() {
  const url = document.getElementById('psCallbackUrlText').textContent;
  navigator.clipboard.writeText(url).then(() => {
    const btn = document.getElementById('psCopyUrlBtn');
    btn.textContent = 'Copied!'; btn.style.background = '#16a34a';
    setTimeout(() => { btn.textContent = 'Copy'; btn.style.background = '#1d4ed8'; }, 2000);
  }).catch(() => showAdmToast('Could not copy — please copy manually.', 'error'));
}

async function checkProviderBalance() {
  const btn = document.getElementById('psBalanceBtn');
  const display = document.getElementById('psProviderBalanceDisplay');
  btn.disabled = true; btn.textContent = 'Checking…';
  display.style.display = 'none';
  try {
    const d = await fetch('/admin/api/paysetu/provider-balance').then(r => r.json());
    if (d.success) {
      const LOW_THRESHOLD = 500;
      const bal = parseFloat(String(d.balance).replace(/,/g, ''));
      const isLow = !isNaN(bal) && bal < LOW_THRESHOLD;
      display.textContent = `💰 Provider Balance (${d.provider}): ₹${d.balance}${isLow ? ' — ⚠️ LOW' : ''}`;
      display.style.background = isLow ? '#fef9c3' : '#f0fdf4';
      display.style.borderColor = isLow ? '#fcd34d' : '#bbf7d0';
      display.style.color      = isLow ? '#92400e' : '#166534';
      // Also update the alert banner
      const alert = document.getElementById('psLowBalAlert');
      if (isLow) {
        document.getElementById('psLowBalMsg').textContent =
          `Provider wallet balance is low: ₹${d.balance}. Top up your femoney24 account to avoid recharge failures.`;
        alert.style.display = 'block';
      } else { alert.style.display = 'none'; }
    } else {
      display.textContent = '⚠️ ' + (d.message || 'Could not fetch balance');
      display.style.background = '#fef9c3'; display.style.borderColor = '#fcd34d'; display.style.color = '#92400e';
    }
    display.style.display = 'block';
  } catch(e) {
    display.textContent = '❌ Error: ' + e.message;
    display.style.display = 'block';
  }
  finally { btn.disabled = false; btn.textContent = '💰 Check Balance'; }
}

async function togglePsProvider(id, activate) {
  try {
    const d = await fetch(`/admin/api/paysetu/providers/${id}/toggle`, {
      method: 'PATCH',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ active: activate })
    }).then(r => r.json());
    if (d.success) {
      showAdmToast(activate ? '✅ Provider activated' : '✅ Provider deactivated');
      loadPsProviders();
    } else showAdmToast('Failed: ' + d.message, 'error');
  } catch(e) { showAdmToast(e.message, 'error'); }
}

// ── Recharge Plans ────────────────────────────────────────────────────────────

const PLAN_OPS = {
  mobile: [['airtel','Airtel'],['vi','Vi'],['bsnl','BSNL']],
  dth:    [['tataplay','Tata Play'],['dishtv','Dish TV'],['airtel_dth','Airtel DTH']]
};

function plansFilterOperatorUpdate() {
  const type = document.getElementById('plansFilterType').value;
  const sel  = document.getElementById('plansFilterOp');
  sel.innerHTML = '<option value="">All</option>';
  (PLAN_OPS[type] || []).forEach(([v,l]) => sel.innerHTML += `<option value="${v}">${l}</option>`);
}

function planModalOpUpdate() {
  const type = document.getElementById('planFormType').value;
  const sel  = document.getElementById('planFormOp');
  sel.innerHTML = '';
  (PLAN_OPS[type] || []).forEach(([v,l]) => sel.innerHTML += `<option value="${v}">${l}</option>`);
}

async function loadPlansTable() {
  const tbody = document.getElementById('plansTableBody');
  tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;color:#94a3b8;padding:1rem">Loading…</td></tr>';
  const type   = document.getElementById('plansFilterType').value;
  const op     = document.getElementById('plansFilterOp').value;
  const circle = (document.getElementById('plansFilterCircle')?.value || '').trim();
  let url = '/admin/api/recharge-plans';
  const params = [];
  if (type)   params.push('type=' + encodeURIComponent(type));
  if (op)     params.push('operator=' + encodeURIComponent(op));
  if (circle) params.push('circle=' + encodeURIComponent(circle));
  if (params.length) url += '?' + params.join('&');
  try {
    const d = await fetch(url).then(r => r.json());
    if (!d.success || !d.plans.length) {
      tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;color:#94a3b8;padding:1.5rem">No plans found.</td></tr>';
      return;
    }
    tbody.innerHTML = d.plans.map(p => `
      <tr>
        <td><strong>₹${p.amount}</strong></td>
        <td>${p.validity}</td>
        <td style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="${p.description}">${p.description}</td>
        <td><span style="background:#ede9fe;color:#6d28d9;border-radius:99px;padding:2px 9px;font-size:0.72rem;font-weight:700">${p.category}</span></td>
        <td style="font-size:0.78rem;color:#475569">${p.circle || 'All India'}</td>
        <td style="text-transform:capitalize">${p.operator}</td>
        <td style="text-transform:capitalize">${p.type}</td>
        <td>
          <span style="cursor:pointer;background:${p.is_active?'#dcfce7':'#fee2e2'};color:${p.is_active?'#16a34a':'#dc2626'};border-radius:99px;padding:2px 10px;font-size:0.72rem;font-weight:700"
            onclick="togglePlan(${p.id},this)">${p.is_active?'Active':'Off'}</span>
        </td>
        <td style="white-space:nowrap">
          <button onclick='editPlan(${JSON.stringify(p)})' style="padding:3px 10px;background:#e0e7ff;color:#4338ca;border:none;border-radius:6px;font-size:0.75rem;font-weight:600;cursor:pointer;margin-right:4px">Edit</button>
          <button onclick="deletePlan(${p.id})" style="padding:3px 10px;background:#fee2e2;color:#dc2626;border:none;border-radius:6px;font-size:0.75rem;font-weight:600;cursor:pointer">Del</button>
        </td>
      </tr>`).join('');
  } catch(e) { tbody.innerHTML = '<tr><td colspan="9" style="color:#dc2626;padding:1rem">Error loading plans.</td></tr>'; }
}

function openPlanModal(edit) {
  document.getElementById('planModal').style.display = 'flex';
  document.getElementById('planModalErr').textContent = '';
  document.getElementById('planEditId').value = edit ? edit.id : '';
  document.getElementById('planModalTitle').textContent = edit ? 'Edit Plan' : 'Add Plan';
  document.getElementById('planFormType').value = edit ? edit.type : 'mobile';
  planModalOpUpdate();
  if (edit) document.getElementById('planFormOp').value = edit.operator;
  document.getElementById('planFormAmount').value   = edit ? edit.amount      : '';
  document.getElementById('planFormValidity').value = edit ? edit.validity    : '';
  document.getElementById('planFormDesc').value     = edit ? edit.description : '';
  document.getElementById('planFormCat').value      = edit ? edit.category    : 'data';
  document.getElementById('planFormSort').value     = edit ? (edit.sort_order || 0) : 0;
  document.getElementById('planFormCircle').value   = edit ? (edit.circle || 'All India') : 'All India';
}
function closePlanModal() { document.getElementById('planModal').style.display = 'none'; }
function editPlan(p) { openPlanModal(p); }

async function submitPlanForm() {
  const btn = document.getElementById('planSaveBtn');
  const err = document.getElementById('planModalErr');
  const id  = document.getElementById('planEditId').value;
  const body = {
    type:        document.getElementById('planFormType').value,
    operator:    document.getElementById('planFormOp').value,
    amount:      document.getElementById('planFormAmount').value,
    validity:    document.getElementById('planFormValidity').value.trim(),
    description: document.getElementById('planFormDesc').value.trim(),
    category:    document.getElementById('planFormCat').value,
    sort_order:  document.getElementById('planFormSort').value,
    circle:      (document.getElementById('planFormCircle').value || 'All India').trim(),
    is_active:   1
  };
  if (!body.amount || !body.validity || !body.description) {
    err.textContent = 'Amount, validity and description are required.'; return;
  }
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const url    = id ? `/admin/api/recharge-plans/${id}` : '/admin/api/recharge-plans';
    const method = id ? 'PUT' : 'POST';
    const d = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) }).then(r => r.json());
    if (d.success) { closePlanModal(); loadPlansTable(); showAdmToast('✅ Plan saved'); }
    else { err.textContent = d.error || 'Failed to save.'; }
  } catch(e) { err.textContent = e.message; }
  btn.disabled = false; btn.textContent = 'Save Plan';
}

async function togglePlan(id, el) {
  try {
    const d = await fetch(`/admin/api/recharge-plans/${id}/toggle`, {method:'POST'}).then(r => r.json());
    if (d.success) loadPlansTable();
    else showAdmToast('Toggle failed', 'error');
  } catch(e) { showAdmToast(e.message,'error'); }
}

async function deletePlan(id) {
  if (!confirm('Delete this plan?')) return;
  try {
    const d = await fetch(`/admin/api/recharge-plans/${id}`, {method:'DELETE'}).then(r => r.json());
    if (d.success) { loadPlansTable(); showAdmToast('🗑️ Plan deleted'); }
    else showAdmToast('Delete failed', 'error');
  } catch(e) { showAdmToast(e.message,'error'); }
}

async function deleteAllPlans() {
  const type = document.getElementById('plansFilterType').value;
  const op   = document.getElementById('plansFilterOp').value;
  const scope = [op, type].filter(Boolean).join(' ') || 'ALL';
  if (!confirm(`⚠️ Permanently delete ${scope} plans from the database?\n\nThis cannot be undone.`)) return;
  try {
    const params = [];
    if (type) params.push('type=' + encodeURIComponent(type));
    if (op)   params.push('operator=' + encodeURIComponent(op));
    const url = '/admin/api/recharge-plans' + (params.length ? '?' + params.join('&') : '');
    const d = await fetch(url, { method: 'DELETE' }).then(r => r.json());
    if (d.success) { loadPlansTable(); showAdmToast('🗑️ Plans deleted'); }
    else showAdmToast('Delete failed', 'error');
  } catch(e) { showAdmToast(e.message, 'error'); }
}

async function loadDthLimits() {
  try {
    const d = await fetch('/admin/api/settings').then(r => r.json());
    if (d.success) {
      const s = d.settings;
      document.getElementById('dthLimitMin').value = s.dth_recharge_min || 200;
      document.getElementById('dthLimitMax').value = s.dth_recharge_max || 50000;
    }
  } catch(e) {}
}

async function saveDthLimits() {
  const min = parseInt(document.getElementById('dthLimitMin').value, 10);
  const max = parseInt(document.getElementById('dthLimitMax').value, 10);
  const msg = document.getElementById('dthLimitsMsg');
  if (isNaN(min) || min < 1) { showAdmToast('Enter a valid minimum amount', 'error'); return; }
  if (isNaN(max) || max <= min) { showAdmToast('Max must be greater than min', 'error'); return; }
  try {
    const d = await fetch('/admin/api/settings', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ dth_recharge_min: min, dth_recharge_max: max })
    }).then(r => r.json());
    if (d.success) {
      msg.textContent = `Saved — Min ₹${min}, Max ₹${max}`;
      msg.style.display = 'block';
      setTimeout(() => msg.style.display = 'none', 3000);
      showAdmToast('DTH limits updated');
    } else showAdmToast('Save failed', 'error');
  } catch(e) { showAdmToast(e.message, 'error'); }
}

// Load plans when section becomes active
document.addEventListener('DOMContentLoaded', () => {
  const plansSection = document.getElementById('plans');
  if (plansSection) {
    const obs = new MutationObserver(() => {
      if (!plansSection.hidden) { plansFilterOperatorUpdate(); loadPlansTable(); loadDthLimits(); obs.disconnect(); }
    });
    obs.observe(plansSection, { attributes: true, attributeFilter: ['hidden'] });
  }
});
</script>

