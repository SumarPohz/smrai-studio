async function approveInvReq(id, btn) {
  btn.disabled = true; btn.textContent = '…';
  const r = await fetch(`/admin/api/investor-requests/${id}/approve`, { method: 'PATCH' }).then(r => r.json()).catch(() => ({}));
  if (r.success) loadInvestors(); else { alert('Failed'); btn.disabled = false; btn.textContent = 'Approve'; }
}
async function rejectInvReq(id, btn) {
  if (!confirm('Reject this request?')) return;
  btn.disabled = true; btn.textContent = '…';
  const r = await fetch(`/admin/api/investor-requests/${id}/reject`, { method: 'PATCH', headers: {'Content-Type':'application/json'}, body: '{}' }).then(r => r.json()).catch(() => ({}));
  if (r.success) loadInvestors(); else { alert('Failed'); btn.disabled = false; btn.textContent = 'Reject'; }
}
async function clearInvReq(id, btn) {
  if (!confirm('Remove this request permanently?')) return;
  btn.disabled = true; btn.textContent = '…';
  const r = await fetch(`/admin/api/investor-requests/${id}`, { method: 'DELETE' }).then(r => r.json()).catch(() => ({}));
  if (r.success) loadInvestors(); else { alert('Failed'); btn.disabled = false; btn.textContent = 'Clear'; }
}
async function saveInvConfig(btn) {
  const amount = document.getElementById('invCfgAmount').value;
  const equity = document.getElementById('invCfgEquity').value;
  const valuation = document.getElementById('invCfgValuation').value;
  btn.disabled = true; const orig = btn.textContent; btn.textContent = 'Saving…';
  const r = await fetch('/admin/api/investment-config', { method: 'PATCH', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ amount, equity, valuation }) }).then(r => r.json()).catch(() => ({}));
  btn.textContent = r.success ? 'Saved ✓' : 'Failed';
  setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2000);
}

// ── Investment modal (record / edit) ───────────────────────────────────────
let _invModalValuation = 125000;

function openRecordInv(userId, name, defaultAmt) {
  document.getElementById('invModalTitle').textContent = 'Record Investment';
  document.getElementById('invModalUserId').value = userId;
  document.getElementById('invModalInvId').value = '';
  document.getElementById('invModalName').textContent = name;
  document.getElementById('invModalAmount').value = defaultAmt || '';
  document.getElementById('invModalRef').value = '';
  document.getElementById('invModalErr').textContent = '';
  document.getElementById('invModalEquityPreview').textContent = '';
  if (defaultAmt) invModalCalc();
  document.getElementById('invModal').style.display = 'flex';
}

function openEditInv(invId, name, amount, paymentId) {
  document.getElementById('invModalTitle').textContent = 'Edit Investment';
  document.getElementById('invModalUserId').value = '';
  document.getElementById('invModalInvId').value = invId;
  document.getElementById('invModalName').textContent = name;
  document.getElementById('invModalAmount').value = amount;
  document.getElementById('invModalRef').value = paymentId || '';
  document.getElementById('invModalErr').textContent = '';
  invModalCalc();
  document.getElementById('invModal').style.display = 'flex';
}

function closeInvModal() {
  document.getElementById('invModal').style.display = 'none';
}

function invModalCalc() {
  const amt = parseFloat(document.getElementById('invModalAmount').value) || 0;
  const preview = document.getElementById('invModalEquityPreview');
  if (!amt) { preview.textContent = ''; return; }
  const eq = ((amt / _invModalValuation) * 100).toFixed(2);
  preview.textContent = `→ ${eq}% equity at ₹${_invModalValuation.toLocaleString('en-IN')} valuation`;
}

async function saveInvModal() {
  const userId = document.getElementById('invModalUserId').value;
  const invId  = document.getElementById('invModalInvId').value;
  const amount = document.getElementById('invModalAmount').value;
  const ref    = document.getElementById('invModalRef').value.trim();
  const errEl  = document.getElementById('invModalErr');
  const btn    = document.getElementById('invModalSaveBtn');
  if (!amount || parseFloat(amount) < 1) { errEl.textContent = 'Please enter a valid amount'; return; }
  btn.disabled = true; btn.textContent = 'Saving…';
  errEl.textContent = '';
  try {
    let r;
    if (invId) {
      r = await fetch(`/admin/api/investments/${invId}`, {
        method: 'PATCH', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ amount: parseFloat(amount), payment_ref: ref || undefined }),
      }).then(r => r.json());
    } else {
      r = await fetch('/admin/api/investments/manual', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ user_id: parseInt(userId), amount: parseFloat(amount), payment_ref: ref || undefined }),
      }).then(r => r.json());
    }
    if (r.success) { closeInvModal(); loadInvestors(); }
    else { errEl.textContent = r.message || 'Failed to save'; }
  } catch (_) { errEl.textContent = 'Something went wrong'; }
  btn.disabled = false; btn.textContent = 'Save Investment';
}

// Close modal on backdrop click
document.getElementById('invModal').addEventListener('click', function(e) {
  if (e.target === this) closeInvModal();
});

async function saveEnvField(key, inputId, btn) {
