  } catch (err) { console.error("deleteTemplate:", err); }
  pendingDeleteTplId = null;
});

// ── Thumbnail file upload ─────────────────────────────────────────────────────
async function uploadThumbnailFile(file) {
  if (!builderTplId) { alert("Save a draft first before uploading a thumbnail."); return; }
  const statusEl = document.getElementById("admTplThumbStatus");
  if (file.size > 5 * 1024 * 1024) { statusEl.textContent = "File too large (max 5 MB)."; return; }
  statusEl.textContent = "Uploading…";
  const fd = new FormData();
  fd.append("image", file);
  try {
    const r = await fetch(`/admin/api/templates/${builderTplId}/image`, { method: "POST", body: fd });
    const d = await r.json();
    if (!d.success) { statusEl.textContent = "Upload failed."; return; }
    document.getElementById("admTplThumb").src = d.imageUrl;
    document.getElementById("admTplThumbBox").hidden = false;
    statusEl.textContent = "Thumbnail saved!";
    tplLoaded = false;
    loadTemplates();
  } catch (err) {
    statusEl.textContent = "Error: " + err.message;
  }
}

document.getElementById("admTplThumbFile").addEventListener("change", function() {
  if (this.files[0]) uploadThumbnailFile(this.files[0]);
});

// Drag & drop on the upload zone
const uploadZone = document.getElementById("admTplUploadZone");
uploadZone.addEventListener("dragover", e => { e.preventDefault(); uploadZone.classList.add("adm-tpl-upload-zone--over"); });
uploadZone.addEventListener("dragleave", ()  => uploadZone.classList.remove("adm-tpl-upload-zone--over"));
uploadZone.addEventListener("drop", e => {
  e.preventDefault();
  uploadZone.classList.remove("adm-tpl-upload-zone--over");
  const file = e.dataTransfer.files[0];
  if (file && file.type.startsWith("image/")) uploadThumbnailFile(file);
});

// Remove thumbnail
document.getElementById("admTplThumbRemove").addEventListener("click", async () => {
  if (!builderTplId) return;
  await fetch(`/admin/api/templates/${builderTplId}/thumbnail`, {
    method: "POST", headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ thumbnailUrl: null }),
  });
  document.getElementById("admTplThumbBox").hidden = true;
  document.getElementById("admTplThumb").src = "";
  document.getElementById("admTplThumbStatus").textContent = "Thumbnail removed.";
  tplLoaded = false;
  loadTemplates();
});

