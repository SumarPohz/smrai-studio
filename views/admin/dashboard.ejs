  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const r = await fetch("/admin/api/env-settings", {
      method: "PATCH", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ [key]: val }),
    });
    const d = await r.json();
    btn.textContent = d.success ? 'Saved ✓' : 'Failed';
    setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2000);
  } catch (_) { btn.textContent = 'Error'; btn.disabled = false; }
}

async function loadEnvSettings() {
  // Values are never pre-displayed for security
}

async function saveEnvSettings() {
  const msg = document.getElementById("envSaveMsg");
  const payload = {};
  for (const [key, elId] of Object.entries(ENV_FIELD_MAP)) {
    const el = document.getElementById(elId);
    if (el && el.value.trim()) payload[key] = el.value.trim();
  }
  try {
    const r = await fetch("/admin/api/env-settings", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const d = await r.json();
    if (d.success) {
      msg.textContent = "Saved! Changes are now live.";
      msg.className = "adm-ads-msg adm-msg-ok";
    } else {
      msg.textContent = "Failed to save.";
      msg.className = "adm-ads-msg adm-msg-error";
    }
  } catch (_) {
    msg.textContent = "Error saving.";
    msg.className = "adm-ads-msg adm-msg-error";
  }
  setTimeout(() => { msg.textContent = ""; }, 4000);
}

function toggleEnvReveal(inputId, btn) {
  const el = document.getElementById(inputId);
  if (!el) return;
  const isHidden = el.type === 'password';
  el.type = isHidden ? 'text' : 'password';
  btn.innerHTML = isHidden ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
}

