// Force-refund a stuck pending recharge
async function forceRefundPending(id) {
  if (!confirm(`Force-refund transaction #${id}? This will mark it as failed and return the amount to the user's wallet.`)) return;
  try {
    const d = await fetch(`/admin/api/recharge-transactions/${id}/refund`, { method: 'POST' }).then(r => r.json());
    if (d.success) { showAdmToast('✅ ' + d.message, 'success'); loadPsTxns(); }
    else showAdmToast(d.message || 'Refund failed', 'error');
  } catch(e) { showAdmToast(e.message, 'error'); }
}

