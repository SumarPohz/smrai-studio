                data-current="${u.role}">
          ${u.role === "admin" || u.role === "subadmin" ? "⬇ Demote to User" : "⬆ Promote to Sub-Admin"}
        </button>
        <button class="adm-toggle-active-btn ${u.is_active ? "adm-toggle-active-btn-deactivate" : "adm-toggle-active-btn-activate"}"
                id="toggleActiveBtn"
                data-uid="${u.id}"
