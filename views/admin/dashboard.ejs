        <td style="padding:0.6rem 0.75rem;white-space:nowrap">
          <button onclick="openEditInv(${i.id},'${i.name}',${i.amount},'${i.payment_id}')" style="padding:0.25rem 0.65rem;background:#f59e0b;color:#fff;border:none;border-radius:5px;font-size:0.75rem;font-weight:600;cursor:pointer">Edit</button>
