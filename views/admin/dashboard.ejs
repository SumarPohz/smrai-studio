});

// ESC key closes the builder
document.addEventListener("keydown", function(e) {
  if (e.key === "Escape" && !document.getElementById("admTplBuilder").hidden) closeBuilder();
});

function openBuilder(id) {
  builderTplId = id;
  const tpl    = id ? tplList.find(t => t.id === id) : null;
  document.getElementById("admTplBuilderTitle").textContent = id ? "Edit Template" : "Create Template";

  // Reset form
  document.getElementById("admTplTitle").value    = tpl?.title       || "";
  document.getElementById("admTplDesc").value     = tpl?.description || "";
  document.getElementById("admTplCategory").value = tpl?.category    || "experienced";
  document.getElementById("admTplBadge").value    = tpl?.badge       || "New";

  const cs = tpl?.color_scheme || {};
  document.getElementById("admTplColorPrimary").value   = cs.primary   || "#1e3a5f";
  document.getElementById("admTplColorSecondary").value = cs.secondary || "#f3f4f6";
  document.getElementById("admTplColorAccent").value    = cs.accent    || "#3b82f6";
  document.getElementById("admTplColorText").value      = cs.text      || "#1f2937";

  // Layout radio
  const layoutVal = tpl?.layout_type || "two-column-left";
  document.querySelectorAll("input[name='admTplLayout']").forEach(r => {
    r.checked = r.value === layoutVal;
  });

  // Pricing
  document.getElementById("admTplIsPaid").checked = tpl ? tpl.is_paid : true;
  document.getElementById("admTplPrice").value    = tpl?.price_inr || CATEGORY_PRICE[document.getElementById("admTplCategory").value] || 49;
  document.getElementById("admTplPriceWrap").style.display = tpl ? (tpl.is_paid ? "" : "none") : "";

  // Thumbnail
  const thumbBox = document.getElementById("admTplThumbBox");
  const thumbImg = document.getElementById("admTplThumb");
  if (tpl?.thumbnail_url) {
    thumbImg.src   = tpl.thumbnail_url;
    thumbBox.hidden = false;
  } else {
    thumbBox.hidden = true;
  }

  // Reset thumbnail status
  document.getElementById("admTplThumbStatus").textContent = "";

  // Background image
  setAdmBgPreview(tpl?.background_image_url || null);
  document.getElementById("admTplBgStatus").textContent = "";

  // Design settings
  const ds = tpl?.design_settings || {};
  document.getElementById("dsFont").value              = ds.fontFamily        || "segoe";
  document.getElementById("dsHeadingWeight").value     = ds.headingWeight     || "800";
  document.getElementById("dsBodySize").value          = ds.bodySize          || "medium";
  document.getElementById("dsBorderRadius").value      = ds.borderRadius      || "soft";
  document.getElementById("dsShadow").value            = ds.shadow            || "none";
  document.getElementById("dsSectionTitleStyle").value = ds.sectionTitleStyle || "underline";
  document.getElementById("dsHeaderStyle").value       = ds.headerStyle       || "classic";
  document.getElementById("dsPillShape").value         = ds.pillShape         || "rounded";

  // Sections
  renderSectionsList(tpl ? null : null); // load from API if editing
  if (id) {
    fetch(`/admin/api/templates/${id}/sections`)
      .then(r => r.json())
      .then(d => d.success && renderSectionsList(d.sections))
      .catch(() => {});
  }

  // Switch to first tab
  switchTplTab("basic");
  document.getElementById("admTplBuilderError").hidden = true;
  document.getElementById("admTplBuilder").hidden = false;
  document.getElementById("admTplBuilder").scrollTop = 0;

  // Enable preview links if editing existing template
  if (id) updatePreviewLinks();
}

function closeBuilder() {
  document.getElementById("admTplBuilder").hidden = true;
  builderTplId = null;
}

// ── Tab switching ────────────────────────────────────────────────────────────
const TAB_ORDER = ["basic", "layout", "sections", "design", "pricing", "preview"];

document.querySelectorAll(".adm-tpl-tab").forEach(tab => {
  tab.addEventListener("click", () => switchTplTab(tab.dataset.tab));
});

document.getElementById("admTplNextBtn").addEventListener("click", () => {
  const cur = TAB_ORDER.indexOf(currentTab());
  if (cur < TAB_ORDER.length - 1) switchTplTab(TAB_ORDER[cur + 1]);
});
document.getElementById("admTplBackBtn").addEventListener("click", () => {
  const cur = TAB_ORDER.indexOf(currentTab());
  if (cur > 0) switchTplTab(TAB_ORDER[cur - 1]);
});

function currentTab() {
  const active = document.querySelector(".adm-tpl-tab.active");
  return active ? active.dataset.tab : "basic";
}

function switchTplTab(name) {
  document.querySelectorAll(".adm-tpl-tab").forEach(t => t.classList.toggle("active", t.dataset.tab === name));
  document.querySelectorAll(".adm-tpl-tab-content").forEach(c => c.classList.toggle("active", c.dataset.tabContent === name));
  if (name === "preview" && builderTplId) updatePreviewLinks();
  // Update Back / Next buttons
  const idx = TAB_ORDER.indexOf(name);
  document.getElementById("admTplBackBtn").hidden = idx <= 0;
  document.getElementById("admTplNextBtn").hidden = idx >= TAB_ORDER.length - 1;
}

