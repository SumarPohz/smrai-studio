    document.getElementById("roleToggleBtn").addEventListener("click", function () {
      const cur = this.dataset.current;
      const isElevated = cur === "admin" || cur === "subadmin";
      if (!isElevated) {
        // Promoting to subadmin — show investor sub-form
        this.style.display = "none";
        document.getElementById("promoteInvForm").style.display = "block";
        document.getElementById("promoteInvFields").style.display = "none";
        document.getElementById("promoteInvEquity").textContent = "";
        document.getElementById("promoteInvErr").textContent = "";
        document.getElementById("promoteInvAmount").value = "";
        document.getElementById("promoteInvValuation").value = _invModalValuation || 125000;
      } else {
        // Demoting — instant
        _doRoleChange(this, "user");
      }
    });

    // Load permissions grid if this is a subadmin
    if (u.role === "subadmin") {
      _loadPermsGrid(u.id);
    }

    async function _doRoleChange(btn, newRole) {
      if (btn) btn.disabled = true;
      const uid = document.getElementById("roleToggleBtn").dataset.uid;
      try {
        const r = await fetch(`/admin/api/user/${uid}/role`, {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ role: newRole }),
        });
        const d = await r.json();
        if (d.success) {
          _applyRoleUI(uid, newRole);
          if (newRole === "subadmin") _loadPermsGrid(uid);
        } else {
          alert(d.message || "Failed to update role.");
          document.getElementById("roleToggleBtn").style.display = "";
          document.getElementById("promoteInvForm").style.display = "none";
        }
      } catch (_) {
        alert("Network error.");
        document.getElementById("roleToggleBtn").style.display = "";
        document.getElementById("promoteInvForm").style.display = "none";
      } finally {
        if (btn) btn.disabled = false;
      }
    }

    // Wire promote investor sub-form buttons via addEventListener (not onclick)
    document.getElementById("promoteInvYes").addEventListener("click", _showPromoteInvFields);
    document.getElementById("promoteInvNo").addEventListener("click", () => _confirmPromote(false));
    document.getElementById("promoteInvAmount").addEventListener("input", _promoteInvCalc);
    document.getElementById("promoteInvValuation").addEventListener("input", _promoteInvCalc);
    document.getElementById("promoteInvConfirmBtn").addEventListener("click", () => _confirmPromote(true));
    document.querySelector("#promoteInvForm button[data-cancel]")?.addEventListener("click", _hidePromoteInvForm);

    // ── Toggle active handler ────────────────────────────────────────────
    document.getElementById("toggleActiveBtn").addEventListener("click", async function () {
      const uid  = this.dataset.uid;
      const prev = this.dataset.active === "true";
      this.disabled = true;
      try {
        const r = await fetch(`/admin/api/user/${uid}/toggle-active`, { method: "PATCH" });
        const d = await r.json();
        if (d.success) {
          const nowActive = d.is_active;
          this.dataset.active = nowActive;
          this.innerHTML = `<i class="fas ${nowActive ? "fa-ban" : "fa-check-circle"}"></i> ${nowActive ? "Deactivate" : "Activate"}`;
          this.className = `adm-toggle-active-btn ${nowActive ? "adm-toggle-active-btn-deactivate" : "adm-toggle-active-btn-activate"}`;
          const badge = document.getElementById("modalActiveBadge");
          badge.textContent = nowActive ? "Active" : "Inactive";
          badge.className   = `adm-badge ${nowActive ? "adm-badge-active" : "adm-badge-inactive"}`;
        } else {
          alert(d.message || "Failed to update status.");
        }
      } catch (_) {
        alert("Network error.");
      } finally {
        this.disabled = false;
      }
    });

    // ── Delete user handler ─────────────────────────────────────────────
    document.getElementById("deleteUserBtn").addEventListener("click", function () {
      const uid  = this.dataset.uid;
      const name = this.dataset.name;
      document.getElementById("userDeleteMsg").innerHTML =
        `This will permanently delete <strong>${name}</strong> and all their data. This cannot be undone.`;
      document.getElementById("userDeleteModal").hidden = false;
      document.getElementById("userDeleteConfirm").dataset.uid = uid;
    });

  } catch (_) {
    body.innerHTML = "<p>Error loading user.</p>";
  }
}

function closeModal() {
  const m = document.getElementById("userModal");
  if (m) m.hidden = true;
  document.body.style.overflow = "";
}

// ── Admin: Change Password + Set PIN helpers ────────────────────────────────
let _adminPwdUserId = null, _adminPinUserId = null;

function openAdminPwdModal(uid) {
  _adminPwdUserId = uid;
  document.getElementById('adminPwdInput').value = '';
  document.getElementById('adminPwdErr').textContent = '';
  document.getElementById('adminPwdModal').style.display = 'flex';
  setTimeout(() => document.getElementById('adminPwdInput').focus(), 50);
}

async function submitAdminPwd() {
  const pwd = document.getElementById('adminPwdInput').value.trim();
  const err = document.getElementById('adminPwdErr');
  if (pwd.length < 6) { err.textContent = "Min 6 characters."; return; }
  err.textContent = '';
  const res  = await fetch(`/admin/api/user/${_adminPwdUserId}/set-password`, {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ password: pwd })
  });
  const data = await res.json();
  if (data.success) {
    document.getElementById('adminPwdModal').style.display = 'none';
    showAdmToast("Password updated successfully.");
  } else {
    err.textContent = data.message || "Failed.";
  }
}

function openAdminPinModal(uid) {
  _adminPinUserId = uid;
  document.querySelectorAll('#adminPinModal .adm-pin-box').forEach(b => b.value = '');
  document.getElementById('adminPinErr').textContent = '';
  document.getElementById('adminPinModal').style.display = 'flex';
  const boxes = document.querySelectorAll('#adminPinModal .adm-pin-box');
  boxes.forEach((box, i) => {
    box.oninput = () => { if (box.value && i < 3) boxes[i+1].focus(); };
    box.onkeydown = e => { if (e.key === 'Backspace' && !box.value && i > 0) { e.preventDefault(); boxes[i-1].focus(); } };
  });
  setTimeout(() => boxes[0].focus(), 50);
}

async function submitAdminPin() {
  const boxes = document.querySelectorAll('#adminPinModal .adm-pin-box');
  const pin   = Array.from(boxes).map(b => b.value).join('');
  const err   = document.getElementById('adminPinErr');
  if (!/^\d{4}$/.test(pin)) { err.textContent = "Enter all 4 digits."; return; }
  err.textContent = '';
  const res  = await fetch(`/admin/api/user/${_adminPinUserId}/set-pin`, {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ pin })
  });
  const data = await res.json();
  if (data.success) {
    document.getElementById('adminPinModal').style.display = 'none';
    showAdmToast("Wallet PIN set successfully.");
  } else {
    err.textContent = data.message || "Failed.";
  }
}

// ── Promote-to-admin investor sub-form helpers (global scope) ───────────────
function _showPromoteInvFields() {
  document.getElementById("promoteInvFields").style.display = "block";
  document.getElementById("promoteInvYes").style.background = "#ede9fe";
}
function _hidePromoteInvForm() {
  document.getElementById("promoteInvForm").style.display = "none";
  document.getElementById("roleToggleBtn").style.display = "";
}
function _promoteInvCalc() {
  const amt = parseFloat(document.getElementById("promoteInvAmount").value) || 0;
  const val = parseFloat(document.getElementById("promoteInvValuation").value) || 0;
  const el = document.getElementById("promoteInvEquity");
  el.textContent = (amt && val) ? "→ Equity: " + ((amt / val) * 100).toFixed(2) + "%" : "";
}
async function _confirmPromote(withInvestment) {
  const confirmBtn = document.getElementById("promoteInvConfirmBtn");
  const errEl = document.getElementById("promoteInvErr");
  if (confirmBtn) { confirmBtn.disabled = true; confirmBtn.textContent = "Saving…"; }
  const uid = document.getElementById("roleToggleBtn").dataset.uid;
  if (withInvestment) {
    const amount = parseFloat(document.getElementById("promoteInvAmount").value);
    const valuation = parseFloat(document.getElementById("promoteInvValuation").value);
    if (!amount || amount < 1) { if (errEl) errEl.textContent = "Enter a valid amount"; if (confirmBtn) { confirmBtn.disabled = false; confirmBtn.textContent = "Confirm & Promote"; } return; }
    if (!valuation || valuation < 1) { if (errEl) errEl.textContent = "Enter a valid valuation"; if (confirmBtn) { confirmBtn.disabled = false; confirmBtn.textContent = "Confirm & Promote"; } return; }
    if (errEl) errEl.textContent = "";
    const r1 = await fetch(`/admin/api/user/${uid}/role`, {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ role: "subadmin" }),
    }).then(r => r.json()).catch(() => ({}));
    if (!r1.success) { if (errEl) errEl.textContent = r1.message || "Failed to set role"; if (confirmBtn) { confirmBtn.disabled = false; confirmBtn.textContent = "Confirm & Promote"; } return; }
    const r2 = await fetch("/admin/api/investments/manual", {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ user_id: parseInt(uid), amount, payment_ref: "Admin recorded", valuation }),
    }).then(r => r.json()).catch(() => ({}));
    if (!r2.success) { if (errEl) errEl.textContent = r2.message || "Role set but investment failed"; if (confirmBtn) { confirmBtn.disabled = false; confirmBtn.textContent = "Confirm & Promote"; } return; }
    _applyRoleUI(uid, "subadmin", true);
    _loadPermsGrid(uid);
  } else {
    await _doRoleChange(null, "subadmin");
  }
  if (confirmBtn) { confirmBtn.disabled = false; confirmBtn.textContent = "Confirm & Promote"; }
}
function _applyRoleUI(uid, newRole, hasInvestment) {
  const isElevated = newRole === "admin" || newRole === "subadmin";
  const badgeClass = newRole === "admin" ? "adm-badge-admin" : newRole === "subadmin" ? "adm-badge-subadmin" : "adm-badge-user";
  const displayLabel = newRole === "subadmin" ? (hasInvestment ? "Investor" : "Sub-Admin") : newRole;
  const toggleBtn = document.getElementById("roleToggleBtn");
  toggleBtn.dataset.current = newRole;
  toggleBtn.textContent = isElevated ? "⬇ Demote to User" : "⬆ Promote to Sub-Admin";
  toggleBtn.className = "adm-role-btn " + (isElevated ? "adm-role-btn-demote" : "adm-role-btn-promote");
  toggleBtn.style.display = "";
  document.getElementById("modalRoleBadge").textContent = displayLabel;
  document.getElementById("modalRoleBadge").className = "adm-badge " + badgeClass;
  const row = document.querySelector(`tr[data-uid="${uid}"]`);
  if (row) {
    const badge = row.querySelector(".adm-badge");
    if (badge) { badge.textContent = displayLabel; badge.className = "adm-badge " + badgeClass; }
  }
  document.getElementById("promoteInvForm").style.display = "none";
}

// ── Permissions grid (shown in user modal for subadmins) ────────────────────
const _SECTIONS = ["overview","users","activity","requests","pricing","templates","homepage","ads","coupons","apikeys","investors"];
const _SECTION_LABELS = { overview:"Overview", users:"Users", activity:"Activity", requests:"Requests", pricing:"Pricing", templates:"Templates", homepage:"Home Page", ads:"Ads", coupons:"Coupons", apikeys:"API Keys", investors:"Investors" };

async function _loadPermsGrid(uid) {
  let permsWrap = document.getElementById("permsGridWrap");
  if (!permsWrap) return;
  permsWrap.innerHTML = '<p style="color:#9ca3af;font-size:0.8rem">Loading permissions…</p>';
  const d = await fetch(`/admin/api/user/${uid}/permissions`).then(r => r.json()).catch(() => ({}));
  if (!d.success) { permsWrap.innerHTML = '<p style="color:#dc2626;font-size:0.8rem">Failed to load permissions</p>'; return; }
  const perms = d.permissions || {};
  permsWrap.innerHTML = `
    <div style="font-size:0.8rem;font-weight:700;color:#374151;margin-bottom:0.6rem">Section Permissions</div>
    <table style="width:100%;border-collapse:collapse;font-size:0.78rem">
      <thead><tr>
        <th style="text-align:left;padding:0.3rem 0.5rem;color:#6b7280">Section</th>
        <th style="text-align:center;padding:0.3rem 0.5rem;color:#6b7280">None</th>
        <th style="text-align:center;padding:0.3rem 0.5rem;color:#6b7280">View</th>
        <th style="text-align:center;padding:0.3rem 0.5rem;color:#6b7280">Edit</th>
      </tr></thead>
      <tbody>${_SECTIONS.map(s => `<tr style="border-top:1px solid #f3f4f6">
        <td style="padding:0.35rem 0.5rem;font-weight:600;color:#374151">${_SECTION_LABELS[s]}</td>
        ${["none","view","edit"].map(lvl => `<td style="text-align:center;padding:0.35rem 0.5rem">
          <input type="radio" name="perm_${s}" value="${lvl}" ${perms[s]===lvl||(!perms[s]&&lvl==='none')?'checked':''} style="cursor:pointer;accent-color:#6366f1">
        </td>`).join('')}
      </tr>`).join('')}</tbody>
    </table>
    <button id="savePermsBtn" style="margin-top:0.75rem;padding:0.45rem 1.1rem;background:#6366f1;color:#fff;border:none;border-radius:6px;font-size:0.82rem;font-weight:600;cursor:pointer">Save Permissions</button>
    <span id="permsSaveMsg" style="font-size:0.75rem;color:#16a34a;margin-left:0.5rem"></span>
  `;
  document.getElementById("savePermsBtn").addEventListener("click", async function() {
    this.disabled = true; this.textContent = "Saving…";
    const sections = {};
    _SECTIONS.forEach(s => {
      const checked = permsWrap.querySelector(`input[name="perm_${s}"]:checked`);
      if (checked) sections[s] = checked.value;
    });
    const r = await fetch(`/admin/api/user/${uid}/permissions`, {
      method: "PATCH", headers: {"Content-Type":"application/json"},
      body: JSON.stringify({ sections }),
    }).then(r => r.json()).catch(() => ({}));
    const msg = document.getElementById("permsSaveMsg");
    if (r.success) { msg.textContent = "Saved!"; } else { msg.style.color="#dc2626"; msg.textContent = "Failed"; }
    this.textContent = "Save Permissions"; this.disabled = false;
    setTimeout(() => { if (msg) msg.textContent = ""; }, 2500);
  });
}

