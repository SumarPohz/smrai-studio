<%- include("../partials/header") %>
<link rel="stylesheet" href="/css/admin.css">
<script>
  document.body.classList.add("adm-page");
</script>

<!-- Hamburger drawer overlay (mobile only) -->
<div class="adm-drawer-overlay" id="admDrawerOverlay"></div>

<div class="adm-shell">

  <!-- ── Sidebar ─────────────────────────────────────────────────────────── -->
  <aside class="adm-sidebar">
    <div class="adm-sidebar-logo">
      <img src="/images/logo.png" alt="SmrAI-Studio" style="height:32px; width:auto;">
      <span>Admin</span>
    </div>
    <nav class="adm-sidebar-nav">
      <% var _p = function(sec){ return !isSubAdmin || (myPerms && myPerms[sec] && myPerms[sec] !== 'none'); }; %>
      <% if (_p('overview')) { %>
      <a href="#overview"  class="adm-nav-link adm-nav-active" data-section="overview">
        <i class="fas fa-chart-line"></i> Overview
      </a>
      <% } %>
      <% if (_p('users')) { %>
      <a href="#users"     class="adm-nav-link" data-section="users">
        <i class="fas fa-users"></i> Users
      </a>
      <% } %>
      <% if (_p('activity')) { %>
      <a href="#activity"  class="adm-nav-link" data-section="activity">
        <i class="fas fa-stream"></i> Activity
      </a>
      <% } %>
      <% if (_p('requests')) { %>
      <a href="#requests"  class="adm-nav-link" data-section="requests">
        <i class="fas fa-inbox"></i> Requests
        <span class="adm-nav-badge" id="navRequestsBadge" hidden></span>
      </a>
      <% } %>
      <% if (_p('pricing')) { %>
      <a href="#pricing"   class="adm-nav-link" data-section="pricing">
        <i class="fas fa-tags"></i> Pricing
      </a>
      <% } %>
      <% if (_p('templates')) { %>
      <a href="#templates" class="adm-nav-link" data-section="templates">
        <i class="fas fa-layer-group"></i> Templates
      </a>
      <% } %>
      <% if (_p('homepage')) { %>
      <a href="#homepage" class="adm-nav-link" data-section="homepage">
        <i class="fas fa-home"></i> Home Page
      </a>
      <% } %>
      <% if (_p('ads')) { %>
      <a href="#bgremover" class="adm-nav-link" data-section="bgremover">
        <i class="fas fa-eraser"></i> BG Remover
      </a>
      <a href="#ads" class="adm-nav-link" data-section="ads">
        <i class="fas fa-rectangle-ad"></i> Ads
      </a>
      <% } %>
      <% if (_p('coupons')) { %>
      <a href="#coupons" class="adm-nav-link" data-section="coupons">
        <i class="fas fa-ticket"></i> Coupons
      </a>
      <% } %>
      <% if (_p('apikeys')) { %>
      <a href="#apikeys" class="adm-nav-link" data-section="apikeys">
        <i class="fas fa-key"></i> API Keys
      </a>
      <% } %>
      <% if (_p('investors')) { %>
      <a href="#investors" class="adm-nav-link" data-section="investors" id="investorsNavLink">
        <i class="fas fa-handshake"></i> Investors
        <span class="adm-nav-badge" id="investorPendingBadge" style="display:none">0</span>
      </a>
      <% } %>
      <% if (_p('wallet')) { %>
      <a href="#wallet" class="adm-nav-link" data-section="wallet">
        <i class="fas fa-wallet"></i> Wallet
      </a>
      <% } %>
      <% if (_p('subscriptions')) { %>
      <a href="#subscriptions" class="adm-nav-link" data-section="subscriptions">
        <i class="fas fa-bolt"></i> Subscriptions
      </a>
      <% } %>
      <% if (_p('paysetu')) { %>
      <a href="#paysetu" class="adm-nav-link" data-section="paysetu">
        <i class="fas fa-satellite-dish"></i> PaySetu
      </a>
      <% } %>
      <a href="#plans" class="adm-nav-link" data-section="plans">
        <i class="fas fa-list-alt"></i> Recharge Plans
      </a>
      <a href="/dashboard" class="adm-nav-link adm-nav-back">
        <i class="fas fa-arrow-left"></i> Back to App
      </a>
    </nav>
  </aside>

  <!-- ── Main content ────────────────────────────────────────────────────── -->
  <div class="adm-main">

    <!-- Topbar -->
    <header class="adm-topbar">
      <div class="adm-topbar-left">
        <button class="adm-mobile-menu-btn" id="admMobileMenu" type="button">
          <i class="fas fa-bars"></i>
        </button>
        <h1 class="adm-topbar-title">Admin Dashboard</h1>
      </div>
      <div class="adm-topbar-right">
        <span class="adm-topbar-user">
          <i class="fas fa-shield-alt"></i>
          <%= currentUser.name %>
        </span>
      </div>
    </header>

    <!-- ── Section: Overview ──────────────────────────────────────────────── -->
    <div id="overview" class="adm-section-page">

      <% if (myInvestment) { %>
      <% const _invName = (myProfile && myProfile.full_name) ? myProfile.full_name : currentUser.name; %>
      <style>
        .inv-card {
          background: linear-gradient(135deg,#0f0c29 0%,#1a1a4e 55%,#0d1b2a 100%);
          border-radius: 18px;
          padding: 2.5rem 2.5rem;
          color: #fff;
          margin-bottom: 1.75rem;
          box-shadow: 0 16px 48px rgba(0,0,0,0.45);
          position: relative;
        }
        .inv-card-blobs { position:absolute;inset:0;border-radius:18px;overflow:hidden;pointer-events:none; }
        .inv-card-blob1 { position:absolute;top:-70px;right:-70px;width:220px;height:220px;background:rgba(99,102,241,0.1);border-radius:50%; }
        .inv-card-blob2 { position:absolute;bottom:-50px;left:220px;width:140px;height:140px;background:rgba(139,92,246,0.07);border-radius:50%; }
        .inv-card-inner { display:flex;align-items:center;gap:2rem;position:relative;z-index:1; }
        .inv-card-avatar { width:88px;height:88px;border-radius:50%;object-fit:cover;border:3px solid rgba(255,255,255,0.25);flex-shrink:0; }
        .inv-card-avatar-letter { width:88px;height:88px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:#fff;flex-shrink:0;border:3px solid rgba(255,255,255,0.15); }
        .inv-card-info { flex:1;min-width:0; }
        .inv-card-badge { display:inline-flex;align-items:center;gap:0.3rem;background:rgba(22,163,74,0.18);border:1px solid rgba(22,163,74,0.35);color:#4ade80;font-size:0.64rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:0.22rem 0.7rem;border-radius:99px;margin-bottom:0.5rem; }
        .inv-card-name { font-size:1.45rem;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
        .inv-card-sub  { font-size:0.78rem;color:#94a3b8;letter-spacing:0.06em;text-transform:uppercase;margin-top:0.15rem; }
        .inv-card-divider { width:1px;height:64px;background:rgba(255,255,255,0.12);flex-shrink:0; }
        .inv-card-stats { display:flex;gap:0;flex-shrink:0; }
        .inv-card-stat { padding:0 1.75rem;text-align:center;border-right:1px solid rgba(255,255,255,0.1); }
        .inv-card-stat:last-child { border-right:none; }
        .inv-card-stat-val { font-size:1.3rem;font-weight:800;white-space:nowrap; }
        .inv-card-stat-lbl { font-size:0.6rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.07em;margin-top:0.25rem; }
        .inv-card-cta { flex-shrink:0;background:rgba(99,102,241,0.2);border:1px solid rgba(99,102,241,0.45);color:#a5b4fc;font-size:0.78rem;font-weight:700;padding:0.6rem 1.2rem;border-radius:9px;text-decoration:none;white-space:nowrap;transition:background 0.2s; }
        .inv-card-cta:hover { background:rgba(99,102,241,0.38); }

        @media (max-width: 768px) {
          .inv-card { padding: 1rem 1.1rem; }
          .inv-card-inner { flex-wrap:wrap;gap:0.75rem;align-items:center; }
          .inv-card-avatar,
          .inv-card-avatar-letter { width:52px;height:52px;font-size:1.2rem; }
          .inv-card-info { flex:1;min-width:0; }
          .inv-card-badge { font-size:0.55rem;padding:0.15rem 0.5rem;margin-bottom:0.25rem; }
          .inv-card-name { font-size:1rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
          .inv-card-sub  { font-size:0.65rem; }
          .inv-card-divider { display:none; }
          .inv-card-stats { width:100%;justify-content:space-between;gap:0; }
          .inv-card-stat { padding:0.3rem 0;flex:1;border-right:none;border-left:none;text-align:center; }
          .inv-card-stat + .inv-card-stat { border-left:1px solid rgba(255,255,255,0.1); }
          .inv-card-stat-val { font-size:0.95rem; }
          .inv-card-stat-lbl { font-size:0.55rem; }
          .inv-card-cta { display:none; }
        }
      </style>

      <div class="inv-card">
        <div class="inv-card-blobs">
          <div class="inv-card-blob1"></div>
          <div class="inv-card-blob2"></div>
        </div>
        <div class="inv-card-inner">
          <!-- Avatar -->
          <% if (myProfile && myProfile.profile_image_url) { %>
            <img src="<%= myProfile.profile_image_url %>" alt="<%= _invName %>" class="inv-card-avatar">
          <% } else { %>
            <div class="inv-card-avatar-letter"><%= _invName.charAt(0).toUpperCase() %></div>
          <% } %>

          <!-- Name + badge -->
          <div class="inv-card-info">
            <div class="inv-card-badge">● Active Investor</div>
            <div class="inv-card-name"><%= _invName %></div>
            <div class="inv-card-sub">Investor · <%= companyName %></div>
          </div>

          <!-- Vertical divider (desktop only) -->
          <div class="inv-card-divider"></div>

          <!-- Stats -->
          <div class="inv-card-stats">
            <div class="inv-card-stat">
              <div class="inv-card-stat-val" style="color:#fbbf24">₹<%= Number(myInvestment.amount).toLocaleString('en-IN') %></div>
              <div class="inv-card-stat-lbl">Total Investment</div>
            </div>
            <div class="inv-card-stat">
              <div class="inv-card-stat-val" style="color:#4ade80"><%= Number(myInvestment.equity_percent).toFixed(2) %>%</div>
              <div class="inv-card-stat-lbl">Equity Received</div>
            </div>
            <div class="inv-card-stat">
              <div class="inv-card-stat-val" style="color:#e2e8f0">₹<%= Number(myInvestment.valuation).toLocaleString('en-IN') %></div>
              <div class="inv-card-stat-lbl">Valuation</div>
            </div>
          </div>

          <!-- CTA -->
          <a href="/investor/dashboard" class="inv-card-cta">View Card →</a>
        </div>
      </div>
      <% } %>

      <!-- Stat cards -->
      <div class="adm-stat-grid">
        <div class="adm-stat-card" style="--adm-card-delay:0.05s" data-detail="users">
          <div class="adm-stat-icon adm-icon-blue"><i class="fas fa-users"></i></div>
          <div class="adm-stat-text">
            <div class="adm-stat-num" data-target="<%= stats.totalUsers %>">0</div>
            <div class="adm-stat-label">Total Users</div>
          </div>
        </div>
        <div class="adm-stat-card" style="--adm-card-delay:0.10s" data-detail="activity">
          <div class="adm-stat-icon adm-icon-green"><i class="fas fa-bolt"></i></div>
          <div class="adm-stat-text">
            <div class="adm-stat-num" data-target="<%= stats.activeToday %>">0</div>
            <div class="adm-stat-label">Active Today</div>
          </div>
        </div>
        <div class="adm-stat-card" style="--adm-card-delay:0.15s" data-detail="resumes">
          <div class="adm-stat-icon adm-icon-purple"><i class="fas fa-file-alt"></i></div>
          <div class="adm-stat-text">
            <div class="adm-stat-num" data-target="<%= stats.totalResumes %>">0</div>
            <div class="adm-stat-label">Resumes</div>
          </div>
        </div>
        <div class="adm-stat-card" style="--adm-card-delay:0.20s" data-detail="downloads">
          <div class="adm-stat-icon adm-icon-orange"><i class="fas fa-download"></i></div>
          <div class="adm-stat-text">
            <div class="adm-stat-num" data-target="<%= stats.totalDownloads %>">0</div>
            <div class="adm-stat-label">Downloads</div>
          </div>
        </div>
        <div class="adm-stat-card" style="--adm-card-delay:0.25s" data-detail="revenue">
          <div class="adm-stat-icon adm-icon-emerald"><i class="fas fa-rupee-sign"></i></div>
          <div class="adm-stat-text">
            <div class="adm-stat-num" data-target="<%= stats.totalRevenue %>" data-prefix="₹">₹0</div>
            <div class="adm-stat-label">Revenue</div>
          </div>
        </div>
        <div class="adm-stat-card" style="--adm-card-delay:0.28s">
          <div class="adm-stat-icon" style="background:#fef3c7;color:#d97706"><i class="fas fa-satellite-dish"></i></div>
          <div class="adm-stat-text">
            <div class="adm-stat-num" data-target="<%= stats.paysetuVolume %>" data-prefix="₹">₹0</div>
            <div class="adm-stat-label">PaySetu Volume</div>
          </div>
        </div>
        <div class="adm-stat-card" style="--adm-card-delay:0.30s" data-detail="ai">
          <div class="adm-stat-icon adm-icon-pink"><i class="fas fa-robot"></i></div>
          <div class="adm-stat-text">
            <div class="adm-stat-num" data-target="<%= stats.aiRequests %>">0</div>
            <div class="adm-stat-label">AI Requests</div>
          </div>
        </div>
      </div>

      <!-- Charts -->
      <div class="adm-charts-row">
        <div class="adm-chart-box">
          <h3 class="adm-chart-title">Page Visit Heatmap</h3>
          <canvas id="chartRoutes" height="140"></canvas>
        </div>
        <div class="adm-chart-box">
          <h3 class="adm-chart-title">Downloads by Template</h3>
          <canvas id="chartTemplates" height="140"></canvas>
        </div>
      </div>

    </div><!-- /overview -->

    <!-- ── Section: Users ─────────────────────────────────────────────────── -->
    <div id="users" class="adm-section-page" hidden>

      <div class="adm-section">
        <div class="adm-section-header">
          <h2>User Management</h2>
          <input class="adm-search" id="userSearch" type="search" placeholder="Search name or email…">
        </div>
        <div class="adm-table-wrap">
          <table class="adm-table adm-users-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Email</th>
                <th>Role</th>
                <th>Resumes</th>
                <th>Downloads</th>
                <th>Revenue</th>
                <th>Wallet</th>
                <th>Last Active</th>
              </tr>
            </thead>
            <tbody id="usersBody">
              <tr><td colspan="8" class="adm-loading">Loading users…</td></tr>
            </tbody>
          </table>
        </div>
        <div class="adm-pagination" id="userPagination"></div>
      </div>

    </div><!-- /users -->

    <!-- ── Section: Activity ──────────────────────────────────────────────── -->
    <div id="activity" class="adm-section-page" hidden>

      <div class="adm-section">
        <div class="adm-section-header">
          <h2>Live Activity Feed</h2>
          <div style="display:flex;align-items:center;gap:0.6rem;margin-left:auto">
            <span class="adm-badge adm-badge-green">
              <span class="adm-pulse"></span> Live
            </span>
            <div class="adm-delete-wrap">
              <select id="actDeletePeriod" class="adm-delete-select">
                <option value="">🗑 Delete…</option>
                <option value="recent">Last 1 hour</option>
                <option value="today">Today</option>
                <option value="yesterday">Yesterday</option>
                <option value="all">All activity</option>
              </select>
            </div>
          </div>
        </div>
        <div id="activityFeed">
          <div class="adm-loading">Loading activity…</div>
        </div>
      </div>

    </div><!-- /activity -->

    <!-- ── Section: Requests ──────────────────────────────────────────────── -->
    <div id="requests" class="adm-section-page" hidden>

      <div class="adm-section">
        <div class="adm-section-header">
          <h2>Service Requests</h2>
          <div style="display:flex;align-items:center;gap:0.6rem">
            <select id="srFilterStatus" class="adm-sr-filter">
              <option value="">All statuses</option>
              <option value="new">New</option>
              <option value="in_progress">In Progress</option>
              <option value="done">Done</option>
              <option value="closed">Closed</option>
            </select>
          </div>
        </div>

        <div class="adm-table-wrap">
          <table class="adm-table adm-requests-table">
            <thead>
              <tr>
                <th>From</th>
                <th>Service</th>
                <th>Details</th>
                <th>Status</th>
                <th>Date</th>
                <th></th>
                <th></th>
              </tr>
            </thead>
            <tbody id="srBody">
              <tr><td colspan="7" class="adm-loading">Loading…</td></tr>
            </tbody>
          </table>
        </div>
        <div class="adm-pagination" id="srPagination"></div>
      </div>

    </div><!-- /requests -->

    <!-- ── Section: Pricing ───────────────────────────────────────────────── -->
    <div id="pricing" class="adm-section-page" hidden>

      <div class="adm-section">
        <div class="adm-section-header">
          <h2>Resume Pricing</h2>
          <p class="adm-section-desc">Set the download price for each resume category. Changes apply immediately to all new purchases.</p>
        </div>

        <div class="adm-price-grid">

          <!-- Fresher -->
          <div class="adm-price-card">
            <div class="adm-price-card-icon adm-icon-green"><i class="fas fa-seedling"></i></div>
            <div class="adm-price-card-info">
              <h3>Fresher</h3>
              <p>Simple & Minimal templates for entry-level profiles</p>
            </div>
            <div class="adm-price-card-input-wrap">
              <span class="adm-price-currency">₹</span>
              <input type="number" class="adm-price-input" id="price_fresher" min="0" step="1" placeholder="100" />
            </div>
            <button class="adm-price-save-btn" data-key="price_fresher">
              <i class="fas fa-check"></i> Save
            </button>
            <span class="adm-price-status" id="status_price_fresher" hidden></span>
          </div>

          <!-- Experienced -->
          <div class="adm-price-card">
            <div class="adm-price-card-icon adm-icon-blue"><i class="fas fa-briefcase"></i></div>
            <div class="adm-price-card-info">
              <h3>Experienced</h3>
              <p>Modern, Bold Sidebar, Creative, Corporate templates</p>
            </div>
            <div class="adm-price-card-input-wrap">
              <span class="adm-price-currency">₹</span>
              <input type="number" class="adm-price-input" id="price_experienced" min="0" step="1" placeholder="100" />
            </div>
            <button class="adm-price-save-btn" data-key="price_experienced">
              <i class="fas fa-check"></i> Save
            </button>
            <span class="adm-price-status" id="status_price_experienced" hidden></span>
          </div>

          <!-- Developer -->
          <div class="adm-price-card">
            <div class="adm-price-card-icon adm-icon-purple"><i class="fas fa-code"></i></div>
            <div class="adm-price-card-info">
              <h3>Developer</h3>
              <p>Tech-Focused template for software engineers</p>
            </div>
            <div class="adm-price-card-input-wrap">
              <span class="adm-price-currency">₹</span>
              <input type="number" class="adm-price-input" id="price_developer" min="0" step="1" placeholder="500" />
            </div>
            <button class="adm-price-save-btn" data-key="price_developer">
              <i class="fas fa-check"></i> Save
            </button>
            <span class="adm-price-status" id="status_price_developer" hidden></span>
          </div>

          <!-- ATS Friendly -->
          <div class="adm-price-card">
            <div class="adm-price-card-icon adm-icon-green"><i class="fas fa-robot"></i></div>
            <div class="adm-price-card-info">
              <h3>ATS Friendly CV</h3>
              <p>ATS-optimised developer template with semantic headings and clickable contact links</p>
            </div>
            <div class="adm-price-card-input-wrap">
              <span class="adm-price-currency">₹</span>
              <input type="number" class="adm-price-input" id="price_ats-friendly" min="0" step="1" placeholder="500" />
            </div>
            <button class="adm-price-save-btn" data-key="price_ats-friendly">
              <i class="fas fa-check"></i> Save
            </button>
            <span class="adm-price-status" id="status_price_ats-friendly" hidden></span>
          </div>

        </div><!-- /adm-price-grid -->

        <!-- Wallet Cap -->
        <div style="margin-top:1.75rem">
          <h3 style="font-size:0.9rem;font-weight:700;color:#1e293b;margin-bottom:0.4rem">
            <i class="fas fa-wallet" style="color:#6366f1"></i> Wallet Cap (Reserved Balance)
          </h3>
          <p style="font-size:0.8rem;color:#64748b;margin-bottom:0.85rem">
            Users cannot spend below this amount. Usable balance = wallet balance &minus; cap. Set to 0 for no restriction.
          </p>
          <div class="adm-price-card">
            <div class="adm-price-card-icon adm-icon-purple"><i class="fas fa-lock"></i></div>
            <div class="adm-price-card-info">
              <h3>Wallet Cap</h3>
              <p>Minimum reserved balance users cannot spend</p>
            </div>
            <div class="adm-price-card-input-wrap">
              <span class="adm-price-currency">₹</span>
              <input type="number" class="adm-price-input" id="wallet_cap" min="0" step="1" placeholder="100" />
            </div>
            <button class="adm-price-save-btn" data-key="wallet_cap">
              <i class="fas fa-check"></i> Save
            </button>
            <span class="adm-price-status" id="status_wallet_cap" hidden></span>
          </div>
        </div>

      </div>

    </div><!-- /pricing -->

    <!-- ══════════════════════════════════════════════════════════════════════
         SECTION: TEMPLATES — Admin Template Builder
    ══════════════════════════════════════════════════════════════════════════ -->
    <div id="templates" class="adm-section-page" hidden>

      <div class="adm-section">
        <div class="adm-section-header adm-section-header--actions">
          <div>
            <h2>Template Builder</h2>
            <p class="adm-section-desc">Create, configure and publish custom resume templates. Published templates appear in the public gallery.</p>
          </div>
          <button class="adm-btn-primary" id="admTplCreateBtn" type="button">
            <i class="fas fa-plus"></i> Create Template
          </button>
        </div>

        <!-- Stats row -->
        <div class="adm-tpl-stats-row">
          <div class="adm-tpl-stat"><span id="admTplTotal">0</span><label>Total</label></div>
          <div class="adm-tpl-stat adm-tpl-stat--green"><span id="admTplPublished">0</span><label>Published</label></div>
          <div class="adm-tpl-stat adm-tpl-stat--grey"><span id="admTplDraft">0</span><label>Draft</label></div>
        </div>

        <!-- Template list table -->
