//  HOME PAGE EDITOR
// ════════════════════════════════════════════════════════════════════════════
let hpData  = {};
let hpLoaded  = false;
let adsLoaded     = false;
let couponsLoaded = false;

// Sub-tab switching
document.querySelectorAll(".adm-hp-tab").forEach(btn => {
  btn.addEventListener("click", function() {
    document.querySelectorAll(".adm-hp-tab").forEach(b => b.classList.remove("active"));
    document.querySelectorAll(".adm-hp-panel").forEach(p => p.classList.remove("active"));
    this.classList.add("active");
    document.querySelector(`[data-hp-panel="${this.dataset.hpTab}"]`)?.classList.add("active");
  });
});

async function loadHomepage() {
  if (hpLoaded) return;
  const r = await fetch("/admin/api/homepage");
  const d = await r.json();
  if (!d.success) return;
  hpData   = d.data;
  hpLoaded = true;
  populateHeroForm(hpData.hero         || {});
  populateSvcCards(hpData.services     || {});
  populateFeatCards(hpData.features    || {});
  populateTstCards(hpData.testimonials || {});
}

// ── Hero ───────────────────────────────────────────────────────────────────
function populateHeroForm(h) {
  document.getElementById("hp_hero_tag").value      = h.tag      || "";
  document.getElementById("hp_hero_headline").value = h.headline || "";
  document.getElementById("hp_hero_subtitle").value = h.subtitle || "";
  document.getElementById("hp_hero_trust").value    = h.trustText|| "";
}

async function saveHpSection(section) {
  let payload = {};
  let msgEl;

  if (section === "hero") {
    msgEl   = document.getElementById("hp_hero_msg");
    payload = {
      tag:       document.getElementById("hp_hero_tag").value.trim(),
      headline:  document.getElementById("hp_hero_headline").value.trim(),
      subtitle:  document.getElementById("hp_hero_subtitle").value.trim(),
      trustText: document.getElementById("hp_hero_trust").value.trim(),
    };
    if (!payload.headline) { showHpMsg(msgEl,"Headline is required.","error"); return; }
  } else if (section === "services") {
    msgEl   = document.getElementById("hp_svc_msg");
    payload = {
      title:    document.getElementById("hp_svc_title").value.trim(),
      subtitle: document.getElementById("hp_svc_subtitle").value.trim(),
      cards:    collectHpCards("svc"),
    };
  } else if (section === "features") {
    msgEl   = document.getElementById("hp_feat_msg");
    payload = {
      title:    document.getElementById("hp_feat_title").value.trim(),
      subtitle: document.getElementById("hp_feat_subtitle").value.trim(),
      cards:    collectHpCards("feat"),
    };
  } else if (section === "testimonials") {
    msgEl   = document.getElementById("hp_tst_msg");
    payload = {
      title:    document.getElementById("hp_tst_title").value.trim(),
      subtitle: document.getElementById("hp_tst_subtitle").value.trim(),
      cards:    collectHpCards("tst"),
    };
  }

  showHpMsg(msgEl, "Saving…", "info");
  try {
    const r = await fetch(`/admin/api/homepage/${section}`, {
      method: "PUT", headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const d = await r.json();
    if (d.success) { showHpMsg(msgEl, "Saved! Changes are live.", "ok"); hpLoaded = false; }
    else           { showHpMsg(msgEl, "Save failed.", "error"); }
  } catch (err) {
    showHpMsg(msgEl, "Error: " + err.message, "error");
  }
}

function showHpMsg(el, text, type) {
  if (!el) return;
  el.textContent = text;
  el.className   = "adm-hp-msg adm-hp-msg--" + type;
  if (type === "ok") setTimeout(() => { el.textContent = ""; el.className = "adm-hp-msg"; }, 3500);
}

// ── Services cards ─────────────────────────────────────────────────────────
function populateSvcCards(s) {
  document.getElementById("hp_svc_title").value    = s.title    || "";
  document.getElementById("hp_svc_subtitle").value = s.subtitle || "";
  const container = document.getElementById("hp_svc_cards_list");
  container.innerHTML = "";
  (s.cards || []).forEach((c, i) => appendSvcCard(container, c, i));
}

function appendSvcCard(container, c, i) {
  const el = document.createElement("div");
  el.className = "adm-hp-card-row";
  el.dataset.idx = i;
  el.innerHTML = `
    <div class="adm-hp-card-row-header">
      <span class="adm-hp-card-num">${i+1}</span>
      <strong class="adm-hp-card-title-preview">${escHtml(c.title||"New Card")}</strong>
      <button type="button" class="adm-btn-icon adm-hp-card-delete" title="Remove"><i class="fas fa-trash"></i></button>
    </div>
    <div class="adm-hp-card-body">
      <div class="adm-stpl-field-row">
        <div class="adm-stpl-field">
          <label>Title</label>
          <input type="text" class="svc-title" value="${escHtml(c.title||"")}" maxlength="80" />
        </div>
        <div class="adm-stpl-field">
          <label>Link (optional)</label>
          <input type="text" class="svc-link" value="${escHtml(c.link||"")}" placeholder="/resume-templates" />
        </div>
      </div>
      <div class="adm-stpl-field">
        <label>Description</label>
        <textarea class="svc-desc" rows="2">${escHtml(c.description||"")}</textarea>
      </div>
      <div class="adm-stpl-field">
        <label>Image URL <small style="font-weight:400;color:#94a3b8;">— or upload below</small></label>
        <div class="adm-hp-img-row">
          <input type="text" class="svc-img-url" value="${escHtml(c.imageUrl||"")}" placeholder="https://… or leave blank for default style" />
          <input type="file" class="svc-img-file" accept="image/*" hidden />
          <button type="button" class="adm-btn-secondary adm-hp-upload-btn"><i class="fas fa-upload"></i></button>
        </div>
        <% if (true) { /* service image preview */ %><img class="adm-hp-img-preview" src="${escHtml(c.imageUrl||"")}" alt="" style="${c.imageUrl?'':'display:none'}" /><% } %>
      </div>
    </div>`;
  wireCardDelete(el, "services");
  wireImgUpload(el, ".svc-img-file", ".adm-hp-upload-btn", ".svc-img-url", ".adm-hp-img-preview");
  container.appendChild(el);
}

function addHpCard(prefix) {
  if (prefix === "svc") {
    const c = document.getElementById("hp_svc_cards_list");
    appendSvcCard(c, {}, c.children.length);
  } else if (prefix === "feat") {
    const c = document.getElementById("hp_feat_cards_list");
    appendFeatCard(c, {}, c.children.length);
  } else if (prefix === "tst") {
    const c = document.getElementById("hp_tst_cards_list");
    appendTstCard(c, {}, c.children.length);
  }
}

function collectHpCards(prefix) {
  const map = { svc:"hp_svc_cards_list", feat:"hp_feat_cards_list", tst:"hp_tst_cards_list" };
  const rows = document.getElementById(map[prefix]).querySelectorAll(".adm-hp-card-row");
  const cards = [];
  if (prefix === "svc") {
    rows.forEach(row => cards.push({
      title:       row.querySelector(".svc-title")?.value.trim()   || "",
      description: row.querySelector(".svc-desc")?.value.trim()    || "",
      link:        row.querySelector(".svc-link")?.value.trim()     || "",
      imageUrl:    row.querySelector(".svc-img-url")?.value.trim()  || "",
      bgClass:     "resume-bg",
    }));
  } else if (prefix === "feat") {
    rows.forEach(row => cards.push({
      icon:        row.querySelector(".feat-icon")?.value.trim()    || "",
      color:       row.querySelector(".feat-color")?.value          || "blue",
      title:       row.querySelector(".feat-title")?.value.trim()   || "",
      description: row.querySelector(".feat-desc")?.value.trim()    || "",
    }));
  } else if (prefix === "tst") {
    rows.forEach(row => cards.push({
      avatar:  row.querySelector(".tst-avatar-url")?.value.trim()   || "",
      name:    row.querySelector(".tst-name")?.value.trim()         || "",
      role:    row.querySelector(".tst-role")?.value.trim()         || "",
      text:    row.querySelector(".tst-text")?.value.trim()         || "",
    }));
  }
  return cards;
}

