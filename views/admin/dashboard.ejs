  const previewUrl = `/admin/preview/${tpl.slug}`;

  // Footer preview button
  const footerBtn = document.getElementById("admTplPreviewBtn");
  footerBtn.href = previewUrl;
  footerBtn.style.display = "";

  // Preview tab
  document.getElementById("admPreviewHint").hidden = true;
  document.getElementById("admPreviewFrame").hidden = false;
  document.getElementById("admPreviewOpenBtn").href = previewUrl;
