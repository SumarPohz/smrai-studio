            <span class="adm-badge ${u.role === "admin" ? "adm-badge-admin" : u.role === "subadmin" ? "adm-badge-subadmin" : "adm-badge-user"}" id="modalRoleBadge">${u.role === "subadmin" ? (u.has_investment ? "Investor" : "Sub-Admin") : u.role}</span>
