// ── Shared helpers ─────────────────────────────────────────────────────────
function wireCardDelete(el, section) {
  el.querySelector(".adm-hp-card-delete").addEventListener("click", async function() {
    if (!confirm("Remove this card? It will be deleted immediately.")) return;
    el.remove();
    await saveHpSection(section); // persist to DB right away
  });
}

function wireImgUpload(el, fileSelector, btnSelector, urlSelector, previewSelector) {
  const fileInput = el.querySelector(fileSelector);
  const btn       = el.querySelector(btnSelector);
  const urlInput  = el.querySelector(urlSelector);
  const preview   = el.querySelector(previewSelector);
  btn.addEventListener("click", () => fileInput.click());
  fileInput.addEventListener("change", async function() {
    if (!this.files.length) return;
    const fd = new FormData();
    fd.append("image", this.files[0]);
    try {
      const r = await fetch("/admin/api/homepage/upload-image", { method: "POST", body: fd });
      const d = await r.json();
      if (d.success) {
        urlInput.value = d.imageUrl;
        if (preview) { preview.src = d.imageUrl; preview.style.display = ""; }
      }
    } catch(e) { showAdmToast("Upload failed", "error"); }
  });
  urlInput.addEventListener("input", function() {
    if (preview && this.value) { preview.src = this.value; preview.style.display = ""; }
    else if (preview)          { preview.style.display = "none"; }
  });
}

// ── API Keys / Env settings ──────────────────────────────────────────────────
const ENV_FIELD_MAP = {
  RAZORPAY_KEY_ID:         'envRazorpayKeyId',
  RAZORPAY_KEY_SECRET:     'envRazorpayKeySecret',
  RAZORPAY_WEBHOOK_SECRET: 'envRazorpayWebhookSecret',
  OPENAI_API_KEY:          'envOpenaiApiKey',
  BASE_URL:                'envBaseUrl',
  EMAIL_HOST:              'envEmailHost',
  EMAIL_PORT:              'envEmailPort',
  EMAIL_USER:              'envEmailUser',
  EMAIL_PASS:              'envEmailPass',
};

async function saveEnvField(key, inputId, btn) {
  const val = document.getElementById(inputId)?.value.trim();
  const orig = btn.textContent;
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const r = await fetch("/admin/api/env-settings", {
      method: "PATCH", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ [key]: val }),
    });
    const d = await r.json();
    btn.textContent = d.success ? 'Saved ✓' : 'Failed';
    setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2000);
  } catch (_) { btn.textContent = 'Error'; btn.disabled = false; }
}

async function loadEnvSettings() {
  // Values are never pre-displayed for security
}

async function saveEnvSettings() {
  const msg = document.getElementById("envSaveMsg");
  const payload = {};
  for (const [key, elId] of Object.entries(ENV_FIELD_MAP)) {
    const el = document.getElementById(elId);
    if (el && el.value.trim()) payload[key] = el.value.trim();
  }
  try {
    const r = await fetch("/admin/api/env-settings", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const d = await r.json();
    if (d.success) {
      msg.textContent = "Saved! Changes are now live.";
      msg.className = "adm-ads-msg adm-msg-ok";
    } else {
      msg.textContent = "Failed to save.";
      msg.className = "adm-ads-msg adm-msg-error";
    }
  } catch (_) {
    msg.textContent = "Error saving.";
    msg.className = "adm-ads-msg adm-msg-error";
  }
  setTimeout(() => { msg.textContent = ""; }, 4000);
}

function toggleEnvReveal(inputId, btn) {
  const el = document.getElementById(inputId);
  if (!el) return;
  const isHidden = el.type === 'password';
  el.type = isHidden ? 'text' : 'password';
  btn.innerHTML = isHidden ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
}

// ── Google Translate toggle ───────────────────────────────────────────────────
function applyToggleUI(enabled) {
  const slider = document.getElementById('gtSlider');
  const knob   = document.getElementById('gtKnob');
  if (!slider) return;
  slider.style.background = enabled ? '#16a34a' : '#d1d5db';
  knob.style.transform    = enabled ? 'translateX(20px)' : 'translateX(0)';
}
async function saveTranslateSetting(enabled) {
  applyToggleUI(enabled);
  try {
    await fetch("/admin/api/settings", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ google_translate_enabled: String(enabled) }),
    });
  } catch (_) {}
}

// ── Tracking scripts ─────────────────────────────────────────────────────────
async function loadTrackingScripts() {
  try {
    const r = await fetch("/admin/api/settings");
    const d = await r.json();
    if (d.settings) {
      document.getElementById("adsensePublisherId").value = d.settings.adsense_publisher_id || "";
      document.getElementById("facebookPixelId").value    = d.settings.facebook_pixel_id    || "";
      document.getElementById("homepageAdSlot").value     = d.settings.homepage_ad_slot     || "";
      document.getElementById("footerAdSlot").value       = d.settings.footer_ad_slot       || "";
      const gtEnabled = d.settings.google_translate_enabled === 'true';
      const toggle = document.getElementById('googleTranslateToggle');
      if (toggle) { toggle.checked = gtEnabled; applyToggleUI(gtEnabled); }
    }
  } catch (_) {}
}

async function saveTrackingScripts() {
  const btn = document.getElementById("saveTrackingBtn");
  const msg = document.getElementById("trackingMsg");
  const adsenseId      = document.getElementById("adsensePublisherId").value.trim();
  const pixelId        = document.getElementById("facebookPixelId").value.trim();
  const homepageSlot   = document.getElementById("homepageAdSlot").value.trim();
  const footerSlot     = document.getElementById("footerAdSlot").value.trim();
  btn.disabled = true;
  try {
    const r = await fetch("/admin/api/settings", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ adsense_publisher_id: adsenseId, facebook_pixel_id: pixelId, homepage_ad_slot: homepageSlot, footer_ad_slot: footerSlot }),
    });
    const d = await r.json();
    if (d.success) {
      msg.textContent = "Saved!"; msg.className = "adm-ads-msg adm-msg-ok";
    } else {
      msg.textContent = "Failed to save."; msg.className = "adm-ads-msg adm-msg-error";
    }
  } catch (_) {
    msg.textContent = "Error saving."; msg.className = "adm-ads-msg adm-msg-error";
  }
  btn.disabled = false;
  setTimeout(() => { msg.textContent = ""; }, 3000);
}

// ── Ads section ─────────────────────────────────────────────────────────────
async function loadAds() {
  adsLoaded = true;
  loadTrackingScripts();
  try {
    const sr = await fetch("/admin/api/ads/settings");
    const sd = await sr.json();
    renderMasterToggle(sd.adsEnabled !== false);
  } catch(_) { renderMasterToggle(true); }
  await renderAdsTable();
}

function renderMasterToggle(enabled) {
  const btn  = document.getElementById("adsMasterBtn");
  const stat = document.getElementById("adsMasterStatus");
  const desc = document.getElementById("adsMasterDesc");
  const icon = document.getElementById("adsMasterIcon");
  if (enabled) {
    stat.textContent = "Ads are ON";
    desc.textContent = "All ad slots are active and visible to visitors.";
    btn.textContent  = "Turn Off Ads";
    btn.className    = "adm-ads-master-btn adm-ads-master-off";
    icon.className   = "fas fa-circle-dot adm-master-icon-on";
  } else {
    stat.textContent = "Ads are OFF";
    desc.textContent = "No ads are shown anywhere on the site.";
    btn.textContent  = "Turn On Ads";
    btn.className    = "adm-ads-master-btn adm-ads-master-on";
    icon.className   = "fas fa-circle-dot adm-master-icon-off";
  }
  btn.disabled = false;
  btn.onclick = () => toggleMasterAds(!enabled);
}

async function toggleMasterAds(enable) {
  const btn = document.getElementById("adsMasterBtn");
  btn.disabled = true;
  try {
    const r = await fetch("/admin/api/ads/settings", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ enabled: enable }),
    });
    const d = await r.json();
    if (d.success) {
      renderMasterToggle(d.adsEnabled);
      showAdmToast(d.adsEnabled ? "Ads turned ON" : "Ads turned OFF");
    } else {
      showAdmToast("Failed to update ads setting", "error");
      btn.disabled = false;
    }
  } catch(_) {
    showAdmToast("Network error", "error");
    btn.disabled = false;
  }
}

async function renderAdsTable() {
  const wrap = document.getElementById("adsTableWrap");
  try {
    const r = await fetch("/admin/api/ads");
    const d = await r.json();
    if (!d.success || !d.ads.length) {
      wrap.innerHTML = '<p class="adm-empty-msg">No ads yet. Add one above.</p>';
      return;
    }
    const slotLabel = { sidebar: "Top Banner", footer: "Before Footer" };
    wrap.innerHTML = `
      <table class="adm-ads-table">
        <thead>
          <tr>
            <th>Slot</th><th>Preview</th><th>Title</th><th>Link</th><th>Status</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          ${d.ads.map(ad => `
            <tr data-id="${ad.id}">
              <td><span class="adm-ads-slot-badge adm-ads-slot-${ad.slot}">${slotLabel[ad.slot] || ad.slot}</span></td>
              <td><img src="${escHtml(ad.image_url || '')}" class="adm-ads-thumb" alt=""></td>
              <td>${escHtml(ad.title || '—')}</td>
              <td><a href="${escHtml(ad.link_url)}" target="_blank" class="adm-ads-link" title="${escHtml(ad.link_url)}">${escHtml(ad.link_url.length > 35 ? ad.link_url.slice(0,35)+'…' : ad.link_url)}</a></td>
              <td>
                <button class="adm-ads-toggle adm-ads-toggle-${ad.is_active ? 'on' : 'off'}" data-id="${ad.id}" title="${ad.is_active ? 'Click to deactivate' : 'Click to activate'}">
                  ${ad.is_active ? '<i class="fas fa-toggle-on"></i> Active' : '<i class="fas fa-toggle-off"></i> Inactive'}
                </button>
              </td>
              <td>
                <button class="adm-btn-danger adm-ads-delete" data-id="${ad.id}"><i class="fas fa-trash"></i></button>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>`;

    // Wire toggle buttons
    wrap.querySelectorAll(".adm-ads-toggle").forEach(btn => {
      btn.addEventListener("click", async function() {
        const id = this.dataset.id;
        try {
          await fetch(`/admin/api/ads/${id}/toggle`, { method: "PUT" });
          await renderAdsTable();
        } catch(_) { showAdmToast("Toggle failed", "error"); }
      });
    });

    // Wire delete buttons
    wrap.querySelectorAll(".adm-ads-delete").forEach(btn => {
      btn.addEventListener("click", async function() {
        if (!confirm("Delete this ad permanently?")) return;
        const id = this.dataset.id;
        try {
          await fetch(`/admin/api/ads/${id}`, { method: "DELETE" });
          await renderAdsTable();
          showAdmToast("Ad deleted");
        } catch(_) { showAdmToast("Delete failed", "error"); }
      });
    });
  } catch(_) {
    wrap.innerHTML = '<p class="adm-empty-msg adm-error-text">Failed to load ads.</p>';
  }
}

// Image preview
document.getElementById("adsImage").addEventListener("change", function() {
  const preview = document.getElementById("adsImagePreview");
  if (this.files[0]) {
    preview.src = URL.createObjectURL(this.files[0]);
    preview.style.display = "";
  } else {
    preview.style.display = "none";
  }
});

// Add form submit
document.getElementById("adsAddForm").addEventListener("submit", async function(e) {
  e.preventDefault();
  const btn = document.getElementById("adsSubmitBtn");
  const msg = document.getElementById("adsMsgAdd");
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Uploading…';
  msg.textContent = "";
  const fd = new FormData(this);
  try {
    const r = await fetch("/admin/api/ads", { method: "POST", body: fd });
    const d = await r.json();
    if (d.success) {
      showAdmToast("Ad added successfully");
      this.reset();
      document.getElementById("adsImagePreview").style.display = "none";
      await renderAdsTable();
    } else {
      msg.textContent = d.error || "Failed to add ad.";
      msg.className = "adm-ads-msg adm-msg-error";
    }
  } catch(_) {
    msg.textContent = "Network error.";
    msg.className = "adm-ads-msg adm-msg-error";
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-plus"></i> Add Ad';
  }
});

// ── Coupons section ──────────────────────────────────────────────────────────
async function loadCoupons() {
  couponsLoaded = true;
  await renderCouponsTable();
}

async function renderCouponsTable() {
  const wrap = document.getElementById("couponsTableWrap");
  try {
    const r = await fetch("/admin/api/coupons");
    const d = await r.json();
    if (!d.success || !d.coupons.length) {
      wrap.innerHTML = '<p class="adm-empty-msg">No coupons yet. Create one above.</p>';
      return;
    }
    wrap.innerHTML = `
      <table class="adm-ads-table adm-cp-table">
        <thead>
          <tr>
            <th>Code</th><th>Discount</th><th>Uses</th><th>Min ₹</th><th>Expiry</th><th>First-time</th><th>Status</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          ${d.coupons.map(c => {
            const usesLabel = c.max_uses > 0 ? `${c.uses_count}/${c.max_uses}` : `${c.uses_count} / ∞`;
            const expLabel = c.expires_at ? new Date(c.expires_at).toLocaleDateString("en-IN") : "No expiry";
            const expired = c.expires_at && new Date(c.expires_at) < new Date();
            const discLabel = c.discount_type === "percent" ? `${c.discount_value}%` : `₹${c.discount_value}`;
            return `<tr data-id="${c.id}">
              <td><span class="adm-cp-code-badge">${escHtml(c.code)}</span>
                  ${c.description ? `<br><small class="adm-cp-desc">${escHtml(c.description)}</small>` : ''}
              </td>
              <td><span class="adm-cp-discount-badge adm-cp-disc-${c.discount_type}">${discLabel} off</span></td>
              <td>${usesLabel}</td>
              <td>${c.min_amount > 0 ? "₹" + c.min_amount : "—"}</td>
              <td class="${expired ? 'adm-cp-expired' : ''}">${expLabel}</td>
              <td>${c.first_time_only ? '<span class="adm-cp-ft-badge">Yes</span>' : '—'}</td>
              <td>
                <button class="adm-ads-toggle adm-ads-toggle-${c.is_active ? 'on' : 'off'} adm-cp-toggle" data-id="${c.id}" title="${c.is_active ? 'Deactivate' : 'Activate'}">
                  ${c.is_active ? '<i class="fas fa-toggle-on"></i> Active' : '<i class="fas fa-toggle-off"></i> Inactive'}
                </button>
              </td>
              <td>
                <button class="adm-btn-danger adm-cp-delete" data-id="${c.id}"><i class="fas fa-trash"></i></button>
              </td>
            </tr>`;
          }).join('')}
        </tbody>
      </table>`;

    wrap.querySelectorAll(".adm-cp-toggle").forEach(btn => {
      btn.addEventListener("click", async function() {
        try {
          await fetch(`/admin/api/coupons/${this.dataset.id}/toggle`, { method: "PUT" });
          await renderCouponsTable();
        } catch(_) { showAdmToast("Toggle failed", "error"); }
      });
    });
    wrap.querySelectorAll(".adm-cp-delete").forEach(btn => {
      btn.addEventListener("click", async function() {
        if (!confirm("Delete this coupon permanently?")) return;
        try {
          await fetch(`/admin/api/coupons/${this.dataset.id}`, { method: "DELETE" });
          await renderCouponsTable();
          showAdmToast("Coupon deleted");
        } catch(_) { showAdmToast("Delete failed", "error"); }
      });
    });
  } catch(_) {
    wrap.innerHTML = '<p class="adm-empty-msg adm-error-text">Failed to load coupons.</p>';
  }
}

document.getElementById("couponCreateForm").addEventListener("submit", async function(e) {
  e.preventDefault();
  const btn = document.getElementById("cpSubmitBtn");
  const msg = document.getElementById("cpMsgCreate");
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating…';
  msg.textContent = "";
  const body = {
    code:           document.getElementById("cpCode").value.trim().toUpperCase(),
    description:    document.getElementById("cpDesc").value.trim(),
    discount_type:  document.getElementById("cpType").value,
    discount_value: document.getElementById("cpValue").value,
    max_uses:       document.getElementById("cpMaxUses").value || "0",
    min_amount:     document.getElementById("cpMinAmount").value || "0",
    expires_at:     document.getElementById("cpExpiry").value || null,
    first_time_only:document.getElementById("cpFirstTime").checked,
  };
  try {
    const r = await fetch("/admin/api/coupons", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    const d = await r.json();
    if (d.success) {
      showAdmToast("Coupon created!");
      this.reset();
      await renderCouponsTable();
    } else {
      msg.textContent = d.error || "Failed to create coupon.";
      msg.className = "adm-ads-msg adm-msg-error";
    }
  } catch(_) {
    msg.textContent = "Network error.";
    msg.className = "adm-ads-msg adm-msg-error";
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-plus"></i> Create Coupon';
  }
});
</script>

