<%- include("partials/header") %>
<script src="/socket.io/socket.io.js"></script>

<section class="dash-section">
  <div class="dash-welcome-row">
    <div>
      <h1 class="dash-welcome">Welcome back, <%= currentUser ? currentUser.name.split(" ")[0] : "" %>! 👋</h1>
      <p class="dash-subtitle">Here's what's happening on SmrAI-Studio today.</p>
    </div>
    <% if (currentUser && currentUser.role === 'admin') { %>
    <div class="dash-subadmin-card">
      <div style="position:absolute;top:-30px;right:-30px;width:100px;height:100px;background:rgba(99,102,241,0.12);border-radius:50%;pointer-events:none"></div>
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.9rem;position:relative;z-index:1">
        <div style="width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;color:#fff;flex-shrink:0;border:2px solid rgba(255,255,255,0.15)"><%= currentUser.name.charAt(0).toUpperCase() %></div>
        <div style="flex:1;min-width:0">
          <div style="font-size:0.9rem;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= currentUser.name %></div>
          <div style="font-size:0.62rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;margin-top:0.05rem">Admin · SmrAI Studio</div>
        </div>
        <span style="flex-shrink:0;background:rgba(239,68,68,0.18);border:1px solid rgba(239,68,68,0.35);color:#fca5a5;font-size:0.55rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:0.18rem 0.5rem;border-radius:99px">● Admin</span>
      </div>
      <div style="position:relative;z-index:1">
        <a href="/admin" style="display:block;width:100%;padding:0.5rem;background:#6366f1;color:#fff;font-size:0.75rem;font-weight:700;border-radius:7px;text-align:center;text-decoration:none;box-sizing:border-box">Admin Panel</a>
      </div>
    </div>
    <% } else if (currentUser && currentUser.role === 'subadmin') { %>
    <% var _saName = (subadminProfile && subadminProfile.full_name) ? subadminProfile.full_name : currentUser.name; %>
    <div class="dash-subadmin-card">
      <div style="position:absolute;top:-30px;right:-30px;width:100px;height:100px;background:rgba(99,102,241,0.12);border-radius:50%;pointer-events:none"></div>
      <!-- Top: avatar + name + badge -->
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.9rem;position:relative;z-index:1">
        <% if (subadminProfile && subadminProfile.profile_image_url) { %>
          <img src="<%= subadminProfile.profile_image_url %>" alt="<%= _saName %>" style="width:46px;height:46px;border-radius:50%;object-fit:cover;border:2px solid rgba(255,255,255,0.25);flex-shrink:0">
        <% } else { %>
          <div style="width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;color:#fff;flex-shrink:0;border:2px solid rgba(255,255,255,0.15)"><%= _saName.charAt(0).toUpperCase() %></div>
        <% } %>
        <div style="flex:1;min-width:0">
          <div style="font-size:0.9rem;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= _saName %></div>
          <div style="font-size:0.62rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;margin-top:0.05rem"><%= subadminInvestment ? 'Investor' : 'Sub-Admin' %> · SmrAI Studio</div>
        </div>
        <% if (subadminInvestment) { %>
          <span style="flex-shrink:0;background:rgba(22,163,74,0.18);border:1px solid rgba(22,163,74,0.35);color:#4ade80;font-size:0.55rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:0.18rem 0.5rem;border-radius:99px">● Investor</span>
        <% } else { %>
          <span style="flex-shrink:0;background:rgba(99,102,241,0.2);border:1px solid rgba(99,102,241,0.4);color:#a5b4fc;font-size:0.55rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:0.18rem 0.5rem;border-radius:99px">● Sub-Admin</span>
        <% } %>
      </div>
      <!-- Stats (investor only) -->
      <% if (subadminInvestment) { %>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.4rem;margin-bottom:0.75rem;position:relative;z-index:1">
        <div style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:0.5rem 0.4rem;text-align:center">
          <div style="font-size:0.82rem;font-weight:800;color:#fbbf24">₹<%= Number(subadminInvestment.amount).toLocaleString('en-IN') %></div>
          <div style="font-size:0.52rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.04em;margin-top:0.1rem">Invested</div>
        </div>
        <div style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:0.5rem 0.4rem;text-align:center">
          <div style="font-size:0.82rem;font-weight:800;color:#4ade80"><%= Number(subadminInvestment.equity_percent).toFixed(2) %>%</div>
          <div style="font-size:0.52rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.04em;margin-top:0.1rem">Equity</div>
        </div>
        <div style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:0.5rem 0.4rem;text-align:center">
          <div style="font-size:0.82rem;font-weight:800;color:#e2e8f0">₹<%= Number(subadminInvestment.valuation).toLocaleString('en-IN') %></div>
          <div style="font-size:0.52rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.04em;margin-top:0.1rem">Valuation</div>
        </div>
      </div>
      <% } %>
      <!-- Button -->
      <div style="display:flex;gap:0.5rem;position:relative;z-index:1">
        <% if (subadminInvestment) { %>
          <a href="/investor/dashboard" style="flex:1;padding:0.45rem 0.5rem;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:#e2e8f0;font-size:0.72rem;font-weight:600;border-radius:7px;text-align:center;text-decoration:none">View Card</a>
        <% } %>
        <a href="/admin" style="flex:2;padding:0.45rem 0.5rem;background:#6366f1;color:#fff;font-size:0.72rem;font-weight:700;border-radius:7px;text-align:center;text-decoration:none">Admin Dashboard</a>
      </div>
    </div>
    <% } %>
  </div>

  <!-- ── All Services ─────────────────────────────────────────────────── -->
  <div style="margin-bottom:2rem">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
      <div>
        <h2 style="font-size:1.1rem;font-weight:800;color:#111827;margin:0 0 0.2rem">Explore Services</h2>
        <p style="font-size:0.82rem;color:#6b7280;margin:0">Everything available on SmrAI-Studio</p>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.85rem" class="dash-svc-grid">

      <a href="/resume-templates" style="display:flex;align-items:center;gap:0.85rem;background:#fff;border:1.5px solid #ede9fe;border-radius:14px;padding:1rem 1.1rem;text-decoration:none;transition:box-shadow 0.18s,transform 0.18s" onmouseover="this.style.boxShadow='0 6px 20px rgba(109,40,217,0.13)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='none';this.style.transform='none'">
        <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#ede9fe,#c4b5fd);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0">📄</div>
        <div style="min-width:0">
          <div style="font-size:0.88rem;font-weight:700;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">Resume Builder</div>
          <div style="font-size:0.72rem;color:#7c3aed;margin-top:1px">8 templates · PDF + JPG</div>
        </div>
      </a>

      <a href="/paysetu" style="display:flex;align-items:center;gap:0.85rem;background:#fff;border:1.5px solid #fed7aa;border-radius:14px;padding:1rem 1.1rem;text-decoration:none;transition:box-shadow 0.18s,transform 0.18s" onmouseover="this.style.boxShadow='0 6px 20px rgba(234,88,12,0.12)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='none';this.style.transform='none'">
        <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#fff7ed,#fdba74);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0">💳</div>
        <div style="min-width:0">
          <div style="font-size:0.88rem;font-weight:700;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">PaySetu</div>
          <div style="font-size:0.72rem;color:#ea580c;margin-top:1px">Recharge &amp; Pay Bills</div>
        </div>
      </a>

      <a href="/application-builder" style="display:flex;align-items:center;gap:0.85rem;background:#fff;border:1.5px solid #e9d5ff;border-radius:14px;padding:1rem 1.1rem;text-decoration:none;transition:box-shadow 0.18s,transform 0.18s" onmouseover="this.style.boxShadow='0 6px 20px rgba(124,58,237,0.12)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='none';this.style.transform='none'">
        <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#faf5ff,#d8b4fe);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0">📋</div>
        <div style="min-width:0">
          <div style="font-size:0.88rem;font-weight:700;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">Applications</div>
          <div style="font-size:0.72rem;color:#7c3aed;margin-top:1px">Govt forms &amp; A4 docs</div>
        </div>
      </a>

      <a href="/photo-editor" style="display:flex;align-items:center;gap:0.85rem;background:#fff;border:1.5px solid #a5f3eb;border-radius:14px;padding:1rem 1.1rem;text-decoration:none;transition:box-shadow 0.18s,transform 0.18s" onmouseover="this.style.boxShadow='0 6px 20px rgba(13,148,136,0.12)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='none';this.style.transform='none'">
        <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#f0fdfa,#5eead4);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0">🖼️</div>
        <div style="min-width:0">
          <div style="font-size:0.88rem;font-weight:700;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">Photo Editor</div>
          <div style="font-size:0.72rem;color:#0f766e;margin-top:1px">Edit &amp; enhance photos</div>
        </div>
      </a>

      <a href="/background-remover" style="display:flex;align-items:center;gap:0.85rem;background:#fff;border:1.5px solid #bbf7d0;border-radius:14px;padding:1rem 1.1rem;text-decoration:none;transition:box-shadow 0.18s,transform 0.18s" onmouseover="this.style.boxShadow='0 6px 20px rgba(22,163,74,0.12)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='none';this.style.transform='none'">
        <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#f0fdf4,#86efac);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0">✂️</div>
        <div style="min-width:0">
          <div style="font-size:0.88rem;font-weight:700;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">BG Remover</div>
          <div style="font-size:0.72rem;color:#16a34a;margin-top:1px">AI background removal</div>
        </div>
      </a>

      <a href="/reels" style="display:flex;align-items:center;gap:0.85rem;background:#fff;border:1.5px solid #fecdd3;border-radius:14px;padding:1rem 1.1rem;text-decoration:none;transition:box-shadow 0.18s,transform 0.18s" onmouseover="this.style.boxShadow='0 6px 20px rgba(225,29,72,0.12)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='none';this.style.transform='none'">
        <div style="width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#fff1f2,#fda4af);display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0">🎬</div>
        <div style="min-width:0">
          <div style="font-size:0.88rem;font-weight:700;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">AI Reels</div>
          <div style="font-size:0.72rem;color:#e11d48;margin-top:1px">Generate video reels</div>
        </div>
      </a>

    </div>
  </div>
  <style>
    @media (max-width: 640px) {
      /* ── Explore Services grid ── */
      .dash-svc-grid { grid-template-columns: repeat(2,1fr) !important; gap: 0.5rem !important; }
      .dash-svc-grid > a { padding: 0.6rem 0.65rem !important; gap: 0.5rem !important; border-radius: 11px !important; }
      .dash-svc-grid > a > div:first-child { width: 32px !important; height: 32px !important; font-size: 1rem !important; border-radius: 9px !important; }

      /* ── Action / image cards — keep 2-col, compact ── */
      .card-grid { grid-template-columns: repeat(2,1fr) !important; gap: 0.55rem !important; margin-top: 0.75rem !important; }
      .service-image { height: 88px !important; }
      .service-card-body { padding: 0.6rem 0.75rem 0.7rem !important; }
      .service-card-body h3 { font-size: 0.78rem !important; margin-bottom: 0.2rem !important; }
      .service-card-body p { font-size: 0.67rem !important; line-height: 1.4 !important; }

      /* ── Other dash cards (refer, wallet) ── */
      .card-grid .card { padding: 0.85rem !important; }
      .card-grid .card h2 { font-size: 0.88rem !important; }
    }
    @media (max-width: 360px) {
      .dash-svc-grid { grid-template-columns: repeat(2,1fr) !important; }
      .card-grid     { grid-template-columns: repeat(2,1fr) !important; }
    }
  </style>

  <!-- Action cards -->
  <div class="card-grid">
    <a href="/resume-templates" class="service-card service-card-link">
      <div class="service-image resume-bg"></div>
      <div class="service-card-body">
        <h3>Resume Making</h3>
        <p>Generate a clean, ATS-friendly resume with professional wording and layout in minutes.</p>
      </div>
    </a>
    <a href="/photo-editor" class="service-card service-card-link">
      <div class="service-image photo-editor-bg">
        <svg class="ped-icon" width="56" height="56" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="100" height="100" rx="22" fill="#3abcb1"/>
          <path d="M22 28 Q22 18 32 18 L58 18 Q78 18 78 38 Q78 58 58 58 L46 58 L46 78 Q46 82 42 82 L26 82 Q22 82 22 78 Z" fill="white"/>
          <path d="M46 38 Q46 28 56 28 Q66 28 66 38 Q66 48 56 48 L46 48 Z" fill="#3abcb1"/>
        </svg>
      </div>
      <div class="service-card-body">
        <h3>Photo Editor</h3>
        <p>Edit images, create graphics and designs with the full-featured Photopea online editor.</p>
      </div>
    </a>
    <a href="/background-remover" class="service-card service-card-link">
      <div class="service-image" style="background-image:url('/images/bgre.png');background-size:cover;background-position:center;"></div>
      <div class="service-card-body">
        <h3>Background Remover</h3>
        <p>Remove image backgrounds instantly with AI — clean, precise cutouts in seconds.</p>
      </div>
    </a>
    <div class="card refer-earn-card">
      <div class="ref-card-top">
        <div class="ref-card-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        </div>
        <div>
          <h2 style="margin:0 0 0.15rem">Refer &amp; Earn</h2>
          <p style="margin:0;font-size:0.82rem;color:#6b7280">Earn ₹10 for every friend you invite</p>
        </div>
      </div>
      <div class="ref-card-perks">
        <span class="ref-perk ref-perk--green">Your friend gets 30% off</span>
        <span class="ref-perk ref-perk--purple">You earn ₹10 wallet credit</span>
      </div>
      <a href="/refer" class="btn-primary ref-card-btn">Share Your Code</a>
    </div>

    <%# ── Wallet Card ── %>
    <div class="card wallet-dash-card">
      <div class="ref-card-top">
        <div class="ref-card-icon" style="background:linear-gradient(135deg,#0891b2,#0f766e)">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="1" y="4" width="22" height="16" rx="3"/><path d="M1 10h22"/><circle cx="17" cy="15" r="1.5" fill="currentColor"/></svg>
        </div>
        <div>
          <h2 style="margin:0 0 0.15rem">My Wallet</h2>
          <p style="margin:0;font-size:0.82rem;color:#6b7280">Your earnings &amp; credits</p>
        </div>
      </div>
      <div class="wallet-dash-balance">
        <span class="wallet-dash-amount">₹<%= (walletBalance || 0).toFixed(0) %></span>
        <% if ((walletBalance || 0) > 0) { %>
        <span class="wallet-dash-badge">Ready to use</span>
        <% } else { %>
        <span class="wallet-dash-badge wallet-dash-badge--empty">No balance</span>
        <% } %>
      </div>
      <div style="display:flex;gap:0.5rem;margin-top:0.25rem">
        <a href="/wallet" class="btn-primary" style="flex:1;text-align:center;text-decoration:none;font-size:0.85rem;padding:0.55rem 0.75rem">View Wallet</a>
        <a href="/refer" class="btn-ghost" style="flex:1;text-align:center;text-decoration:none;font-size:0.85rem;padding:0.55rem 0.75rem">Refer &amp; Earn</a>
      </div>
    </div>

    <%# ── Investor Card (only shown to active investors) ── %>
    <% if (currentUser && currentUser.role === 'investor') { %>
    <div class="card investor-card-active">
      <div class="ref-card-top">
        <div class="ref-card-icon" style="background:linear-gradient(135deg,#f59e0b,#ef4444)">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <div>
          <h2 style="margin:0 0 0.15rem">Investor Dashboard</h2>
          <p style="margin:0;font-size:0.82rem">View your equity stake and investment details</p>
        </div>
      </div>
      <div class="investor-badge-row">
        <span class="investor-badge inv-badge-dark-gold">Active Investor</span>
      </div>
      <a href="/investor/dashboard" class="btn-primary" style="display:inline-block;text-decoration:none">View Investor Card</a>
    </div>
    <% } %>

    <div class="card">
      <h2>Service Request</h2>
      <p style="font-size:0.9rem;color:#6b7280;margin-bottom:1rem">Need something custom? Tell us what you need.</p>

      <div id="srSuccess" hidden style="text-align:center;padding:1.5rem 0">
        <div style="font-size:2rem;margin-bottom:0.5rem">✅</div>
        <p style="font-weight:600;color:#111827">Request submitted!</p>
        <p style="font-size:0.85rem;color:#6b7280">We'll get back to you soon.</p>
        <button class="btn-ghost" style="margin-top:0.75rem;font-size:0.85rem" onclick="resetSrForm()">Submit another</button>
      </div>

      <form id="srForm">
        <div class="sr-field">
          <label class="sr-label">Service Type</label>
          <select name="service_type" class="sr-input" required>
            <option value="">Select a service…</option>
            <option value="resume">AI Resume &amp; Cover Letter</option>
            <option value="logo">Logo + Brand Kit</option>
            <option value="landing_page">Landing Page Copy + Design</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="sr-field">
          <label class="sr-label">Details</label>
          <textarea name="details" class="sr-input sr-textarea" rows="3" placeholder="Tell us about your project…" required></textarea>
        </div>
        <button type="submit" class="btn-primary sr-submit" id="srSubmitBtn">Submit Request</button>
      </form>

      <!-- Past requests list -->
      <div id="myRequestsList" style="margin-top:1.25rem"></div>
    </div>


  </div>

  <!-- ── User Testimonials ──────────────────────────────────────────────── -->
  <div style="margin-top:2.5rem;margin-bottom:0.5rem">
    <h2 style="font-size:1.05rem;font-weight:800;color:#111827;margin:0 0 0.25rem">What Our Users Say</h2>
    <p style="font-size:0.8rem;color:#6b7280;margin:0 0 1rem">Real feedback from the SmrAI Studio community</p>
  </div>

  <div class="dash-testi-wrap">
    <div class="dash-testi-track">
      <!-- Original set -->
      <div class="dash-testi-card">
        <div class="dash-testi-stars">★★★★★</div>
        <p class="dash-testi-quote">"SmrAI Studio has everything I need in one place. Built my resume and landed a job interview in 3 days!"</p>
        <div class="dash-testi-author">Rahul M. · Student</div>
      </div>
      <div class="dash-testi-card">
        <div class="dash-testi-stars">★★★★★</div>
        <p class="dash-testi-quote">"The PaySetu recharge is so smooth. Fastest bill payment experience I've ever had — done in 30 seconds."</p>
        <div class="dash-testi-author">Priya S. · Freelancer</div>
      </div>
      <div class="dash-testi-card">
        <div class="dash-testi-stars">★★★★★</div>
        <p class="dash-testi-quote">"Background remover works like magic. Cleaned up 50+ product photos for my store in minutes. Incredible!"</p>
        <div class="dash-testi-author">Anil K. · E-commerce Seller</div>
      </div>
      <div class="dash-testi-card">
