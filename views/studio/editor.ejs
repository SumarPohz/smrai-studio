// ── Property setters ──────────────────────────────────────────────────────────
function setProp(id, key, val) {
  const l = layers.find(l => l.id === id);
  if (!l) return;
  l[key] = val;
  drawFrame(playhead);
}

function setBgType(id, type) {
  const l = layers.find(l => l.id === id);
  if (!l) return;
  l.bgType  = type;
  l.bgValue = type === 'color' ? (l.bgValue || '#000000') : '';
  l.bgEl    = null;
  renderProps();
  drawFrame(playhead);
}

function editWord(layerId, idx, val) {
  const l = layers.find(l => l.id === layerId);
  if (l && l.words[idx]) l.words[idx].word = val;
}

function linkCaption(capId, voiceId) {
  const cap   = layers.find(l => l.id === capId);
  const voice = layers.find(l => l.id === voiceId);
  if (!cap || !voice) return;
  cap.words     = JSON.parse(JSON.stringify(voice.captionWords || []));
  cap.startTime = voice.startTime;
  cap.duration  = voice.duration;
  renderProps();
  renderTimeline();
}

async function uploadLayerMedia(id, input, role) {
  if (!input.files[0]) return;
  const file = input.files[0];
  const localUrl = URL.createObjectURL(file);
  const l = layers.find(l => l.id === id);
  if (!l) return;

  if (role === 'bg') {
    const isVid = file.type.startsWith('video/');
    l.bgType  = isVid ? 'video' : 'image';
    l.bgEl    = null;
    if (isVid) {
      const v = document.createElement('video');
      v.src = localUrl; v.muted = true; v.loop = true; v.playsInline = true;
      v.addEventListener('loadeddata', () => { l.bgEl = v; if (!isPlaying) drawFrame(playhead); });
      v.play();
    } else {
      const img = new Image();
      img.onload = () => { l.bgEl = img; if (!isPlaying) drawFrame(playhead); };
      img.src = localUrl;
    }
    l.bgValue = localUrl;
  }

  // Upload to server for persistence
  const fd = new FormData();
  fd.append('media', file);
  try {
    const d = await fetch('/studio/upload-media', { method:'POST', body:fd }).then(r=>r.json());
    if (d.ok) { l.bgValue = d.url; }
  } catch {}

  renderProps();
  drawFrame(playhead);
}

function reloadAudio(id) {
  const l = layers.find(l => l.id === id);
  if (!l || !l.musicId) return;
  if (l.audioEl) { l.audioEl.pause(); l.audioEl = null; }
  const a = new Audio(`/music/${l.musicId}.mp3`);
  a.loop   = true;
  a.volume = l.volume || 0.15;
  l.audioEl = a;
}

function syncAudio(id) {
  const l = layers.find(l => l.id === id);
  if (l?.audioEl) l.audioEl.volume = l.volume || 0;
}

// ═══════════════════════════════════════════════════════════════════════════════
// CANVAS RENDERING
// ═══════════════════════════════════════════════════════════════════════════════
function drawFrame(t) {
  ctx.clearRect(0, 0, W, H);

  // Draw layers bottom-to-top (layers[0] = bottom)
  for (const l of layers) {
    if (!l.visible) continue;
    const end = l.duration > 0 ? l.startTime + l.duration : Infinity;
    if (t < l.startTime || t > end) continue;
    switch (l.type) {
      case 'background': drawBg(l); break;
      case 'text':       drawText(l, t); break;
      case 'caption':    drawCaption(l, t); break;
    }
  }
}

function drawBg(l) {
  if (l.bgType === 'color') {
    ctx.fillStyle = l.bgValue || '#000';
    ctx.fillRect(0, 0, W, H);
  } else if ((l.bgType === 'image' || l.bgType === 'video') && l.bgEl) {
    const el  = l.bgEl;
    const ew  = el.naturalWidth  || el.videoWidth  || W;
    const eh  = el.naturalHeight || el.videoHeight || H;
    const r   = Math.max(W / ew, H / eh);
    const bw  = ew * r, bh = eh * r;
    ctx.drawImage(el, (W - bw) / 2, (H - bh) / 2, bw, bh);
  } else {
    ctx.fillStyle = '#000';
    ctx.fillRect(0, 0, W, H);
  }
}

function drawText(l, t) {
  const elapsed = t - l.startTime;
  const dur     = l.duration || 1;
  let alpha = 1, offsetY = 0;

  // Animations
  if (l.animation === 'fadeIn') {
    alpha = Math.min(1, elapsed / Math.min(0.6, dur * 0.3));
  } else if (l.animation === 'slideUp') {
    const p = Math.min(1, elapsed / Math.min(0.7, dur * 0.35));
    alpha   = p;
    offsetY = (1 - p) * 120;
  }

  const textToShow = l.animation === 'typewriter'
    ? (l.text || '').substring(0, Math.floor(elapsed * 18))
    : (l.text || '');

  ctx.save();
  ctx.globalAlpha  = alpha;
  ctx.font         = `bold ${l.fontSize||72}px '${l.fontFamily||'Arial'}', sans-serif`;
  ctx.fillStyle    = l.color || '#ffffff';
  ctx.textAlign    = l.align || 'center';
  ctx.textBaseline = 'middle';
  ctx.shadowColor  = 'rgba(0,0,0,0.85)';
  ctx.shadowBlur   = 14;

  const cx = l.align === 'left' ? 80 : l.align === 'right' ? W - 80 : W / 2;
  const cy = (l.y || 0.5) * H + offsetY;
  const maxW = W - 160;

  // Word-wrap
  const lineH = (l.fontSize || 72) * 1.4;
  const words = textToShow.split(' ');
  let line = '', curY = cy - lineH;
  const lines = [];
  for (const w of words) {
    const test = line ? line + ' ' + w : w;
    if (ctx.measureText(test).width > maxW && line) { lines.push(line); line = w; }
    else line = test;
  }
  if (line) lines.push(line);
  const totalH = lines.length * lineH;
  lines.forEach((ln, i) => {
    ctx.fillText(ln, cx, cy - totalH / 2 + i * lineH + lineH / 2);
  });

  ctx.restore();
}

function drawCaption(l, t) {
  const words = l.words;
  if (!words || !words.length) return;

  // Find current word index
  let curIdx = -1;
  for (let i = 0; i < words.length; i++) {
    if (t >= words[i].start && (i === words.length - 1 || t < words[i + 1].start)) {
      curIdx = i; break;
    }
  }
  if (curIdx === -1) return;

  // 3-word chunk
  const chunkStart = Math.floor(curIdx / 3) * 3;
  const chunk = words.slice(chunkStart, Math.min(chunkStart + 3, words.length));
  const curInChunk = curIdx - chunkStart;

  const fs = l.fontSize || 64;
  const hl = { yellow:'#FFD700', cyan:'#67e8f9', pink:'#f9a8d4' }[l.style || 'yellow'];

  ctx.save();
  ctx.font         = `bold ${fs}px Arial, sans-serif`;
  ctx.textBaseline = 'middle';

  // Measure total line width
  const lineText  = chunk.map(w => w.word).join(' ');
  const totalW    = ctx.measureText(lineText).width;
  const padX = 36, padY = 24;
  const boxW = totalW + padX * 2;
  const boxH = fs + padY * 2;
  const cx   = W / 2;
  const cy   = (l.captionY || 0.88) * H;

  // Background pill
  ctx.fillStyle = 'rgba(0,0,0,0.65)';
  roundRect(ctx, cx - boxW / 2, cy - boxH / 2, boxW, boxH, 16);
  ctx.fill();

  // Draw words word-by-word
  let wordX = cx - totalW / 2;
  chunk.forEach((w, i) => {
    const ww = ctx.measureText(w.word).width;
    ctx.fillStyle   = i === curInChunk ? hl : '#ffffff';
    ctx.shadowColor = 'rgba(0,0,0,0.8)';
    ctx.shadowBlur  = 6;
    ctx.textAlign   = 'left';
    ctx.fillText(w.word, wordX, cy);
    wordX += ww + ctx.measureText(' ').width;
  });
  ctx.restore();
}

function roundRect(c, x, y, w, h, r) {
  c.beginPath();
  c.moveTo(x + r, y);
  c.lineTo(x + w - r, y);
  c.quadraticCurveTo(x + w, y, x + w, y + r);
  c.lineTo(x + w, y + h - r);
  c.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  c.lineTo(x + r, y + h);
  c.quadraticCurveTo(x, y + h, x, y + h - r);
  c.lineTo(x, y + r);
  c.quadraticCurveTo(x, y, x + r, y);
  c.closePath();
}

// ═══════════════════════════════════════════════════════════════════════════════
// PLAYBACK
// ═══════════════════════════════════════════════════════════════════════════════
function setTotalDuration(v) {
  totalDuration = Math.max(5, Math.min(600, v || 30));
  document.getElementById('durInput').value = totalDuration;
  document.getElementById('seekBar').max = totalDuration;
  renderTimeline();
  updateTimeDisplay();
}

function togglePlay() {
  if (isPlaying) stopPlay(); else startPlay();
}

function startPlay() {
  if (playhead >= totalDuration) playhead = 0;
  isPlaying   = true;
  lastFrameTs = performance.now();
  document.getElementById('playBtn').textContent = '⏸';
  startAudioLayers();
  animLoop();
}

function stopPlay() {
  isPlaying = false;
  document.getElementById('playBtn').textContent = '▶';
  stopAudioLayers();
  cancelAnimationFrame(rafId);
}

function resetPlayhead() {
  stopPlay();
  playhead = 0;
  document.getElementById('seekBar').value = 0;
  updateTimeDisplay();
  drawFrame(0);
}

function seekTo(t) {
  playhead = Math.max(0, Math.min(totalDuration, t));
  updateTimeDisplay();
  drawFrame(playhead);
  if (isPlaying) { syncAudioLayers(); }
}

function animLoop() {
  if (!isPlaying && !isRecording) return;
  const now = performance.now();
  const dt  = (now - lastFrameTs) / 1000;
  lastFrameTs = now;
  playhead += dt;
  if (playhead >= totalDuration) {
    playhead = totalDuration;
    drawFrame(playhead);
    if (!isRecording) stopPlay();
    if (isRecording) stopExportRecording();
    return;
  }
  document.getElementById('seekBar').value = playhead;
  updateTimeDisplay();
  drawFrame(playhead);
  rafId = requestAnimationFrame(animLoop);
}

function updateTimeDisplay() {
  document.getElementById('timeDisp').textContent =
    `${fmtSec(playhead)} / ${fmtSec(totalDuration)}`;
  // Update seekbar gradient
  const sb = document.getElementById('seekBar');
  const pct = (playhead / totalDuration * 100).toFixed(1);
  sb.style.background = `linear-gradient(to right, var(--accent) ${pct}%, #27272a ${pct}%)`;
}

// ── Audio layer play/pause/sync ───────────────────────────────────────────────
function startAudioLayers() {
  for (const l of layers) {
    if (!l.visible) continue;
    if (l.type === 'music' && l.musicId) {
      if (!l.audioEl) reloadAudio(l.id);
      if (l.audioEl) {
        const offset = playhead - l.startTime;
        l.audioEl.currentTime = offset > 0 ? (offset % (l.audioEl.duration || 1)) : 0;
        if (playhead >= l.startTime && (l.duration === 0 || playhead < l.startTime + l.duration)) {
          l.audioEl.volume = l.volume || 0.15;
          l.audioEl.play().catch(() => {});
        }
      }
    }
    if (l.type === 'voice' && l.audioUrl) {
      if (!l.audioEl) { l.audioEl = new Audio(l.audioUrl); }
      const offset = playhead - l.startTime;
      l.audioEl.currentTime = Math.max(0, offset);
      l.audioEl.volume      = Math.min(1, l.volume || 1);
      if (playhead >= l.startTime && (l.duration === 0 || playhead < l.startTime + l.duration)) {
        l.audioEl.play().catch(() => {});
      }
    }
  }
}

function stopAudioLayers() {
  for (const l of layers) {
    if (l.audioEl) l.audioEl.pause();
  }
}

function syncAudioLayers() {
  for (const l of layers) {
    if (!l.audioEl) continue;
    const offset = playhead - l.startTime;
    if (offset >= 0) l.audioEl.currentTime = offset % (l.audioEl.duration || 1);
  }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VOICE RECORDING + CAPTIONS
// ═══════════════════════════════════════════════════════════════════════════════
async function startVoiceRecord(layerId) {
  try {
    voiceStream   = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
    const ac      = getAudioCtx();
    if (ac.state === 'suspended') await ac.resume();

    // Processing chain: HPF → Compressor → Gain → capture destination
    const src = ac.createMediaStreamSource(voiceStream);

    const hpf = ac.createBiquadFilter();
    hpf.type = 'highpass'; hpf.frequency.value = 80;

    const lpf = ac.createBiquadFilter();
    lpf.type = 'lowpass'; lpf.frequency.value = 8000;

    const comp = ac.createDynamicsCompressor();
    comp.threshold.value = -24; comp.knee.value = 30;
    comp.ratio.value = 12; comp.attack.value = 0.003; comp.release.value = 0.25;

    const layer = layers.find(l => l.id === layerId);
    const gainNode = ac.createGain();
    gainNode.gain.value = layer?.gain || 2.0;

    const dest = ac.createMediaStreamDestination();
    src.connect(hpf); hpf.connect(lpf); lpf.connect(comp);
    comp.connect(gainNode); gainNode.connect(dest);

    // Record processed stream
    voiceRecorder = new MediaRecorder(dest.stream);
    captureWords  = [];
    recStartTime  = ac.currentTime;
    voiceLayerId  = layerId;

    const chunks = [];
    voiceRecorder.ondataavailable = e => { if (e.data.size) chunks.push(e.data); };
    voiceRecorder.onstop = () => finishVoiceRecord(layerId, chunks);
    voiceRecorder.start(200);

    // Web Speech API for captions
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (SR) {
      recognition = new SR();
      recognition.continuous    = true;
      recognition.interimResults = true;
      recognition.lang          = 'en-US';
      let phraseStart = 0;
      recognition.onstart  = () => { phraseStart = ac.currentTime - recStartTime; };
      recognition.onresult = (ev) => {
        for (let i = ev.resultIndex; i < ev.results.length; i++) {
          if (!ev.results[i].isFinal) continue;
          const text = ev.results[i][0].transcript.trim();
          const now  = ac.currentTime - recStartTime;
          const words = text.split(/\s+/).filter(Boolean);
          const wDur  = (now - phraseStart) / Math.max(words.length, 1);
          words.forEach((w, wi) => {
            captureWords.push({
              word:  w,
              start: +(phraseStart + wi * wDur).toFixed(2),
              end:   +(phraseStart + (wi + 1) * wDur).toFixed(2),
            });
          });
          phraseStart = now;
        }
      };
      recognition.start();
    }

    renderProps(); // show "Stop Recording" button
    showMsg('🎤 Recording… speak now', '#ef4444');
  } catch (err) {
    showMsg('Microphone access denied: ' + err.message, '#f87171');
  }
}

async function stopVoiceRecord() {
  if (recognition) { recognition.stop(); recognition = null; }
  if (voiceRecorder && voiceRecorder.state !== 'inactive') voiceRecorder.stop();
  if (voiceStream) { voiceStream.getTracks().forEach(t => t.stop()); voiceStream = null; }
  voiceRecorder = null;
}

async function finishVoiceRecord(layerId, chunks) {
  const blob    = new Blob(chunks, { type: 'video/webm' });
  const localUrl = URL.createObjectURL(blob);
  const duration = captureWords.length ? (captureWords[captureWords.length - 1].end || 5) : 5;

  const layer = layers.find(l => l.id === layerId);
  if (!layer) return;
  layer.audioUrl     = localUrl;
  layer.duration     = Math.ceil(duration) + 0.5;
  layer.captionWords = [...captureWords];
  layer.audioEl      = new Audio(localUrl);

  // Auto-add caption layer if not present
  const hasCap = layers.some(l => l.type === 'caption');
  if (!hasCap && captureWords.length) {
    const cap = defaultLayer('caption');
    cap.name       = 'Captions';
    cap.words      = [...captureWords];
    cap.startTime  = layer.startTime;
    cap.duration   = layer.duration;
    layers.push(cap);
  } else {
    // Update existing caption layer
    const cap = layers.find(l => l.type === 'caption');
    if (cap && captureWords.length) {
      cap.words     = [...captureWords];
      cap.startTime = layer.startTime;
      cap.duration  = layer.duration;
    }
  }

  voiceLayerId = null;
  captureWords = [];

  // Upload to server for persistence
  try {
    const fd = new FormData();
    fd.append('media', blob, 'voice.webm');
    const d = await fetch('/studio/upload-media', { method:'POST', body:fd }).then(r=>r.json());
    if (d.ok) layer.audioUrl = d.url;
  } catch {}

  renderLayerList();
  renderProps();
  renderTimeline();
  drawFrame(playhead);
  showMsg('✅ Voice recorded! Captions auto-generated.', '#4ade80');
}

function previewVoice(id) {
  const l = layers.find(l => l.id === id);
  if (!l?.audioUrl) return;
  const a = l.audioEl || new Audio(l.audioUrl);
  a.currentTime = 0;
  a.volume = Math.min(1, l.volume || 1);
  a.play().catch(() => {});
}

// ═══════════════════════════════════════════════════════════════════════════════
// TIMELINE
// ═══════════════════════════════════════════════════════════════════════════════
function renderTimeline() {
  const el = document.getElementById('timeline');
  if (!layers.length) { el.innerHTML = ''; return; }
  el.innerHTML = [...layers].reverse().map(l => {
    const start = ((l.startTime || 0) / totalDuration * 100).toFixed(1);
    const dur   = l.duration > 0 ? Math.min(l.duration, totalDuration - (l.startTime||0)) : totalDuration;
    const width = (dur / totalDuration * 100).toFixed(1);
    const color = layerColor(l.type);
    return `<div class="tl-row">
      <span class="tl-label">${escH(l.name)}</span>
      <div class="tl-track">
        <div class="tl-block" style="left:${start}%;width:${width}%;background:${color};"></div>
      </div>
    </div>`;
  }).join('');
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXPORT
// ═══════════════════════════════════════════════════════════════════════════════
function exportPng() {
  drawFrame(playhead);
  canvas.toBlob(blob => {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'studio-frame.png';
    a.click();
    URL.revokeObjectURL(a.href);
  }, 'image/png');
}

async function toggleRecording() {
  if (isRecording) { stopExportRecording(); return; }
  // Unlock audio
  const ac = getAudioCtx();
  if (ac.state === 'suspended') await ac.resume();

  // Build audio mix via Web Audio
  const dest = ac.createMediaStreamDestination();
  const masterGain = ac.createGain();
  masterGain.gain.value = 1;
  masterGain.connect(dest);

  // Connect audio layers
  for (const l of layers) {
    if (!l.visible || !l.audioUrl && !l.musicId) continue;
    if (l.type === 'music' && l.musicId) {
      const a = l.audioEl || new Audio(`/music/${l.musicId}.mp3`);
      a.currentTime = 0; a.volume = 1;
      const src = ac.createMediaElementSource(a);
      const g   = ac.createGain();
      g.gain.value = l.volume || 0.15;
      src.connect(g); g.connect(masterGain);
      a.play().catch(() => {});
      l.audioEl = a; // keep ref
    }
    if (l.type === 'voice' && l.audioUrl) {
      const a = new Audio(l.audioUrl);
      a.currentTime = 0; a.volume = 1;
      const src = ac.createMediaElementSource(a);
      const g   = ac.createGain();
      g.gain.value = Math.min(1, l.volume || 1);
      src.connect(g); g.connect(masterGain);
      setTimeout(() => a.play().catch(() => {}), l.startTime * 1000);
    }
  }

  const canvasStream = canvas.captureStream(30);
  const combined = new MediaStream([
    ...canvasStream.getVideoTracks(),
    ...dest.stream.getAudioTracks(),
  ]);

  const mime = MediaRecorder.isTypeSupported('video/webm;codecs=vp9')
    ? 'video/webm;codecs=vp9' : 'video/webm';

  exportRecorder = new MediaRecorder(combined, { mimeType: mime });
  exportChunks   = [];
  exportRecorder.ondataavailable = e => { if (e.data.size) exportChunks.push(e.data); };
  exportRecorder.onstop = downloadExport;
  exportRecorder.start(200);

  isRecording = true;
  playhead    = 0;
  document.getElementById('recBadge').style.display = '';
  document.getElementById('recBtn').textContent = '⏹ Stop';
  document.getElementById('recBtn').style.background = '#7f1d1d';
  lastFrameTs = performance.now();
  animLoop();
  showMsg('Recording started…', '#ef4444');
}

function stopExportRecording() {
  isRecording = false;
  cancelAnimationFrame(rafId);
  exportRecorder?.stop();
  stopAudioLayers();
  document.getElementById('recBadge').style.display = 'none';
  document.getElementById('recBtn').textContent = '● Record Video';
  document.getElementById('recBtn').style.background = '';
}

function downloadExport() {
  const blob = new Blob(exportChunks, { type: 'video/webm' });
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  a.download = (document.getElementById('projectName').value || 'studio') + '.webm';
  a.click();
  URL.revokeObjectURL(a.href);
  showMsg('✅ Video downloaded!', '#4ade80');
}

// ═══════════════════════════════════════════════════════════════════════════════
// SAVE / LOAD
// ═══════════════════════════════════════════════════════════════════════════════
async function saveProject() {
  const name = document.getElementById('projectName').value.trim() || 'Untitled';
  try {
    const d = await fetch('/studio/save', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ id: projectId, name, layers, totalDuration }),
    }).then(r => r.json());
    if (!d.ok) throw new Error(d.error);
    projectId = d.id;
    showMsg('✅ Project saved!', '#4ade80');
  } catch (e) {
    showMsg('Save failed: ' + e.message, '#f87171');
  }
}

async function openProjects() {
  document.getElementById('projectsModal').classList.add('open');
  const d = await fetch('/studio/list').then(r => r.json());
  const el = document.getElementById('projectsList');
  if (!d.ok || !d.projects.length) {
    el.innerHTML = '<p style="font-size:12px;color:#52525b;text-align:center;">No saved projects yet.</p>';
    return;
  }
  el.innerHTML = d.projects.map(p => `
    <div class="proj-item" onclick="loadProject(${p.id})">
      <div>
        <div class="proj-name">${escH(p.name)}</div>
        <div class="proj-meta">${p.total_duration}s · ${new Date(p.updated_at).toLocaleDateString()}</div>
      </div>
      <button class="st-btn st-btn-danger" style="font-size:11px;padding:4px 10px;" onclick="event.stopPropagation();deleteProject(${p.id},this)">🗑</button>
    </div>`).join('');
}

function closeProjects() { document.getElementById('projectsModal').classList.remove('open'); }

async function loadProject(id) {
  const d = await fetch('/studio/list').then(r=>r.json());
  // Re-fetch full project data (list only has summary — load from a detail route)
  // For now: send layers via the same list endpoint (we store all data there)
  // We need a dedicated load endpoint, but for now save includes layers
  // Workaround: save returns id; load by refreshing projects list with full data
  showMsg('Loading project…', '#a1a1aa');
  // TODO: Add GET /studio/:id endpoint in Phase 2 for full load
  closeProjects();
}

async function deleteProject(id, btn) {
  if (!confirm('Delete this project?')) return;
  const d = await fetch(`/studio/${id}`, { method:'DELETE' }).then(r=>r.json());
  if (d.ok) btn.closest('.proj-item').remove();
}

// ═══════════════════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════════════════
function showMsg(msg, color = '#a1a1aa') {
  const el = document.getElementById('exportMsg');
  el.textContent = msg; el.style.color = color;
  setTimeout(() => { if (el.textContent === msg) el.textContent = ''; }, 4000);
}

function fmtSec(s) {
  const m = Math.floor(s / 60);
  const sec = Math.floor(s % 60);
  return `${m}:${sec.toString().padStart(2,'0')}`;
}

function escH(s) {
  return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Add-layer dropdown
function toggleAddMenu(e) {
  e.stopPropagation();
  document.getElementById('addMenu').classList.toggle('open');
}
function closeAddMenu() { document.getElementById('addMenu').classList.remove('open'); }
document.addEventListener('click', () => closeAddMenu());

// ═══════════════════════════════════════════════════════════════════════════════
// INIT — start with a background layer
// ═══════════════════════════════════════════════════════════════════════════════
addLayer('background');
setTotalDuration(30);
drawFrame(0);
</script>

