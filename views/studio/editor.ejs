<%- include('../partials/header', { title: 'Video Studio — SmrAI Studio' }) %>
<style>
:root { --bg:#09090b; --card:#18181b; --border:#27272a; --accent:#7c3aed; --accent2:#06b6d4; }
*,*::before,*::after { box-sizing:border-box; }
body,#st-page { background:var(--bg); color:#f4f4f5; font-family:'Inter',sans-serif; min-height:100vh; }
#st-page { display:flex; flex-direction:column; height:100vh; overflow:hidden; }

/* ── Header ── */
.st-header {
  display:flex; align-items:center; gap:10px; padding:10px 16px;
  background:var(--card); border-bottom:1px solid var(--border);
  flex-shrink:0; flex-wrap:wrap;
}
.st-logo { font-size:1rem; font-weight:800; white-space:nowrap; }
.st-project-name {
  background:transparent; border:1px solid transparent; border-radius:6px;
  color:#f4f4f5; font-size:14px; font-weight:600; padding:4px 8px;
  min-width:160px; outline:none; transition:border-color .15s;
}
.st-project-name:focus { border-color:var(--accent); background:#09090b; }
.dur-label { font-size:12px; color:#71717a; white-space:nowrap; }
.dur-input {
  width:60px; background:#09090b; border:1px solid var(--border);
  border-radius:6px; color:#f4f4f5; font-size:13px; padding:4px 8px; outline:none;
  text-align:center;
}
.dur-input:focus { border-color:var(--accent); }
.st-btn {
  display:inline-flex; align-items:center; gap:5px; padding:6px 14px;
  border-radius:7px; font-size:12px; font-weight:600; border:none; cursor:pointer;
  transition:opacity .15s; white-space:nowrap;
}
.st-btn:disabled { opacity:.4; cursor:not-allowed; }
.st-btn-primary { background:var(--accent); color:#fff; }
.st-btn-ghost   { background:#27272a; color:#d4d4d8; }
.st-btn-danger  { background:#7f1d1d; color:#fca5a5; }
.st-btn-cyan    { background:#164e63; color:#67e8f9; }
.ml-auto { margin-left:auto; }

/* ── Main grid ── */
.st-grid {
  display:grid;
  grid-template-columns: 250px 1fr 260px;
  flex:1; overflow:hidden; gap:0;
}
.st-panel {
  display:flex; flex-direction:column; overflow:hidden;
  border-right:1px solid var(--border);
}
.st-panel:last-child { border-right:none; }
.st-panel-center { border-right:1px solid var(--border); }
.panel-hd {
  display:flex; align-items:center; justify-content:space-between;
  padding:10px 12px; border-bottom:1px solid var(--border);
  font-size:11px; font-weight:700; color:#71717a; letter-spacing:.06em;
  text-transform:uppercase; flex-shrink:0;
}
.panel-body { flex:1; overflow-y:auto; padding:10px; }
.panel-body::-webkit-scrollbar { width:4px; }
.panel-body::-webkit-scrollbar-thumb { background:#27272a; border-radius:2px; }

/* ── Add layer dropdown ── */
.add-layer-wrap { position:relative; }
.add-dropdown {
  display:none; position:absolute; top:calc(100% + 4px); right:0;
  background:var(--card); border:1px solid var(--border); border-radius:10px;
  padding:6px; z-index:200; min-width:150px;
}
.add-dropdown.open { display:block; }
.add-dropdown button {
  display:flex; align-items:center; gap:8px; width:100%;
  padding:8px 10px; background:transparent; border:none; border-radius:6px;
  color:#d4d4d8; font-size:13px; cursor:pointer; text-align:left;
}
.add-dropdown button:hover { background:#27272a; }

/* ── Layer list items ── */
.layer-item {
  display:flex; align-items:center; gap:6px;
  padding:8px 8px; border-radius:8px; cursor:pointer;
  border:1.5px solid transparent; transition:border-color .12s, background .12s;
  margin-bottom:4px; user-select:none;
}
.layer-item:hover { background:#1f1f23; }
.layer-item.selected { border-color:var(--accent); background:rgba(124,58,237,.1); }
.layer-item.hidden { opacity:.4; }
.layer-icon { font-size:14px; flex-shrink:0; }
.layer-name { flex:1; font-size:12px; font-weight:600; color:#e4e4e7; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.layer-vis  { background:none; border:none; cursor:pointer; color:#52525b; font-size:14px; padding:2px; flex-shrink:0; }
.layer-vis:hover { color:#a1a1aa; }
.layer-del  { background:none; border:none; cursor:pointer; color:#52525b; font-size:12px; padding:2px; flex-shrink:0; }
.layer-del:hover { color:#f87171; }

/* ── Center panel ── */
#previewWrap {
  flex:1; display:flex; align-items:center; justify-content:center;
  background:#000; overflow:hidden; position:relative;
}
#stCanvas { display:block; max-width:100%; max-height:100%; object-fit:contain; }
.rec-badge {
  display:none; position:absolute; top:10px; right:14px;
  background:#ef4444; color:#fff; font-size:11px; font-weight:700;
  padding:3px 10px; border-radius:999px; letter-spacing:.05em;
  animation:recBlink 1s ease-in-out infinite;
}
@keyframes recBlink { 0%,100%{opacity:1}50%{opacity:.3} }

/* ── Playback bar ── */
.playback-bar {
  display:flex; align-items:center; gap:8px; padding:8px 12px;
  border-top:1px solid var(--border); flex-shrink:0; background:var(--card);
}
.pb-btn {
  background:#27272a; border:none; border-radius:6px; color:#d4d4d8;
  font-size:14px; padding:5px 10px; cursor:pointer;
}
.pb-btn:hover { background:#3f3f46; }
#seekBar {
  flex:1; -webkit-appearance:none; height:4px; border-radius:2px;
  background:linear-gradient(to right, var(--accent) 0%, #27272a 0%);
  outline:none; cursor:pointer;
}
#seekBar::-webkit-slider-thumb {
  -webkit-appearance:none; width:14px; height:14px; border-radius:50%;
  background:var(--accent); cursor:pointer;
}
#timeDisp { font-size:11px; color:#71717a; white-space:nowrap; min-width:60px; text-align:right; }

/* ── Timeline ── */
#timeline {
  flex-shrink:0; border-top:1px solid var(--border);
  background:#111113; overflow-y:auto; max-height:160px;
  padding:8px 12px; display:flex; flex-direction:column; gap:3px;
}
.tl-row { display:flex; align-items:center; gap:6px; height:20px; }
.tl-label { font-size:10px; color:#52525b; width:56px; text-align:right; flex-shrink:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.tl-track { flex:1; background:#1c1c1e; border-radius:3px; height:100%; position:relative; }
.tl-block { position:absolute; height:100%; border-radius:3px; opacity:.8; }
#tlCursor { position:absolute; top:0; bottom:0; width:2px; background:var(--accent); pointer-events:none; }

/* ── Export bar ── */
.export-bar {
  display:flex; align-items:center; gap:8px; padding:8px 16px;
  background:var(--card); border-top:1px solid var(--border); flex-shrink:0; flex-wrap:wrap;
}
.export-bar span { font-size:12px; color:#71717a; }

/* ── Properties panel ── */
.prop-section { margin-bottom:16px; }
.prop-label { font-size:11px; font-weight:700; color:#71717a; text-transform:uppercase; letter-spacing:.06em; margin-bottom:6px; display:block; }
.prop-input {
  width:100%; background:#09090b; border:1px solid var(--border); border-radius:7px;
  color:#f4f4f5; font-size:13px; padding:7px 10px; outline:none;
}
.prop-input:focus { border-color:var(--accent); }
.prop-textarea { resize:vertical; min-height:80px; font-family:inherit; }
.prop-row { display:flex; gap:6px; align-items:center; }
.prop-row .prop-input { flex:1; }
.chip-row { display:flex; gap:5px; flex-wrap:wrap; }
.chip {
  padding:4px 10px; border-radius:5px; font-size:11px; font-weight:700;
  cursor:pointer; border:1.5px solid var(--border); color:#a1a1aa; background:transparent;
}
.chip.active { border-color:var(--accent); color:#c4b5fd; background:rgba(124,58,237,.12); }
.prop-range { width:100%; accent-color:var(--accent); }
.prop-color { width:100%; height:36px; border:none; border-radius:7px; cursor:pointer; background:transparent; }
.prop-hint { font-size:11px; color:#52525b; line-height:1.5; margin-top:6px; }

/* Voice recording indicator */
.voice-rec-dot {
  display:inline-block; width:8px; height:8px; border-radius:50%;
  background:#ef4444; margin-right:5px; animation:recBlink 1s infinite;
}

/* Caption word list */
.cap-word { display:inline-flex; align-items:center; gap:3px; margin:2px; }
.cap-word input {
  background:#09090b; border:1px solid var(--border); border-radius:4px;
  color:#f4f4f5; font-size:11px; padding:2px 5px; width:80px; outline:none;
}
.cap-word input:focus { border-color:var(--accent); }

/* Modal */
#projectsModal {
  display:none; position:fixed; inset:0; background:rgba(0,0,0,.75);
  z-index:500; align-items:center; justify-content:center;
}
#projectsModal.open { display:flex; }
.modal-inner {
  background:var(--card); border:1px solid var(--border); border-radius:16px;
  padding:22px; width:min(480px,94vw); max-height:80vh; overflow-y:auto;
}
.proj-item {
  display:flex; align-items:center; gap:10px; padding:10px; border-radius:8px;
  border:1.5px solid var(--border); margin-bottom:8px; cursor:pointer;
}
.proj-item:hover { border-color:var(--accent); }
.proj-name { flex:1; font-size:13px; font-weight:600; color:#e4e4e7; }
.proj-meta { font-size:11px; color:#52525b; }
</style>

<div id="st-page">

  <!-- ── Header ── -->
  <div class="st-header">
    <div class="st-logo">🎥 Video Studio</div>
    <input id="projectName" class="st-project-name" value="Untitled Project" maxlength="80" />
    <span class="dur-label">Duration</span>
    <input id="durInput" class="dur-input" type="number" value="30" min="5" max="600" onchange="setTotalDuration(+this.value)" />
    <span class="dur-label">sec</span>
    <button class="st-btn st-btn-ghost" onclick="openProjects()">📂 Projects</button>
    <button class="st-btn st-btn-primary" onclick="saveProject()">💾 Save</button>
    <a href="/dashboard" class="st-btn st-btn-ghost ml-auto">← Dashboard</a>
  </div>

  <!-- ── Main grid ── -->
  <div class="st-grid">

    <!-- ── LEFT: Layers ── -->
    <div class="st-panel">
      <div class="panel-hd">
        Layers
        <div class="add-layer-wrap">
          <button class="st-btn st-btn-ghost" style="font-size:11px;padding:4px 10px;" onclick="toggleAddMenu(event)">+ Add ▾</button>
          <div class="add-dropdown" id="addMenu">
            <button onclick="addLayer('text');closeAddMenu()">📝 Text Overlay</button>
            <button onclick="addLayer('music');closeAddMenu()">🎵 Background Music</button>
            <button onclick="addLayer('voice');closeAddMenu()">🎤 Voice Over</button>
            <button onclick="addLayer('caption');closeAddMenu()">💬 Captions</button>
          </div>
        </div>
      </div>
      <div class="panel-body" id="layersList"></div>
    </div>

    <!-- ── CENTER: Preview + Playback + Timeline ── -->
    <div class="st-panel st-panel-center" style="display:flex;flex-direction:column;">
      <div id="previewWrap">
        <span class="rec-badge" id="recBadge">● REC</span>
        <canvas id="stCanvas" width="1080" height="1920"></canvas>
      </div>

      <!-- Playback bar -->
      <div class="playback-bar">
        <button class="pb-btn" onclick="resetPlayhead()" title="Rewind">⏮</button>
        <button class="pb-btn" id="playBtn" onclick="togglePlay()">▶</button>
        <input type="range" id="seekBar" min="0" max="30" step="0.05" value="0" oninput="seekTo(+this.value)" />
        <span id="timeDisp">0:00 / 0:30</span>
      </div>

      <!-- Timeline -->
      <div id="timeline"></div>
    </div>

    <!-- ── RIGHT: Properties ── -->
    <div class="st-panel">
      <div class="panel-hd">Properties</div>
      <div class="panel-body" id="propsPanel">
        <p style="font-size:12px;color:#52525b;text-align:center;margin-top:20px;">Select a layer to edit its properties</p>
      </div>
    </div>

  </div>

  <!-- ── Export bar ── -->
  <div class="export-bar">
    <span>Export:</span>
    <button class="st-btn st-btn-ghost" onclick="exportPng()">📷 Screenshot</button>
    <button class="st-btn st-btn-cyan"  id="recBtn" onclick="toggleRecording()">● Record Video</button>
    <span id="exportMsg" style="font-size:12px;color:#a1a1aa;"></span>
  </div>

</div><!-- /st-page -->

<!-- ── Projects Modal ── -->
<div id="projectsModal">
  <div class="modal-inner">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
      <div style="font-size:1rem;font-weight:800;">📂 Saved Projects</div>
      <button class="st-btn st-btn-ghost" onclick="closeProjects()">✕</button>
    </div>
    <div id="projectsList"></div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════════════════════════════
// CONSTANTS & CANVAS
// ═══════════════════════════════════════════════════════════════════════════════
const W = 1080, H = 1920;
const canvas = document.getElementById('stCanvas');
const ctx    = canvas.getContext('2d');

// Scale canvas to fit available space
function scaleCanvas() {
  const wrap = document.getElementById('previewWrap');
  const scl  = Math.min(wrap.clientWidth / W, wrap.clientHeight / H);
  canvas.style.width  = (W * scl) + 'px';
  canvas.style.height = (H * scl) + 'px';
}
window.addEventListener('resize', scaleCanvas);
window.addEventListener('load', scaleCanvas);
setTimeout(scaleCanvas, 100);

// Music presets from server
const MUSIC_LIST = <%- JSON.stringify(musicList) %>;

// ═══════════════════════════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════════════════════════
let layers       = [];          // array of layer objects
let selectedId   = null;        // selected layer id
let totalDuration = 30;         // seconds
let playhead     = 0;           // current time in seconds
let isPlaying    = false;
let isRecording  = false;
let lastFrameTs  = 0;
let rafId        = null;
let projectId    = null;

// Audio context
let audioCtx     = null;
function getAudioCtx() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  return audioCtx;
}

// Voice recording state
let voiceStream    = null;
let voiceRecorder  = null;
let voiceLayerId   = null;  // which voice layer is currently recording
let recognition    = null;
let recStartTime   = 0;
let captureWords   = [];

// WebM export state
let exportRecorder = null;
let exportChunks   = [];

// ═══════════════════════════════════════════════════════════════════════════════
// LAYER MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════
let _lid = 0;
function uid() { return 'l' + (++_lid); }

function defaultLayer(type) {
  const base = {
    id: uid(), type, visible: true,
    startTime: 0, duration: totalDuration,
  };
  switch (type) {
    case 'background': return { ...base,
      name: 'Background', duration: 0, // 0 = always visible
      bgType: 'color', bgValue: '#000000',
      bgEl: null,
    };
    case 'text': return { ...base,
      name: 'Text', duration: 5,
      text: 'Your text here',
      fontSize: 72, fontFamily: 'Arial', color: '#ffffff',
      align: 'center', animation: 'fadeIn',
      x: 0.5, y: 0.5,
    };
    case 'music': return { ...base,
      name: 'Music', musicId: MUSIC_LIST[0] || null,
      volume: 0.15, audioEl: null,
    };
    case 'voice': return { ...base,
      name: 'Voice Over', audioUrl: null,
      volume: 1.0, gain: 2.0, audioEl: null,
    };
    case 'caption': return { ...base,
      name: 'Captions',
      words: [],    // [{word, start, end}]
      fontSize: 64, captionY: 0.88,
      style: 'yellow',
    };
    default: return base;
  }
}

function addLayer(type) {
  const layer = defaultLayer(type);
  // Background always goes to bottom; others added on top
  if (type === 'background') {
    layers.unshift(layer);
  } else {
    layers.push(layer);
  }
  selectLayer(layer.id);
  renderLayerList();
  renderTimeline();
  drawFrame(playhead);
}

function removeLayer(id) {
  layers = layers.filter(l => l.id !== id);
  if (selectedId === id) { selectedId = null; renderProps(); }
  renderLayerList();
  renderTimeline();
  drawFrame(playhead);
}

function selectLayer(id) {
  selectedId = id;
  renderLayerList();
  renderProps();
}

function toggleVisibility(id, e) {
  e.stopPropagation();
  const l = layers.find(l => l.id === id);
  if (l) { l.visible = !l.visible; renderLayerList(); drawFrame(playhead); }
}

// Layer order helpers (bring up/send down handled by list order — bottom = rendered first)
function layerTypeIcon(type) {
  return { background:'🖼', text:'📝', music:'🎵', voice:'🎤', caption:'💬' }[type] || '▪';
}
function layerColor(type) {
  return { background:'#52525b', text:'#7c3aed', music:'#16a34a', voice:'#0891b2', caption:'#d97706' }[type] || '#52525b';
}

function renderLayerList() {
  const el = document.getElementById('layersList');
  if (!layers.length) {
    el.innerHTML = '<p style="font-size:12px;color:#52525b;text-align:center;padding:16px;">No layers yet.<br>Click + Add to begin.</p>';
    return;
  }
  // Render in reverse so top layer appears first in list
  el.innerHTML = [...layers].reverse().map(l => `
    <div class="layer-item ${l.id === selectedId ? 'selected' : ''} ${l.visible ? '' : 'hidden'}"
         onclick="selectLayer('${l.id}')">
      <span class="layer-icon">${layerTypeIcon(l.type)}</span>
      <span class="layer-name">${escH(l.name)}</span>
      <button class="layer-vis" onclick="toggleVisibility('${l.id}',event)" title="${l.visible ? 'Hide' : 'Show'}">
        ${l.visible ? '👁' : '🙈'}
      </button>
      ${l.type !== 'background' ? `<button class="layer-del" onclick="event.stopPropagation();removeLayer('${l.id}')" title="Delete">✕</button>` : ''}
    </div>`).join('');
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROPERTIES PANEL
// ═══════════════════════════════════════════════════════════════════════════════
function renderProps() {
  const panel = document.getElementById('propsPanel');
  if (!selectedId) {
    panel.innerHTML = '<p style="font-size:12px;color:#52525b;text-align:center;margin-top:20px;">Select a layer to edit its properties</p>';
    return;
  }
  const l = layers.find(l => l.id === selectedId);
  if (!l) return;

  switch (l.type) {
    case 'background': panel.innerHTML = propsBg(l); break;
    case 'text':       panel.innerHTML = propsText(l); break;
    case 'music':      panel.innerHTML = propsMusic(l); break;
    case 'voice':      panel.innerHTML = propsVoice(l); break;
    case 'caption':    panel.innerHTML = propsCaption(l); break;
  }
}

function propsBg(l) {
  return `
  <div class="prop-section">
    <span class="prop-label">Layer Name</span>
    <input class="prop-input" value="${escH(l.name)}" oninput="setProp('${l.id}','name',this.value)" />
  </div>
  <div class="prop-section">
    <span class="prop-label">Background Type</span>
    <div class="chip-row">
      <button class="chip ${l.bgType==='color'?'active':''}" onclick="setBgType('${l.id}','color')">Color</button>
      <button class="chip ${l.bgType==='image'?'active':''}" onclick="setBgType('${l.id}','image')">Image</button>
      <button class="chip ${l.bgType==='video'?'active':''}" onclick="setBgType('${l.id}','video')">Video</button>
    </div>
  </div>
  ${l.bgType === 'color' ? `
  <div class="prop-section">
    <span class="prop-label">Color</span>
    <input type="color" class="prop-color" value="${l.bgValue||'#000000'}" oninput="setProp('${l.id}','bgValue',this.value)" />
  </div>` : `
  <div class="prop-section">
    <span class="prop-label">Upload ${l.bgType === 'video' ? 'Video' : 'Image'}</span>
    <label style="display:block;border:1.5px dashed var(--border);border-radius:8px;padding:16px;text-align:center;cursor:pointer;color:#71717a;font-size:12px;" for="bgUpload_${l.id}">
      📁 Click to upload<br><small>${l.bgType==='video'?'MP4, WebM':'JPG, PNG, WebP'}</small>
    </label>
    <input type="file" id="bgUpload_${l.id}" style="display:none;" accept="${l.bgType==='video'?'video/*':'image/*'}" onchange="uploadLayerMedia('${l.id}',this,'bg')" />
    ${l.bgValue ? `<p style="font-size:11px;color:#4ade80;margin-top:6px;">✓ Media loaded</p>` : ''}
  </div>`}`;
}

function propsText(l) {
  return `
  <div class="prop-section">
    <span class="prop-label">Layer Name</span>
    <input class="prop-input" value="${escH(l.name)}" oninput="setProp('${l.id}','name',this.value)" />
  </div>
  <div class="prop-section">
    <span class="prop-label">Text Content</span>
    <textarea class="prop-input prop-textarea" oninput="setProp('${l.id}','text',this.value)">${escH(l.text||'')}</textarea>
  </div>
  <div class="prop-section">
    <span class="prop-label">Font Size: <b id="fs_${l.id}">${l.fontSize||72}</b>px</span>
    <input type="range" class="prop-range" min="24" max="200" value="${l.fontSize||72}"
      oninput="setProp('${l.id}','fontSize',+this.value);document.getElementById('fs_${l.id}').textContent=this.value" />
  </div>
  <div class="prop-section">
    <span class="prop-label">Font Style</span>
    <div class="chip-row">
      ${['Arial','Impact','Georgia','Courier New'].map(f => `<button class="chip ${l.fontFamily===f?'active':''}" style="font-family:'${f}'" onclick="setProp('${l.id}','fontFamily','${f}');renderProps()">${f==='Arial'?'Clean':f==='Impact'?'Bold':f==='Georgia'?'Serif':'Mono'}</button>`).join('')}
    </div>
  </div>
  <div class="prop-section">
    <span class="prop-label">Color</span>
    <input type="color" class="prop-color" value="${l.color||'#ffffff'}" oninput="setProp('${l.id}','color',this.value)" />
  </div>
  <div class="prop-section">
    <span class="prop-label">Alignment</span>
    <div class="chip-row">
      ${['left','center','right'].map(a => `<button class="chip ${l.align===a?'active':''}" onclick="setProp('${l.id}','align','${a}');renderProps()">${a==='left'?'☰ Left':a==='center'?'≡ Center':'☷ Right'}</button>`).join('')}
    </div>
  </div>
  <div class="prop-section">
