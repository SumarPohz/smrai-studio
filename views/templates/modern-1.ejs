<!-- MODERN-1: Two-column navy/yellow layout -->
<div class="modern-left">
  <div class="modern-avatar">
    <% if (data.profileImageUrl) { %>
      <img src="<%= data.profileImageUrl %>" alt="Profile" />
    <% } else { %>
      <div class="modern-avatar-placeholder">PHOTO</div>
    <% } %>
  </div>

  <div class="modern-name-block">
    <h2><%= data.fullName || "" %></h2>
    <p class="role"><%= data.roleTitle || "" %></p>
  </div>

  <div class="modern-sidebar-section">
    <h3>CONTACT</h3>
    <p><span>📞</span> <%= data.phone || "" %></p>
    <p><span>✉️</span> <%= data.email || "" %></p>
    <% if (data.location) { %>
      <p><span>📍</span> <%= data.location %></p>
    <% } %>
    <% if (data.linkedinUrl) { %>
      <p><span>🔗</span> <%= data.linkedinUrl.replace(/^https?:\/\//, '') %></p>
    <% } %>
  </div>

  <div class="modern-sidebar-section">
    <h3>EDUCATION</h3>
    <p><%= data.education || "" %></p>
  </div>

  <div class="modern-sidebar-section">
    <h3>LANGUAGES</h3>
    <p><%= data.languages || "" %></p>
  </div>

  <% const _mod_certLines = (data.certifications || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
  <% if (_mod_certLines.length) { %>
  <div class="modern-sidebar-section">
    <h3>CERTIFICATIONS</h3>
    <ul>
      <% _mod_certLines.forEach(function(c) { %><li><%= c %></li><% }); %>
    </ul>
  </div>
  <% } %>

  <% const _mod_achLines = (data.achievements || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
  <% if (_mod_achLines.length) { %>
  <div class="modern-sidebar-section">
    <h3>ACHIEVEMENTS</h3>
    <ul>
      <% _mod_achLines.forEach(function(a) { %><li><%= a %></li><% }); %>
    </ul>
  </div>
  <% } %>

  <% const _mod_awdLines = (data.awards || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
  <% if (_mod_awdLines.length) { %>
  <div class="modern-sidebar-section">
    <h3>AWARDS</h3>
    <ul>
      <% _mod_awdLines.forEach(function(a) { %><li><%= a %></li><% }); %>
    </ul>
  </div>
  <% } %>

  <% if (data.training) { %>
  <div class="modern-sidebar-section">
    <h3>TRAINING</h3>
    <p><%= data.training %></p>
  </div>
  <% } %>

  <% if (data.volunteering) { %>
  <div class="modern-sidebar-section">
    <h3>VOLUNTEERING</h3>
    <p><%= data.volunteering %></p>
  </div>
  <% } %>

  <% if (data.hobbies) { %>
  <div class="modern-sidebar-section">
    <h3>HOBBIES</h3>
    <p><%= data.hobbies %></p>
  </div>
  <% } %>

  <% const _mod_pubLines = (data.publications || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
  <% if (_mod_pubLines.length) { %>
  <div class="modern-sidebar-section">
    <h3>PUBLICATIONS</h3>
    <ul>
      <% _mod_pubLines.forEach(function(p) { %><li><%= p %></li><% }); %>
    </ul>
  </div>
  <% } %>
</div>

<div class="modern-right">
  <div class="modern-section-block">
    <h3>PROFESSIONAL SUMMARY</h3>
    <p><%= data.summary || "" %></p>
  </div>

  <div class="modern-section-block">
    <h3>EXPERIENCE</h3>

    <% if (experienceItems.length) { %>
      <% experienceItems.forEach(exp => { %>
        <div class="exp-entry">
          <div class="exp-heading">
            <span class="exp-title"><strong><%= exp.title %></strong><% if (exp.company) { %> <em class="exp-company"> · <%= exp.company %></em><% } %></span>
            <% if (exp.dates) { %><span class="exp-dates"><%= exp.dates %></span><% } %>
          </div>
          <% if (exp.description) { %><div class="exp-body"><%= exp.description %></div><% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p class="exp-text"><%= data.experience || "" %></p>
    <% } %>
  </div>

  <div class="modern-section-block">
    <h3>SKILLS</h3>
    <% if (skillsLines.length) { %>
      <ul>
        <% skillsLines.forEach(line => { %>
          <li><%= line %></li>
        <% }) %>
      </ul>
    <% } else { %>
      <p><%= data.skills || "" %></p>
    <% } %>
  </div>

  <% if (projectItems && projectItems.length) { %>
  <div class="modern-section-block">
    <h3>PROJECTS</h3>
    <% projectItems.forEach(function(proj) { %>
      <div class="exp-entry">
        <div class="exp-heading">
          <span class="exp-title"><strong><%= proj.name %></strong><% if (proj.link) { %> <em class="exp-company"> · <%= proj.link.replace(/^https?:\/\//, '') %></em><% } %></span>
          <% if (proj.tech) { %><span class="exp-dates"><%= proj.tech %></span><% } %>
        </div>
        <% if (proj.description && proj.description.length) { %><div class="exp-body"><%= proj.description.join(' ') %></div><% } %>
      </div>
    <% }); %>
  </div>
  <% } %>

  <% if (data.references) { %>
  <div class="modern-section-block">
    <h3>REFERENCES</h3>
    <p class="exp-text"><%= data.references %></p>
  </div>
  <% } %>
</div>
