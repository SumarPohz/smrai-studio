<!-- CLASSIC-BORDER: Bordered sections with blue accents -->
<div class="cb-inner">
  <div class="cb-header">
    <h2 class="cb-name"><%= data.fullName || "" %></h2>
    <p class="cb-role"><%= data.roleTitle || "" %></p>
    <div class="cb-contact">
      <span>📞 <%= data.phone || "" %></span>
      <span>✉️ <%= data.email || "" %></span>
      <% if (data.location)    { %><span>📍 <%= data.location %></span><% } %>
      <% if (data.linkedinUrl) { %><span>🔗 <%= data.linkedinUrl.replace(/^https?:\/\//, '') %></span><% } %>
    </div>
  </div>

  <div class="cb-divider"></div>

  <div class="cb-section">
    <h3>Professional Summary</h3>
    <p><%= data.summary || "" %></p>
  </div>

  <div class="cb-divider"></div>

  <div class="cb-section">
    <h3>Experience</h3>
    <% if (experienceItems.length) { %>
      <% experienceItems.forEach(exp => { %>
        <div class="exp-entry">
          <div class="cb-exp-header">
            <strong><%= exp.title %></strong><% if (exp.company) { %> <em class="exp-company"> · <%= exp.company %></em><% } %>
            <% if (exp.dates) { %><span class="exp-dates"><%= exp.dates %></span><% } %>
          </div>
          <% if (exp.description) { %><div class="exp-body"><%= exp.description %></div><% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p class="exp-text"><%= data.experience || "" %></p>
    <% } %>
  </div>

  <div class="cb-divider"></div>

  <div class="cb-two-col">
    <div class="cb-section">
      <h3>Education</h3>
      <p><%= data.education || "" %></p>
    </div>

    <div class="cb-section">
      <h3>Languages</h3>
      <p><%= data.languages || "" %></p>
    </div>
  </div>

  <div class="cb-divider"></div>

  <div class="cb-section">
    <h3>Skills</h3>
    <% if (skillsLines.length) { %>
      <div class="cb-skills">
        <% skillsLines.forEach(line => { %>
          <span class="cb-skill-tag"><%= line %></span>
        <% }) %>
      </div>
    <% } else { %>
      <p><%= data.skills || "" %></p>
    <% } %>
  </div>

  <% const _cb_certLines = (data.certifications || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
  <% if (_cb_certLines.length) { %>
  <div class="cb-divider"></div>
  <div class="cb-section">
    <h3>Certifications</h3>
    <div class="cb-skills">
      <% _cb_certLines.forEach(function(c) { %><span class="cb-skill-tag"><%= c %></span><% }); %>
    </div>
  </div>
  <% } %>

  <% if (projectItems && projectItems.length) { %>
  <div class="cb-divider"></div>
  <div class="cb-section">
    <h3>Projects</h3>
    <% projectItems.forEach(function(proj) { %>
      <div class="exp-entry">
        <div class="cb-exp-header">
          <strong><%= proj.name %></strong><% if (proj.link) { %> <em class="exp-company"> · <%= proj.link.replace(/^https?:\/\//, '') %></em><% } %>
          <% if (proj.tech) { %><span class="exp-dates"><%= proj.tech %></span><% } %>
        </div>
        <% if (proj.description && proj.description.length) { %><div class="exp-body"><%= proj.description.join(' ') %></div><% } %>
      </div>
    <% }); %>
  </div>
  <% } %>

  <% const _cb_achLines = (data.achievements || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
  <% if (_cb_achLines.length) { %>
  <div class="cb-divider"></div>
  <div class="cb-section">
    <h3>Achievements</h3>
    <ul>
      <% _cb_achLines.forEach(function(a) { %><li><%= a %></li><% }); %>
    </ul>
  </div>
  <% } %>

  <% const _cb_awdLines = (data.awards || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
  <% if (_cb_awdLines.length) { %>
  <div class="cb-divider"></div>
  <div class="cb-section">
    <h3>Awards</h3>
    <ul>
      <% _cb_awdLines.forEach(function(a) { %><li><%= a %></li><% }); %>
    </ul>
  </div>
  <% } %>

  <% if (data.training) { %>
  <div class="cb-divider"></div>
  <div class="cb-section">
    <h3>Training</h3>
    <p><%= data.training %></p>
  </div>
  <% } %>

  <% if (data.volunteering) { %>
  <div class="cb-divider"></div>
  <div class="cb-section">
    <h3>Volunteering</h3>
    <p><%= data.volunteering %></p>
  </div>
  <% } %>

  <% if (data.hobbies) { %>
  <div class="cb-divider"></div>
  <div class="cb-section">
    <h3>Hobbies &amp; Interests</h3>
    <p><%= data.hobbies %></p>
  </div>
  <% } %>

  <% const _cb_pubLines = (data.publications || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
  <% if (_cb_pubLines.length) { %>
  <div class="cb-divider"></div>
  <div class="cb-section">
    <h3>Publications</h3>
    <ul>
      <% _cb_pubLines.forEach(function(p) { %><li><%= p %></li><% }); %>
    </ul>
  </div>
  <% } %>

  <% if (data.references) { %>
  <div class="cb-divider"></div>
  <div class="cb-section">
    <h3>References</h3>
    <p><%= data.references %></p>
  </div>
  <% } %>
</div>
