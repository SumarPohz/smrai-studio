<!-- BOLD-SIDEBAR: top-strip | content-wrap (flex:1) | footer-strip -->

<!-- ── Top accent strip (same color as footer) ── -->
<div class="bs-top-strip"></div>

<!-- ── Content wrapper: grows to fill space, pushes footer to bottom ── -->
<div class="bs-content-wrap">

  <!-- ── Header: photo | name + role + 2×2 contact grid ── -->
  <div class="bs-header">
    <div class="bs-header-photo">
      <% if (data.profileImageUrl) { %>
        <img src="<%= data.profileImageUrl %>" alt="Profile" />
      <% } else { %>
        <div class="bs-avatar-placeholder">PHOTO</div>
      <% } %>
    </div>

    <div class="bs-header-info">
      <h1 class="bs-name"><%= data.fullName || "" %></h1>
      <p class="bs-role"><%= data.roleTitle || "" %></p>

      <div class="bs-contact-grid">
        <% if (data.phone)       { %><span class="bs-contact-item">📞 <%= data.phone %></span><% } %>
        <% if (data.email)       { %><span class="bs-contact-item">✉️ <%= data.email %></span><% } %>
        <% if (data.location)    { %><span class="bs-contact-item">📍 <%= data.location %></span><% } %>
        <% if (data.linkedinUrl) { %><span class="bs-contact-item">🔗 <%= data.linkedinUrl.replace(/^https?:\/\//, '') %></span><% } %>
      </div>
    </div>
  </div>

  <div class="bs-divider"></div>

  <!-- ── Full-width About Me ── -->
  <% if (data.summary) { %>
  <div class="bs-about">
    <h3>About Me</h3>
    <p><%= data.summary %></p>
  </div>
  <% } %>

  <!-- ── Two-column body: Education+Skills | Work Experience ── -->
  <div class="bs-body">

    <!-- Left: Education, Skills -->
    <div class="bs-left">

      <div class="bs-section">
        <h3>Education</h3>
        <p><%= data.education || "" %></p>
      </div>

      <div class="bs-section">
        <h3>Skills</h3>
        <% if (skillsLines.length) { %>
          <ul class="bs-skill-list">
            <% skillsLines.forEach(line => { %>
              <li><%= line %></li>
            <% }) %>
          </ul>
        <% } else { %>
          <p><%= data.skills || "" %></p>
        <% } %>
      </div>

      <% const _bs_certLines = (data.certifications || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
      <% if (_bs_certLines.length) { %>
      <div class="bs-section">
        <h3>Certifications</h3>
        <ul class="bs-skill-list">
          <% _bs_certLines.forEach(function(c) { %><li><%= c %></li><% }); %>
        </ul>
      </div>
      <% } %>

      <% const _bs_achLines = (data.achievements || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
      <% if (_bs_achLines.length) { %>
      <div class="bs-section">
        <h3>Achievements</h3>
        <ul class="bs-skill-list">
          <% _bs_achLines.forEach(function(a) { %><li><%= a %></li><% }); %>
        </ul>
      </div>
      <% } %>

      <% const _bs_awdLines = (data.awards || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
      <% if (_bs_awdLines.length) { %>
      <div class="bs-section">
        <h3>Awards</h3>
        <ul class="bs-skill-list">
          <% _bs_awdLines.forEach(function(a) { %><li><%= a %></li><% }); %>
        </ul>
      </div>
      <% } %>

    </div>

    <!-- Right: Work Experience — dates-left column per entry -->
    <div class="bs-right">
      <div class="bs-content-section">
        <h3>Work Experience</h3>

        <% if (experienceItems.length) { %>
          <% experienceItems.forEach(exp => { %>
            <div class="bs-exp-item">
              <div class="bs-exp-dates"><%= exp.dates || "" %></div>
              <div class="bs-exp-detail">
                <div class="bs-exp-title"><%= exp.title || "" %></div>
                <% if (exp.company) { %>
                  <div class="bs-exp-company"><%= exp.company %></div>
                <% } %>
                <% if (exp.description) { %>
                  <div class="bs-exp-desc"><%= exp.description %></div>
                <% } %>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p class="bs-fallback"><%= data.experience || "" %></p>
        <% } %>
      </div>

      <% if (projectItems && projectItems.length) { %>
      <div class="bs-content-section">
        <h3>Projects</h3>
        <% projectItems.forEach(function(proj) { %>
          <div class="bs-exp-item">
            <div class="bs-exp-dates"><%= proj.tech || "" %></div>
            <div class="bs-exp-detail">
              <div class="bs-exp-title"><%= proj.name %><% if (proj.link) { %> · <em><%= proj.link.replace(/^https?:\/\//, '') %></em><% } %></div>
              <% if (proj.description && proj.description.length) { %><div class="bs-exp-desc"><%= proj.description.join(' ') %></div><% } %>
            </div>
          </div>
        <% }); %>
      </div>
      <% } %>

      <% if (data.training) { %>
      <div class="bs-content-section">
        <h3>Training</h3>
        <p class="bs-fallback"><%= data.training %></p>
      </div>
      <% } %>

      <% if (data.volunteering) { %>
      <div class="bs-content-section">
        <h3>Volunteering</h3>
        <p class="bs-fallback"><%= data.volunteering %></p>
      </div>
      <% } %>
    </div>

  </div>

</div><!-- /.bs-content-wrap -->

<!-- ── Footer strip: Languages | References (always at bottom) ── -->
<div class="bs-footer">

  <!-- Languages (left) -->
  <div class="bs-footer-col">
    <h3>Languages</h3>
    <%
      const langLines = (data.languages || "")
        .split(/\r?\n/)
        .map(l => l.trim())
        .filter(l => l.length > 0);
    %>
    <% if (langLines.length) { %>
      <ul class="bs-lang-list">
        <% langLines.forEach(l => { %><li><%= l %></li><% }) %>
      </ul>
    <% } else { %>
      <p class="bs-footer-text"><%= data.languages || "" %></p>
    <% } %>
  </div>

  <!-- Hobbies & Publications (middle) -->
  <% if (data.hobbies || data.publications) { %>
  <div class="bs-footer-col">
    <% if (data.hobbies) { %>
      <h3>Hobbies</h3>
      <p class="bs-footer-text"><%= data.hobbies %></p>
    <% } %>
    <% const _bs_pubLines = (data.publications || "").split(/\r?\n+/).map(l => l.trim().replace(/^[-•*]\s*/, "")).filter(Boolean); %>
    <% if (_bs_pubLines.length) { %>
      <h3>Publications</h3>
      <ul class="bs-lang-list">
        <% _bs_pubLines.forEach(function(p) { %><li><%= p %></li><% }); %>
      </ul>
    <% } %>
  </div>
  <% } %>

  <!-- References (right) — hidden gracefully when empty -->
  <div class="bs-footer-col">
    <%
      const rawRefs = (data.references || "").trim();
      const refEntries = rawRefs
        ? rawRefs.split(/\n?---\n?|\n{2,}/).map(s => s.trim()).filter(Boolean).slice(0, 3)
        : [];
    %>
    <% if (refEntries.length) { %>
      <h3>Reference</h3>
      <div class="bs-ref-grid">
        <% refEntries.forEach(entry => { %>
          <%
            const refLines = entry.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
            const refName  = refLines[0] || "";
            const refInst  = refLines[1] || "";
            const refPhone = refLines[2] || "";
            const refWeb   = refLines[3] || "";
          %>
          <div class="bs-ref-entry">
            <div class="bs-ref-name"><%= refName %></div>
            <% if (refInst)  { %><div class="bs-ref-institution"><%= refInst %></div><% } %>
            <div class="bs-ref-contact">
              <% if (refPhone) { %><span>📞 <%= refPhone %></span><% } %>
              <% if (refWeb)   { %><span>🌐 <%= refWeb %></span><% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

</div>
