        <path fill="#4285F4" d="M1.22 0C.55.37.1 1.05.1 1.9v20.2c0 .85.45 1.53 1.12 1.9l.09.05 11.33-11.33v-.27L1.31-.05l-.09.05z"/>
        <path fill="#34A853" d="M16.14 16.14l-3.6-3.6v-.27l3.6-3.6.08.05 4.27 2.43c1.22.69 1.22 1.82 0 2.51l-4.27 2.43-.08.05z"/>
        <path fill="#FBBC05" d="M16.22 16.09L12.54 12.4 1.22 23.72c.4.43 1.07.48 1.82.05l13.18-7.68z"/>
