    <a href="https://play.google.com/store/apps/details?id=com.smrai.studio&pli=1"
       class="header-play-btn" target="_blank" rel="noopener noreferrer" title="Get it on Google Play">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" style="flex-shrink:0">
