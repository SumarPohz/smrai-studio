<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- ── Primary SEO ── -->
  <title>SmrAI-Studio – AI Resume Builder with Voice Input</title>
  <meta name="description"  content="Create professional resumes using AI voice input and smart suggestions. Download A4 JPG or PDF instantly. Perfect for students and job seekers in India.">
  <meta name="keywords"     content="AI resume builder, resume maker online, voice resume builder, professional CV builder, resume AI India">
  <meta name="author"       content="Sumar Pohsnem">
  <meta name="robots"       content="index, follow">
  <meta name="theme-color"  content="#0f172a">

  <!-- ── Canonical ── -->
  <link rel="canonical" href="https://smrai-studio.onrender.com/">

  <!-- ── Favicons ── -->
  <link rel="icon"             type="image/png" sizes="32x32" href="/images/favicon-32.png">
  <link rel="icon"             type="image/png" sizes="16x16" href="/images/favicon-16.png">
  <link rel="apple-touch-icon" sizes="180x180"                href="/images/apple-touch-icon.png">

  <!-- ── Open Graph (Facebook, WhatsApp, LinkedIn) ── -->
  <meta property="og:title"        content="<%= locals.ogTitle       || 'SmrAI-Studio – AI Resume Builder' %>">
  <meta property="og:description"  content="<%= locals.ogDescription || 'Create professional resumes with AI voice input and smart suggestions. Download A4 JPG or PDF instantly.' %>">
  <meta property="og:image"        content="<%= locals.ogImage       || 'https://smraistudio.sumarpohz.com/images/meta.png' %>">
  <meta property="og:image:width"  content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:url"          content="<%= locals.ogUrl         || 'https://smraistudio.sumarpohz.com/' %>">
  <meta property="og:type"         content="website">

  <!-- ── Twitter Card ── -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="<%= locals.ogTitle       || 'SmrAI-Studio – AI Resume Builder' %>">
  <meta name="twitter:description" content="<%= locals.ogDescription || 'AI-powered resume builder with voice input and smart content enhancement.' %>">
  <meta name="twitter:image"       content="<%= locals.ogImage       || 'https://smrai-studio.onrender.com/images/so-pre.jpeg' %>">

  <!-- ── Structured Data (JSON-LD) ── -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "SmrAI-Studio",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "AI-powered resume builder with voice input and smart content enhancement.",
    "url": "https://smrai-studio.onrender.com/"
  }
  </script>

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/templates.css" />
  <% if (locals.adsensePublisherId) { %>
  <meta name="google-adsense-account" content="<%= locals.adsensePublisherId %>">
  <% } %>
  <% if (locals.adsEnabled && locals.adsensePublisherId) { %>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=<%= locals.adsensePublisherId %>"
          crossorigin="anonymous"></script>
  <% } %>
  <% if (locals.facebookPixelId) { %>
  <script>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
    n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
    document,'script','https://connect.facebook.net/en_US/fbevents.js');
    fbq('init','<%= locals.facebookPixelId %>');
    fbq('track','PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=<%= locals.facebookPixelId %>&ev=PageView&noscript=1"/></noscript>
  <% } %>
  <% if (locals.googleTranslateEnabled) { %>
  <style>
    /* Hide default Google widget chrome, keep only our custom select */
    #google_translate_element { display:none !important; }
    .goog-te-banner-frame { display:none !important; }
    .skiptranslate iframe { display:none !important; }
    body { top: 0 !important; }
    /* Desktop translate button + dropdown */
    #gt-desktop-wrap {
      position: relative;
      display: flex;
      align-items: center;
    }
    #gt-desktop-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 8px;
      border: 1.5px solid #e2e8f0;
      background: #fff;
      cursor: pointer;
      padding: 0;
      transition: box-shadow 0.15s, border-color 0.15s;
    }
    #gt-desktop-btn:hover { border-color: #6366f1; box-shadow: 0 2px 8px rgba(99,102,241,0.15); }
    #gt-desktop-panel {
      display: none;
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      z-index: 9999;
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      box-shadow: 0 8px 28px rgba(0,0,0,0.14);
      padding: 8px;
      width: 200px;
      max-height: 300px;
      overflow-y: auto;
      flex-wrap: wrap;
      gap: 5px;
    }
    #gt-desktop-panel.open { display: flex; }
    #gt-desktop-panel button {
      background: #f1f5f9;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      padding: 4px 8px;
      font-size: 0.78rem;
      cursor: pointer;
      color: #1e293b;
      transition: background 0.12s;
      white-space: nowrap;
    }
    #gt-desktop-panel button:hover { background: #dbeafe; color: #1d4ed8; }
    @media (max-width: 768px) {
      #gt-desktop-wrap { display: none; }
    }
    /* Mobile fixed translate button */
    #gt-mobile-btn {
      display: none;
    }
    @media (max-width: 768px) {
      #gt-mobile-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        position: fixed;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        z-index: 9999;
        width: 36px;
        height: 36px;
        background: #fff;
        border-radius: 8px 0 0 8px;
        box-shadow: -2px 2px 8px rgba(0,0,0,0.18);
        cursor: pointer;
        border: none;
        padding: 0;
      }
      #gt-mobile-btn svg { width: 20px; height: 20px; }
      /* Mobile dropdown panel */
      #gt-mobile-panel {
        display: none;
        position: fixed;
        right: 36px;
        top: 50%;
        transform: translateY(-50%);
        z-index: 9998;
        background: #fff;
        border-radius: 8px 0 0 8px;
        box-shadow: -3px 2px 12px rgba(0,0,0,0.18);
        padding: 0.4rem 0;
        min-width: 150px;
        max-height: 60vh;
        overflow-y: auto;
      }
      #gt-mobile-panel.open { display: block; }
      #gt-mobile-panel button {
        display: block;
        width: 100%;
        padding: 0.5rem 1rem;
        background: none;
        border: none;
        text-align: left;
        font-size: 0.82rem;
        color: #374151;
        cursor: pointer;
        white-space: nowrap;
      }
      #gt-mobile-panel button:hover { background: #f3f4f6; }
    }
  </style>
  <% } %>
</head>
