<%- include("partials/header") %>

<style>
.tp-page { min-height: 100vh; background: #e2e5ea; position: relative; overflow: hidden; padding: 80px 20px 60px; font-family: 'Segoe UI', system-ui, sans-serif; }

/* ── Animated BG ── */
.contact-bg { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
.contact-bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); animation: orbFloat 8s ease-in-out infinite; }
.contact-bg-orb:nth-child(1) { width: 500px; height: 500px; background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%); top: -100px; left: -100px; }
.contact-bg-orb:nth-child(2) { width: 400px; height: 400px; background: radial-gradient(circle, rgba(168,85,247,0.14) 0%, transparent 70%); top: 30%; right: -80px; animation-delay: -3s; }
.contact-bg-orb:nth-child(3) { width: 350px; height: 350px; background: radial-gradient(circle, rgba(236,72,153,0.1) 0%, transparent 70%); bottom: -50px; left: 30%; animation-delay: -5s; }
.contact-bg-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(99,102,241,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,0.05) 1px, transparent 1px); background-size: 50px 50px; }
@keyframes orbFloat { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-30px) scale(1.05)} }

.tp-wrapper { max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }

/* ── Header ── */
.tp-header { text-align: center; margin-bottom: 40px; }
.tp-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.25); border-radius: 50px; padding: 6px 16px; font-size: 13px; color: #4f46e5; margin-bottom: 20px; }
.tp-header h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; color: #111827; margin: 0 0 12px; line-height: 1.1; }
.tp-header p { color: #4b5563; font-size: 0.95rem; }

/* ── Tab Nav ── */
.tp-tabs { display: flex; gap: 8px; margin-bottom: 24px; background: #1e2030; border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 6px; width: fit-content; }
.tp-tab { padding: 8px 22px; border-radius: 10px; font-size: 0.88rem; font-weight: 600; cursor: pointer; color: #64748b; border: none; background: transparent; transition: all 0.25s; }
.tp-tab.active { background: linear-gradient(135deg, #6366f1, #a855f7); color: #fff; box-shadow: 0 4px 12px rgba(99,102,241,0.3); }

/* ── Content Panel ── */
.tp-panel { display: none; }
.tp-panel.active { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media(max-width:768px){ .tp-panel.active { grid-template-columns: 1fr 1fr; gap: 6px; align-items: start; } }

/* ── Section Card ── */
.tp-card { background: #1e2030; border: 1px solid rgba(255,255,255,0.08); border-radius: 18px; padding: 22px 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.15); transition: all 0.3s; }
.tp-card:hover { background: #252840; border-color: rgba(99,102,241,0.3); transform: translateY(-2px); }
.tp-card h3 { font-size: 0.98rem; font-weight: 700; color: #f1f5f9; margin: 0 0 12px; display: flex; align-items: center; gap: 8px; }
.tp-card h3 .sec-icon { font-size: 16px; }
.tp-card p { color: #94a3b8; font-size: 0.87rem; line-height: 1.75; margin: 0 0 8px; }
.tp-card p:last-child { margin: 0; }
.tp-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 4px; }
.tp-list li { display: flex; align-items: flex-start; gap: 8px; color: #94a3b8; font-size: 0.83rem; line-height: 1.5; padding: 5px 8px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 7px; }
.tp-list li::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #6366f1; flex-shrink: 0; margin-top: 5px; }

/* ── Contact strip ── */
.tp-contact { background: #1e2030; border: 1px solid rgba(99,102,241,0.2); border-radius: 16px; padding: 18px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-top: 16px; }
.tp-contact p { color: #94a3b8; font-size: 0.87rem; margin: 0; }
.tp-contact a { color: #818cf8; text-decoration: none; font-weight: 600; }
.tp-contact a:hover { color: #a5b4fc; }

@media(max-width:768px){
  .tp-page { padding: 20px 8px 12px; }
  .tp-header { margin-bottom: 10px; }
  .tp-header h1 { font-size: 1.3rem; margin-bottom: 4px; }
  .tp-header p { font-size: 0.75rem; margin: 0; }
  .tp-badge { font-size: 11px; padding: 3px 10px; margin-bottom: 8px; }
  .tp-tabs { width: 100%; margin-bottom: 10px; padding: 4px; }
  .tp-tab { flex: 1; text-align: center; padding: 5px 4px; font-size: 0.76rem; }
  .tp-panel.active { gap: 6px; }
  .tp-card { padding: 6px 8px; border-radius: 8px; align-self: start; height: auto; }
  .tp-card h3 { font-size: 0.7rem; margin-bottom: 3px; gap: 4px; }
  .tp-card h3 .sec-icon { font-size: 11px; }
  .tp-card p { font-size: 0.66rem; line-height: 1.4; margin-bottom: 0; }
  .tp-list { gap: 1px !important; }
  .tp-list li { font-size: 0.64rem !important; gap: 3px !important; padding: 1px 4px !important; line-height: 1.25 !important; align-items: center !important; white-space: normal; }
  .tp-list li::before { width: 3px; height: 3px; margin-top: 0; flex-shrink: 0; }
  .tp-contact { padding: 8px 10px; margin-top: 8px; }
  .tp-contact p, .tp-contact a { font-size: 0.76rem; }
}
</style>

<!-- Animated Background -->
<div class="contact-bg">
  <div class="contact-bg-grid"></div>
  <div class="contact-bg-orb"></div>
  <div class="contact-bg-orb"></div>
  <div class="contact-bg-orb"></div>
</div>

