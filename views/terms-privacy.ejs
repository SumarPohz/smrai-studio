      <p>Questions about our terms or privacy policy?</p>
      <a href="mailto:tech@sumarpohz.com">tech@sumarpohz.com</a>
    </div>

  </div>
</div>

<script>
function switchTab(tab) {
  document.querySelectorAll('.tp-tab').forEach((t, i) => t.classList.toggle('active', (i === 0 && tab === 'privacy') || (i === 1 && tab === 'terms')));
  document.getElementById('panel-privacy').classList.toggle('active', tab === 'privacy');
  document.getElementById('panel-terms').classList.toggle('active', tab === 'terms');
}
</script>

