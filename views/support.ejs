<%- include("partials/header") %>

<style>
/* ── Reset & Base ── */
.contact-page { min-height: 100vh; background: #e2e5ea; position: relative; overflow: hidden; padding: 80px 20px 60px; font-family: 'Segoe UI', system-ui, sans-serif; }

/* ── Animated BG ── */
.contact-bg { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
.contact-bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); animation: orbFloat 8s ease-in-out infinite; }
.contact-bg-orb:nth-child(1) { width: 500px; height: 500px; background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%); top: -100px; left: -100px; animation-delay: 0s; }
.contact-bg-orb:nth-child(2) { width: 400px; height: 400px; background: radial-gradient(circle, rgba(168,85,247,0.14) 0%, transparent 70%); top: 30%; right: -80px; animation-delay: -3s; }
.contact-bg-orb:nth-child(3) { width: 350px; height: 350px; background: radial-gradient(circle, rgba(236,72,153,0.1) 0%, transparent 70%); bottom: -50px; left: 30%; animation-delay: -5s; }
.contact-bg-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(99,102,241,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,0.05) 1px, transparent 1px); background-size: 50px 50px; }
@keyframes orbFloat { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-30px) scale(1.05)} }

/* ── Layout ── */
.contact-wrapper { max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }

/* ── Header ── */
.contact-header { text-align: center; margin-bottom: 40px; }
.contact-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.25); border-radius: 50px; padding: 6px 16px; font-size: 13px; color: #4f46e5; margin-bottom: 20px; }
.contact-header h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; color: #111827; margin: 0 0 16px; line-height: 1.1; }
.contact-header p { color: #4b5563; font-size: 1.1rem; max-width: 500px; margin: 0 auto; }

/* ── Grid ── */
.contact-grid { display: grid; grid-template-columns: 1fr 1.6fr; gap: 32px; align-items: stretch; }
.contact-grid > * { align-self: stretch; }
@media(max-width:768px){ .contact-grid { grid-template-columns: 1fr; } }

/* ── Info Cards ── */
.contact-info { display: flex; flex-direction: column; gap: 16px; margin-top: 0; }
.info-cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.info-card { background: #1e2030; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 16px; display: flex; align-items: flex-start; gap: 12px; transition: all 0.3s; box-shadow: 0 2px 12px rgba(0,0,0,0.15); }
.info-card:hover { background: #252840; border-color: rgba(99,102,241,0.4); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(99,102,241,0.15); }
.info-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
.info-icon.purple { background: rgba(99,102,241,0.2); }
.info-icon.pink { background: rgba(236,72,153,0.2); }
.info-icon.blue { background: rgba(59,130,246,0.2); }
.info-icon.green { background: rgba(34,197,94,0.2); }
.info-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #64748b; margin-bottom: 3px; }
.info-value { color: #e2e8f0; font-size: 0.85rem; font-weight: 500; line-height: 1.3; }
.info-sub { color: #64748b; font-size: 0.75rem; margin-top: 2px; }
@media(max-width:768px){
  .contact-page { padding: 50px 12px 30px; }
  .contact-header { margin-bottom: 20px; }
  .contact-info { gap: 8px; }
  .info-cards-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
  .info-card { padding: 8px; gap: 6px; border-radius: 10px; }
  .info-icon { width: 24px; height: 24px; font-size: 11px; border-radius: 7px; }
  .info-label { font-size: 8px; }
  .info-value { font-size: 0.72rem; }
  .info-sub { font-size: 0.65rem; }
  .social-strip { padding: 10px 12px; }
  .social-strip h4 { margin-bottom: 6px; font-size: 10px; }
  .faq-list { gap: 4px; }
  .faq-item { padding: 4px 8px; font-size: 11px; }
  .faq-dot { width: 4px; height: 4px; }
  .form-card { padding: 14px; border-radius: 14px; }
  .form-card h2 { font-size: 1rem; margin: 0 0 2px; }
  .form-card > p { font-size: 0.75rem; margin-bottom: 8px; line-height: 1.3; }
  .form-row { grid-template-columns: 1fr 1fr; gap: 8px; }
  .form-group { margin-bottom: 6px; }
  .form-group label { margin-bottom: 3px; font-size: 10px; letter-spacing: 0.5px; }
  .form-group input, .form-group select { padding: 7px 10px; font-size: 0.83rem; border-radius: 8px; line-height: 1.2; }
  .form-group textarea { padding: 7px 10px; font-size: 0.83rem; border-radius: 8px; min-height: 70px; max-height: 70px; resize: none; }
  .btn-send { padding: 9px; font-size: 0.85rem; border-radius: 9px; margin-top: 2px; }
}
@media(max-width:400px){ .info-cards-grid { grid-template-columns: 1fr 1fr; } }

/* ── Common Issues Strip ── */
.social-strip { background: #1e2030; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 14px 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.15); }
.social-strip h4 { color: #94a3b8; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 8px; }
.faq-list { display: flex; flex-direction: column; gap: 5px; }
.faq-item { display: flex; align-items: center; gap: 8px; padding: 6px 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.04); color: #94a3b8; font-size: 12px; }
.faq-dot { width: 6px; height: 6px; border-radius: 50%; background: #6366f1; flex-shrink: 0; }

/* ── Form Card ── */
.form-card { background: #1e2030; border: 1px solid rgba(255,255,255,0.08); border-radius: 24px; padding: 28px; box-shadow: 0 4px 24px rgba(0,0,0,0.15); margin-top: 0; }
.form-card h2 { font-size: 1.3rem; font-weight: 700; color: #f1f5f9; margin: 0 0 4px; }
.form-card p { color: #64748b; font-size: 0.85rem; margin: 0 0 16px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
@media(max-width:500px){ .form-row { grid-template-columns: 1fr 1fr; gap: 8px; } }

.form-group { margin-bottom: 12px; }
.form-group label { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.8px; color: #64748b; margin-bottom: 6px; font-weight: 600; }
.form-group input,
.form-group select,
.form-group textarea { width: 100%; background: #151622; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 10px 14px; color: #f1f5f9; font-size: 0.9rem; outline: none; transition: all 0.25s; box-sizing: border-box; font-family: inherit; }
.form-group input::placeholder,
.form-group textarea::placeholder { color: #475569; }
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { border-color: rgba(99,102,241,0.6); background: rgba(99,102,241,0.06); box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
.form-group select option { background: #1e1e2e; color: #f1f5f9; }
.form-group textarea { resize: vertical; min-height: 80px; }

/* ── Submit Button ── */
.btn-send { width: 100%; padding: 14px 24px; border: none; border-radius: 12px; background: linear-gradient(135deg, #6366f1, #a855f7); color: #fff; font-size: 1rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; transition: all 0.3s; position: relative; overflow: hidden; letter-spacing: 0.3px; }
.btn-send::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, #818cf8, #c084fc); opacity: 0; transition: opacity 0.3s; }
.btn-send:hover::before { opacity: 1; }
.btn-send:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(99,102,241,0.4); }
.btn-send:active { transform: translateY(0); }
.btn-send span, .btn-send svg { position: relative; z-index: 1; }
.btn-send.loading { pointer-events: none; opacity: 0.8; }

/* ── Toast ── */
.contact-toast { position: fixed; bottom: 30px; right: 30px; z-index: 9999; padding: 14px 22px; border-radius: 14px; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 10px; transform: translateY(100px); opacity: 0; transition: all 0.4s cubic-bezier(0.34,1.56,0.64,1); max-width: 340px; box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
.contact-toast.show { transform: translateY(0); opacity: 1; }
.contact-toast.success { background: linear-gradient(135deg, #059669, #10b981); color: #fff; }
.contact-toast.error { background: linear-gradient(135deg, #dc2626, #ef4444); color: #fff; }

/* ── Flash Messages ── */
.contact-flash { padding: 14px 20px; border-radius: 12px; margin-bottom: 20px; font-size: 0.9rem; display: flex; align-items: center; gap: 10px; }
.contact-flash.success { background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3); color: #6ee7b7; }
.contact-flash.error { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
</style>

<!-- Animated Background -->
<div class="contact-bg">
  <div class="contact-bg-grid"></div>
  <div class="contact-bg-orb"></div>
  <div class="contact-bg-orb"></div>
  <div class="contact-bg-orb"></div>
</div>

<div class="contact-page">
  <div class="contact-wrapper">

    <!-- Header -->
    <div class="contact-header">
      <div class="contact-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Support Center
      </div>
      <h1>How can we<br>help you?</h1>
      <p>Having trouble? Our support team is ready to assist you promptly.</p>
    </div>

    <!-- Grid -->
    <div class="contact-grid">

      <!-- Left: Info -->
      <div class="contact-info">

        <div class="info-cards-grid">
          <div class="info-card">
            <div class="info-icon purple">📧</div>
            <div>
              <div class="info-label">Support Email</div>
              <div class="info-value">tech@sumarpohz.com</div>
              <div class="info-sub">Reply within 24h</div>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon blue">⚡</div>
            <div>
              <div class="info-label">Response Time</div>
              <div class="info-value">Within 24–48h</div>
              <div class="info-sub">Business days only</div>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon green">🕐</div>
            <div>
              <div class="info-label">Support Hours</div>
              <div class="info-value">Mon – Fri 10AM–6PM</div>
              <div class="info-sub">IST</div>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon pink">🟢</div>
            <div>
              <div class="info-label">Status</div>
              <div class="info-value">All systems normal</div>
              <div class="info-sub">No active incidents</div>
            </div>
          </div>
        </div>

        <div class="social-strip">
          <h4>Common Issues</h4>
          <div class="faq-list">
            <div class="faq-item"><span class="faq-dot"></span>Login or password problems</div>
            <div class="faq-item"><span class="faq-dot"></span>Payment or download issues</div>
            <div class="faq-item"><span class="faq-dot"></span>Resume not saving or loading</div>
            <div class="faq-item"><span class="faq-dot"></span>Account access problems</div>
            <div class="faq-item"><span class="faq-dot"></span>Template rendering issues</div>
          </div>
        </div>

      </div>

      <!-- Right: Form -->
      <div class="form-card">
        <h2>Submit a support ticket</h2>
        <p>Describe your issue and we'll get back to you as quickly as possible.</p>

        <% if (locals.contactSuccess) { %>
          <div class="contact-flash success">✅ Ticket submitted! We'll reply within 24–48 hours.</div>
        <% } %>
        <% if (locals.contactError) { %>
          <div class="contact-flash error">❌ <%= locals.contactError %></div>
        <% } %>

        <form id="supportForm" action="/support" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label>Your Name</label>
              <input type="text" name="name" placeholder="John Doe" required value="<%= locals.user ? locals.user.name || '' : '' %>">
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" name="email" placeholder="john@example.com" required value="<%= locals.user ? locals.user.email || '' : '' %>">
            </div>
          </div>

          <div class="form-group">
            <label>Issue Type</label>
            <select name="subject">
              <option value="Login Issue">Login Issue</option>
              <option value="Payment Problem">Payment Problem</option>
              <option value="Resume Not Saving">Resume Not Saving</option>
              <option value="Download Issue">Download Issue</option>
              <option value="Account Access">Account Access</option>
              <option value="Bug Report">Bug Report</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label>Describe Your Issue</label>
            <textarea name="message" placeholder="Please describe the problem in detail..." required></textarea>
          </div>

          <button type="submit" class="btn-send" id="sendBtn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            <span>Submit Ticket</span>
          </button>
        </form>
      </div>

    </div>
  </div>
</div>

<!-- Toast -->
<div class="contact-toast" id="contactToast"></div>

<script>
(function(){
  <% if (locals.contactSuccess) { %>
    showContactToast("Ticket submitted! We'll reply within 24\u201348 hours.", 'success');
  <% } else if (locals.contactError) { %>
    showContactToast('<%= locals.contactError %>', 'error');
  <% } %>

  function showContactToast(msg, type) {
    const t = document.getElementById('contactToast');
    t.textContent = (type === 'success' ? '✅ ' : '❌ ') + msg;
    t.className = 'contact-toast ' + type + ' show';
    setTimeout(() => t.classList.remove('show'), 4000);
  }

  document.getElementById('supportForm').addEventListener('submit', function(){
    const btn = document.getElementById('sendBtn');
    btn.classList.add('loading');
    btn.querySelector('span').textContent = 'Submitting...';
  });
})();
</script>

<%- include("partials/footer") %>
