<%- include('../partials/header') %>

<style>
  :root {
    --ds-bg: #f5f6fa;
    --ds-white: #ffffff;
    --ds-border: #e0e3ea;
    --ds-blue: #1a2b6b;
    --ds-blue-light: #eef2ff;
    --ds-orange: #f97316;
    --ds-green: #16a34a;
    --ds-red: #dc2626;
    --ds-muted: #64748b;
    --ds-radius: 10px;
  }

  body { background: var(--ds-bg) !important; }

  .ds-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 24px 20px 48px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* ── Two-column grid ── */
  .ds-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 20px;
    align-items: start;
  }
  @media (max-width: 768px) {
    .ds-layout { grid-template-columns: 1fr; }
    .ds-sidebar { display: none; }
  }

  /* ── Section card ── */
  .ds-card {
    background: var(--ds-white);
    border-radius: var(--ds-radius);
    padding: 20px 24px;
    box-shadow: 0 1px 6px rgba(26,43,107,0.07);
    margin-bottom: 16px;
  }
  .ds-card-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--ds-blue);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ── Service type tabs ── */
  .ds-type-tabs {
    display: flex;
    gap: 0;
    border: 1.5px solid var(--ds-border);
    border-radius: 8px;
    overflow: hidden;
    width: fit-content;
  }
  .ds-type-tab {
    padding: 9px 24px;
    font-size: 14px;
    font-weight: 600;
    color: var(--ds-muted);
    cursor: pointer;
    border: none;
    background: transparent;
    transition: all 0.18s;
  }
  .ds-type-tab.active {
    background: var(--ds-blue);
    color: #fff;
  }
  .ds-type-tab:not(.active):hover { background: var(--ds-blue-light); color: var(--ds-blue); }

  /* ── Operator grid ── */
  .ds-op-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 16px;
  }
  .ds-op-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 14px 20px;
    border: 2px solid var(--ds-border);
    border-radius: var(--ds-radius);
    cursor: pointer;
    background: #fff;
    transition: all 0.18s;
    min-width: 100px;
  }
  .ds-op-card:hover { border-color: var(--ds-blue); background: var(--ds-blue-light); }
  .ds-op-card.selected { border-color: var(--ds-blue); background: var(--ds-blue-light); }
  .ds-op-logo {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 900;
    color: #fff;
    letter-spacing: -1px;
  }
  .ds-op-name { font-size: 12px; font-weight: 600; color: #334155; }

  /* ── Operator brand colors ── */
  .op-jio    { background: #1a2b6b; }
  .op-airtel { background: #e8001d; }
  .op-vi     { background: #9b1fe8; }
  .op-bsnl   { background: #1e7e34; }
  .op-tata   { background: #e07020; }
  .op-dish   { background: #0077b6; }
  .op-adth   { background: #e8001d; }
  .op-sun    { background: #f39c12; }
  .op-vd2h   { background: #2980b9; }

  /* ── Mobile top bar (back arrow) ── */
  .ds-mobile-topbar {
    display: none;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, #1e4db7 0%, #2563eb 100%);
    padding: 12px 14px;
    color: #fff;
  }
  .ds-mobile-back {
    background: rgba(255,255,255,0.18);
    border: none; color: #fff;
    font-size: 18px;
    width: 34px; height: 34px;
    border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    padding: 0; flex-shrink: 0;
  }
  .ds-mobile-topbar-title { font-size: 16px; font-weight: 700; }
  @media (max-width: 768px) { .ds-mobile-topbar { display: flex; } }

  /* ── Selected operator badge ── */
  .ds-op-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--ds-blue);
    flex-shrink: 0;
  }
  .ds-op-badge .badge-logo {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 900;
    color: #fff;
  }

  /* ── Form fields ── */
  .ds-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
    margin-top: 4px;
  }
  @media (max-width: 640px) { .ds-form-row { grid-template-columns: 1fr; } }
  .ds-field label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--ds-muted);
    margin-bottom: 6px;
  }
  .ds-input, .ds-select {
    width: 100%;
    padding: 10px 12px;
    border: 1.5px solid var(--ds-border);
    border-radius: 8px;
    font-size: 14px;
    color: #1e293b;
    background: #f8fafc;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.18s;
    -webkit-appearance: none;
  }
  .ds-input:focus, .ds-select:focus { border-color: var(--ds-blue); background: #fff; }
  .ds-select-wrap { position: relative; }
  .ds-select-wrap::after {
    content: '▾';
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    pointer-events: none;
  }
  .ds-input.error { border-color: var(--ds-red); }

  /* ── Plans section ── */
  .ds-plans-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 14px;
  }
  .ds-plans-title { font-size: 14px; font-weight: 700; color: #334155; }
  .ds-search-bar {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--ds-border);
    border-radius: 8px;
    overflow: hidden;
    background: #f8fafc;
  }
  .ds-search-input {
    border: none;
    padding: 8px 12px;
    font-size: 13px;
    background: transparent;
    outline: none;
    width: 160px;
    color: #1e293b;
  }
  .ds-search-icon { padding: 0 10px; color: #94a3b8; font-size: 14px; }

  /* Category tabs */
  .ds-cat-tabs {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 2px;
    margin-bottom: 12px;
  }
  .ds-cat-tabs::-webkit-scrollbar { display: none; }
  .ds-cat-tab {
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    border: 1.5px solid var(--ds-border);
    background: #fff;
    color: var(--ds-muted);
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .ds-cat-tab.active {
    background: var(--ds-blue);
    color: #fff;
    border-color: var(--ds-blue);
  }

  /* Filter chips */
  .ds-chips {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .ds-chip {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    border: 1.5px solid #e2e8f0;
    background: #f8fafc;
    color: #475569;
    transition: all 0.15s;
  }
  .ds-chip.active {
    background: var(--ds-blue-light);
    border-color: var(--ds-blue);
    color: var(--ds-blue);
  }

  /* Plan grid */
  .ds-plan-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 640px) { .ds-plan-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 400px) { .ds-plan-grid { grid-template-columns: 1fr; } }

  .ds-plan-card {
    border: 1.5px solid var(--ds-border);
    border-radius: var(--ds-radius);
    padding: 14px;
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s;
    background: #fff;
  }
  .ds-plan-card:hover { border-color: var(--ds-blue); box-shadow: 0 2px 10px rgba(26,43,107,0.10); }
  .ds-plan-amt { font-size: 22px; font-weight: 800; color: var(--ds-blue); margin-bottom: 4px; }
  .ds-plan-validity { font-size: 12px; color: var(--ds-muted); margin-bottom: 4px; }
  .ds-plan-desc { font-size: 12px; color: #475569; margin-bottom: 6px; line-height: 1.5; }
  .ds-plan-subs { font-size: 10.5px; color: #f97316; font-weight: 600; margin-bottom: 10px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ds-plan-btn {
    width: 100%;
    padding: 8px;
    border: 1.5px solid var(--ds-blue);
    border-radius: 8px;
    background: transparent;
    color: var(--ds-blue);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .ds-plan-btn:hover { background: var(--ds-blue); color: #fff; }

  .ds-no-plans {
    text-align: center;
    padding: 32px;
    color: var(--ds-muted);
    font-size: 14px;
  }

  /* ── Sidebar ── */
  .ds-sidebar-card {
    background: var(--ds-white);
    border-radius: var(--ds-radius);
    overflow: hidden;
    box-shadow: 0 1px 6px rgba(26,43,107,0.07);
  }
  .ds-sidebar-header {
    background: var(--ds-blue);
    color: #fff;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .ds-biller-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid #f1f5f9;
    cursor: pointer;
    transition: background 0.15s;
  }
  .ds-biller-item:hover { background: #f8fafc; }
  .ds-biller-item.active { background: #fff7ed; border-left: 3px solid var(--ds-orange); }
  .ds-biller-item:last-child { border-bottom: none; }
  .ds-biller-logo {
    width: 36px; height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 900;
    color: #fff;
    flex-shrink: 0;
  }
  .ds-biller-name { font-size: 13px; font-weight: 600; color: #334155; }

  /* ── Modals ── */
  .ds-modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 500;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .ds-modal-backdrop.open { display: flex; }
  .ds-modal {
    background: #fff;
    border-radius: 14px;
    padding: 28px;
    max-width: 440px;
    width: 100%;
    position: relative;
    box-shadow: 0 8px 40px rgba(0,0,0,0.18);
  }
  .ds-modal-close {
    position: absolute;
    top: 14px; right: 16px;
    background: none; border: none;
    font-size: 20px; cursor: pointer; color: #94a3b8;
    line-height: 1;
  }
  .ds-modal-close:hover { color: #1e293b; }
  .ds-modal-title { font-size: 18px; font-weight: 800; color: var(--ds-blue); margin-bottom: 16px; }

  /* Plan breakdown modal */
  .bk-amount { font-size: 32px; font-weight: 800; color: var(--ds-blue); margin-bottom: 8px; }
  .bk-details-title { font-size: 13px; font-weight: 700; color: #64748b; margin: 14px 0 8px; }
  .bk-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .bk-table td { padding: 8px 12px; border: 1px solid var(--ds-border); }
  .bk-table td:first-child { color: var(--ds-muted); font-weight: 600; width: 40%; background: #f8fafc; }
  .bk-table td:last-child { color: #1e293b; font-weight: 600; }
  .bk-btn {
    width: 100%;
    margin-top: 20px;
    padding: 13px;
    background: var(--ds-blue);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .bk-btn:hover { opacity: 0.9; }

  /* PIN modal */
  .pm-sub { font-size: 13px; color: var(--ds-muted); margin-bottom: 20px; }
  .pm-otp-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 8px;
  }
  .pm-otp-box {
    width: 56px; height: 56px;
    border: 2px solid var(--ds-border);
    border-radius: 10px;
    font-size: 24px;
    font-weight: 700;
    text-align: center;
    outline: none;
    transition: border-color 0.18s, box-shadow 0.18s;
    background: #f8fafc;
    -webkit-text-security: disc;
  }
  .pm-otp-box:focus { border-color: var(--ds-blue); background: #fff; box-shadow: 0 0 0 3px rgba(26,43,107,0.12); }
  .pm-otp-box.filled { border-color: var(--ds-blue); background: var(--ds-blue-light); }
  .pm-error { color: var(--ds-red); font-size: 13px; text-align: center; min-height: 18px; margin: 8px 0; }
  .pm-set-link { text-align: center; font-size: 12px; margin-top: 8px; }
  .pm-set-link a { color: var(--ds-blue); font-weight: 600; }
  .pm-btn-row { display: flex; gap: 10px; margin-top: 16px; }
  .pm-btn {
    flex: 1; padding: 12px;
    border-radius: 10px;
    font-size: 14px; font-weight: 700;
    cursor: pointer; border: none;
    transition: opacity 0.2s;
  }
  .pm-btn.confirm { background: var(--ds-blue); color: #fff; }
  .pm-btn.confirm:disabled { opacity: 0.45; cursor: not-allowed; }
  .pm-btn.cancel { background: #f1f5f9; color: #475569; }
  .pm-btn.cancel:hover { background: #e2e8f0; }

  /* ── No PIN Modal ── */
  .no-pin-modal { text-align: center; padding: 2rem 1.5rem; }
  .no-pin-icon { font-size: 3rem; margin-bottom: 0.5rem; }
  .no-pin-body {
    font-size: 0.88rem; color: #475569; line-height: 1.6;
    margin: 0.75rem auto 1.5rem; max-width: 280px;
  }
  .no-pin-cta-btn {
    display: block; width: 100%; padding: 0.78rem;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff; font-weight: 700; font-size: 1rem;
    border-radius: 12px; text-decoration: none;
    margin-bottom: 0.65rem; transition: opacity 0.2s;
    box-sizing: border-box;
  }
  .no-pin-cta-btn:hover { opacity: 0.88; }
  .no-pin-cancel { width: 100%; margin-top: 0; background: #f1f5f9; color: #64748b; font-size: 0.85rem; }

  /* ── Spinner ── */
  .ds-spinner-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(255,255,255,0.55); z-index: 600;
    align-items: center; justify-content: center;
  }
  .ds-spinner-overlay.show { display: flex; }
  .ds-spinner {
    width: 44px; height: 44px;
    border: 4px solid #e2e8f0; border-top-color: var(--ds-blue);
    border-radius: 50%; animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Recharge Status Modal ── */
  .rcg-overlay {
    position: fixed; inset: 0;
    background: rgba(15,23,42,0.5);
    display: flex; align-items: center; justify-content: center;
    z-index: 900; opacity: 0; pointer-events: none;
    transition: opacity 0.25s;
  }
  .rcg-overlay.show { opacity: 1; pointer-events: all; }
  .rcg-card {
    background: #fff; border-radius: 20px;
    padding: 36px 28px 24px; width: min(400px, 92vw);
    text-align: center;
    box-shadow: 0 24px 64px rgba(0,0,0,0.18);
    transform: translateY(28px) scale(0.95);
    transition: transform 0.35s cubic-bezier(0.34,1.5,0.64,1);
  }
  .rcg-overlay.show .rcg-card { transform: translateY(0) scale(1); }
  .rcg-icon-wrap {
    width: 76px; height: 76px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 18px;
  }
  .rcg-icon-wrap.success { background: #dcfce7; }
  .rcg-icon-wrap.pending { background: #fef3c7; }
  .rcg-icon-wrap.failed  { background: #fee2e2; }
  @keyframes rcg-draw { to { stroke-dashoffset: 0; } }
  @keyframes rcg-spin  { to { transform: rotate(360deg); } }
  .rcg-anim-check { stroke-dasharray: 56; stroke-dashoffset: 56; animation: rcg-draw 0.45s 0.15s ease forwards; }
  .rcg-anim-spin  { transform-origin: center; animation: rcg-spin 1.4s linear infinite; }
  .rcg-title {
    font-size: 20px; font-weight: 700; margin-bottom: 6px; line-height: 1.3;
  }
  .rcg-title.success { color: #15803d; }
  .rcg-title.pending { color: #92400e; }
  .rcg-title.failed  { color: #b91c1c; }
  .rcg-subtitle {
    font-size: 14px; color: var(--ds-muted); margin-bottom: 18px; line-height: 1.55;
  }
  .rcg-pills {
    display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin-bottom: 18px;
  }
  .rcg-pill {
    background: #f1f5f9; border-radius: 100px;
    padding: 5px 13px; font-size: 13px; color: #334155; font-weight: 500;
  }
  .rcg-refund {
    background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px;
    padding: 10px 14px; font-size: 13px; color: #166534;
    display: flex; align-items: center; gap: 8px; margin-bottom: 18px;
    text-align: left;
  }
  .rcg-progress { height: 3px; background: #e2e8f0; border-radius: 3px; margin-bottom: 20px; overflow: hidden; }
  .rcg-progress-bar { height: 100%; border-radius: 3px; width: 100%; }
  .rcg-progress-bar.success { background: var(--ds-green); }
  .rcg-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 4px; }
  .rcg-btn {
    flex: 1; min-width: 120px; padding: 12px 10px; border-radius: 10px;
    font-size: 14px; font-weight: 600; cursor: pointer; border: none;
    transition: opacity 0.18s, transform 0.18s;
  }
  .rcg-btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .rcg-btn.primary   { flex: 0 0 100%; background: var(--ds-blue); color: #fff; }
  .rcg-btn.secondary { background: #f1f5f9; color: #334155; }
  /* keep small toast for non-recharge alerts */
  .ds-toast {
    position: fixed; bottom: 28px; left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: #1e293b; color: #fff;
    padding: 11px 20px; border-radius: 10px;
    font-size: 14px; font-weight: 500;
    z-index: 700; opacity: 0; transition: all 0.3s;
    white-space: nowrap; max-width: 90vw; text-align: center;
  }
  .ds-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  .ds-toast.success { background: var(--ds-green); }
  .ds-toast.error { background: var(--ds-red); }

  @keyframes shake {
    0%,100% { transform: translateX(0); }
    20%,60%  { transform: translateX(-7px); }
    40%,80%  { transform: translateX(7px); }
  }
  .shake { animation: shake 0.35s ease; }

  /* ── DTH amount card button ── */
  .ds-btn-recharge {
    width: 100%;
    padding: 12px;
    background: var(--ds-blue);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .ds-btn-recharge:disabled { opacity: 0.4; cursor: not-allowed; }
  .ds-btn-recharge:not(:disabled):hover { opacity: 0.88; }
  .ds-amount-prefix-wrap { position: relative; }
  .ds-amount-prefix { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); font-weight: 700; color: #64748b; pointer-events: none; }
  .ds-amount-prefix-wrap .ds-input { padding-left: 26px; }

  /* ── Wallet strip ── */
  .ds-wallet-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--ds-blue-light);
    border: 1px solid #c7d2fe;
    border-radius: 8px;
    padding: 10px 16px;
    margin-bottom: 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ds-blue);
  }

  /* ── Mobile overrides ── */
  @media (max-width: 768px) {
    .ds-page { padding: 10px 10px 60px; }

    /* Wallet strip */
    .ds-wallet-strip { padding: 7px 12px; font-size: 11px; margin-bottom: 10px; border-radius: 6px; }

    /* Cards */
    .ds-card { padding: 12px 14px; margin-bottom: 10px; border-radius: 8px; }
    .ds-card-title { font-size: 13px; margin-bottom: 10px; }

    /* Service type tabs */
    .ds-type-tabs { width: 100%; }
    .ds-type-tab { padding: 7px 0; font-size: 12px; flex: 1; text-align: center; }

    /* Operator grid — 5 per row on mobile (fits Jio/Airtel/Vi/BSNL/BSNL Special) */
    .ds-op-grid { gap: 6px; margin-top: 10px; }
    .ds-op-card { padding: 8px 4px; min-width: 0; flex: 1 1 calc(20% - 6px); gap: 3px; border-radius: 8px; }
    .ds-op-logo { width: 36px; height: 36px; font-size: 13px; }
    .ds-op-name { font-size: 10px; }

    /* Form */
    .ds-field label { font-size: 11px; margin-bottom: 4px; }
    .ds-input, .ds-select { padding: 8px 10px; font-size: 13px; }

    /* Plans */
    .ds-plans-header { gap: 6px; margin-bottom: 8px; }
    .ds-plans-title { font-size: 12px; }
    .ds-search-input { width: 120px; font-size: 12px; padding: 6px 8px; }
    .ds-cat-tab { padding: 5px 12px; font-size: 11px; }
    .ds-chip { padding: 3px 9px; font-size: 11px; }
    .ds-chips { gap: 5px; margin-bottom: 10px; }
    .ds-plan-grid { gap: 8px; }
    .ds-plan-card { padding: 10px; }
    .ds-plan-amt { font-size: 17px; margin-bottom: 2px; }
    .ds-plan-validity { font-size: 11px; margin-bottom: 2px; }
    .ds-plan-desc { font-size: 11px; margin-bottom: 8px; line-height: 1.4; }
    .ds-plan-btn { padding: 6px; font-size: 11px; }
  }
  @media (max-width: 768px) {
    .header-fixed-wrap { display: none !important; }
    footer             { display: none !important; }
    main               { padding-top: 0 !important; }
    .refer-float, .whatsapp-float, .gc-float { display: none !important; }
  }

  /* ── Receipt Modal ── */
  .rcpt-overlay {
    position: fixed; inset: 0;
    background: rgba(15,23,42,0.6);
    display: flex; align-items: center; justify-content: center;
    z-index: 950; opacity: 0; pointer-events: none;
    transition: opacity 0.25s;
  }
  .rcpt-overlay.show { opacity: 1; pointer-events: all; }
  .rcpt-card {
    background: #fff;
    width: min(480px, 96vw);
    max-height: 90vh;
    overflow-y: auto;
    border-radius: 12px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.2);
    transform: translateY(24px) scale(0.97);
    transition: transform 0.3s cubic-bezier(0.34,1.5,0.64,1);
  }
  .rcpt-overlay.show .rcpt-card { transform: translateY(0) scale(1); }
  .rcpt-body { padding: 24px 24px 16px; }
  .rcpt-header {
    display: flex; align-items: center; justify-content: space-between;
    padding-bottom: 16px; border-bottom: 2px solid #e2e8f0; margin-bottom: 16px;
  }
  .rcpt-logo { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .rcpt-logo img { height: 44px; width: auto; object-fit: contain; }
  .rcpt-logo-name { font-size: 10px; font-weight: 800; color: #1e4db7; letter-spacing: 0.5px; }
  .rcpt-title-wrap { text-align: center; flex: 1; padding: 0 12px; }
  .rcpt-title { font-size: 13px; font-weight: 700; color: #1e293b; line-height: 1.4; }
  .rcpt-brand {
    background: linear-gradient(135deg, #1e4db7, #2563eb);
    color: #fff; border-radius: 8px; padding: 7px 10px;
    text-align: center; min-width: 68px;
  }
  .rcpt-brand-name { font-size: 11px; font-weight: 800; letter-spacing: 0.5px; }
  .rcpt-brand-sub  { font-size: 9px; opacity: 0.85; margin-top: 2px; }
  .rcpt-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
  .rcpt-table td { border: 1px solid #cbd5e1; padding: 9px 12px; font-size: 13px; vertical-align: top; }
  .rcpt-table td:first-child { color: #64748b; font-weight: 500; width: 40%; }
  .rcpt-table td:last-child  { color: #0f172a; font-weight: 600; word-break: break-all; }
  .rcpt-status-ok { color: #16a34a; font-weight: 700; }
  .rcpt-note {
    font-size: 11px; color: #64748b; text-align: center;
    border-top: 1px solid #e2e8f0; padding-top: 12px; line-height: 1.6;
  }
  .rcpt-actions {
    display: flex; gap: 10px; padding: 14px 24px 18px;
  }
  .rcpt-btn {
    flex: 1; padding: 11px 8px; border-radius: 10px; border: none;
    font-size: 13px; font-weight: 600; cursor: pointer; transition: opacity 0.15s;
  }
  .rcpt-btn:hover { opacity: 0.85; }
  .rcpt-btn.primary   { background: var(--ds-blue); color: #fff; }
  .rcpt-btn.secondary { background: #f1f5f9; color: #334155; }
  .rcpt-btn.close-btn { background: #fee2e2; color: #991b1b; }
  @media print {
    body * { visibility: hidden !important; }
    .rcpt-card, .rcpt-card * { visibility: visible !important; }
    .rcpt-card {
      position: fixed !important; top: 0 !important; left: 0 !important;
      width: 100% !important; max-height: none !important;
      box-shadow: none !important; border-radius: 0 !important;
      transform: none !important;
    }
    .rcpt-actions { display: none !important; }
  }
</style>

