<script>
  const HAS_WALLET_PIN = <%- JSON.stringify(hasPin) %>;
  const OPERATORS = {
    mobile: [
      { id: 'Jio',           label: 'Jio',          cls: 'op-jio',    abbr: 'JIO' },
      { id: 'Airtel',        label: 'Airtel',        cls: 'op-airtel', abbr: 'AIR' },
      { id: 'Vi (Vodafone)', label: 'Vi',            cls: 'op-vi',     abbr: 'Vi'  },
      { id: 'BSNL',          label: 'BSNL',          cls: 'op-bsnl',   abbr: 'BSN' },
      { id: 'BSNL Special',  label: 'BSNL Special',  cls: 'op-bsnl',   abbr: 'BSN' },
    ],
    dth: [
      { id: 'Tata Play',    label: 'Tata Play',     cls: 'op-tata',   abbr: 'TP'  },
      { id: 'Dish TV',      label: 'Dish TV',        cls: 'op-dish',   abbr: 'DTH' },
      { id: 'Airtel DTH',   label: 'Airtel DTH',    cls: 'op-adth',   abbr: 'AIR' },
      { id: 'Sun Direct',   label: 'Sun Direct',    cls: 'op-sun',    abbr: 'SUN' },
      { id: 'Videocon D2H', label: 'Videocon D2H',  cls: 'op-vd2h',   abbr: 'D2H' },
    ],
  };

  let currentType = 'mobile';
  let selectedOp = null;
  let allPlans = [];
  let filteredPlans = [];
  let currentCat = 'all';
  let currentChip = 'all';
  let pendingPlan = null;

  document.addEventListener('DOMContentLoaded', () => {
    const urlType = new URLSearchParams(location.search).get('type') || 'mobile';
    setType(urlType, false);
    loadBalance();
  });

  /* ── Type toggle ── */
  function setType(t, resetForm = true) {
    currentType = t;
    selectedOp = null;
    document.getElementById('tab-mobile').classList.toggle('active', t === 'mobile');
    document.getElementById('tab-dth').classList.toggle('active', t === 'dth');
    document.getElementById('sidebar-title').textContent = t === 'mobile' ? 'Telecom Billers' : 'DTH Billers';
    renderOpGrid();
    renderSidebar();
    if (resetForm) {
      hideForm(); hidePlans(); hideDthCard();
    }
  }

  /* ── Operator grid ── */
  function renderOpGrid() {
    const grid = document.getElementById('op-grid');
    grid.innerHTML = OPERATORS[currentType].map(op => `
      <div class="ds-op-card${selectedOp && selectedOp.id === op.id ? ' selected' : ''}"
           onclick="selectOp(${JSON.stringify(op).replace(/"/g, '&quot;')})">
        <div class="ds-op-logo ${op.cls}">${op.abbr}</div>
        <div class="ds-op-name">${op.label}</div>
      </div>`).join('');
  }

  function selectOp(op) {
    selectedOp = op;
    renderOpGrid();
    renderSidebar();
    showForm();
    hidePlans();
    hideDthCard();
    document.getElementById('num-input').value = '';
    document.getElementById('confirm-input').value = '';
    document.getElementById('dth-amount-input').value = '';
    document.getElementById('num-error').style.display = 'none';
    allPlans = []; filteredPlans = [];
    // Jio plans are All India — no region selection needed
    const regionField = document.getElementById('region-field');
    if (regionField) {
      const isJio = op.id === 'Jio';
      regionField.style.display = isJio ? 'none' : '';
      if (isJio) document.getElementById('region-select').value = '';
    }
  }

  /* ── Sidebar ── */
  function renderSidebar() {
    const list = document.getElementById('sidebar-list');
    list.innerHTML = OPERATORS[currentType].map(op => `
      <div class="ds-biller-item${selectedOp && selectedOp.id === op.id ? ' active' : ''}"
           onclick="selectOp(${JSON.stringify(op).replace(/"/g, '&quot;')})">
        <div class="ds-biller-logo ${op.cls}">${op.abbr}</div>
        <div class="ds-biller-name">${op.label}</div>
      </div>`).join('');
  }

  /* ── Form ── */
  function showForm() {
    const card = document.getElementById('form-card');
    card.style.display = 'block';
    const isMobile = currentType === 'mobile';
    document.getElementById('form-title').textContent = isMobile ? 'Mobile Prepaid Recharge' : 'DTH Prepaid Recharge';
    document.getElementById('num-label').textContent = isMobile ? 'Mobile Number' : 'Subscriber ID';
    document.getElementById('confirm-label').textContent = isMobile ? 'Confirm Mobile Number' : 'Confirm Subscriber ID';
    document.getElementById('num-input').placeholder = isMobile ? 'e.g. 9876543210' : 'e.g. 1234567890';
    document.getElementById('confirm-input').placeholder = isMobile ? 'e.g. 9876543210' : 'e.g. 1234567890';
    // Badge
    document.getElementById('op-badge').innerHTML = `
      <div class="badge-logo ${selectedOp.cls}">${selectedOp.abbr}</div>
      <span>${selectedOp.label}</span>`;
  }
  function hideForm() { document.getElementById('form-card').style.display = 'none'; }

  /* ── Number validation → fetch plans ── */
  function onNumberInput() {
    const n = document.getElementById('num-input').value.trim();
    const c = document.getElementById('confirm-input').value.trim();
    validate(n, c);
  }
  function onConfirmInput() {
    const n = document.getElementById('num-input').value.trim();
    const c = document.getElementById('confirm-input').value.trim();
    validate(n, c);
  }
  function validate(n, c) {
    const errEl = document.getElementById('num-error');
    if (c && n !== c) { errEl.style.display = 'block'; hidePlans(); hideDthCard(); return; }
    errEl.style.display = 'none';
    if (n.length >= 6 && c === n) {
      if (currentType === 'mobile') { hideDthCard(); fetchPlans(); }
      else { hidePlans(); showDthAmountCard(); }
    } else {
      hidePlans(); hideDthCard();
    }
  }

  async function fetchPlans() {
    if (!selectedOp) return;
    showSpinner(true);
    try {
      const r = await fetch(`/api/recharge/plans?type=${currentType}&operator=${encodeURIComponent(selectedOp.id)}`);
      const d = await r.json();
      showSpinner(false);
      if (d.success && d.plans.length) {
        allPlans = d.plans;
        currentCat = 'all'; currentChip = 'all';
        resetFilters();
        applyFilters();
        showPlans();
      } else {
        hidePlans();
      }
    } catch { showSpinner(false); hidePlans(); }
  }

  function showPlans() { document.getElementById('plans-card').style.display = 'block'; }
  function hidePlans() { document.getElementById('plans-card').style.display = 'none'; }
  function showDthAmountCard() {
    document.getElementById('dth-amount-card').style.display = 'block';
    document.getElementById('dth-amount-input').value = '';
    document.getElementById('dth-recharge-btn').disabled = true;
    setTimeout(() => document.getElementById('dth-amount-input').focus(), 100);
  }
  function hideDthCard() { document.getElementById('dth-amount-card').style.display = 'none'; }
  let _dthMin = 200, _dthMax = 50000;
  async function loadDthLimits() {
    try {
      const d = await fetch('/api/recharge/dth-limits').then(r => r.json());
      if (d.success) {
        _dthMin = d.min; _dthMax = d.max;
        const inp = document.getElementById('dth-amount-input');
        inp.min = _dthMin; inp.max = _dthMax;
        document.getElementById('dth-amount-hint').textContent =
          `Min ₹${_dthMin.toLocaleString('en-IN')} · Max ₹${_dthMax.toLocaleString('en-IN')}`;
      }
    } catch(e) {}
  }
  loadDthLimits();

  function onDthAmountInput() {
    const v = parseFloat(document.getElementById('dth-amount-input').value);
    document.getElementById('dth-recharge-btn').disabled = !(v >= _dthMin && v <= _dthMax);
  }
  function openDthPinModal() {
    const amt = parseFloat(document.getElementById('dth-amount-input').value);
    if (!amt || amt < _dthMin) return;
    pendingPlan = { amount: amt, validity: '—', description: `${selectedOp.label} DTH Recharge` };
    openPinModal();
  }

  /* ── Category & chip filters ── */
  function setCat(cat) {
    currentCat = cat;
    document.querySelectorAll('.ds-cat-tab').forEach(t => t.classList.toggle('active', t.dataset.cat === cat));
    applyFilters();
  }
  function setChip(chip) {
    currentChip = chip;
    document.querySelectorAll('.ds-chip').forEach(c => c.classList.toggle('active', c.dataset.filter === chip));
    applyFilters();
  }
  function resetFilters() {
    document.querySelectorAll('.ds-cat-tab').forEach(t => t.classList.toggle('active', t.dataset.cat === 'all'));
    document.querySelectorAll('.ds-chip').forEach(c => c.classList.toggle('active', c.dataset.filter === 'all'));
  }

  function applyFilters() {
    const search = (document.getElementById('plan-search').value || '').toLowerCase();
    let plans = allPlans.filter(p => {
      // Category
      const desc = (p.description || '').toLowerCase();
      const val = (p.validity || '').toLowerCase();
      const cat = (p.category || '').toLowerCase();
      if (currentCat === 'data'  && cat !== 'data'  && !desc.includes('gb')   && !desc.includes('data'))  return false;
      if (currentCat === 'voice' && cat !== 'voice' && !desc.includes('call')  && !desc.includes('voice')) return false;
      if (currentCat === 'long'  && cat !== 'long'  && !val.includes('90')     && !val.includes('365')
                                                     && !val.includes('year')   && !val.includes('annual')) return false;
      // Chip
      const amt = parseFloat(p.amount);
      if (currentChip === 'u199'    && amt > 199) return false;
      if (currentChip === '200-499' && (amt < 200 || amt > 499)) return false;
      if (currentChip === 'o500'    && amt < 500) return false;
      if (currentChip === '28d' && !val.includes('28')) return false;
      if (currentChip === '84d' && !val.includes('84') && !val.includes('90')) return false;
      if (currentChip === '365d' && !val.includes('365') && !val.includes('year') && !val.includes('annual')) return false;
      // Search — numeric input matches exact amount only; text matches description/validity
      if (search) {
        if (/^\d+$/.test(search)) {
          if (String(p.amount) !== search) return false;
        } else {
          if (!desc.includes(search) && !val.includes(search)) return false;
        }
      }
      return true;
    });
    filteredPlans = plans;
    renderPlans(plans);
  }

  function filterPlans() { applyFilters(); }

  function renderPlans(plans) {
    const grid = document.getElementById('plan-grid');
    if (!plans.length) {
      grid.innerHTML = '<div class="ds-no-plans">No plans found for this filter.</div>';
      return;
    }
    grid.innerHTML = plans.map((p, i) => {
      const subs = p.subscriptions?.length
        ? `<div class="ds-plan-subs">📺 ${p.subscriptions.slice(0, 3).join(' · ')}</div>`
        : '';
      return `
      <div class="ds-plan-card">
        <div class="ds-plan-amt">₹ ${p.amount}</div>
        <div class="ds-plan-validity">Validity: ${p.validity}</div>
        <div class="ds-plan-desc">${p.description}</div>
        ${subs}
        <button class="ds-plan-btn" onclick="openBkModal(${i})">Recharge</button>
      </div>`;
    }).join('');
  }

  /* ── Plan Breakdown Modal ── */
  function openBkModal(idx) {
    pendingPlan = filteredPlans[idx];
    document.getElementById('bk-amount').textContent = '₹ ' + pendingPlan.amount;
    document.getElementById('bk-desc').textContent = pendingPlan.description;
    const rows = [
      ['Amount',   '₹ ' + pendingPlan.amount],
      ['Validity', pendingPlan.validity],
      ['Details',  pendingPlan.description],
    ];
    document.getElementById('bk-table').innerHTML = rows.map(([k,v]) =>
      `<tr><td>${k}</td><td>${v}</td></tr>`).join('');
    document.getElementById('bk-modal').classList.add('open');
  }
  function closeBkModal() { document.getElementById('bk-modal').classList.remove('open'); }

  /* ── PIN Modal ── */
  function openPinModal() {
    closeBkModal();
    if (!HAS_WALLET_PIN) {
      document.getElementById('no-pin-modal').classList.add('open');
      return;
    }
    clearPinInputs();
    document.getElementById('pm-error').textContent = '';
    document.getElementById('pm-set-link').style.display = 'none';
    document.getElementById('pin-modal').classList.add('open');
    setTimeout(() => document.querySelector('#pm-row .pm-otp-box').focus(), 100);
  }
  function closeNoPinModal() {
    document.getElementById('no-pin-modal').classList.remove('open');
  }
  function closePinModal() {
    document.getElementById('pin-modal').classList.remove('open');
    clearPinInputs();
  }
  function clearPinInputs() {
    document.querySelectorAll('#pm-row .pm-otp-box').forEach(b => {
      b.value = ''; b.classList.remove('filled');
    });
    document.getElementById('pm-confirm-btn').disabled = true;
  }

  // OTP box wiring
  document.addEventListener('DOMContentLoaded', () => {
    const boxes = document.querySelectorAll('#pm-row .pm-otp-box');
    boxes.forEach((box, i) => {
      box.addEventListener('input', e => {
        const v = e.target.value.replace(/\D/g, '');
        e.target.value = v.slice(-1);
        e.target.classList.toggle('filled', !!e.target.value);
        if (v && i < boxes.length - 1) boxes[i + 1].focus();
        const pin = Array.from(boxes).map(b => b.value).join('');
        document.getElementById('pm-confirm-btn').disabled = pin.length < 4;
      });
      box.addEventListener('keydown', e => {
        if (e.key === 'Backspace' && !box.value && i > 0) {
          boxes[i - 1].value = '';
          boxes[i - 1].classList.remove('filled');
          boxes[i - 1].focus();
          document.getElementById('pm-confirm-btn').disabled = true;
        }
      });
    });
  });

  async function confirmPin() {
    const boxes = document.querySelectorAll('#pm-row .pm-otp-box');
    const pin = Array.from(boxes).map(b => b.value).join('');
    if (pin.length < 4) return;
    document.getElementById('pm-confirm-btn').disabled = true;
    document.getElementById('pm-error').textContent = '';
    showSpinner(true);
    try {
      const r = await fetch('/api/user/pin/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pin })
      });
      const d = await r.json();
      showSpinner(false);
      if (d.success) {
        closePinModal();
        doRecharge();
      } else if (d.message === 'no_pin') {
        document.getElementById('pm-error').textContent = "No PIN set. Please generate one first.";
        document.getElementById('pm-set-link').style.display = 'block';
        document.getElementById('pm-confirm-btn').disabled = false;
      } else {
        document.getElementById('pm-error').textContent = d.message || 'Incorrect PIN.';
        document.getElementById('pm-row').classList.add('shake');
        setTimeout(() => document.getElementById('pm-row').classList.remove('shake'), 400);
        clearPinInputs();
      }
    } catch {
      showSpinner(false);
      document.getElementById('pm-error').textContent = 'Network error. Try again.';
      document.getElementById('pm-confirm-btn').disabled = false;
    }
  }

  /* ── Execute Recharge ── */
  async function doRecharge() {
    const mobile = document.getElementById('num-input').value.trim();
    if (!mobile || !selectedOp || !pendingPlan) return;
    showSpinner(true);
    try {
      const r = await fetch('/api/recharge', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mobile, operator: selectedOp.id, amount: pendingPlan.amount, type: currentType })
      });
      const d = await r.json();
      showSpinner(false);
      if (d.success) {
        updateBalance(d.balance);
        if (d.pending) {
          showRcgModal({
            type: 'pending',
            title: 'Recharge Processing',
            subtitle: 'Your recharge is being processed. This usually completes within a few minutes.',
            pills: [`₹${pendingPlan.amount}`, selectedOp.label, `Ref: ${d.ref}`],
            actions: [
              { label: 'View History', cls: 'secondary', fn: "window.location='/paysetu/history'" },
              { label: 'Done', cls: 'primary', fn: 'hideRcgModal()' }
            ]
          });
        } else {
          window._lastReceipt = {
            amount:   pendingPlan.amount,
            operator: selectedOp.label,
            mobile:   document.getElementById('num-input').value,
            type:     currentType === 'dth' ? 'DTH' : 'Mobile',
            ref:      d.ref,
            date:     new Date().toLocaleString('en-IN', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })
          };
          showRcgModal({
            type: 'success',
            title: 'Recharge Successful!',
            subtitle: `Your ${selectedOp.label} number has been recharged.`,
            pills: [`₹${pendingPlan.amount}`, selectedOp.label, `Ref: ${d.ref}`],
            autoDismiss: 6000,
            actions: [
              { label: '↗ Share Receipt', cls: 'secondary', fn: 'shareReceipt()' },
              { label: '📋 History',      cls: 'secondary', fn: "window.location='/paysetu/history'" },
              { label: 'Done',            cls: 'primary',   fn: 'hideRcgModal()' }
            ]
          });
        }
        pendingPlan = null;
      } else {
        showRcgModal({
          type: 'failed',
          title: 'Recharge Failed',
          subtitle: d.message || 'Something went wrong at the provider. Please try again.',
          pills: [`₹${pendingPlan?.amount}`, selectedOp?.label].filter(Boolean),
          showRefund: true,
          actions: [
            { label: 'Try Again', cls: 'secondary', fn: 'hideRcgModal()' },
            { label: 'View History', cls: 'primary', fn: "window.location='/paysetu/history'" }
          ]
        });
      }
    } catch { showSpinner(false); showToast('Network error. Try again.', 'error'); }
  }

  /* ── Helpers ── */
  let _walletCap = 0;
  async function loadBalance() {
    try {
      const d = await fetch('/api/wallet/balance').then(r => r.json());
      if (d.balance !== undefined) {
        _walletCap = d.cap || 0;
        updateBalance(d.balance);
      }
    } catch {}
  }
  function updateBalance(bal) {
    const usable = Math.max(0, bal - _walletCap);
    document.getElementById('ds-bal').textContent = '₹' + usable.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    let hint = document.getElementById('ds-bal-hint');
    if (_walletCap > 0) {
      if (!hint) {
        hint = document.createElement('span');
        hint.id = 'ds-bal-hint';
        hint.style.cssText = 'font-size:10px;color:#94a3b8;margin-left:6px';
        document.getElementById('ds-bal').after(hint);
      }
      hint.textContent = `(₹${_walletCap} reserved)`;
    } else if (hint) {
      hint.textContent = '';
    }
  }
  function showSpinner(v) { document.getElementById('spinner').classList.toggle('show', v); }
  function showToast(msg, type = '') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'ds-toast show' + (type ? ' ' + type : '');
    setTimeout(() => t.classList.remove('show'), 4000);
  }

  /* ── Recharge Status Modal ── */
  const _RCG_ICONS = {
    success: `<svg width="38" height="38" viewBox="0 0 52 52" fill="none">
      <circle cx="26" cy="26" r="24" stroke="#16a34a" stroke-width="2.5" fill="none"/>
      <polyline class="rcg-anim-check" points="15,27 23,35 37,18" fill="none" stroke="#16a34a" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    pending: `<svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <path class="rcg-anim-spin" d="M12 6v6l4 2"/>
    </svg>`,
    failed: `<svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round">
      <circle cx="12" cy="12" r="10"/>
      <line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
    </svg>`
  };
  let _rcgTimer = null;

  function showRcgModal({ type, title, subtitle, pills = [], showRefund = false, autoDismiss = 0, actions = [] }) {
    document.getElementById('rcgIconWrap').className = 'rcg-icon-wrap ' + type;
    document.getElementById('rcgIconWrap').innerHTML = _RCG_ICONS[type] || '';
    const titleEl = document.getElementById('rcgTitle');
    titleEl.className = 'rcg-title ' + type;
    titleEl.textContent = title;
    document.getElementById('rcgSubtitle').textContent = subtitle;
    document.getElementById('rcgPills').innerHTML = pills.map(p => `<span class="rcg-pill">${p}</span>`).join('');
    document.getElementById('rcgRefund').style.display = showRefund ? 'flex' : 'none';
    const prog = document.getElementById('rcgProgress');
    const bar  = document.getElementById('rcgProgressBar');
    if (_rcgTimer) { clearTimeout(_rcgTimer); _rcgTimer = null; }
    if (autoDismiss > 0) {
      prog.style.display = 'block';
      bar.className = 'rcg-progress-bar ' + type;
      bar.style.transition = 'none'; bar.style.width = '100%';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        bar.style.transition = `width ${autoDismiss}ms linear`; bar.style.width = '0%';
      }));
      _rcgTimer = setTimeout(hideRcgModal, autoDismiss);
    } else { prog.style.display = 'none'; }
    document.getElementById('rcgActions').innerHTML = actions.map(a =>
      `<button class="rcg-btn ${a.cls}" onclick="${a.fn}">${a.label}</button>`
    ).join('');
    document.getElementById('rcgOverlay').classList.add('show');
  }
  function hideRcgModal() {
    document.getElementById('rcgOverlay').classList.remove('show');
    if (_rcgTimer) { clearTimeout(_rcgTimer); _rcgTimer = null; }
  }

  function shareReceipt() {
    const r = window._lastReceipt;
    if (!r) return;
    document.getElementById('rcptTable').innerHTML = [
      ['Operator',         r.operator],
      ['Service No',       r.mobile],
      ['Type',             r.type],
      ['Amount (₹)',       Number(r.amount).toFixed(2)],
      ['Reference No',     r.ref],
      ['Status',           '<span class="rcpt-status-ok">SUCCESS</span>'],
      ['Transaction Date', r.date],
    ].map(([k, v]) => `<tr><td>${k}</td><td>${v}</td></tr>`).join('');
    document.getElementById('rcptOverlay').classList.add('show');
  }

  function closeReceipt() {
    document.getElementById('rcptOverlay').classList.remove('show');
  }

  function shareReceiptText() {
    const r = window._lastReceipt;
    if (!r) return;
    const text = `✅ Payment Confirmation Receipt\n\nOperator: ${r.operator}\nService No: ${r.mobile}\nType: ${r.type}\nAmount: ₹${Number(r.amount).toFixed(2)}\nReference No: ${r.ref}\nStatus: SUCCESS\nDate: ${r.date}\n\n— SmrAI PaySetu`;
    if (navigator.share) {
      navigator.share({ title: 'Payment Receipt', text }).catch(() => {});
    } else {
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.querySelector('.rcpt-btn.secondary');
        if (btn) { const o = btn.textContent; btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = o, 2000); }
      }).catch(() => {
        const ta = document.createElement('textarea');
        ta.value = text; ta.style.cssText = 'position:fixed;top:-9999px';
        document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
      });
    }
  }
</script>

