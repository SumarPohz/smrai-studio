<%- include('../partials/header') %>

<style>
  :root {
    --ps-blue: #1e4db7;
    --ps-bg:   #eef2fb;
  }

  body { background: var(--ps-bg) !important; }

  .ps-page {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 0 80px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    min-height: 100vh;
  }

  /* Top bar */
  .ps-topbar {
    background: #fff;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid #eef2fb;
  }
  .ps-back-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: #f1f5f9;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    font-size: 16px; color: #1e293b;
    flex-shrink: 0;
  }
  .ps-topbar-title { font-size: 16px; font-weight: 700; color: #1e293b; }

  /* Select Support card */
  .ps-sup-card {
    margin: 16px 12px 0;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(30,77,183,0.06);
  }
  .ps-sup-label {
    font-size: 13px;
    font-weight: 600;
    color: #475569;
    padding: 14px 16px 10px;
    border-bottom: 1px solid #f1f5f9;
  }
  .ps-sup-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    text-decoration: none;
    color: #1e4db7;
    font-size: 14px;
    font-weight: 500;
    border: none;
    background: none;
    width: 100%;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.12s;
  }
  .ps-sup-item:not(:last-child) { border-bottom: 1px solid #f1f5f9; }
  .ps-sup-item:active { background: #f8fafc; }
  .ps-sup-icon { font-size: 18px; }
  .ps-sup-chevron { margin-left: auto; font-size: 14px; color: #cbd5e1; }

  /* Section title */
  .ps-tut-title {
    font-size: 15px;
    font-weight: 700;
    color: #1e293b;
    margin: 20px 12px 10px;
  }

  /* Tutorial cards */
  .ps-tut-card {
    margin: 0 12px 12px;
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(30,77,183,0.07);
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.15s;
  }
  .ps-tut-card:active { transform: scale(0.98); }

  .ps-tut-thumb {
    width: 100%;
    height: 170px;
    position: relative;
    display: flex;
    align-items: center;
    padding: 20px;
    box-sizing: border-box;
  }
  .ps-tut-thumb-1 { background: linear-gradient(135deg, #0f2366 0%, #1e3a8a 50%, #1e4db7 100%); }
  .ps-tut-thumb-2 { background: linear-gradient(135deg, #1e293b 0%, #0f2366 50%, #1e4db7 100%); }
  .ps-tut-thumb-3 { background: linear-gradient(135deg, #7c3aed 0%, #4f46e5 50%, #2563eb 100%); }

  .ps-tut-thumb-text {
    color: #fff;
    font-size: 18px;
    font-weight: 800;
    line-height: 1.3;
    max-width: 65%;
    z-index: 1;
  }
  .ps-tut-thumb-text .highlight { color: #facc15; }
  .ps-tut-thumb-text .highlight-blue { color: #60a5fa; }

  .ps-tut-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 52px; height: 52px;
    background: rgba(255,255,255,0.25);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    backdrop-filter: blur(4px);
  }

  /* Decorative circles on thumbnail */
  .ps-tut-deco {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 10px;
    opacity: 0.3;
    font-size: 22px;
  }

  .ps-tut-caption {
    padding: 12px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #1e293b;
    line-height: 1.4;
  }

  /* WhatsApp CTA */
  .ps-wa-cta {
    margin: 8px 12px 0;
    background: #25d366;
    border-radius: 14px;
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: #fff;
    box-shadow: 0 4px 14px rgba(37,211,102,0.3);
  }
  .ps-wa-cta:active { opacity: 0.9; }
  .ps-wa-icon { font-size: 30px; }
  .ps-wa-text .wt-title { font-size: 14px; font-weight: 700; }
  .ps-wa-text .wt-sub   { font-size: 11.5px; opacity: 0.9; margin-top: 2px; }

  /* Video modal */
  .ps-vid-backdrop {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .ps-vid-backdrop.open { display: flex; }
  .ps-vid-modal {
    background: #000;
    border-radius: 14px;
    overflow: hidden;
    width: 100%;
    max-width: 480px;
    position: relative;
  }
  .ps-vid-close {
    position: absolute;
    top: 10px; right: 12px;
    color: #fff;
    font-size: 24px;
    cursor: pointer;
    z-index: 10;
    line-height: 1;
    background: rgba(0,0,0,0.5);
    border-radius: 50%;
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    border: none;
  }
  .ps-vid-modal iframe {
    width: 100%;
    aspect-ratio: 16/9;
    border: none;
    display: block;
  }

  /* Bottom Tab Bar */
  .ps-tabs {
    display: none;
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: #fff;
    border-top: 1px solid #e2e8f0;
    z-index: 200;
    box-shadow: 0 -2px 12px rgba(0,0,0,0.08);
  }
  @media (max-width: 768px) { .ps-tabs { display: flex; } }
  .ps-tab {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; gap: 3px;
    padding: 9px 0 7px;
    text-decoration: none;
    color: #94a3b8;
    font-size: 10px; font-weight: 500;
    transition: color 0.15s;
  }
  .ps-tab.active { color: var(--ps-blue); }
  .ps-tab .tab-icon { font-size: 19px; line-height: 1; }

  @media (min-width: 769px) {
    .ps-page { max-width: 960px; }
    .ps-sup-card, .ps-tut-card, .ps-wa-cta {
      max-width: 520px; margin-left: auto; margin-right: auto;
    }
    .ps-tut-title { max-width: 520px; margin-left: auto; margin-right: auto; padding: 0; }
  }
  @media (max-width: 768px) {
    .header-fixed-wrap { display: none !important; }
    footer             { display: none !important; }
    main               { padding-top: 0 !important; }
    .refer-float, .whatsapp-float, .gc-float { display: none !important; }
  }

  /* Toast */
  .sup-toast {
    position: fixed; bottom: 90px; left: 50%;
    transform: translateX(-50%) translateY(12px);
    background: #1e293b; color: #fff;
    padding: 12px 20px; border-radius: 12px;
    font-size: 14px; font-weight: 500;
    z-index: 500; opacity: 0;
    transition: opacity 0.25s, transform 0.25s;
    white-space: nowrap; pointer-events: none;
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
  }
  .sup-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
</style>

<div class="ps-page">

  <!-- Top bar -->
  <div class="ps-topbar">
    <a class="ps-back-btn" href="/paysetu">&#8592;</a>
