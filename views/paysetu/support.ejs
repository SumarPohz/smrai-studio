  <!-- Tutorial 2 -->
  <div class="ps-tut-card" onclick="openVid('tut2')">
    <div class="ps-tut-thumb ps-tut-thumb-2">
      <div class="ps-tut-thumb-text">
        <span style="color:#fff;font-weight:900">HOW TO USE</span><br>
        <span class="highlight-blue" style="font-size:16px">MOBILE RECHARGE</span><br>
        <span style="font-size:13px;opacity:0.9">COMMISSION APP</span>
        <div style="margin-top:10px;background:#e53935;border-radius:6px;padding:5px 12px;display:inline-block;font-size:12px;font-weight:700">WATCH NOW!</div>
