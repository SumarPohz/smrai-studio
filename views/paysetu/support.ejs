      <span class="ps-sup-chevron">›</span>
    </a>
    <a class="ps-sup-item" href="https://wa.me/918787509536" target="_blank">
      <span class="ps-sup-icon">💬</span>
      WhatsApp Support
      <span class="ps-sup-chevron">›</span>
    </a>
  </div>

  <!-- Tutorials -->
  <div class="ps-tut-title">Tutorials</div>

  <!-- Tutorial 1 -->
