</div>

<!-- Toast -->
<div class="sup-toast" id="supToast"></div>

<!-- Video Modal -->
<div class="ps-vid-backdrop" id="vidBackdrop" onclick="closeVid(event)">
  <div class="ps-vid-modal">
    <button class="ps-vid-close" onclick="closeVid(null, true)">✕</button>
    <iframe id="vidFrame" src="" allowfullscreen allow="autoplay; encrypted-media"></iframe>
  </div>
</div>

<!-- Bottom Tab Bar -->
<div class="ps-tabs">
  <a class="ps-tab" href="/paysetu">
    <span class="tab-icon">🏠</span>Home
  </a>
  <a class="ps-tab" href="/paysetu/history">
    <span class="tab-icon">📋</span>Reports
  </a>
  <a class="ps-tab active" href="/paysetu/support">
    <span class="tab-icon">🎧</span>Support
  </a>
  <a class="ps-tab" href="/paysetu/settings">
    <span class="tab-icon">⚙️</span>Settings
  </a>
</div>

<script>
  // Map tutorial IDs to YouTube video IDs — replace with real IDs when available
  const TUTORIALS = {
    tut1: '',   // e.g. 'dQw4w9WgXcQ'
    tut2: '',
    tut3: '',
  };

  function showSupportToast(msg) {
    const t = document.getElementById('supToast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(window._supToastTimer);
    window._supToastTimer = setTimeout(() => t.classList.remove('show'), 3000);
  }

  function openVid(id) {
    const ytId = TUTORIALS[id];
    if (!ytId) {
      showSupportToast('🎬 Tutorial video coming soon!');
      return;
    }
    document.getElementById('vidFrame').src =
      'https://www.youtube.com/embed/' + ytId + '?autoplay=1';
    document.getElementById('vidBackdrop').classList.add('open');
  }

  function closeVid(e, force) {
    if (force || e.target === document.getElementById('vidBackdrop')) {
      document.getElementById('vidFrame').src = '';
      document.getElementById('vidBackdrop').classList.remove('open');
    }
  }
</script>

