<%- include('../partials/header') %>

<style>
  :root {
    --ps-blue:   #1e4db7;
    --ps-orange: #f97316;
    --ps-green:  #16a34a;
    --ps-red:    #dc2626;
    --ps-bg:     #eef2fb;
  }

  body { background: var(--ps-bg) !important; }

  .ps-page {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 0 80px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    min-height: 100vh;
  }

  /* ── Top bar ── */
  .ps-topbar {
    background: #fff;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid #eef2fb;
  }
  .ps-back-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: #f1f5f9;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    font-size: 16px; color: #1e293b;
    flex-shrink: 0;
  }
  .ps-topbar-title { font-size: 16px; font-weight: 700; color: #1e293b; }

  /* ── Profile card ── */
  .ps-profile-card {
    margin: 16px 12px 0;
    background: #fff;
    border-radius: 16px;
    padding: 18px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    box-shadow: 0 2px 10px rgba(30,77,183,0.06);
  }
  .ps-profile-avatar {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: #e2e8f0;
    display: flex; align-items: center; justify-content: center;
    font-size: 28px;
    flex-shrink: 0;
  }
  .ps-profile-name  { font-size: 15px; font-weight: 700; color: #1e293b; }
  .ps-profile-phone { font-size: 12.5px; color: #475569; margin-top: 2px; }
  .ps-profile-email { font-size: 12px; color: #94a3b8; margin-top: 1px; }

  /* ── Section label ── */
  .ps-section-label {
    font-size: 10.5px;
    font-weight: 700;
    color: #94a3b8;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 16px 12px 6px;
  }

  /* ── List card ── */
  .ps-list-card {
    margin: 0 12px;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(30,77,183,0.06);
  }
  .ps-list-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    border: none;
    background: none;
    width: 100%;
    font-family: inherit;
    text-align: left;
    transition: background 0.12s;
  }
  .ps-list-item:not(:last-child) {
    border-bottom: 1px solid #f1f5f9;
  }
  .ps-list-item:active { background: #f8fafc; }
  .ps-item-icon {
    width: 42px; height: 42px;
    border-radius: 50%;
    background: #f1f5f9;
    display: flex; align-items: center; justify-content: center;
    font-size: 19px;
    flex-shrink: 0;
  }
  .ps-item-body { flex: 1; min-width: 0; }
  .ps-item-title { font-size: 13.5px; font-weight: 600; color: #1e293b; }
  .ps-item-sub   { font-size: 11.5px; color: #94a3b8; margin-top: 2px; }
  .ps-item-chevron { font-size: 13px; color: #cbd5e1; flex-shrink: 0; }

  /* ── Logout card ── */
  .ps-logout-card {
    margin: 0 12px;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(30,77,183,0.06);
  }
  .ps-logout-btn {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    text-decoration: none;
    color: #1e293b;
    width: 100%;
    font-family: inherit;
    font-size: 13.5px;
    font-weight: 600;
    border: none;
    background: none;
    cursor: pointer;
    text-align: left;
  }
  .ps-logout-btn:active { background: #fef2f2; }
  .ps-logout-icon {
    width: 42px; height: 42px;
    border-radius: 50%;
    background: #f1f5f9;
    display: flex; align-items: center; justify-content: center;
    font-size: 19px;
  }

  /* ── Social media ── */
  .ps-social-wrap {
    margin: 20px 12px 0;
    text-align: center;
  }
  .ps-social-label {
    font-size: 12px;
    color: #94a3b8;
    font-weight: 500;
    margin-bottom: 12px;
  }
  .ps-social-row {
    display: flex;
    justify-content: center;
    gap: 12px;
  }
  .ps-social-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 19px;
    text-decoration: none;
    transition: transform 0.15s;
  }
  .ps-social-btn:active { transform: scale(0.92); }
  .ps-social-ig  { background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
  .ps-social-yt  { background: #ff0000; }
  .ps-social-x   { background: #1c1c1c; }
  .ps-social-fb  { background: #1877f2; }
  .ps-social-tg  { background: #229ED9; }

  /* ── Bottom Tab Bar ── */
  .ps-tabs {
    display: none;
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: #fff;
    border-top: 1px solid #e2e8f0;
    z-index: 200;
    box-shadow: 0 -2px 12px rgba(0,0,0,0.08);
  }
  @media (max-width: 768px) { .ps-tabs { display: flex; } }
  .ps-tab {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; gap: 3px;
    padding: 9px 0 7px;
    text-decoration: none;
    color: #94a3b8;
    font-size: 10px; font-weight: 500;
    transition: color 0.15s;
  }
  .ps-tab.active { color: var(--ps-blue); }
  .ps-tab .tab-icon { font-size: 19px; line-height: 1; }

  @media (min-width: 769px) {
    .ps-page { max-width: 960px; }
    .ps-profile-card,
    .ps-list-card,
    .ps-logout-card,
    .ps-social-wrap { max-width: 520px; margin-left: auto; margin-right: auto; }
    .ps-section-label { max-width: 520px; margin-left: auto; margin-right: auto; padding: 0; }
  }
</style>

<div class="ps-page">

  <!-- Top bar -->
  <div class="ps-topbar">
    <a class="ps-back-btn" href="/paysetu">&#8592;</a>
    <span class="ps-topbar-title">Settings</span>
  </div>

  <!-- Profile card -->
  <div class="ps-profile-card">
    <div class="ps-profile-avatar">👤</div>
    <div>
      <div class="ps-profile-name"><%= currentUser.name || currentUser.email.split('@')[0] %></div>
      <% if (psPhone) { %>
        <div class="ps-profile-phone">+91 <%= psPhone %></div>
      <% } %>
      <div class="ps-profile-email"><%= currentUser.email %></div>
    </div>
  </div>

  <!-- GENERAL SETTINGS -->
  <div class="ps-section-label">General Settings</div>
  <div class="ps-list-card">

    <a class="ps-list-item" href="/dashboard">
      <div class="ps-item-icon">👤</div>
      <div class="ps-item-body">
        <div class="ps-item-title">Profile Settings</div>
        <div class="ps-item-sub">Name, Email Id</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </a>

    <button class="ps-list-item" onclick="comingSoon('Theme Settings')">
      <div class="ps-item-icon">🎨</div>
      <div class="ps-item-body">
        <div class="ps-item-title">Theme Settings</div>
        <div class="ps-item-sub">Dark, Light, System</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </button>

    <a class="ps-list-item" href="/paysetu/set-pin">
      <div class="ps-item-icon">🔐</div>
      <div class="ps-item-body">
        <div class="ps-item-title">Security Settings</div>
        <div class="ps-item-sub">App Lock, Wallet PIN</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </a>

    <button class="ps-list-item" onclick="comingSoon('KYC / Upgrade Account')">
      <div class="ps-item-icon">🪪</div>
      <div class="ps-item-body">
        <div class="ps-item-title">KYC / Upgrade Account</div>
        <div class="ps-item-sub">Identity Verification</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </button>

    <a class="ps-list-item" href="/paysetu/history">
      <div class="ps-item-icon">🛍️</div>
      <div class="ps-item-body">
        <div class="ps-item-title">Transactions History</div>
        <div class="ps-item-sub">Recharge, Bill, etc.</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </a>

    <a class="ps-list-item" href="/paysetu/support">
      <div class="ps-item-icon">🎧</div>
      <div class="ps-item-body">
        <div class="ps-item-title">24x7 Help &amp; Support</div>
        <div class="ps-item-sub">Support, FAQ</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </a>

    <button class="ps-list-item" onclick="comingSoon('Refer & Earn')">
      <div class="ps-item-icon">🔗</div>
      <div class="ps-item-body">
        <div class="ps-item-title">Refer &amp; Earn</div>
        <div class="ps-item-sub">Cashback every time</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </button>

  </div>

  <!-- WALLET MPIN -->
  <div class="ps-section-label">Wallet Security</div>
  <div class="ps-list-card">
    <div style="padding:16px;display:flex;align-items:center;gap:14px">
      <div class="ps-item-icon" style="background:<%= hasMpin ? 'linear-gradient(135deg,#d1fae5,#6ee7b7)' : 'linear-gradient(135deg,#fee2e2,#fca5a5)' %>">
        <%= hasMpin ? '🔒' : '🔓' %>
      </div>
      <div style="flex:1;min-width:0">
        <div class="ps-item-title">Wallet MPIN</div>
        <div class="ps-item-sub" style="color:<%= hasMpin ? '#16a34a' : '#dc2626' %>">
          <%= hasMpin ? '✓ PIN is set and active' : 'No PIN set — payments unprotected' %>
        </div>
      </div>
      <button onclick="openMpinModal()" style="background:<%= hasMpin ? '#f1f5f9' : '#f97316' %>;color:<%= hasMpin ? '#475569' : '#fff' %>;border:none;border-radius:10px;padding:8px 14px;font-size:12px;font-weight:700;cursor:pointer;flex-shrink:0;font-family:inherit">
        <%= hasMpin ? 'Change PIN' : 'Set PIN' %>
      </button>
    </div>
  </div>

  <!-- MPIN Modal -->
  <div id="mpinModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9000;align-items:flex-end;justify-content:center">
    <div style="background:#fff;border-radius:24px 24px 0 0;padding:28px 24px 40px;width:100%;max-width:480px;margin:0 auto">
      <div style="text-align:center;margin-bottom:20px">
        <div style="font-size:36px;margin-bottom:8px">🔐</div>
        <div style="font-size:17px;font-weight:800;color:#0f172a" id="mpinModalTitle"><%= hasMpin ? 'Change Wallet MPIN' : 'Set Wallet MPIN' %></div>
        <div style="font-size:12.5px;color:#64748b;margin-top:4px">4-digit PIN to secure all wallet payments</div>
      </div>

      <!-- New PIN -->
      <div style="font-size:11px;font-weight:700;color:#475569;letter-spacing:0.5px;text-transform:uppercase;margin-bottom:10px">New PIN</div>
      <div style="display:flex;gap:12px;justify-content:center;margin-bottom:20px" id="mpin-new-row">
        <input class="mpin-box" type="password" inputmode="numeric" maxlength="1" style="width:54px;height:54px;border:2px solid #e2e8f0;border-radius:12px;font-size:22px;font-weight:700;text-align:center;outline:none;background:#f8fafc;color:#1e3a8a;transition:border-color 0.2s;-webkit-text-security:disc">
        <input class="mpin-box" type="password" inputmode="numeric" maxlength="1" style="width:54px;height:54px;border:2px solid #e2e8f0;border-radius:12px;font-size:22px;font-weight:700;text-align:center;outline:none;background:#f8fafc;color:#1e3a8a;transition:border-color 0.2s;-webkit-text-security:disc">
        <input class="mpin-box" type="password" inputmode="numeric" maxlength="1" style="width:54px;height:54px;border:2px solid #e2e8f0;border-radius:12px;font-size:22px;font-weight:700;text-align:center;outline:none;background:#f8fafc;color:#1e3a8a;transition:border-color 0.2s;-webkit-text-security:disc">
        <input class="mpin-box" type="password" inputmode="numeric" maxlength="1" style="width:54px;height:54px;border:2px solid #e2e8f0;border-radius:12px;font-size:22px;font-weight:700;text-align:center;outline:none;background:#f8fafc;color:#1e3a8a;transition:border-color 0.2s;-webkit-text-security:disc">
      </div>

      <!-- Confirm PIN -->
      <div style="font-size:11px;font-weight:700;color:#475569;letter-spacing:0.5px;text-transform:uppercase;margin-bottom:10px">Confirm PIN</div>
      <div style="display:flex;gap:12px;justify-content:center;margin-bottom:20px" id="mpin-confirm-row">
        <input class="mpin-box" type="password" inputmode="numeric" maxlength="1" style="width:54px;height:54px;border:2px solid #e2e8f0;border-radius:12px;font-size:22px;font-weight:700;text-align:center;outline:none;background:#f8fafc;color:#1e3a8a;transition:border-color 0.2s;-webkit-text-security:disc">
        <input class="mpin-box" type="password" inputmode="numeric" maxlength="1" style="width:54px;height:54px;border:2px solid #e2e8f0;border-radius:12px;font-size:22px;font-weight:700;text-align:center;outline:none;background:#f8fafc;color:#1e3a8a;transition:border-color 0.2s;-webkit-text-security:disc">
        <input class="mpin-box" type="password" inputmode="numeric" maxlength="1" style="width:54px;height:54px;border:2px solid #e2e8f0;border-radius:12px;font-size:22px;font-weight:700;text-align:center;outline:none;background:#f8fafc;color:#1e3a8a;transition:border-color 0.2s;-webkit-text-security:disc">
        <input class="mpin-box" type="password" inputmode="numeric" maxlength="1" style="width:54px;height:54px;border:2px solid #e2e8f0;border-radius:12px;font-size:22px;font-weight:700;text-align:center;outline:none;background:#f8fafc;color:#1e3a8a;transition:border-color 0.2s;-webkit-text-security:disc">
      </div>

      <div id="mpinErr" style="color:#dc2626;font-size:12.5px;text-align:center;min-height:18px;margin-bottom:12px"></div>
      <div id="mpinOk" style="color:#16a34a;font-size:13px;font-weight:600;text-align:center;display:none;margin-bottom:12px">✅ PIN saved successfully!</div>

      <button id="mpinSaveBtn" onclick="saveMpin()" disabled style="width:100%;padding:14px;background:#f97316;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit;opacity:0.45">Save PIN</button>
      <button onclick="closeMpinModal()" style="width:100%;padding:12px;background:none;border:none;color:#64748b;font-size:13.5px;font-weight:600;cursor:pointer;margin-top:8px;font-family:inherit">Cancel</button>
    </div>
  </div>

  <!-- REVIEW & POLICY -->
  <div class="ps-section-label">Review &amp; Policy</div>
  <div class="ps-list-card">

    <a class="ps-list-item" href="/terms" target="_blank">
      <div class="ps-item-icon">📄</div>
      <div class="ps-item-body">
        <div class="ps-item-title">Terms &amp; Conditions</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </a>

    <a class="ps-list-item" href="/privacy" target="_blank">
      <div class="ps-item-icon">🛡️</div>
      <div class="ps-item-body">
        <div class="ps-item-title">Privacy Policy</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </a>

    <a class="ps-list-item" href="/refund-policy" target="_blank">
      <div class="ps-item-icon">📃</div>
      <div class="ps-item-body">
        <div class="ps-item-title">Refund Policy</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </a>

    <button class="ps-list-item" onclick="comingSoon('Rate & Review')">
      <div class="ps-item-icon">⭐</div>
      <div class="ps-item-body">
        <div class="ps-item-title">Rate &amp; Review</div>
      </div>
      <span class="ps-item-chevron">›</span>
    </button>

  </div>

  <!-- Logout -->
  <div class="ps-section-label" style="margin-top:16px">&nbsp;</div>
  <div class="ps-logout-card">
    <a class="ps-logout-btn" href="/logout">
      <div class="ps-logout-icon">🚪</div>
      Logout
    </a>
  </div>

  <!-- Social Media -->
  <div class="ps-social-wrap">
    <div class="ps-social-label">Follow Us On Social Media</div>
    <div class="ps-social-row">
      <a class="ps-social-btn ps-social-ig" href="#" target="_blank" title="Instagram">📸</a>
      <a class="ps-social-btn ps-social-yt" href="#" target="_blank" title="YouTube">▶️</a>
      <a class="ps-social-btn ps-social-x"  href="#" target="_blank" title="X (Twitter)" style="color:#fff;font-size:14px;font-weight:800">𝕏</a>
      <a class="ps-social-btn ps-social-fb" href="#" target="_blank" title="Facebook" style="color:#fff;font-size:18px;font-weight:800">f</a>
      <a class="ps-social-btn ps-social-tg" href="#" target="_blank" title="Telegram">✈️</a>
    </div>
  </div>

</div>

<!-- Coming Soon Toast -->
<div id="psToast" style="position:fixed;bottom:78px;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;border-radius:20px;padding:8px 20px;font-size:13px;font-weight:600;z-index:9999;pointer-events:none;opacity:0;transition:opacity 0.2s;white-space:nowrap"></div>

<!-- Bottom Tab Bar (mobile only) -->
<div class="ps-tabs">
  <a class="ps-tab" href="/paysetu">
    <span class="tab-icon">🏠</span>Home
  </a>
  <a class="ps-tab" href="/paysetu/history">
    <span class="tab-icon">📋</span>Reports
  </a>
  <a class="ps-tab" href="/paysetu/support">
    <span class="tab-icon">🎧</span>Support
  </a>
  <a class="ps-tab active" href="/paysetu/settings">
    <span class="tab-icon">⚙️</span>Settings
  </a>
</div>

<script>
  /* ── Coming Soon toast ── */
  let _csTimer = null;
  function comingSoon(name) {
    const t = document.getElementById('psToast');
    t.textContent = (name || 'This feature') + ' — Coming Soon! 🚀';
    t.style.opacity = '1';
    clearTimeout(_csTimer);
    _csTimer = setTimeout(() => t.style.opacity = '0', 2500);
  }

  /* ── MPIN Modal ── */
  const _allBoxes = () => Array.from(document.querySelectorAll('.mpin-box'));
  const _newBoxes  = () => Array.from(document.querySelectorAll('#mpin-new-row .mpin-box'));
  const _confBoxes = () => Array.from(document.querySelectorAll('#mpin-confirm-row .mpin-box'));

  function openMpinModal() {
    const modal = document.getElementById('mpinModal');
    modal.style.display = 'flex';
    _allBoxes().forEach(b => { b.value = ''; b.style.borderColor = '#e2e8f0'; });
    document.getElementById('mpinErr').textContent = '';
    document.getElementById('mpinOk').style.display  = 'none';
    document.getElementById('mpinSaveBtn').disabled   = true;
    document.getElementById('mpinSaveBtn').style.opacity = '0.45';
    _newBoxes()[0].focus();
  }

  function closeMpinModal() {
    document.getElementById('mpinModal').style.display = 'none';
  }

  function _checkComplete() {
    const full = _allBoxes().every(b => b.value.length === 1);
    const btn  = document.getElementById('mpinSaveBtn');
    btn.disabled       = !full;
    btn.style.opacity  = full ? '1' : '0.45';
  }

  /* OTP-style box navigation */
  document.addEventListener('DOMContentLoaded', () => {
    _allBoxes().forEach((box, idx, arr) => {
      box.addEventListener('input', e => {
        const val = e.target.value.replace(/\D/g, '');
        e.target.value = val ? val.slice(-1) : '';
        if (val && idx < arr.length - 1) arr[idx + 1].focus();
        _checkComplete();
      });
      box.addEventListener('keydown', e => {
        if (e.key === 'Backspace' && !e.target.value && idx > 0) {
          arr[idx - 1].focus();
          arr[idx - 1].value = '';
          _checkComplete();
        }
      });
      box.addEventListener('paste', e => {
        e.preventDefault();
        const digits = (e.clipboardData.getData('text') || '').replace(/\D/g, '').slice(0, arr.length - idx);
        digits.split('').forEach((d, i) => {
          if (arr[idx + i]) arr[idx + i].value = d;
        });
        const next = arr[Math.min(idx + digits.length, arr.length - 1)];
        next.focus();
        _checkComplete();
      });
    });
  });

  async function saveMpin() {
    const newPin  = _newBoxes().map(b => b.value).join('');
    const confPin = _confBoxes().map(b => b.value).join('');
    const errEl   = document.getElementById('mpinErr');
    const okEl    = document.getElementById('mpinOk');
    const btn     = document.getElementById('mpinSaveBtn');

    errEl.textContent = '';
    okEl.style.display = 'none';

    if (newPin.length !== 4 || confPin.length !== 4) {
      errEl.textContent = 'Please fill in all 4 digits.'; return;
    }
    if (newPin !== confPin) {
      errEl.textContent = 'PINs do not match. Please try again.';
      _confBoxes().forEach(b => { b.value = ''; b.style.borderColor = '#dc2626'; });
      _confBoxes()[0].focus();
      _checkComplete();
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Saving…';
    btn.style.opacity = '0.7';

    try {
      const res = await fetch('/api/user/pin/set', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pin: newPin })
      });
      const data = await res.json();

      if (res.ok && data.success) {
        okEl.style.display = 'block';
        btn.textContent = 'Saved ✓';
        btn.style.background = '#16a34a';
        setTimeout(() => {
          closeMpinModal();
          location.reload();
        }, 1200);
      } else {
        errEl.textContent = data.message || 'Failed to save PIN. Try again.';
        btn.disabled = false;
        btn.textContent = 'Save PIN';
        btn.style.opacity = '1';
      }
    } catch {
      errEl.textContent = 'Network error. Please try again.';
      btn.disabled = false;
      btn.textContent = 'Save PIN';
      btn.style.opacity = '1';
    }
  }

  /* Close modal on backdrop click */
  document.getElementById('mpinModal').addEventListener('click', function(e) {
    if (e.target === this) closeMpinModal();
  });
</script>

