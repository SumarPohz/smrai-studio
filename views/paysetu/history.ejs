<%- include('../partials/header') %>

<style>
  :root {
    --ps-blue: #1e4db7;
    --ps-orange: #f97316;
    --ps-green: #16a34a;
    --ps-red: #dc2626;
    --ps-bg: #f0f4ff;
  }

  .ps-wrap {
    max-width: 480px;
    margin: 0 auto;
    background: var(--ps-bg);
    min-height: 100vh;
    padding-bottom: 72px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* ── Header ── */
  .ps-header {
    background: linear-gradient(135deg, var(--ps-blue) 0%, #2563eb 100%);
    padding: 16px 16px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    color: #fff;
  }
  .ps-back-btn {
    background: rgba(255,255,255,0.18);
    border: none;
    color: #fff;
    font-size: 20px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .ps-header-title { font-size: 18px; font-weight: 700; }

  /* ── Tab Bar ── */
  .ps-tab-bar {
    background: #fff;
    display: flex;
    border-bottom: 2px solid #e2e8f0;
  }
  .ps-htab {
    flex: 1;
    padding: 14px;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    color: #94a3b8;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
    background: none;
    border-left: none;
    border-right: none;
    border-top: none;
  }
  .ps-htab.active { color: var(--ps-blue); border-bottom-color: var(--ps-blue); }

  /* ── Panels ── */
  .ps-panel { display: none; padding: 12px; }
  .ps-panel.visible { display: block; }

  /* ── Transaction Item ── */
  .ps-txn-item {
    background: #fff;
    border-radius: 14px;
    padding: 14px 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
    box-shadow: 0 1px 6px rgba(30,77,183,0.07);
  }
  .ps-txn-icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: #eff6ff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }
  .ps-txn-main { flex: 1; min-width: 0; }
  .ps-txn-title {
    font-size: 14px;
    font-weight: 700;
    color: #1e293b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ps-txn-sub { font-size: 12px; color: #64748b; margin-top: 2px; }
  .ps-txn-right { text-align: right; flex-shrink: 0; }
  .ps-txn-amount { font-size: 15px; font-weight: 700; color: #1e293b; }
  .ps-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    margin-top: 4px;
  }
  .ps-badge.success { background: #dcfce7; color: #166534; }
  .ps-badge.failed  { background: #fee2e2; color: #991b1b; }
  .ps-badge.pending { background: #fef9c3; color: #854d0e; }

  /* ── Skeleton ── */
  .ps-skeleton {
    background: #fff;
    border-radius: 14px;
    padding: 14px;
    margin-bottom: 8px;
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .sk-box {
    border-radius: 8px;
    background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
    background-size: 200% 100%;
    animation: shimmer 1.2s infinite;
  }
  @keyframes shimmer { to { background-position: -200% 0; } }
  .sk-icon { width: 42px; height: 42px; border-radius: 12px; flex-shrink: 0; }
  .sk-lines { flex: 1; }
  .sk-line { height: 12px; border-radius: 6px; margin-bottom: 6px; }
  .sk-line.wide { width: 70%; }
  .sk-line.narrow { width: 45%; }

  /* ── Empty State ── */
  .ps-empty {
    text-align: center;
    padding: 48px 20px;
    color: #94a3b8;
  }
  .ps-empty-icon { font-size: 48px; margin-bottom: 12px; }
  .ps-empty-text { font-size: 15px; font-weight: 600; }
  .ps-empty-sub { font-size: 13px; margin-top: 4px; }

  /* ── Bottom Tab Bar ── */
  .ps-tabs {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 480px;
    background: #fff;
    border-top: 1px solid #e2e8f0;
    display: flex;
    z-index: 100;
    box-shadow: 0 -2px 12px rgba(0,0,0,0.08);
  }
  .ps-tab {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 10px 0 8px;
    text-decoration: none;
    color: #94a3b8;
    font-size: 10.5px;
    font-weight: 500;
    transition: color 0.15s;
  }
  .ps-tab.active { color: var(--ps-blue); }
  .ps-tab .tab-icon { font-size: 20px; line-height: 1; }

  /* ── Desktop-only base resets ── */
  .ht-toolbar { display: none; }
  .ht-detail  { display: none; }

  /* ── Desktop Layout ── */
  @media (min-width: 769px) {
    .ps-wrap { max-width: 100%; background: #f0f4ff; padding-bottom: 0; }
    .ps-header   { display: none; }
    .ps-tab-bar  { display: none; }
    .ps-tabs     { display: none; }
    .ps-panel    { padding: 0; }
    .ps-txn-item { display: none; }

    .ht-page {
      max-width: 1120px;
      margin: 0 auto;
      padding: 28px 20px 48px;
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 20px;
      align-items: start;
    }

    .ht-main {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 1px 8px rgba(0,0,0,0.08);
      overflow: hidden;
    }

    .ht-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 24px 0;
      border-bottom: 1px solid #e2e8f0;
    }
    .ht-title { font-size: 17px; font-weight: 700; color: #1e293b; }
    .ht-toolbar .ps-htab { flex: none; padding: 12px 18px; font-size: 13px; }

    .ht-thead,
    .ht-trow {
      display: grid;
      grid-template-columns: 110px 1fr 140px 90px 90px 80px;
      padding: 0 24px;
    }
    .ht-thead { border-bottom: 1px solid #e2e8f0; }
    .ht-th {
      font-size: 11px; font-weight: 600; color: #94a3b8;
      padding: 10px 0; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .ht-trow {
      border-bottom: 1px solid #f1f5f9;
      cursor: pointer;
      transition: background 0.12s;
    }
    .ht-trow:hover     { background: #f8fafc; }
    .ht-trow.ht-selected { background: #eff6ff; }
    .ht-td {
      padding: 13px 0; font-size: 13px; color: #334155;
      display: flex; align-items: center; gap: 6px;
    }
    .ht-td-date { color: #64748b; font-size: 12px; }
    .ht-td-op   { font-weight: 600; color: #1e293b; }
    .ht-td-amt  { font-weight: 700; color: #1e293b; }

    .ht-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .ht-dot.success { background: #16a34a; }
    .ht-dot.failed  { background: #dc2626; }
    .ht-dot.pending { background: #d97706; }

    /* ── Detail Panel ── */
    .ht-detail {
      background: #fff; border-radius: 12px;
      box-shadow: 0 1px 8px rgba(0,0,0,0.08);
      padding: 24px; position: sticky; top: 80px;
    }
    .ht-detail.open { display: block; }
    .ht-detail-close {
      float: right; background: none; border: none;
      font-size: 18px; cursor: pointer; color: #94a3b8; line-height: 1;
    }
    .ht-detail-label {
      font-size: 11px; font-weight: 600; color: #94a3b8;
      text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 3px;
    }
    .ht-detail-value {
      font-size: 14px; color: #1e293b; font-weight: 500;
      margin-bottom: 16px; word-break: break-all;
    }
    .ht-detail-amt { font-size: 28px; font-weight: 800; color: #1e293b; margin: 10px 0 18px; }
    .ht-status-badge {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;
    }
    .ht-status-badge.success { background: #dcfce7; color: #166534; }
    .ht-status-badge.failed  { background: #fee2e2; color: #991b1b; }
    .ht-status-badge.pending { background: #fef9c3; color: #854d0e; }
  }
  @media (max-width: 768px) {
    .header-fixed-wrap { display: none !important; }
    footer             { display: none !important; }
    main               { padding-top: 0 !important; }
    .refer-float, .whatsapp-float, .gc-float { display: none !important; }
  }
</style>

<div class="ps-wrap">

  <!-- Mobile Header -->
  <div class="ps-header">
    <button class="ps-back-btn" onclick="history.back()">←</button>
    <span class="ps-header-title">Transaction History</span>
  </div>

  <!-- Mobile Tab Bar -->
  <div class="ps-tab-bar">
    <button class="ps-htab active" id="tab-recharge" onclick="switchTab('recharge')">📱 Recharges</button>
    <button class="ps-htab" id="tab-bills" onclick="switchTab('bills')">🧾 Bills</button>
  </div>

  <!-- Desktop Grid -->
  <div class="ht-page">
    <div class="ht-main">

      <!-- Desktop Toolbar -->
      <div class="ht-toolbar">
        <span class="ht-title">Transaction History</span>
        <div>
          <button class="ps-htab active" id="dtab-recharge" onclick="switchTab('recharge')">📱 Recharges</button>
          <button class="ps-htab" id="dtab-bills" onclick="switchTab('bills')">🧾 Bills</button>
        </div>
      </div>

      <!-- Recharges Panel -->
      <div class="ps-panel visible" id="panel-recharge">
        <div id="recharge-skeleton">
          <% for(let i=0;i<4;i++){ %>
          <div class="ps-skeleton">
            <div class="sk-box sk-icon"></div>
            <div class="sk-lines">
              <div class="sk-box sk-line wide"></div>
              <div class="sk-box sk-line narrow"></div>
            </div>
          </div>
          <% } %>
        </div>
        <div id="recharge-list" style="display:none;"></div>
      </div>

      <!-- Bills Panel -->
      <div class="ps-panel" id="panel-bills">
        <div id="bills-skeleton">
          <% for(let i=0;i<4;i++){ %>
          <div class="ps-skeleton">
            <div class="sk-box sk-icon"></div>
            <div class="sk-lines">
              <div class="sk-box sk-line wide"></div>
              <div class="sk-box sk-line narrow"></div>
            </div>
          </div>
          <% } %>
        </div>
        <div id="bills-list" style="display:none;"></div>
      </div>

    </div><!-- /.ht-main -->

    <!-- Detail Panel (desktop only) -->
    <div class="ht-detail" id="htDetail">
      <button class="ht-detail-close" onclick="closeDetail()">✕</button>
      <div style="clear:both; margin-bottom:6px; font-size:11px; font-weight:600; color:#94a3b8; text-transform:uppercase; letter-spacing:0.05em;">Transaction Details</div>
      <div class="ht-detail-amt" id="hdAmt"></div>
      <div id="hdStatus"></div>
      <div style="margin-top:22px;">
        <div class="ht-detail-label">Date &amp; Time</div>
        <div class="ht-detail-value" id="hdDate"></div>
        <div class="ht-detail-label">Operator / Biller</div>
        <div class="ht-detail-value" id="hdOp"></div>
        <div class="ht-detail-label">Number</div>
        <div class="ht-detail-value" id="hdNum"></div>
        <div class="ht-detail-label">Type</div>
        <div class="ht-detail-value" id="hdType"></div>
        <div class="ht-detail-label">Reference</div>
        <div class="ht-detail-value" id="hdRef"></div>
      </div>
    </div>

  </div><!-- /.ht-page -->

</div><!-- /.ps-wrap -->

<!-- Mobile Bottom Tabs -->
<div class="ps-tabs">
  <a class="ps-tab" href="/paysetu">
    <span class="tab-icon">🏠</span>Home
  </a>
  <a class="ps-tab" href="/paysetu/wallet-topup">
    <span class="tab-icon">👛</span>Wallet
  </a>
  <a class="ps-tab active" href="/paysetu/history">
    <span class="tab-icon">📋</span>History
  </a>
</div>

<script>
  const OP_ICONS = {
    'Airtel':'📶','Jio':'💎','Vi (Vodafone)':'📲','BSNL':'📡',
    'Tata Play':'📺','Dish TV':'🛰️','Airtel DTH':'📺','default':'📱'
  };
  const CAT_ICONS = {
    'electricity':'⚡','water':'💧','gas':'🔥','broadband':'🌐','dth':'📺','other':'🏦'
  };

  let rechargeLoaded = false;
  let billsLoaded    = false;
  window._rHistory   = [];
  window._bHistory   = [];

  function isDesktop() { return window.innerWidth >= 769; }

  document.addEventListener('DOMContentLoaded', () => {
    loadRecharges();
  });

  function switchTab(tab) {
    document.getElementById('tab-recharge').classList.toggle('active', tab === 'recharge');
    document.getElementById('tab-bills').classList.toggle('active', tab === 'bills');
    document.getElementById('dtab-recharge')?.classList.toggle('active', tab === 'recharge');
    document.getElementById('dtab-bills')?.classList.toggle('active', tab === 'bills');
    document.getElementById('panel-recharge').classList.toggle('visible', tab === 'recharge');
    document.getElementById('panel-bills').classList.toggle('visible', tab === 'bills');
    if (tab === 'bills'    && !billsLoaded)    loadBills();
    if (tab === 'recharge' && !rechargeLoaded) loadRecharges();
  }

  async function loadRecharges() {
    try {
      const r = await fetch('/api/recharge/history');
      const d = await r.json();
      document.getElementById('recharge-skeleton').style.display = 'none';
      const list = document.getElementById('recharge-list');
      list.style.display = 'block';
      if (d.success && d.history.length) {
        window._rHistory = d.history;
        if (isDesktop()) {
          list.innerHTML =
            `<div class="ht-thead">
              <div class="ht-th">Date</div>
              <div class="ht-th">Operator</div>
              <div class="ht-th">Number</div>
              <div class="ht-th">Type</div>
              <div class="ht-th">Amount</div>
              <div class="ht-th">Status</div>
            </div>` +
            d.history.map((tx, i) => {
              const date = new Date(tx.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'2-digit' });
              return `<div class="ht-trow" onclick="showDetail(${i},'recharge')">
                <div class="ht-td ht-td-date">${date}</div>
                <div class="ht-td ht-td-op">${tx.operator}</div>
                <div class="ht-td">${tx.mobile}</div>
                <div class="ht-td">${tx.type === 'dth' ? 'DTH' : 'Mobile'}</div>
                <div class="ht-td ht-td-amt">₹${Number(tx.amount).toFixed(0)}</div>
                <div class="ht-td"><span class="ht-dot ${tx.status}"></span>${tx.status}</div>
              </div>`;
            }).join('');
        } else {
          list.innerHTML = d.history.map(tx => {
            const icon = OP_ICONS[tx.operator] || OP_ICONS.default;
            const date = new Date(tx.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'2-digit' });
            return `<div class="ps-txn-item">
              <div class="ps-txn-icon">${icon}</div>
              <div class="ps-txn-main">
                <div class="ps-txn-title">${tx.operator} · ${tx.type === 'dth' ? 'DTH' : 'Mobile'}</div>
                <div class="ps-txn-sub">${tx.mobile} · ${date}</div>
              </div>
              <div class="ps-txn-right">
                <div class="ps-txn-amount">₹${Number(tx.amount).toFixed(0)}</div>
                <span class="ps-badge ${tx.status}">${tx.status}</span>
              </div>
            </div>`;
          }).join('');
        }
      } else {
        list.innerHTML = emptyState('📱', 'No recharges yet', 'Your recharge history will appear here');
      }
      rechargeLoaded = true;
    } catch {
      document.getElementById('recharge-skeleton').style.display = 'none';
      document.getElementById('recharge-list').innerHTML = emptyState('⚠️', 'Could not load', 'Please try again');
      document.getElementById('recharge-list').style.display = 'block';
    }
  }

  async function loadBills() {
    try {
      const r = await fetch('/api/bbps/history');
      const d = await r.json();
      document.getElementById('bills-skeleton').style.display = 'none';
      const list = document.getElementById('bills-list');
      list.style.display = 'block';
      if (d.success && d.history.length) {
        window._bHistory = d.history;
        if (isDesktop()) {
          list.innerHTML =
            `<div class="ht-thead">
              <div class="ht-th">Date</div>
              <div class="ht-th">Biller</div>
              <div class="ht-th">Account</div>
              <div class="ht-th">Category</div>
              <div class="ht-th">Amount</div>
              <div class="ht-th">Status</div>
            </div>` +
            d.history.map((tx, i) => {
              const date = new Date(tx.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'2-digit' });
              return `<div class="ht-trow" onclick="showDetail(${i},'bills')">
                <div class="ht-td ht-td-date">${date}</div>
                <div class="ht-td ht-td-op">${tx.biller_name || tx.biller_id}</div>
                <div class="ht-td">${tx.customer_number}</div>
                <div class="ht-td">${tx.category || '—'}</div>
                <div class="ht-td ht-td-amt">₹${Number(tx.amount).toFixed(0)}</div>
                <div class="ht-td"><span class="ht-dot ${tx.status}"></span>${tx.status}</div>
              </div>`;
            }).join('');
        } else {
          list.innerHTML = d.history.map(tx => {
            const icon = CAT_ICONS[tx.category] || '🏦';
            const date = new Date(tx.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'2-digit' });
            return `<div class="ps-txn-item">
              <div class="ps-txn-icon">${icon}</div>
              <div class="ps-txn-main">
                <div class="ps-txn-title">${tx.biller_name || tx.biller_id}</div>
                <div class="ps-txn-sub">${tx.customer_number} · ${date}</div>
              </div>
              <div class="ps-txn-right">
                <div class="ps-txn-amount">₹${Number(tx.amount).toFixed(0)}</div>
                <span class="ps-badge ${tx.status}">${tx.status}</span>
              </div>
            </div>`;
          }).join('');
        }
      } else {
        list.innerHTML = emptyState('🧾', 'No bills paid yet', 'Your bill payment history will appear here');
      }
      billsLoaded = true;
    } catch {
      document.getElementById('bills-skeleton').style.display = 'none';
      document.getElementById('bills-list').innerHTML = emptyState('⚠️', 'Could not load', 'Please try again');
      document.getElementById('bills-list').style.display = 'block';
    }
  }

  function showDetail(i, type) {
    const tx = type === 'recharge' ? window._rHistory[i] : window._bHistory[i];
    if (!tx) return;
    document.getElementById('hdAmt').textContent = '₹' + Number(tx.amount).toFixed(2);
    document.getElementById('hdStatus').innerHTML =
      `<span class="ht-status-badge ${tx.status}">${tx.status}</span>`;
    document.getElementById('hdDate').textContent =
      new Date(tx.created_at).toLocaleString('en-IN', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });
    document.getElementById('hdOp').textContent =
      type === 'recharge' ? tx.operator : (tx.biller_name || tx.biller_id);
    document.getElementById('hdNum').textContent =
      type === 'recharge' ? tx.mobile : tx.customer_number;
    document.getElementById('hdType').textContent =
      type === 'recharge' ? (tx.type === 'dth' ? 'DTH Prepaid' : 'Mobile Prepaid') : (tx.category || '—');
    document.getElementById('hdRef').textContent = tx.external_ref || tx.id || '—';

    document.querySelectorAll('.ht-trow').forEach(r => r.classList.remove('ht-selected'));
    const rows = document.querySelectorAll('.ht-trow');
    if (rows[i]) rows[i].classList.add('ht-selected');
    document.getElementById('htDetail').classList.add('open');
  }

  function closeDetail() {
    document.getElementById('htDetail').classList.remove('open');
    document.querySelectorAll('.ht-trow').forEach(r => r.classList.remove('ht-selected'));
  }

  function emptyState(icon, title, sub) {
    return `<div class="ps-empty">
      <div class="ps-empty-icon">${icon}</div>
      <div class="ps-empty-text">${title}</div>
      <div class="ps-empty-sub">${sub}</div>
    </div>`;
  }
</script>

<%- include('../partials/footer') %>
