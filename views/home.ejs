<%- include("partials/header") %>

<!-- 3D animated background — home page only -->
<div class="home-bg-scene" aria-hidden="true">
  <div class="hblob hblob-1"></div>
  <div class="hblob hblob-2"></div>
  <div class="hblob hblob-3"></div>
  <div class="hblob hblob-4"></div>
  <div class="hblob-grid"></div>
</div>

<div class="page-container">

  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <%
  var _heroImgs = (hp_hero.heroImages && hp_hero.heroImages.length)
    ? hp_hero.heroImages
    : (hp_hero.heroImage ? [hp_hero.heroImage] : ['/images/hero-photo.png']);
  var _heroJson = JSON.stringify(_heroImgs).replace(/"/g, '&quot;');
  %>
  <section class="hero">
    <div class="hero-content">
      <p class="hero-tag"><%= hp_hero.tag || 'AI-Powered Resume Studio' %></p>
      <h1><%- hp_hero.headline || 'Build a job-ready resume in minutes, not hours.' %></h1>

      <!-- Mobile-only card -->
      <div class="hero-illustration hero-illustration-inline">
        <div class="hero-card">
          <div class="hero-card-header">
            <span class="badge">Live Preview</span>
            <span class="dot-group"><span></span><span></span><span></span></span>
          </div>
          <div class="hero-card-body">
            <div class="hero-gallery" data-images="<%= _heroJson %>">
              <div class="hcg-track">
                <% var _mn = _heroImgs.length > 3 ? 4 : _heroImgs.length; %>
                <% for (var _mi = 0; _mi < _mn; _mi++) { %>
                <div class="hcg-item"><img src="<%= _heroImgs[_mi] %>" alt="Profile"
                     onerror="this.style.background='linear-gradient(135deg,#3b82f6,#22c55e)';this.src='';this.onerror=null;"></div>
                <% } %>
              </div>
            </div>
          </div>
          <div class="hero-card-footer">
            <span class="pill">PDF</span>
            <span class="pill">JPG</span>
            <span class="pill accent">1-Click Download</span>
          </div>
        </div>
      </div>

      <p class="hero-subtitle"><%- hp_hero.subtitle || '' %></p>

      <div class="hero-actions">
        <% if (currentUser) { %>
          <a href="/resume-templates" class="btn-primary hero-btn-lg">Start Building Resume</a>
          <a href="/photo-editor" class="hero-btn-photo">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            SmrPhoto Editor
          </a>
        <% } else { %>
          <a href="/register" class="btn-primary hero-btn-lg">Get Started Free</a>
          <a href="/login" class="btn-ghost hero-btn">Log in</a>
        <% } %>
      </div>

      <p class="hero-trust"><%- hp_hero.trustText || '' %></p>
    </div>

    <!-- Desktop illustration card -->
    <div class="hero-illustration">
      <div class="hero-card">
        <div class="hero-card-header">
          <span class="badge">Live Preview</span>
          <span class="dot-group"><span></span><span></span><span></span></span>
        </div>
        <div class="hero-card-body">
          <div class="hero-gallery" data-images="<%= _heroJson %>">
            <div class="hcg-track">
              <% var _dn = _heroImgs.length > 3 ? 4 : _heroImgs.length; %>
              <% for (var _di = 0; _di < _dn; _di++) { %>
              <div class="hcg-item"><img src="<%= _heroImgs[_di] %>" alt="Profile"
                   onerror="this.style.background='linear-gradient(135deg,#3b82f6,#22c55e)';this.src='';this.onerror=null;"></div>
              <% } %>
            </div>
          </div>
        </div>
        <div class="hero-card-footer">
          <span class="pill">PDF</span>
          <span class="pill">JPG</span>
          <span class="pill accent">1-Click Download</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Services ──────────────────────────────────────────────────────────── -->
  <section class="services-section">
    <h2><%= (hp_services.title) || 'What you can do with SmrAI-Studio' %></h2>
    <p class="section-subtitle"><%= (hp_services.subtitle) || '' %></p>

    <div class="service-cards">
      <% const svcCards = hp_services.cards || []; %>
      <% svcCards.forEach(function(card) { %>
        <% if (card.link) { %>
          <a href="<%= card.link === '/resume-templates' ? (currentUser ? '/resume-templates' : '/login') : card.link %>"
             class="service-card service-card-link">
        <% } else { %>
          <article class="service-card">
        <% } %>
          <% if (card.imageUrl) { %>
            <div class="service-image" style="background-image:url('<%= card.imageUrl %>');background-size:cover;background-position:center;"></div>
          <% } else { %>
            <div class="service-image <%= card.bgClass || '' %>"></div>
          <% } %>
          <div class="service-card-body">
            <h3><%- card.title %></h3>
            <p><%- card.description %></p>
          </div>
        <% if (card.link) { %>
          </a>
        <% } else { %>
          </article>
        <% } %>
      <% }); %>
    </div>
  </section>

  <% if (locals.adsEnabled) { %>
  <div class="ad-top-banner">
    <span class="ad-label">Advertisement</span>
    <% if (locals.sidebarAd) { %>
      <a href="<%= sidebarAd.link_url %>" target="_blank" rel="noopener noreferrer sponsored">
        <img src="<%= sidebarAd.image_url %>" alt="<%= sidebarAd.title || 'Advertisement' %>">
      </a>
    <% } else { %>
      <% if (locals.adsEnabled && locals.adsensePublisherId && locals.homepageAdSlot) { %>
      <ins class="adsbygoogle" style="display:block"
           data-ad-client="<%= locals.adsensePublisherId %>"
           data-ad-slot="<%= locals.homepageAdSlot %>"
           data-ad-format="auto" data-full-width-responsive="true"></ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      <% } %>
    <% } %>
  </div>
  <% } %>

  <!-- ── Features ──────────────────────────────────────────────────────────── -->
  <section class="features-section">
    <h2><%= (hp_features.title) || 'Our Main Features' %></h2>
    <p class="section-subtitle"><%= (hp_features.subtitle) || '' %></p>

    <div class="features-grid">
      <% const fCards = hp_features.cards || []; %>
      <% fCards.forEach(function(card) { %>
        <div class="feature-card">
          <div class="feature-icon <%= card.color || '' %>"><%= card.icon || '' %></div>
          <h3><%- card.title %></h3>
          <p><%- card.description %></p>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- ── Testimonials ───────────────────────────────────────────────────────── -->
  <section class="testimonials-section">
    <h2><%= (hp_testimonials.title) || 'Your Success, Our Inspiration' %></h2>
    <p class="section-subtitle"><%= (hp_testimonials.subtitle) || '' %></p>

    <div class="testimonials-grid">
      <% const tCards = hp_testimonials.cards || []; %>
      <% tCards.forEach(function(card) { %>
        <article class="testimonial-card">
          <div class="quote-flag">❝</div>
          <img class="testimonial-avatar" src="<%= card.avatar || '' %>" alt="<%= card.name || '' %>"
               onerror="this.src='https://i.pravatar.cc/56?img=1'">
          <p class="testimonial-text"><%- card.text %></p>
          <p class="testimonial-name"><%- card.name %></p>
          <p class="testimonial-role"><%- card.role %></p>
        </article>
      <% }); %>
    </div>
  </section>

</div>

<style>
  /* ── Home page 3D background ── */
  .home-bg-scene {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hblob-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(99,102,241,0.07) 1px, transparent 1px);
    background-size: 30px 30px;
  }

  .hblob {
    position: absolute;
    border-radius: 50%;
    filter: blur(110px);
    animation: hblobDrift ease-in-out infinite alternate;
  }

  .hblob-1 { width:580px;height:580px;background:radial-gradient(circle at 40% 40%,#3b82f6,#1d4ed8);opacity:.18;top:-180px;left:-160px;animation-duration:18s; }
  .hblob-2 { width:480px;height:480px;background:radial-gradient(circle at 60% 40%,#06b6d4,#0ea5e9);opacity:.14;top:-80px;right:-120px;animation-duration:22s;animation-delay:-7s; }
  .hblob-3 { width:420px;height:420px;background:radial-gradient(circle at 50% 60%,#6366f1,#8b5cf6);opacity:.12;bottom:-100px;left:30%;animation-duration:26s;animation-delay:-13s; }
  .hblob-4 { width:320px;height:320px;background:radial-gradient(circle at 50% 50%,#10b981,#059669);opacity:.10;top:40%;right:5%;animation-duration:20s;animation-delay:-5s; }

  @keyframes hblobDrift {
    0%   { transform: translate(0px,   0px)  scale(1);    }
    33%  { transform: translate(30px, -35px) scale(1.04); }
    66%  { transform: translate(-25px, 20px) scale(0.97); }
    100% { transform: translate(15px,  40px) scale(1.02); }
  }

  .page-container, nav, header, footer, .navbar, .site-footer {
    position: relative;
    z-index: 1;
  }
</style>

<script>
document.querySelectorAll('.hero-gallery').forEach(function(gallery) {
  var images = JSON.parse(gallery.getAttribute('data-images') || '[]');
  if (images.length <= 3) return;
  var track = gallery.querySelector('.hcg-track');
  if (!track) return;
  var cur = 3;

  setInterval(function() {
    var firstItem = track.firstElementChild;
    if (!firstItem || !firstItem.offsetWidth) return; // skip if hidden
    var shift = firstItem.offsetWidth + 5; // item width + gap

    track.style.transition = 'transform 0.4s cubic-bezier(0.4,0,0.2,1)';
    track.style.transform  = 'translateX(-' + shift + 'px)';

    setTimeout(function() {
      track.style.transition = 'none';
      track.style.transform  = 'translateX(0)';
      track.appendChild(track.firstElementChild);
      cur = (cur + 1) % images.length;
      track.lastElementChild.querySelector('img').src = images[cur];
      void track.offsetWidth; // force reflow so transition:none registers
    }, 440);
  }, 2500);
});
</script>
<%- include("partials/footer") %>
