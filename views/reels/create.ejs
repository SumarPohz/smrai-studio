<%- include('../partials/header', { title: 'Create AI Reel — SmrAI Studio' }) %>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<style>
#reel-wizard {
  background: #fff;
  min-height: 100vh;
  color: #111827;
}
.wiz-progress { display:flex; gap:6px; margin-bottom:32px; }
.wiz-seg { height:5px; flex:1; border-radius:999px; background:#e5e7eb; transition:background 0.3s; }
.wiz-seg.done { background:#7c3aed; }
.step-badge { display:inline-block; padding:3px 12px; border-radius:999px; border:1.5px solid #7c3aed; color:#7c3aed; font-size:13px; font-weight:600; margin-left:10px; vertical-align:middle; }
.opt-badge  { display:inline-block; padding:3px 10px; border-radius:999px; border:1.5px solid #7c3aed; color:#7c3aed; font-size:12px; font-weight:600; margin-left:8px; vertical-align:middle; }
.step-title { font-size:1.65rem; font-weight:800; color:#111827; margin-bottom:6px; }
.step-sub   { font-size:14px; color:#6b7280; margin-bottom:22px; }

/* Tabs */
.wiz-tabs { display:flex; border-bottom:1.5px solid #e5e7eb; margin-bottom:20px; }
.wiz-tab  { padding:10px 18px; font-size:14px; font-weight:500; color:#6b7280; cursor:pointer; border:none; border-bottom:2.5px solid transparent; margin-bottom:-1.5px; background:none; display:flex; align-items:center; gap:6px; }
.wiz-tab.active { color:#7c3aed; border-bottom-color:#7c3aed; }

/* Niche presets */
.niche-item { border:1.5px solid #e5e7eb; border-radius:12px; padding:14px 18px; cursor:pointer; margin-bottom:10px; transition:border-color .15s,background .15s; }
.niche-item:hover,.niche-item.selected { border-color:#7c3aed; background:#faf5ff; }
.niche-item-title { font-size:15px; font-weight:600; color:#111827; }
.niche-item-desc  { font-size:13px; color:#9ca3af; margin-top:2px; }

/* Voice */
.wiz-card { border:1.5px solid #e5e7eb; border-radius:14px; overflow:hidden; }
.voice-item { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid #f3f4f6; cursor:pointer; transition:background .12s; }
.voice-item:last-child { border-bottom:none; }
.voice-item.selected { background:#faf5ff; }
.v-radio { width:18px; height:18px; border-radius:50%; border:2px solid #d1d5db; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.voice-item.selected .v-radio { border-color:#7c3aed; }
.v-dot { width:9px; height:9px; border-radius:50%; background:#7c3aed; display:none; }
.voice-item.selected .v-dot { display:block; }
.v-badge { display:inline-block; padding:2px 9px; border-radius:999px; background:#dbeafe; color:#1d4ed8; font-size:11px; font-weight:700; margin-left:6px; }
.v-badge.female { background:#fce7f3; color:#9d174d; }

/* Music */
.music-item { display:flex; align-items:center; gap:14px; padding:13px 18px; border:1.5px solid #e5e7eb; border-radius:12px; margin-bottom:10px; cursor:pointer; transition:border-color .15s; }
.music-item.selected { border-color:#7c3aed; background:#faf5ff; }
.music-color { width:40px; height:40px; border-radius:9px; flex-shrink:0; }

/* Art style */
.art-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }
@media(min-width:540px){ .art-grid{ grid-template-columns:repeat(4,1fr); } }
.art-item { border-radius:12px; overflow:hidden; cursor:pointer; border:2.5px solid transparent; transition:border-color .15s; }
.art-item.selected { border-color:#7c3aed; }
.art-thumb { width:100%; aspect-ratio:9/16; display:flex; align-items:center; justify-content:center; font-size:2rem; }
.art-label { font-size:13px; font-weight:600; color:#111827; margin-top:7px; text-align:center; padding-bottom:4px; }

/* Caption */
.cap-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }
@media(min-width:480px){ .cap-grid{ grid-template-columns:repeat(4,1fr); } }
.cap-item { border:2px solid #e5e7eb; border-radius:14px; overflow:hidden; cursor:pointer; transition:all .18s; background:#fff; box-shadow:0 1px 4px rgba(0,0,0,.06); }
.cap-item:hover { border-color:#a78bfa; box-shadow:0 4px 12px rgba(124,58,237,.12); }
.cap-item.selected { border-color:#7c3aed; box-shadow:0 0 0 3px rgba(124,58,237,.15); }
.cap-preview {
  position:relative;
  aspect-ratio:9/16;
  overflow:hidden;
  display:flex; align-items:flex-end; justify-content:center;
  padding-bottom:14%;
}
.cap-preview-bg {
  position:absolute; inset:0;
  background:linear-gradient(160deg,#1e293b 0%,#334155 50%,#1e3a5f 100%);
}
.cap-preview-scrim {
  position:absolute; bottom:0; left:0; right:0; height:45%;
  background:linear-gradient(to top,rgba(0,0,0,.55),transparent);
}
.cap-preview-text {
  position:relative; z-index:1;
  text-align:center; width:90%;
  line-height:1.2;
}
.cap-label { font-size:12px; font-weight:600; color:#374151; padding:8px 10px; text-align:center; }

/* Effects */
.effect-item { display:flex; align-items:center; justify-content:space-between; padding:16px 18px; border:1.5px solid #e5e7eb; border-radius:12px; margin-bottom:10px; }
.eff-badge { display:inline-block; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:700; margin-left:6px; }
.badge-new     { background:#e0f2fe; color:#0284c7; }
.badge-premium { background:#fef9c3; color:#b45309; }
.toggle { position:relative; width:44px; height:24px; background:#e5e7eb; border-radius:999px; cursor:pointer; transition:background .2s; flex-shrink:0; border:none; outline:none; }
.toggle.on { background:#7c3aed; }
.toggle::after { content:''; position:absolute; top:3px; left:3px; width:18px; height:18px; border-radius:50%; background:#fff; transition:transform .2s; box-shadow:0 1px 3px rgba(0,0,0,.2); }
.toggle.on::after { transform:translateX(20px); }

/* Social */
.social-item { display:flex; align-items:center; gap:12px; padding:14px 18px; border:1.5px solid #e5e7eb; border-radius:12px; margin-bottom:12px; }

/* Inputs */
.wiz-input,.wiz-select,.wiz-textarea { width:100%; border:1.5px solid #e5e7eb; border-radius:10px; padding:12px 14px; font-size:15px; color:#111827; background:#fff; outline:none; transition:border-color .15s; box-sizing:border-box; }
.wiz-input:focus,.wiz-select:focus,.wiz-textarea:focus { border-color:#7c3aed; }
.wiz-textarea { resize:vertical; min-height:100px; font-family:inherit; }
.wiz-label { font-size:14px; font-weight:600; color:#111827; margin-bottom:8px; display:block; }
.char-count { font-size:12px; color:#9ca3af; }

/* Upload zone */
.upload-zone { border:2px dashed #e5e7eb; border-radius:12px; padding:36px; text-align:center; cursor:pointer; transition:border-color .15s; }
.upload-zone:hover { border-color:#a78bfa; }

/* Step visibility — class-based to avoid Tailwind CDN conflicts */
.wiz-step         { display: none !important; }
.wiz-step.active  { display: block !important; }

/* Scrollable step body — keeps Continue/Create always visible */
.wiz-body { max-height: calc(100vh - 320px); overflow-y: auto; padding-right: 4px; }

/* Nav */
.wiz-nav { display:flex; justify-content:space-between; align-items:center; padding-top:24px; border-top:1px solid #f3f4f6; margin-top:32px; }
.btn-back { display:flex; align-items:center; gap:6px; padding:12px 22px; border:1.5px solid #e5e7eb; border-radius:10px; background:#fff; color:#374151; font-size:15px; font-weight:500; cursor:pointer; transition:border-color .15s; }
.btn-back:hover { border-color:#6b7280; }
.btn-next { display:flex; align-items:center; gap:6px; padding:12px 26px; border-radius:10px; background:#7c3aed; color:#fff; font-size:15px; font-weight:600; cursor:pointer; border:none; transition:background .15s; }
.btn-next:hover { background:#6d28d9; }
.btn-next:disabled { opacity:.5; cursor:not-allowed; }
.err-box { display:none; background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.25); border-radius:10px; padding:12px 16px; color:#dc2626; font-size:14px; margin-bottom:16px; }
@keyframes spin { to { transform:rotate(360deg); } }
</style>

<div id="reel-wizard" style="padding-top:80px;padding-bottom:60px;">
<div style="max-width:720px;margin:0 auto;padding:0 20px;">

  <!-- Progress -->
  <div class="wiz-progress" id="wizProg">
    <% for(let i=0;i<5;i++){%><div class="wiz-seg" id="seg<%=i%>"></div><%}%>
  </div>

  <!-- ── STEP 1: Niche ──────────────────────────────────────────────────── -->
  <div id="step-1" class="wiz-step active">
    <h2 class="step-title">Choose your niche <span class="step-badge">Step 1 of 5</span></h2>
    <p class="step-sub">Select a preset or describe your own niche</p>
    <div id="s1err" class="err-box"></div>

    <div class="wiz-tabs">
      <button class="wiz-tab active" id="t1a" onclick="sTab(1,'a')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        Presets
      </button>
      <button class="wiz-tab" id="t1b" onclick="sTab(1,'b')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/></svg>
        Custom
      </button>
    </div>

    <div id="p1a" class="wiz-body">
      <% [
        ['Scary Stories','Scary stories that give you goosebumps'],
        ['History','Viral videos about history spanning from ancient times to the modern day.'],
        ['True Crime','Viral videos about true crime stories.'],
        ['Stoic Motivation','Viral videos about stoic philosophy and life lessons.'],
        ['Finance Tips','Smart money habits and financial freedom strategies.'],
        ['Motivation','Inspirational content to push people to their limits.'],
        ['Biblical Stories','Timeless stories from the Bible brought to life.'],
        ['Mythology','Ancient myths and legends from around the world.'],
        ['Anime Stories','Epic anime-inspired story arcs and character arcs.'],
        ['Act of Kindness','Heartwarming stories of humans helping each other.'],
        ['Tech Tips','Quick and useful technology tips for everyday life.'],
        ['Health Hacks','Simple daily habits for a healthier and longer life.'],
      ].forEach(n => { %>
      <div class="niche-item" onclick="pickNiche('<%= n[0] %>')" data-niche="<%= n[0] %>">
        <div class="niche-item-title"><%= n[0] %></div>
        <div class="niche-item-desc"><%= n[1] %></div>
      </div>
      <% }) %>
    </div>

    <div id="p1b" class="wiz-body" style="display:none;">
      <div style="margin-bottom:20px;">
        <label class="wiz-label">Niche <span style="color:red">*</span></label>
        <textarea id="customNiche" class="wiz-textarea" maxlength="5000"
          placeholder="Describe your content focus, e.g.: 'Weird historical facts that sound fake but are real, delivered in a casual conversational tone with humor'"
          oninput="cc('customNiche','cc1',5000)"></textarea>
        <div style="display:flex;justify-content:space-between;margin-top:4px;">
          <span style="font-size:13px;color:#7c3aed;">Describe your topic</span>
          <span class="char-count" id="cc1">0/5000</span>
        </div>
      </div>
      <div>
        <label class="wiz-label">Example script <span class="opt-badge">Optional</span></label>
        <textarea id="exScript" class="wiz-textarea" style="min-height:130px;" maxlength="2000"
          placeholder="Paste an example of how you want your videos to sound, e.g.:&#10;&#10;&quot;Okay so get this — in 1932, Australia literally declared war on emus...&quot;"
          oninput="cc('exScript','cc2',2000)"></textarea>
        <div style="display:flex;justify-content:space-between;margin-top:4px;">
          <span style="font-size:13px;color:#7c3aed;">AI will match this style and tone</span>
          <span class="char-count" id="cc2">0/2000</span>
        </div>
      </div>
    </div>

    <div class="wiz-nav">
      <div></div>
      <button class="btn-next" onclick="go(2)">Continue <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
    </div>
  </div>

  <!-- ── STEP 2: Language & Voice ────────────────────────────────────────── -->
  <div id="step-2" class="wiz-step" style="display:none;">
    <h2 class="step-title">Language &amp; Voice <span class="step-badge">Step 2 of 5</span></h2>
    <p class="step-sub">Choose the language and voice style for your video</p>

    <div class="wiz-body">
    <div style="margin-bottom:22px;">
      <label class="wiz-label">Language</label>
      <select id="langSel" class="wiz-select">
        <option value="en">🇬🇧 English</option>
        <option value="hi">🇮🇳 Hindi</option>
        <option value="es">🇪🇸 Spanish</option>
        <option value="fr">🇫🇷 French</option>
        <option value="de">🇩🇪 German</option>
        <option value="pt">🇧🇷 Portuguese</option>
        <option value="ja">🇯🇵 Japanese</option>
        <option value="ko">🇰🇷 Korean</option>
      </select>
    </div>

    <label class="wiz-label">Voice Style</label>
    <div class="wiz-card">
      <% [
        ['alloy',   'Alloy',   'Neutral',  false, 'Neutral &amp; balanced — great for any content.'],
        ['echo',    'Echo',    'Male',     false, 'Deep &amp; authoritative — the well known voice of TikTok.'],
        ['fable',   'Fable',   'Male',     false, 'British &amp; storytelling — ideal for narratives.'],
        ['onyx',    'Onyx',    'Male',     false, 'Rich &amp; powerful — perfect for storytelling.'],
        ['nova',    'Nova',    'Female',   true,  'Warm &amp; friendly — great for lifestyle content.'],
        ['shimmer', 'Shimmer', 'Female',   true,  'Soft &amp; calm — ideal for relaxing content.'],
      ].forEach((v,vi) => { %>
      <div class="voice-item <%= vi===0?'selected':'' %>" onclick="pickVoice('<%= v[0] %>')" data-voice="<%= v[0] %>">
        <div style="display:flex;align-items:center;gap:12px;flex:1;">
          <div class="v-radio"><div class="v-dot"></div></div>
          <div>
            <div style="display:flex;align-items:center;">
              <span style="font-size:15px;font-weight:700;color:#111827;"><%= v[1] %></span>
              <span class="v-badge <%= v[3]?'female':'' %>"><%= v[2] %></span>
            </div>
            <div style="font-size:13px;color:#6b7280;margin-top:2px;"><%- v[4] %></div>
          </div>
        </div>
        <button class="play-btn" onclick="event.stopPropagation();playVoice('<%= v[0] %>',this)" title="Preview voice" style="width:34px;height:34px;border-radius:8px;border:1.5px solid #e5e7eb;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#374151;flex-shrink:0;">
          <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </button>
      </div>
      <% }) %>
    </div>
    </div><!-- /wiz-body -->

    <div class="wiz-nav">
      <button class="btn-back" onclick="go(1)"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg> Back</button>
      <button class="btn-next" onclick="go(3)">Continue <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
    </div>
  </div>

  <!-- ── STEP 3: Background Music ────────────────────────────────────────── -->
  <div id="step-3" class="wiz-step" style="display:none;">
    <h2 class="step-title">Background Music <span class="step-badge">Step 3 of 5</span></h2>
    <p class="step-sub">Choose a preset track or upload your own — makes your video 10× more engaging</p>

    <div class="wiz-tabs">
      <button class="wiz-tab active" id="t3a" onclick="sTab(3,'a')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        Preset music
      </button>
      <button class="wiz-tab" id="t3b" onclick="sTab(3,'b')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 19l7-7 3 3-7 7-3-3z"/></svg>
        Custom
      </button>
    </div>

    <div id="p3a" class="wiz-body">
      <% if (!availableMusic || availableMusic.length === 0) { %>
      <div style="text-align:center;padding:24px 0;color:#9ca3af;font-size:14px;">No music tracks uploaded yet. Upload them from the admin panel.</div>
      <% } %>
      <% (availableMusic || []).forEach(m => { %>
      <div class="music-item" onclick="toggleMusic('<%= m[0] %>')" data-music="<%= m[0] %>">
        <div class="music-color" style="background:<%= m[3] %>;"></div>
        <div style="flex:1;">
          <div style="font-size:14px;font-weight:600;color:#111827;"><%= m[1] %></div>
          <div style="font-size:13px;color:#9ca3af;"><%= m[2] %></div>
        </div>
        <button class="play-btn" onclick="event.stopPropagation();playMusic('<%= m[0] %>',this)" title="Preview music" style="width:34px;height:34px;border-radius:8px;border:1.5px solid #e5e7eb;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#374151;flex-shrink:0;">
          <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </button>
      </div>
      <% }) %>
    </div>

    <div id="p3b" class="wiz-body" style="display:none;">
      <label class="wiz-label">Upload your own background music</label>
      <div style="font-size:13px;color:#9ca3af;margin-bottom:14px;">MP3 or WAV · up to 15MB · plays softly under the voiceover</div>
      <input type="file" id="customMusicFile" accept=".mp3,.wav,audio/mpeg,audio/wav" style="display:none;" onchange="onCustomMusicSelected(this)">
      <div class="upload-zone" onclick="document.getElementById('customMusicFile').click()" id="customMusicZone">
        <svg width="28" height="28" fill="none" stroke="#9ca3af" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 10px;display:block;"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        <div id="customMusicName" style="font-size:14px;font-weight:600;color:#374151;">Click to upload or drag &amp; drop</div>
        <div style="font-size:13px;color:#9ca3af;margin-top:4px;">MP3, WAV up to 15MB</div>
      </div>
      <div id="customMusicPreviewWrap" style="display:none;margin-top:14px;">
        <audio id="customMusicPreview" controls style="width:100%;border-radius:8px;"></audio>
        <button onclick="clearCustomMusic()" style="margin-top:8px;font-size:13px;color:#dc2626;background:none;border:none;cursor:pointer;padding:0;">✕ Remove</button>
      </div>
    </div>

    <div class="wiz-nav">
      <button class="btn-back" onclick="go(2)"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg> Back</button>
      <button class="btn-next" onclick="go(4)">Continue <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
    </div>
  </div>

  <!-- ── STEP 4: Art Style ───────────────────────────────────────────────── -->
  <div id="step-4" class="wiz-step" style="display:none;">
    <h2 class="step-title">Art Style <span class="step-badge">Step 4 of 5</span></h2>
    <p class="step-sub">Choose the visual style for your video</p>

    <div class="wiz-body">
    <div class="art-grid">
      <% [
        ['cinematic',  'Cinematic',   'linear-gradient(160deg,#0f172a,#1e293b,#334155)', '🎬'],
        ['creepy',     'Creepy Comic','linear-gradient(160deg,#1c0a00,#3b1f0a,#5c2e0e)', '👻'],
        ['vibrant',    'Modern Cartoon','linear-gradient(160deg,#7c3aed,#ec4899,#f97316)', '✨'],
        ['disney',     'Disney',      'linear-gradient(160deg,#1e3a5f,#2563eb,#60a5fa)',  '🏰'],
        ['nature',     'Nature',      'linear-gradient(160deg,#052e16,#166534,#4ade80)',  '🌿'],
        ['urban',      'Urban',       'linear-gradient(160deg,#111827,#374151,#6b7280)',  '🏙️'],
        ['fantasy',    'Fantasy',     'linear-gradient(160deg,#4a044e,#a21caf,#e879f9)',  '🔮'],
        ['historical', 'Historical',  'linear-gradient(160deg,#451a03,#92400e,#d97706)',  '📜'],
        ['realistic',  'Realistic',   'linear-gradient(160deg,#1c2526,#2d4a3e,#4a7c59)',  '📷'],
      ].forEach((a,ai) => { %>
      <div class="art-item <%= ai===0?'selected':'' %>" onclick="pickArt('<%= a[0] %>')" data-art="<%= a[0] %>">
        <div class="art-thumb" style="background:<%= a[2] %>;border-radius:9px;position:relative;overflow:hidden;">
          <% if (typeof artGifs !== 'undefined' && artGifs[a[0]]) { %>
            <img src="<%= artGifs[a[0]] %>" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" alt="<%= a[1] %>">
          <% } else { %>
            <span style="font-size:2.2rem;"><%= a[3] %></span>
          <% } %>
        </div>
        <div class="art-label"><%= a[1] %></div>
      </div>
      <% }) %>
    </div>
    </div><!-- /wiz-body -->

    <div class="wiz-nav">
      <button class="btn-back" onclick="go(3)"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg> Back</button>
      <button class="btn-next" onclick="go(5)">Continue <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
    </div>
  </div>

  <!-- ── STEP 5: Effects & Duration ───────────────────────────────────────── -->
  <div id="step-5" class="wiz-step" style="display:none;">
    <h2 class="step-title">Effects &amp; Duration <span class="step-badge">Step 5 of 5</span></h2>
    <p class="step-sub">Choose effects and video duration — captions are added automatically</p>
    <div id="s5err" class="err-box"></div>

    <div class="wiz-body">
    <div class="cap-grid" style="display:none"><!-- caption picker removed -->
    </div>

    <!-- Effects & Duration -->
    <div style="margin-top:26px;padding-top:22px;border-top:1px solid #f3f4f6;">
      <div style="font-size:14px;font-weight:700;color:#111827;margin-bottom:14px;">Effects &amp; Duration</div>
      <div class="effect-item">
        <div>
          <div style="font-size:15px;font-weight:700;color:#111827;display:flex;align-items:center;">Shake effect <span class="eff-badge badge-new">NEW</span></div>
          <div style="font-size:13px;color:#6b7280;margin-top:3px;">Subjects pop out with eerie motion — great for horror, thriller, and suspenseful stories.</div>
        </div>
        <button class="toggle" onclick="toggleEffect('shake',this)" type="button"></button>
      </div>
      <div class="effect-item">
        <div>
          <div style="font-size:15px;font-weight:700;color:#111827;display:flex;align-items:center;">Film grain <span class="eff-badge badge-new">NEW</span></div>
          <div style="font-size:13px;color:#6b7280;margin-top:3px;">Add an old film look with scanlines, dust particles, noise, and a subtle vignette.</div>
        </div>
        <button class="toggle" onclick="toggleEffect('filmGrain',this)" type="button"></button>
      </div>
      <div style="margin-top:18px;">
        <label class="wiz-label" style="display:flex;align-items:center;gap:6px;">
          Video Duration
          <svg width="14" height="14" fill="none" stroke="#9ca3af" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </label>
        <select id="durSel" class="wiz-select" onchange="refreshReelPrice()">
          <option value="30-40">Short (~45 sec) — ₹350</option>
          <option value="60-70">Long (~90 sec) — ₹700</option>
        </select>
      </div>
    </div>
    </div><!-- /wiz-body -->

    <div class="wiz-nav">
      <button class="btn-back" onclick="go(4)"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg> Back</button>
      <button class="btn-next" id="createBtn" onclick="handleCreate()">
        <span id="createBtnTxt">Generate Video</span>
        <span id="createBtnIco"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
      </button>
    </div>
  </div>


</div><!-- /max-width -->
</div><!-- /reel-wizard -->

<!-- ── Payment Modal ──────────────────────────────────────────────────────── -->
<div id="payOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:9999;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:20px;padding:32px 28px;max-width:420px;width:90%;box-shadow:0 25px 60px rgba(0,0,0,0.3);position:relative;">
    <button onclick="closePayModal()" style="position:absolute;top:16px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:#9ca3af;line-height:1;">✕</button>

    <div style="text-align:center;margin-bottom:24px;">
      <div style="width:52px;height:52px;background:#f3f0ff;border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
        <svg width="24" height="24" fill="none" stroke="#7c3aed" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg>
      </div>
      <h3 style="font-size:1.3rem;font-weight:800;color:#111827;margin:0 0 6px;">Generate this Reel</h3>
      <p style="font-size:14px;color:#6b7280;margin:0;">One-time payment — download & keep forever</p>
    </div>

    <% if (walletBalance > 0) { %>
    <!-- Wallet option -->
    <div style="background:#f0fdf4;border:1.5px solid #86efac;border-radius:12px;padding:13px 16px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;background:#dcfce7;border-radius:9px;display:flex;align-items:center;justify-content:center;">
          <svg width="18" height="18" fill="none" stroke="#16a34a" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-2"/><path d="M16 12h5v4h-5a2 2 0 0 1 0-4z"/></svg>
        </div>
        <div>
          <div style="font-size:14px;font-weight:700;color:#15803d;">Wallet Balance</div>
          <div style="font-size:13px;color:#16a34a;">₹<%= walletBalance.toFixed(2) %> available</div>
        </div>
      </div>
      <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
        <input type="checkbox" id="useWalletChk" onchange="onWalletToggle()" style="width:18px;height:18px;accent-color:#7c3aed;cursor:pointer;">
        <span style="font-size:13px;font-weight:600;color:#374151;">Use</span>
      </label>
    </div>
    <% } %>

    <!-- Coupon input -->
    <div style="margin-bottom:18px;">
      <div style="display:flex;gap:8px;">
        <input type="text" id="payCoupon" placeholder="Coupon code (optional)" class="wiz-input"
          style="flex:1;text-transform:uppercase;font-size:14px;"
          oninput="this.value=this.value.toUpperCase()">
        <button onclick="applyPayCoupon()"
          style="padding:12px 14px;background:#f3f0ff;border:1.5px solid #7c3aed;border-radius:10px;color:#7c3aed;font-weight:600;cursor:pointer;white-space:nowrap;font-size:14px;">
          Apply
        </button>
      </div>
      <div id="payCouponMsg" style="font-size:13px;margin-top:6px;min-height:18px;"></div>
    </div>

    <!-- Price display -->
    <div style="background:#f9fafb;border-radius:12px;padding:16px 18px;margin-bottom:22px;display:flex;align-items:center;justify-content:space-between;">
      <div>
        <div style="font-size:14px;font-weight:600;color:#374151;">Total</div>
        <div style="font-size:12px;color:#9ca3af;margin-top:2px;">One video · instant download</div>
      </div>
      <div style="text-align:right;">
        <span id="payOriginalPrice" style="font-size:13px;color:#9ca3af;text-decoration:line-through;display:none;margin-right:6px;">₹…</span>
        <span id="payFinalPrice" style="font-size:1.6rem;font-weight:800;color:#111827;">₹…</span>
      </div>
    </div>

    <!-- Pay button -->
    <button id="payBtn" onclick="startVideoPay()"
      style="width:100%;padding:14px;background:#7c3aed;color:#fff;border:none;border-radius:12px;font-size:16px;font-weight:700;cursor:pointer;transition:background .15s;">
      <span id="payBtnTxt">Pay &amp; Generate</span>
    </button>
  </div>
</div>

<script>
const S = { step:1, niche:'', exScript:'', voice:'alloy', music:[], art:'cinematic', cap:'bold-stroke', effects:{ filmGrain:false, shake:false, animatedHook:false } };
const needsPayment = <%= totalReels %> > 0;

function saveWizardState() {
  try {
    localStorage.setItem('reelWizardState', JSON.stringify({
      ...S,
      topic:       document.getElementById('topicInput')?.value  || '',
      customNiche: document.getElementById('customNiche')?.value || '',
      language:    document.getElementById('langSel')?.value     || 'en',
      duration:    document.getElementById('durSel')?.value      || '30-40',
      savedAt:     Date.now(),
    }));
  } catch {}
}
function clearWizardState() {
  try { localStorage.removeItem('reelWizardState'); } catch {}
}
let payAppliedCoupon = null;
let payFinalAmount   = 350;
let reelBasePrice    = 350; // overwritten when duration changes or on DOMContentLoaded

async function refreshReelPrice() {
  try {
    const dur = document.getElementById('durSel')?.value || '30-40';
    const pr  = await fetch(`/api/reels/video-pay/price?duration=${dur}`).then(r => r.json());
    reelBasePrice  = pr.price || (dur === '60-70' ? 700 : 350);
    payFinalAmount = reelBasePrice;
    payAppliedCoupon = null;
    document.getElementById('payOriginalPrice').style.display = 'none';
    document.getElementById('payOriginalPrice').textContent   = '₹' + reelBasePrice;
    document.getElementById('payFinalPrice').textContent      = '₹' + reelBasePrice;
    document.getElementById('payBtnTxt').textContent          = `Pay ₹${reelBasePrice} & Generate`;
    const msgEl = document.getElementById('payCouponMsg');
    if (msgEl) msgEl.textContent = '';
  } catch {}
}

// ── Voice preview player ──────────────────────────────────────────────────────
const PLAY_ICON  = `<svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>`;
const PAUSE_ICON = `<svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>`;
const SPIN_ICON  = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:spin 1s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`;

let _activeAudio = null;
let _activeBtn   = null;

function _resetBtn(btn) { if (btn) btn.innerHTML = PLAY_ICON; }

function playVoice(voice, btn) {
  // If this button is already playing, pause it
  if (_activeAudio && _activeBtn === btn) {
    _activeAudio.pause();
    _activeAudio = null;
    _activeBtn   = null;
    _resetBtn(btn);
    return;
  }

  // Stop any other playing preview
  if (_activeAudio) { _activeAudio.pause(); _resetBtn(_activeBtn); }

  btn.innerHTML  = SPIN_ICON;
  _activeBtn     = btn;

  const audio    = new Audio(`/reels/voice-preview/${voice}`);
  _activeAudio   = audio;

  audio.oncanplaythrough = () => {
    if (_activeAudio !== audio) return;
    btn.innerHTML = PAUSE_ICON;
    audio.play();
  };
  audio.onended  = () => { _resetBtn(btn); _activeAudio = null; _activeBtn = null; };
  audio.onerror  = () => { _resetBtn(btn); _activeAudio = null; _activeBtn = null; };
  audio.load();
}

// ── Music preview player ──────────────────────────────────────────────────────
let _activeMusicAudio = null;
let _activeMusicBtn   = null;

function playMusic(id, btn) {
  if (_activeMusicAudio && _activeMusicBtn === btn) {
    _activeMusicAudio.pause();
    _activeMusicAudio = null;
    _activeMusicBtn   = null;
    btn.innerHTML     = PLAY_ICON;
    return;
  }

  if (_activeMusicAudio) { _activeMusicAudio.pause(); _resetBtn(_activeMusicBtn); }

  btn.innerHTML   = SPIN_ICON;
  _activeMusicBtn = btn;

  const audio     = new Audio(`/music/preview-${id}.mp3`);
  _activeMusicAudio = audio;

  audio.oncanplaythrough = () => {
    if (_activeMusicAudio !== audio) return;
    btn.innerHTML = PAUSE_ICON;
    audio.play();
  };
  audio.onended  = () => { btn.innerHTML = PLAY_ICON; _activeMusicAudio = null; _activeMusicBtn = null; };
  audio.onerror  = () => { btn.innerHTML = PLAY_ICON; _activeMusicAudio = null; _activeMusicBtn = null; };
  audio.load();
}

function updProg(n) {
  for(let i=0;i<5;i++) {
    document.getElementById('seg'+i).classList.toggle('done', i < n);
  }
}

// ── Custom music upload ───────────────────────────────────────────────────────
function onCustomMusicSelected(input) {
  const file = input.files[0];
  if (!file) return;
  if (file.size > 15 * 1024 * 1024) {
    alert('File too large — maximum 15MB');
    input.value = '';
    return;
  }
  document.getElementById('customMusicName').textContent = '🎵 ' + file.name;
  document.getElementById('customMusicZone').style.borderColor = '#7c3aed';
  S.customMusicFile = file;
  // Show inline audio preview
  const preview = document.getElementById('customMusicPreview');
  preview.src = URL.createObjectURL(file);
  document.getElementById('customMusicPreviewWrap').style.display = 'block';
}

function clearCustomMusic() {
  S.customMusicFile = null;
  document.getElementById('customMusicFile').value = '';
  document.getElementById('customMusicName').textContent = 'Click to upload or drag & drop';
  document.getElementById('customMusicZone').style.borderColor = '';
  document.getElementById('customMusicPreviewWrap').style.display = 'none';
  document.getElementById('customMusicPreview').src = '';
}

function go(n) {
  // Validate step 1
  if (S.step===1 && n>1) {
    const isCustom = document.getElementById('p1b').style.display !== 'none';
    if (isCustom) {
      S.niche = document.getElementById('customNiche').value.trim();
      if (!S.niche || S.niche.length < 3) { showErr('s1err','Please describe your niche (at least 3 characters).'); return; }
      S.exScript = document.getElementById('exScript').value.trim();
    } else if (!S.niche) { showErr('s1err','Please select a niche to continue.'); return; }
    hideErr('s1err');
  }
  document.getElementById('step-'+S.step).classList.remove('active');
  S.step = n;
  document.getElementById('step-'+n).classList.add('active');
  updProg(n);
  window.scrollTo({top:0,behavior:'smooth'});
  saveWizardState();
}

function sTab(step, panel) {
  const panels = step===1 ? ['p1a','p1b'] : ['p3a','p3b'];
  const tabs    = step===1 ? ['t1a','t1b'] : ['t3a','t3b'];
  const idx     = panel==='a' ? 0 : 1;
  panels.forEach((p,i) => document.getElementById(p).style.display = i===idx?'block':'none');
  tabs.forEach((t,i)   => document.getElementById(t).classList.toggle('active', i===idx));
}

function pickNiche(n) {
  document.querySelectorAll('.niche-item').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-niche="'+n+'"]').classList.add('selected');
  S.niche = n; hideErr('s1err'); saveWizardState();
}
function pickVoice(v) {
  document.querySelectorAll('.voice-item').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-voice="'+v+'"]').classList.add('selected');
  S.voice = v; saveWizardState();
}
function toggleMusic(id) {
  const el = document.querySelector('[data-music="'+id+'"]');
  el.classList.toggle('selected');
  const i = S.music.indexOf(id);
  if(i===-1) S.music.push(id); else S.music.splice(i,1);
  saveWizardState();
}
function pickArt(id) {
  document.querySelectorAll('.art-item').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-art="'+id+'"]').classList.add('selected');
  S.art = id; saveWizardState();
}
function toggleEffect(key, btn) {
  S.effects[key] = !S.effects[key];
  btn.classList.toggle('on', S.effects[key]);
  saveWizardState();
}
function pickCap(id) {
  document.querySelectorAll('.cap-item').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-cap="'+id+'"]').classList.add('selected');
  S.cap = id; saveWizardState();
}
function cc(inputId, countId, max) {
  document.getElementById(countId).textContent = document.getElementById(inputId).value.length + '/' + max;
}
function showErr(id, msg) { const el=document.getElementById(id); el.textContent=msg; el.style.display='block'; }
function hideErr(id)       { const el=document.getElementById(id); if(el) el.style.display='none'; }

// ── Payment modal helpers ─────────────────────────────────────────────────────
function openPayModal()  { document.getElementById('payOverlay').style.display = 'flex'; }
function closePayModal() { document.getElementById('payOverlay').style.display = 'none'; }

async function applyPayCoupon() {
  const code  = document.getElementById('payCoupon').value.trim();
  if (!code) return;
  const msgEl = document.getElementById('payCouponMsg');
  msgEl.textContent = 'Checking…'; msgEl.style.color = '#6b7280';
  try {
    const res  = await fetch('/api/reels/video-pay/apply-promo', {
      method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ code }),
    });
    const data = await res.json();
    if (data.valid) {
      payAppliedCoupon = data;
      payFinalAmount   = data.discountType === 'percent'
        ? Math.max(1, Math.round(reelBasePrice * (1 - data.discountValue / 100)))
        : Math.max(1, reelBasePrice - data.discountValue);
      msgEl.textContent = data.message; msgEl.style.color = '#059669';
      document.getElementById('payOriginalPrice').style.display = 'inline';
      document.getElementById('payFinalPrice').textContent      = '₹' + payFinalAmount;
      document.getElementById('payBtnTxt').textContent          = `Pay ₹${payFinalAmount} & Generate`;
    } else {
      payAppliedCoupon = null; payFinalAmount = reelBasePrice;
      msgEl.textContent = data.message; msgEl.style.color = '#dc2626';
      document.getElementById('payOriginalPrice').style.display = 'none';
      document.getElementById('payFinalPrice').textContent      = '₹' + reelBasePrice;
      document.getElementById('payBtnTxt').textContent          = `Pay ₹${reelBasePrice} & Generate`;
    }
  } catch(e) {
    msgEl.textContent = 'Could not apply coupon.'; msgEl.style.color = '#dc2626';
  }
}

function onWalletToggle() {
  const chk = document.getElementById('useWalletChk');
  if (!chk) return;
  const walletBal = <%= walletBalance %>;
  if (chk.checked && walletBal >= payFinalAmount) {
    document.getElementById('payBtnTxt').textContent = `Pay with Wallet — Free`;
    document.getElementById('payFinalPrice').textContent = '₹0';
  } else {
    document.getElementById('payBtnTxt').textContent = `Pay ₹${payFinalAmount} & Generate`;
    document.getElementById('payFinalPrice').textContent = '₹' + payFinalAmount;
  }
}

async function startVideoPay() {
  const btn      = document.getElementById('payBtn');
  const btnTxt   = document.getElementById('payBtnTxt');
  const useWallet = !!document.getElementById('useWalletChk')?.checked;
  btn.disabled = true; btnTxt.textContent = 'Processing…';
  try {
    const orderRes = await fetch('/api/reels/video-pay/create-order', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ couponCode: payAppliedCoupon?.code || null, useWallet, duration: document.getElementById('durSel')?.value || '30-40' }),
    });
    const order = await orderRes.json();
    if (!order.success) throw new Error(order.message || 'Order creation failed');

    // Wallet-only: skip Razorpay entirely
    if (order.walletOnly) {
      closePayModal();
      await doGenerate({ walletOnly: true });
      return;
    }

    const rzp = new Razorpay({
      key:         '<%= razorpayKey %>',
      amount:      order.amount * 100,
      currency:    'INR',
      name:        'SmrAI Studio',
      description: 'AI Reel — ₹' + order.amount,
      order_id:    order.orderId,
      handler: async function(response) {
        closePayModal();
        await doGenerate({
          razorpay_order_id:   response.razorpay_order_id,
          razorpay_payment_id: response.razorpay_payment_id,
          razorpay_signature:  response.razorpay_signature,
          walletDeduction:     order.walletDeduction || 0,
        });
      },
      modal: { ondismiss: function() { btn.disabled = false; btnTxt.textContent = `Pay ₹${payFinalAmount} & Generate`; } },
      prefill: { name: '<%= currentUser.name || "" %>', email: '<%= currentUser.email || "" %>' },
      theme: { color: '#7c3aed' },
    });
    rzp.open();
  } catch(err) {
    btn.disabled = false; btnTxt.textContent = `Pay ₹${payFinalAmount} & Generate`;
    showErr('s5err', err.message);
    closePayModal();
  }
}

// ── Create entry point ────────────────────────────────────────────────────────
function handleCreate() {
  const topic = S.niche;
  if (!topic || topic.length < 3) { showErr('s5err', 'Please select a niche to continue.'); return; }
  hideErr('s5err');

  if (needsPayment) {
    openPayModal();
  } else {
    doGenerate({});
  }
}

async function doGenerate(paymentFields) {
  const topic = S.niche;

  const btn = document.getElementById('createBtn');
  document.getElementById('createBtnTxt').textContent = 'Generating…';
  document.getElementById('createBtnIco').innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>';
  btn.disabled = true;

  try {
    // Upload custom music file first (if user selected one)
    let customMusicPath = null;
    if (S.customMusicFile) {
      const fd = new FormData();
      fd.append('file', S.customMusicFile);
      const upRes  = await fetch('/reels/upload-music', { method: 'POST', body: fd });
      const upData = await upRes.json();
      if (upData.path) customMusicPath = upData.path;
    }

    const res  = await fetch('/reels/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        topic,
        voice:           S.voice,
        language:        document.getElementById('langSel')?.value || 'en',
        artStyle:        S.art,
        duration:        document.getElementById('durSel')?.value || '30-40',
        music:           S.music,
        effects:         S.effects,
        exScript:        S.exScript || '',
        customMusicPath,
        ...paymentFields,
      }),
    });
    const data = await res.json();
    if (!res.ok || data.error) throw new Error(data.error || 'Server error. Please try again.');
    clearWizardState();
    window.location.href = '/reels/loading/' + data.reel_id;
  } catch(err) {
    showErr('s5err', err.message);
    document.getElementById('createBtnTxt').textContent = 'Generate Video';
    document.getElementById('createBtnIco').innerHTML = '<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>';
    btn.disabled = false;
  }
}

async function disconnectAccount(id) {
  if (!confirm('Disconnect this account?')) return;
  try {
    await fetch(`/api/reels/social-accounts/${id}`, { method: 'DELETE' });
    document.getElementById('sa-' + id)?.remove();
  } catch (e) { /* silent */ }
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

document.addEventListener('DOMContentLoaded', async () => {
  const qp = new URLSearchParams(window.location.search);

  // Restore wizard state saved before YouTube OAuth redirect
  const savedState = sessionStorage.getItem('wizState');
  if (savedState) {
    try { Object.assign(S, JSON.parse(savedState)); } catch(e) {}
    sessionStorage.removeItem('wizState');
  }

  // Restore wizard state saved when user was redirected to subscribe (402)
  const pending = sessionStorage.getItem('reels_pending');
  if (pending) {
    try {
      const p = JSON.parse(pending);
      sessionStorage.removeItem('reels_pending');

      Object.assign(S, {
        niche:    p.niche    || S.niche,
        exScript: p.exScript || '',
        voice:    p.voice    || S.voice,
        music:    p.music    || S.music,
        art:      p.art      || S.art,
        cap:      p.cap      || S.cap,
        effects:  p.effects  || S.effects,
      });

      // Restore niche selection visually
      if (p.niche) {
        const nicheEl = document.querySelector('[data-niche="' + p.niche + '"]');
        if (nicheEl) { pickNiche(p.niche); }
        else { sTab(1,'b'); document.getElementById('customNiche').value = p.niche; S.niche = p.niche; }
      }

      // Restore language & duration dropdowns
      if (p.language) { const el = document.getElementById('langSel'); if (el) el.value = p.language; }
      if (p.duration) { const el = document.getElementById('durSel');  if (el) el.value = p.duration; }

      // Jump straight to step 5 (last step)
      document.getElementById('step-1').classList.remove('active');
      S.step = 5;
      document.getElementById('step-5').classList.add('active');
      updProg(5);
    } catch(e) {}
  }

  // Restore general wizard state from localStorage (handles refresh / network drop)
  if (!savedState && !pending) {
    const wizLocal = localStorage.getItem('reelWizardState');
    if (wizLocal) {
      try {
        const ws = JSON.parse(wizLocal);
        if (Date.now() - (ws.savedAt || 0) < 24 * 60 * 60 * 1000) {
          if (ws.topic)    { const el = document.getElementById('topicInput'); if (el) el.value = ws.topic; }
          if (ws.language) { const el = document.getElementById('langSel');   if (el) el.value = ws.language; }
          if (ws.duration) { const el = document.getElementById('durSel');    if (el) el.value = ws.duration; }
          if (ws.niche) {
            const nicheEl = document.querySelector('[data-niche="'+ws.niche+'"]');
            if (nicheEl) { pickNiche(ws.niche); }
            else { sTab(1,'b'); const cn = document.getElementById('customNiche'); if (cn) cn.value = ws.customNiche || ws.niche; S.niche = ws.niche; }
          }
          if (ws.exScript) S.exScript = ws.exScript;
          if (ws.voice)    pickVoice(ws.voice);
          if (ws.music?.length) ws.music.forEach(id => { if (!S.music.includes(id)) toggleMusic(id); });
          if (ws.art)      pickArt(ws.art);
          if (ws.cap) {
            document.querySelectorAll('.cap-item').forEach(el => el.classList.toggle('selected', el.dataset.cap === ws.cap));
            S.cap = ws.cap;
          }
          if (ws.effects) Object.keys(ws.effects).forEach(k => {
            if (ws.effects[k] !== S.effects[k]) {
              S.effects[k] = ws.effects[k];
              document.querySelector('[data-eff="'+k+'"]')?.classList.toggle('active', ws.effects[k]);
            }
          });
          if (ws.step > 1) {
            document.getElementById('step-1').classList.remove('active');
            S.step = ws.step;
            document.getElementById('step-'+ws.step).classList.add('active');
            updProg(ws.step);
          }
        }
      } catch {}
    }
  }

  // Fetch admin-set reel price for current duration
  await refreshReelPrice();

  updProg(1);
  const tp = qp.get('topic');
  if (tp) {
    const match = document.querySelector('[data-niche="'+tp+'"]');
    if (match) { pickNiche(tp); }
    else { sTab(1,'b'); document.getElementById('customNiche').value=tp; cc('customNiche','cc1',5000); S.niche=tp; }
  }

  // Auto-save state when user types topic or custom niche
  document.getElementById('topicInput')?.addEventListener('input', saveWizardState);
  document.getElementById('customNiche')?.addEventListener('input', saveWizardState);

});
</script>

<%- include('../partials/footer') %>
