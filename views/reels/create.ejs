<script>
const S = { step:1, niche:'', voice:'alloy', music:[], art:'cinematic', cap:'bold-stroke', effects:{ filmGrain:false, shake:false, animatedHook:false } };

// ── Voice preview player ──────────────────────────────────────────────────────
const PLAY_ICON  = `<svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>`;
const PAUSE_ICON = `<svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>`;
const SPIN_ICON  = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:spin 1s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`;

let _activeAudio = null;
let _activeBtn   = null;

function _resetBtn(btn) { if (btn) btn.innerHTML = PLAY_ICON; }

function playVoice(voice, btn) {
  // If this button is already playing, pause it
  if (_activeAudio && _activeBtn === btn) {
    _activeAudio.pause();
    _activeAudio = null;
    _activeBtn   = null;
    _resetBtn(btn);
    return;
  }

  // Stop any other playing preview
  if (_activeAudio) { _activeAudio.pause(); _resetBtn(_activeBtn); }

  btn.innerHTML  = SPIN_ICON;
  _activeBtn     = btn;

  const audio    = new Audio(`/reels/voice-preview/${voice}`);
  _activeAudio   = audio;

  audio.oncanplaythrough = () => {
    if (_activeAudio !== audio) return;
    btn.innerHTML = PAUSE_ICON;
    audio.play();
  };
  audio.onended  = () => { _resetBtn(btn); _activeAudio = null; _activeBtn = null; };
  audio.onerror  = () => { _resetBtn(btn); _activeAudio = null; _activeBtn = null; };
  audio.load();
}

// ── Music preview player ──────────────────────────────────────────────────────
let _activeMusicAudio = null;
let _activeMusicBtn   = null;

function playMusic(id, btn) {
  if (_activeMusicAudio && _activeMusicBtn === btn) {
    _activeMusicAudio.pause();
    _activeMusicAudio = null;
    _activeMusicBtn   = null;
    btn.innerHTML     = PLAY_ICON;
    return;
  }

  if (_activeMusicAudio) { _activeMusicAudio.pause(); _resetBtn(_activeMusicBtn); }

  btn.innerHTML   = SPIN_ICON;
  _activeMusicBtn = btn;

  const audio     = new Audio(`/music/preview-${id}.mp3`);
  _activeMusicAudio = audio;

  audio.oncanplaythrough = () => {
    if (_activeMusicAudio !== audio) return;
    btn.innerHTML = PAUSE_ICON;
    audio.play();
  };
  audio.onended  = () => { btn.innerHTML = PLAY_ICON; _activeMusicAudio = null; _activeMusicBtn = null; };
  audio.onerror  = () => { btn.innerHTML = PLAY_ICON; _activeMusicAudio = null; _activeMusicBtn = null; };
  audio.load();
}

function updProg(n) {
  for(let i=0;i<8;i++) {
    document.getElementById('seg'+i).classList.toggle('done', i < n);
  }
}

function go(n) {
  // Validate step 1
  if (S.step===1 && n>1) {
    const isCustom = document.getElementById('p1b').style.display !== 'none';
    if (isCustom) {
      S.niche = document.getElementById('customNiche').value.trim();
      if (!S.niche || S.niche.length < 3) { showErr('s1err','Please describe your niche (at least 3 characters).'); return; }
    } else if (!S.niche) { showErr('s1err','Please select a niche to continue.'); return; }
    hideErr('s1err');
  }
  document.getElementById('step-'+S.step).classList.remove('active');
  S.step = n;
  document.getElementById('step-'+n).classList.add('active');
  updProg(n);
  window.scrollTo({top:0,behavior:'smooth'});
  if (n === 7) loadSocialAccounts();
}

function sTab(step, panel) {
  const panels = step===1 ? ['p1a','p1b'] : ['p3a','p3b'];
  const tabs    = step===1 ? ['t1a','t1b'] : ['t3a','t3b'];
  const idx     = panel==='a' ? 0 : 1;
  panels.forEach((p,i) => document.getElementById(p).style.display = i===idx?'block':'none');
  tabs.forEach((t,i)   => document.getElementById(t).classList.toggle('active', i===idx));
}

function pickNiche(n) {
  document.querySelectorAll('.niche-item').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-niche="'+n+'"]').classList.add('selected');
  S.niche = n; hideErr('s1err');
}
function pickVoice(v) {
  document.querySelectorAll('.voice-item').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-voice="'+v+'"]').classList.add('selected');
  S.voice = v;
}
function toggleMusic(id) {
  const el = document.querySelector('[data-music="'+id+'"]');
  el.classList.toggle('selected');
  const i = S.music.indexOf(id);
  if(i===-1) S.music.push(id); else S.music.splice(i,1);
}
function pickArt(id) {
  document.querySelectorAll('.art-item').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-art="'+id+'"]').classList.add('selected');
  S.art = id;
}
function toggleEffect(key, btn) {
  S.effects[key] = !S.effects[key];
  btn.classList.toggle('on', S.effects[key]);
}
function pickCap(id) {
  document.querySelectorAll('.cap-item').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-cap="'+id+'"]').classList.add('selected');
  S.cap = id;
}
function cc(inputId, countId, max) {
  document.getElementById(countId).textContent = document.getElementById(inputId).value.length + '/' + max;
}
function showErr(id, msg) { const el=document.getElementById(id); el.textContent=msg; el.style.display='block'; }
function hideErr(id)       { const el=document.getElementById(id); if(el) el.style.display='none'; }

async function handleCreate() {
  const name  = document.getElementById('seriesName').value.trim();
  const topic = name || S.niche;
  if (!topic || topic.length < 3) { showErr('s8err','Please enter a series name.'); return; }
  hideErr('s8err');

  const btn = document.getElementById('createBtn');
  document.getElementById('createBtnTxt').textContent = 'Creating…';
  document.getElementById('createBtnIco').innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>';
  btn.disabled = true;

  try {
    const res  = await fetch('/reels/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        topic,
        voice:        S.voice,
        language:     document.getElementById('langSel')?.value || 'en',
        artStyle:     S.art,
        captionStyle: S.cap,
        duration:     document.getElementById('durSel')?.value || '30-40',
        music:        S.music,
        effects:      S.effects,
      }),
    });
    const data = await res.json();
    if (res.status === 402) { window.location.href = data.redirect || '/reels/pricing'; return; }
    if (!res.ok || data.error) throw new Error(data.error || 'Server error. Please try again.');
    window.location.href = '/reels/loading/' + data.reel_id;
  } catch(err) {
    showErr('s8err', err.message);
    document.getElementById('createBtnTxt').textContent = 'Create Series';
    document.getElementById('createBtnIco').innerHTML = '<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>';
    btn.disabled = false;
  }
}

// ── Step 7: Social account helpers ───────────────────────────────────────────

const YT_ICON = `<svg width="20" height="20" viewBox="0 0 24 24"><path fill="#ef4444" d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`;

async function loadSocialAccounts() {
  const container = document.getElementById('s7-accounts');
  try {
    const res  = await fetch('/api/reels/social-accounts');
    const data = await res.json();
    const accounts = data.accounts || [];

    if (accounts.length === 0) {
      container.innerHTML = '';
      return;
    }

    container.innerHTML = accounts.map(a => `
      <div class="social-item" style="margin-bottom:10px;" id="sa-${a.id}">
        ${a.channel_thumb
          ? `<img src="${a.channel_thumb}" width="32" height="32" style="border-radius:50%;object-fit:cover;flex-shrink:0;" />`
          : YT_ICON
        }
        <div style="flex:1;min-width:0;">
          <div style="font-size:14px;font-weight:600;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escHtml(a.channel_name || 'YouTube Channel')}</div>
          <div style="font-size:12px;color:#9ca3af;">YouTube · Connected</div>
        </div>
        <span style="display:inline-flex;align-items:center;gap:4px;font-size:12px;color:#16a34a;font-weight:600;background:#f0fdf4;padding:3px 10px;border-radius:99px;">
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          Connected
        </span>
        <button onclick="disconnectAccount(${a.id})" type="button"
          style="border:none;background:none;cursor:pointer;color:#9ca3af;font-size:12px;padding:4px 6px;border-radius:6px;transition:color .15s;"
          title="Disconnect">✕</button>
      </div>
    `).join('');
  } catch (e) {
    container.innerHTML = '';
  }
}

function connectYouTube() {
  // Save wizard state to sessionStorage so we can restore after OAuth redirect
  sessionStorage.setItem('wizState', JSON.stringify(S));
  window.location.href = '/auth/youtube';
}

async function disconnectAccount(id) {
  if (!confirm('Disconnect this account?')) return;
  try {
    await fetch(`/api/reels/social-accounts/${id}`, { method: 'DELETE' });
    document.getElementById('sa-' + id)?.remove();
  } catch (e) { /* silent */ }
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

document.addEventListener('DOMContentLoaded', () => {
  const qp = new URLSearchParams(window.location.search);

  // Restore wizard state saved before YouTube OAuth redirect
  const savedState = sessionStorage.getItem('wizState');
  if (savedState) {
    try { Object.assign(S, JSON.parse(savedState)); } catch(e) {}
    sessionStorage.removeItem('wizState');
  }

  const stepParam = parseInt(qp.get('step'), 10);

  if (stepParam === 7 || qp.get('ytConnected') || qp.get('ytError')) {
    // Return from YouTube OAuth — go back to step 7
    go(7);
    loadSocialAccounts();
    if (qp.get('ytError')) {
      const errEl = document.getElementById('s7-error');
      errEl.textContent = 'Could not connect YouTube. Please try again.';
      errEl.style.display = 'block';
    }
  } else {
    updProg(1);
    const tp = qp.get('topic');
    if (tp) {
      const match = document.querySelector('[data-niche="'+tp+'"]');
      if (match) { pickNiche(tp); }
      else { sTab(1,'b'); document.getElementById('customNiche').value=tp; cc('customNiche','cc1',5000); S.niche=tp; }
    }
  }

});
</script>

