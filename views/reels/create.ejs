<%- include('../partials/header', { title: 'Create AI Reel — SmrAI Studio' }) %>
<script src="https://cdn.tailwindcss.com"></script>

<style>
#reel-wizard {
  background: #fff;
  min-height: 100vh;
  color: #111827;
}
.wiz-progress { display:flex; gap:6px; margin-bottom:32px; }
.wiz-seg { height:5px; flex:1; border-radius:999px; background:#e5e7eb; transition:background 0.3s; }
.wiz-seg.done { background:#7c3aed; }
.step-badge { display:inline-block; padding:3px 12px; border-radius:999px; border:1.5px solid #7c3aed; color:#7c3aed; font-size:13px; font-weight:600; margin-left:10px; vertical-align:middle; }
.opt-badge  { display:inline-block; padding:3px 10px; border-radius:999px; border:1.5px solid #7c3aed; color:#7c3aed; font-size:12px; font-weight:600; margin-left:8px; vertical-align:middle; }
.step-title { font-size:1.65rem; font-weight:800; color:#111827; margin-bottom:6px; }
.step-sub   { font-size:14px; color:#6b7280; margin-bottom:22px; }

/* Tabs */
.wiz-tabs { display:flex; border-bottom:1.5px solid #e5e7eb; margin-bottom:20px; }
.wiz-tab  { padding:10px 18px; font-size:14px; font-weight:500; color:#6b7280; cursor:pointer; border:none; border-bottom:2.5px solid transparent; margin-bottom:-1.5px; background:none; display:flex; align-items:center; gap:6px; }
.wiz-tab.active { color:#7c3aed; border-bottom-color:#7c3aed; }

/* Niche presets */
.niche-item { border:1.5px solid #e5e7eb; border-radius:12px; padding:14px 18px; cursor:pointer; margin-bottom:10px; transition:border-color .15s,background .15s; }
.niche-item:hover,.niche-item.selected { border-color:#7c3aed; background:#faf5ff; }
.niche-item-title { font-size:15px; font-weight:600; color:#111827; }
.niche-item-desc  { font-size:13px; color:#9ca3af; margin-top:2px; }

/* Voice */
.wiz-card { border:1.5px solid #e5e7eb; border-radius:14px; overflow:hidden; }
.voice-item { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid #f3f4f6; cursor:pointer; transition:background .12s; }
.voice-item:last-child { border-bottom:none; }
.voice-item.selected { background:#faf5ff; }
.v-radio { width:18px; height:18px; border-radius:50%; border:2px solid #d1d5db; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.voice-item.selected .v-radio { border-color:#7c3aed; }
.v-dot { width:9px; height:9px; border-radius:50%; background:#7c3aed; display:none; }
.voice-item.selected .v-dot { display:block; }
.v-badge { display:inline-block; padding:2px 9px; border-radius:999px; background:#dbeafe; color:#1d4ed8; font-size:11px; font-weight:700; margin-left:6px; }
.v-badge.female { background:#fce7f3; color:#9d174d; }

/* Music */
.music-item { display:flex; align-items:center; gap:14px; padding:13px 18px; border:1.5px solid #e5e7eb; border-radius:12px; margin-bottom:10px; cursor:pointer; transition:border-color .15s; }
.music-item.selected { border-color:#7c3aed; background:#faf5ff; }
.music-color { width:40px; height:40px; border-radius:9px; flex-shrink:0; }

/* Art style */
.art-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }
@media(min-width:540px){ .art-grid{ grid-template-columns:repeat(4,1fr); } }
.art-item { border-radius:12px; overflow:hidden; cursor:pointer; border:2.5px solid transparent; transition:border-color .15s; }
.art-item.selected { border-color:#7c3aed; }
.art-thumb { width:100%; aspect-ratio:9/16; display:flex; align-items:center; justify-content:center; font-size:2rem; }
.art-label { font-size:13px; font-weight:600; color:#111827; margin-top:7px; text-align:center; padding-bottom:4px; }

/* Caption */
.cap-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:12px; }
@media(min-width:480px){ .cap-grid{ grid-template-columns:repeat(3,1fr); } }
.cap-item { border:1.5px solid #e5e7eb; border-radius:12px; overflow:hidden; cursor:pointer; transition:border-color .15s; }
.cap-item.selected { border-color:#7c3aed; }
.cap-preview { background:#4b5563; display:flex; flex-direction:column; align-items:center; justify-content:center; aspect-ratio:4/3; gap:4px; padding:8px; }
.cap-label { font-size:13px; font-weight:500; color:#374151; padding:8px 10px; }

/* Effects */
.effect-item { display:flex; align-items:center; justify-content:space-between; padding:16px 18px; border:1.5px solid #e5e7eb; border-radius:12px; margin-bottom:10px; }
.eff-badge { display:inline-block; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:700; margin-left:6px; }
.badge-new     { background:#e0f2fe; color:#0284c7; }
.badge-premium { background:#fef9c3; color:#b45309; }
.toggle { position:relative; width:44px; height:24px; background:#e5e7eb; border-radius:999px; cursor:pointer; transition:background .2s; flex-shrink:0; border:none; outline:none; }
.toggle.on { background:#7c3aed; }
.toggle::after { content:''; position:absolute; top:3px; left:3px; width:18px; height:18px; border-radius:50%; background:#fff; transition:transform .2s; box-shadow:0 1px 3px rgba(0,0,0,.2); }
.toggle.on::after { transform:translateX(20px); }

/* Social */
.social-item { display:flex; align-items:center; gap:12px; padding:14px 18px; border:1.5px solid #e5e7eb; border-radius:12px; margin-bottom:12px; }

/* Inputs */
.wiz-input,.wiz-select,.wiz-textarea { width:100%; border:1.5px solid #e5e7eb; border-radius:10px; padding:12px 14px; font-size:15px; color:#111827; background:#fff; outline:none; transition:border-color .15s; box-sizing:border-box; }
.wiz-input:focus,.wiz-select:focus,.wiz-textarea:focus { border-color:#7c3aed; }
.wiz-textarea { resize:vertical; min-height:100px; font-family:inherit; }
.wiz-label { font-size:14px; font-weight:600; color:#111827; margin-bottom:8px; display:block; }
.char-count { font-size:12px; color:#9ca3af; }

/* Upload zone */
.upload-zone { border:2px dashed #e5e7eb; border-radius:12px; padding:36px; text-align:center; cursor:pointer; transition:border-color .15s; }
.upload-zone:hover { border-color:#a78bfa; }

/* Step visibility — class-based to avoid Tailwind CDN conflicts */
.wiz-step         { display: none !important; }
.wiz-step.active  { display: block !important; }

/* Scrollable step body — keeps Continue/Create always visible */
.wiz-body { max-height: calc(100vh - 320px); overflow-y: auto; padding-right: 4px; }

/* Nav */
.wiz-nav { display:flex; justify-content:space-between; align-items:center; padding-top:24px; border-top:1px solid #f3f4f6; margin-top:32px; }
.btn-back { display:flex; align-items:center; gap:6px; padding:12px 22px; border:1.5px solid #e5e7eb; border-radius:10px; background:#fff; color:#374151; font-size:15px; font-weight:500; cursor:pointer; transition:border-color .15s; }
.btn-back:hover { border-color:#6b7280; }
.btn-next { display:flex; align-items:center; gap:6px; padding:12px 26px; border-radius:10px; background:#7c3aed; color:#fff; font-size:15px; font-weight:600; cursor:pointer; border:none; transition:background .15s; }
.btn-next:hover { background:#6d28d9; }
.btn-next:disabled { opacity:.5; cursor:not-allowed; }
.err-box { display:none; background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.25); border-radius:10px; padding:12px 16px; color:#dc2626; font-size:14px; margin-bottom:16px; }
@keyframes spin { to { transform:rotate(360deg); } }
</style>

<div id="reel-wizard" style="padding-top:80px;padding-bottom:60px;">
<div style="max-width:720px;margin:0 auto;padding:0 20px;">

  <!-- Progress -->
  <div class="wiz-progress" id="wizProg">
    <% for(let i=0;i<8;i++){%><div class="wiz-seg" id="seg<%=i%>"></div><%}%>
  </div>

  <!-- ── STEP 1: Niche ──────────────────────────────────────────────────── -->
  <div id="step-1" class="wiz-step active">
    <h2 class="step-title">Choose your niche <span class="step-badge">Step 1 of 8</span></h2>
    <p class="step-sub">Select a preset or describe your own niche</p>
    <div id="s1err" class="err-box"></div>

    <div class="wiz-tabs">
      <button class="wiz-tab active" id="t1a" onclick="sTab(1,'a')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        Presets
      </button>
      <button class="wiz-tab" id="t1b" onclick="sTab(1,'b')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/></svg>
        Custom
      </button>
    </div>

    <div id="p1a" class="wiz-body">
      <% [
        ['Scary Stories','Scary stories that give you goosebumps'],
        ['History','Viral videos about history spanning from ancient times to the modern day.'],
        ['True Crime','Viral videos about true crime stories.'],
        ['Stoic Motivation','Viral videos about stoic philosophy and life lessons.'],
        ['Finance Tips','Smart money habits and financial freedom strategies.'],
        ['Motivation','Inspirational content to push people to their limits.'],
        ['Biblical Stories','Timeless stories from the Bible brought to life.'],
        ['Mythology','Ancient myths and legends from around the world.'],
        ['Anime Stories','Epic anime-inspired story arcs and character arcs.'],
        ['Act of Kindness','Heartwarming stories of humans helping each other.'],
        ['Tech Tips','Quick and useful technology tips for everyday life.'],
        ['Health Hacks','Simple daily habits for a healthier and longer life.'],
      ].forEach(n => { %>
      <div class="niche-item" onclick="pickNiche('<%= n[0] %>')" data-niche="<%= n[0] %>">
        <div class="niche-item-title"><%= n[0] %></div>
        <div class="niche-item-desc"><%= n[1] %></div>
      </div>
      <% }) %>
    </div>

    <div id="p1b" class="wiz-body" style="display:none;">
      <div style="margin-bottom:20px;">
        <label class="wiz-label">Niche</label>
        <textarea id="customNiche" class="wiz-textarea" maxlength="5000"
          placeholder="Describe your content focus, e.g.: 'Weird historical facts that sound fake but are real, delivered in a casual conversational tone with humor'"
          oninput="cc('customNiche','cc1',5000)"></textarea>
        <div style="display:flex;justify-content:space-between;margin-top:4px;">
          <span style="font-size:13px;color:#7c3aed;">Describe your topic</span>
          <span class="char-count" id="cc1">0/5000</span>
        </div>
      </div>
      <div>
        <label class="wiz-label">Example script <span class="opt-badge">Optional</span></label>
        <textarea id="exScript" class="wiz-textarea" style="min-height:130px;" maxlength="2000"
          placeholder="Paste an example of how you want your videos to sound, e.g.:&#10;&#10;&quot;Okay so get this — in 1932, Australia literally declared war on emus...&quot;"
          oninput="cc('exScript','cc2',2000)"></textarea>
        <div style="display:flex;justify-content:space-between;margin-top:4px;">
          <span style="font-size:13px;color:#7c3aed;">AI will match this style and tone</span>
          <span class="char-count" id="cc2">0/2000</span>
        </div>
      </div>
    </div>

    <div class="wiz-nav">
      <div></div>
      <button class="btn-next" onclick="go(2)">Continue <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
    </div>
  </div>

  <!-- ── STEP 2: Language & Voice ────────────────────────────────────────── -->
  <div id="step-2" class="wiz-step" style="display:none;">
    <h2 class="step-title">Language &amp; Voice <span class="step-badge">Step 2 of 8</span></h2>
    <p class="step-sub">Choose the language and voice style for your video</p>

    <div class="wiz-body">
    <div style="margin-bottom:22px;">
      <label class="wiz-label">Language</label>
      <select id="langSel" class="wiz-select">
        <option value="en">🇬🇧 English</option>
        <option value="hi">🇮🇳 Hindi</option>
        <option value="es">🇪🇸 Spanish</option>
        <option value="fr">🇫🇷 French</option>
        <option value="de">🇩🇪 German</option>
        <option value="pt">🇧🇷 Portuguese</option>
        <option value="ja">🇯🇵 Japanese</option>
        <option value="ko">🇰🇷 Korean</option>
      </select>
    </div>

    <label class="wiz-label">Voice Style</label>
    <div class="wiz-card">
      <% [
        ['alloy',   'Alloy',   'Neutral',  false, 'Neutral &amp; balanced — great for any content.'],
        ['echo',    'Echo',    'Male',     false, 'Deep &amp; authoritative — the well known voice of TikTok.'],
        ['fable',   'Fable',   'Male',     false, 'British &amp; storytelling — ideal for narratives.'],
        ['onyx',    'Onyx',    'Male',     false, 'Rich &amp; powerful — perfect for storytelling.'],
        ['nova',    'Nova',    'Female',   true,  'Warm &amp; friendly — great for lifestyle content.'],
        ['shimmer', 'Shimmer', 'Female',   true,  'Soft &amp; calm — ideal for relaxing content.'],
      ].forEach((v,vi) => { %>
      <div class="voice-item <%= vi===0?'selected':'' %>" onclick="pickVoice('<%= v[0] %>')" data-voice="<%= v[0] %>">
        <div style="display:flex;align-items:center;gap:12px;flex:1;">
          <div class="v-radio"><div class="v-dot"></div></div>
          <div>
            <div style="display:flex;align-items:center;">
              <span style="font-size:15px;font-weight:700;color:#111827;"><%= v[1] %></span>
              <span class="v-badge <%= v[3]?'female':'' %>"><%= v[2] %></span>
            </div>
            <div style="font-size:13px;color:#6b7280;margin-top:2px;"><%- v[4] %></div>
          </div>
        </div>
        <button class="play-btn" onclick="event.stopPropagation();playVoice('<%= v[0] %>',this)" title="Preview voice" style="width:34px;height:34px;border-radius:8px;border:1.5px solid #e5e7eb;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#374151;flex-shrink:0;">
          <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </button>
      </div>
      <% }) %>
    </div>
    </div><!-- /wiz-body -->

    <div class="wiz-nav">
      <button class="btn-back" onclick="go(1)"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg> Back</button>
      <button class="btn-next" onclick="go(3)">Continue <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
    </div>
  </div>

  <!-- ── STEP 3: Background Music ────────────────────────────────────────── -->
  <div id="step-3" class="wiz-step" style="display:none;">
    <h2 class="step-title">Background Music <span class="step-badge">Step 3 of 8</span> <span class="opt-badge">Optional</span></h2>
    <p class="step-sub">Choose as many songs as you want, we'll pick a random one for each video</p>

    <div class="wiz-tabs">
      <button class="wiz-tab active" id="t3a" onclick="sTab(3,'a')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        Preset music
      </button>
      <button class="wiz-tab" id="t3b" onclick="sTab(3,'b')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 19l7-7 3 3-7 7-3-3z"/></svg>
        Custom
      </button>
    </div>

    <div id="p3a" class="wiz-body">
      <% [
        ['happy',    'Happy rhythm',       'Upbeat and energetic, perfect for positive content',            'linear-gradient(135deg,#f59e0b,#ef4444)'],
        ['storm',    'Quiet before storm', 'Building tension and anticipation for dramatic reveals',         'linear-gradient(135deg,#6366f1,#4338ca)'],
        ['peaceful', 'Peaceful vibes',     'Calm and soothing background for relaxed storytelling',         'linear-gradient(135deg,#22c55e,#16a34a)'],
        ['symphony', 'Brilliant symphony', 'Orchestral and majestic for epic storytelling',                 'linear-gradient(135deg,#8b5cf6,#7c3aed)'],
        ['shadows',  'Breathing shadows',  'Mysterious and eerie ambiance for suspenseful videos',          'linear-gradient(135deg,#312e81,#1e1b4b)'],
      ].forEach(m => { %>
      <div class="music-item" onclick="toggleMusic('<%= m[0] %>')" data-music="<%= m[0] %>">
        <div class="music-color" style="background:<%= m[3] %>;"></div>
        <div style="flex:1;">
          <div style="font-size:14px;font-weight:600;color:#111827;"><%= m[1] %></div>
          <div style="font-size:13px;color:#9ca3af;"><%= m[2] %></div>
        </div>
        <button class="play-btn" onclick="event.stopPropagation();playMusic('<%= m[0] %>',this)" title="Preview music" style="width:34px;height:34px;border-radius:8px;border:1.5px solid #e5e7eb;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#374151;flex-shrink:0;">
          <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </button>
      </div>
      <% }) %>
    </div>

    <div id="p3b" class="wiz-body" style="display:none;">
      <div style="margin-bottom:20px;">
        <label class="wiz-label">TikTok Sound URLs <span style="font-size:12px;color:#9ca3af;font-weight:400;">(copy+paste link to TikTok sound)</span></label>
        <textarea class="wiz-textarea" placeholder="Enter TikTok sound URLs, one per line" style="min-height:80px;"></textarea>
      </div>
      <label class="wiz-label">Upload Sound Files</label>
      <div class="upload-zone">
        <svg width="28" height="28" fill="none" stroke="#9ca3af" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 10px;display:block;"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        <div style="font-size:14px;font-weight:600;color:#374151;">Click to upload sound files or drag and drop</div>
        <div style="font-size:13px;color:#9ca3af;margin-top:4px;">MP3, WAV up to 10MB</div>
      </div>
    </div>

    <div class="wiz-nav">
      <button class="btn-back" onclick="go(2)"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg> Back</button>
      <button class="btn-next" onclick="go(4)">Skip <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
    </div>
  </div>

  <!-- ── STEP 4: Art Style ───────────────────────────────────────────────── -->
  <div id="step-4" class="wiz-step" style="display:none;">
    <h2 class="step-title">Art Style <span class="step-badge">Step 4 of 8</span></h2>
    <p class="step-sub">Choose the visual style for your video</p>

    <div class="wiz-body">
    <div class="art-grid">
      <% [
        ['cinematic',  'Cinematic',   'linear-gradient(160deg,#0f172a,#1e293b,#334155)', '🎬'],
        ['creepy',     'Creepy Comic','linear-gradient(160deg,#1c0a00,#3b1f0a,#5c2e0e)', '👻'],
        ['vibrant',    'Modern Cartoon','linear-gradient(160deg,#7c3aed,#ec4899,#f97316)', '✨'],
        ['disney',     'Disney',      'linear-gradient(160deg,#1e3a5f,#2563eb,#60a5fa)',  '🏰'],
        ['nature',     'Nature',      'linear-gradient(160deg,#052e16,#166534,#4ade80)',  '🌿'],
        ['urban',      'Urban',       'linear-gradient(160deg,#111827,#374151,#6b7280)',  '🏙️'],
        ['fantasy',    'Fantasy',     'linear-gradient(160deg,#4a044e,#a21caf,#e879f9)',  '🔮'],
        ['historical', 'Historical',  'linear-gradient(160deg,#451a03,#92400e,#d97706)',  '📜'],
      ].forEach((a,ai) => { %>
      <div class="art-item <%= ai===0?'selected':'' %>" onclick="pickArt('<%= a[0] %>')" data-art="<%= a[0] %>">
        <div class="art-thumb" style="background:<%= a[2] %>;border-radius:9px;"><span style="font-size:2.2rem;"><%= a[3] %></span></div>
        <div class="art-label"><%= a[1] %></div>
      </div>
      <% }) %>
    </div>
    </div><!-- /wiz-body -->

    <div class="wiz-nav">
      <button class="btn-back" onclick="go(3)"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg> Back</button>
      <button class="btn-next" onclick="go(5)">Continue <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
    </div>
  </div>

  <!-- ── STEP 5: Caption Style ──────────────────────────────────────────── -->
  <div id="step-5" class="wiz-step" style="display:none;">
    <h2 class="step-title">Caption Style <span class="step-badge">Step 5 of 8</span></h2>
    <p class="step-sub">Choose how captions will appear in your video</p>

    <div class="wiz-body">
    <div class="cap-grid">
      <!-- Bold Stroke -->
      <div class="cap-item selected" onclick="pickCap('bold-stroke')" data-cap="bold-stroke">
        <div class="cap-preview" style="background:#374151;">
          <span style="font-size:1.7rem;font-weight:900;color:#fff;text-shadow:-2px -2px 0 #000,2px -2px 0 #000,-2px 2px 0 #000,2px 2px 0 #000;">DUSTY</span>
        </div>
        <div class="cap-label">Bold Stroke</div>
      </div>
      <!-- Red Highlight -->
      <div class="cap-item" onclick="pickCap('red-highlight')" data-cap="red-highlight">
        <div class="cap-preview" style="background:#4b5563;">
