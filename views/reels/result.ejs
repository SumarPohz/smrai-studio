<%- include('../partials/header', { title: (reel.title || 'Your Reel is Ready') + ' — SmrAI Studio' }) %>
<script src="https://cdn.tailwindcss.com"></script>

<style>
  #reels-app {
    --accent:  #7c3aed;
    --accent2: #a855f7;
    --surface: rgba(255,255,255,0.04);
    --border:  rgba(255,255,255,0.08);
    min-height: 100vh;
    background: #09090b;
    color: #f4f4f5;
  }
  .glass-card {
    background: var(--surface);
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 16px;
  }
  .orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }
  .btn-primary {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    height: 52px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border: none; border-radius: 12px;
    color: white; font-size: 15px; font-weight: 600;
    cursor: pointer; text-decoration: none;
    transition: opacity 0.2s, transform 0.1s;
    width: 100%;
  }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .btn-ghost {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    height: 52px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: #a1a1aa; font-size: 15px; font-weight: 500;
    cursor: pointer; text-decoration: none;
    transition: all 0.2s;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.2); color: #f4f4f5; }
  .hashtag-chip {
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid rgba(124,58,237,0.35);
    background: rgba(124,58,237,0.1);
    color: #c4b5fd;
    font-size: 13px;
  }
  .copy-btn {
    background: none; border: none; cursor: pointer;
    color: #52525b; font-size: 12px;
    display: flex; align-items: center; gap: 4px;
    transition: color 0.15s; padding: 0;
  }
  .copy-btn:hover { color: #a78bfa; }
  .platform-btn {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 14px 8px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.03);
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }
  .platform-btn:hover {
    border-color: rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.06);
    transform: translateY(-2px);
  }
  .platform-icon { font-size: 24px; }
  .platform-label { font-size: 11px; color: #71717a; }

  /* ── Inline pricing section ─────────────────────────────────────────────── */
  .paywall-section {
    margin-top: 48px;
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 44px;
    text-align: center;
  }
  .paywall-eyebrow {
    display: inline-block;
    background: rgba(124,58,237,0.18);
    color: #a78bfa;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.8rem;
    border-radius: 99px;
    border: 1px solid rgba(124,58,237,0.3);
    margin-bottom: 1rem;
  }
  .paywall-heading {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .paywall-heading span { color: #a78bfa; }
  .paywall-sub {
    color: #71717a;
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 440px;
    margin: 0 auto 2rem;
  }
  .paywall-card {
    max-width: 420px;
    margin: 0 auto;
    background: #18181b;
    border: 1px solid #3f3f46;
    border-radius: 1.25rem;
    padding: 1.75rem 1.75rem 2rem;
    text-align: left;
    position: relative;
    overflow: hidden;
  }
  .paywall-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #7c3aed, #a78bfa);
  }
  .paywall-plan-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.1rem;
  }
  .paywall-plan-name { font-size: 1rem; font-weight: 700; color: #fff; }
  .paywall-plan-tag  { font-size: 0.78rem; color: #71717a; margin-top: 0.2rem; }
  .paywall-price-val { font-size: 1.9rem; font-weight: 800; color: #fff; line-height: 1; text-align: right; }
  .paywall-price-per { font-size: 0.75rem; color: #71717a; text-align: right; margin-top: 0.2rem; }
  .paywall-divider   { border: none; border-top: 1px solid #27272a; margin: 1rem 0; }
  .paywall-features  { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; margin-bottom: 1.5rem; }
  .paywall-features li {
    display: flex; align-items: center; gap: 0.55rem;
    font-size: 0.875rem; color: #d4d4d8;
    background: transparent; border: none; border-radius: 0;
    padding: 0; margin: 0; box-shadow: none;
  }
  .paywall-features li .pf-check {
    width: 17px; height: 17px;
    background: rgba(124,58,237,0.2);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    color: #a78bfa; font-size: 0.6rem;
  }
  .paywall-btn {
    width: 100%;
    padding: 0.85rem;
    background: linear-gradient(135deg, #7c3aed, #6d28d9);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    border: none;
    border-radius: 0.7rem;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    letter-spacing: 0.01em;
  }
  .paywall-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .paywall-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .paywall-note {
    text-align: center;
    color: #52525b;
    font-size: 0.75rem;
    margin-top: 0.75rem;
  }

  /* spinner */
  .pw-spinner {
    display: inline-block;
    width: 16px; height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    vertical-align: middle;
    margin-right: 4px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Toast */
  #toast {
    position: fixed; bottom: 24px; right: 24px;
    background: #18181b; border: 1px solid rgba(34,197,94,0.3);
    color: #86efac; font-size: 14px; font-weight: 500;
    padding: 12px 20px; border-radius: 10px;
    display: none; z-index: 9999;
    animation: slideUp 0.3s ease;
  }
  @keyframes slideUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
</style>

<!-- Toast -->
<div id="toast">✓ Copied to clipboard</div>

<div id="reels-app" style="padding-top: 70px; padding-bottom: 80px;">

  <div class="orb" style="width:400px;height:400px;background:#7c3aed;opacity:0.10;top:-80px;right:-100px;"></div>
  <div class="orb" style="width:300px;height:300px;background:#ec4899;opacity:0.07;bottom:0;left:-80px;"></div>

  <div style="position:relative;z-index:1;max-width:1000px;margin:0 auto;padding:32px 16px;">

    <!-- Header -->
    <div class="text-center mb-10">
      <div style="font-size:40px;margin-bottom:10px;">🎉</div>
      <h1 style="font-size:clamp(1.5rem,4vw,2.4rem);font-weight:800;letter-spacing:-0.02em;line-height:1.2;">
        <% if (reel.title) { %>
          <%= reel.title %>
        <% } else { %>
          Your Reel is <span style="background:linear-gradient(135deg,#a78bfa,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Ready!</span>
        <% } %>
      </h1>
      <p style="color:#52525b;font-size:14px;margin-top:8px;">
        Topic: <span style="color:#71717a;"><%= reel.topic %></span>
      </p>
    </div>

    <!-- 2-column layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">

      <!-- LEFT: Metadata -->
      <div style="display:flex;flex-direction:column;gap:16px;">

        <!-- Caption card -->
        <% if (reel.caption) { %>
        <div class="glass-card p-5">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
            <span style="font-size:11px;font-weight:600;letter-spacing:0.08em;color:#52525b;">CAPTION</span>
            <button class="copy-btn" onclick="copyText('<%= reel.caption.replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>')">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              Copy
            </button>
          </div>
          <p style="font-size:15px;color:#d4d4d8;line-height:1.7;font-style:italic;">"<%= reel.caption %>"</p>
        </div>
        <% } %>

        <!-- Hashtags card -->
        <% if (reel.hashtagsArr && reel.hashtagsArr.length > 0) { %>
        <div class="glass-card p-5">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
            <span style="font-size:11px;font-weight:600;letter-spacing:0.08em;color:#52525b;">HASHTAGS</span>
            <button class="copy-btn" onclick="copyText('<%= reel.hashtagsArr.join(' ').replace(/'/g, "\\'") %>')">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              Copy All
            </button>
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:8px;">
            <% reel.hashtagsArr.forEach(tag => { %>
              <span class="hashtag-chip"><%= tag %></span>
            <% }) %>
          </div>
        </div>
        <% } %>

        <!-- Share platforms -->
        <div class="glass-card p-5">
          <div style="font-size:11px;font-weight:600;letter-spacing:0.08em;color:#52525b;margin-bottom:14px;">SHARE ON</div>
          <div class="grid grid-cols-4 gap-3">
            <a class="platform-btn" href="#" title="Instagram">
              <span class="platform-icon">📸</span>
              <span class="platform-label">Instagram</span>
            </a>
            <a class="platform-btn" href="#" title="TikTok">
              <span class="platform-icon">🎵</span>
              <span class="platform-label">TikTok</span>
            </a>
            <a class="platform-btn" href="#" title="YouTube">
              <span class="platform-icon">▶️</span>
              <span class="platform-label">YouTube</span>
            </a>
            <a class="platform-btn" href="#" title="LinkedIn">
              <span class="platform-icon">💼</span>
              <span class="platform-label">LinkedIn</span>
            </a>
          </div>
        </div>

      </div>

      <!-- RIGHT: Video + actions -->
      <div style="display:flex;flex-direction:column;gap:14px;">

        <!-- Video player (always shown — free preview is playable) -->
        <div class="glass-card" style="overflow:hidden;">
          <div style="background:#000;aspect-ratio:9/16;max-height:70vh;display:flex;align-items:center;justify-content:center;">
            <video
              id="reelPlayer"
              style="width:100%;height:100%;object-fit:contain;"
              controls
              playsinline
              preload="metadata"
              src="<%= reel.video_url %>"
            >
              Your browser doesn't support video playback.
            </video>
          </div>
        </div>

        <!-- Download — subscribers only -->
        <% if (isSubscribed) { %>
        <a
          href="<%= reel.video_url %>"
          download="smrai-reel-<%= reel.id %>.mp4"
          class="btn-primary"
        >
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Download MP4
        </a>
        <a href="/reels/create" class="btn-ghost">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
          Create Another Reel
        </a>
        <% } else { %>
        <!-- Free preview label -->
        <div style="text-align:center;font-size:12px;color:#52525b;padding:4px 0;">
          🔒 Free preview — subscribe to download &amp; create more
        </div>
        <% } %>

      </div>
    </div>

    <!-- ── Inline Pricing Section (non-subscribers only) ──────────────── -->
    <% if (!isSubscribed) { %>
    <div class="paywall-section">

      <div class="paywall-eyebrow">Starter Plan</div>
      <h2 class="paywall-heading">Unlock <span>Downloads</span> &amp; More Reels</h2>
      <p class="paywall-sub">
        Your free preview is ready to watch. Subscribe to download the HD MP4
        and create up to 3 new videos every week.
      </p>

      <div class="paywall-card">
        <div class="paywall-plan-row">
          <div>
            <div class="paywall-plan-name">Starter Plan</div>
            <div class="paywall-plan-tag">3 videos / week · HD download</div>
          </div>
          <div>
            <div class="paywall-price-val">₹199</div>
            <div class="paywall-price-per">per month</div>
          </div>
        </div>

        <hr class="paywall-divider" />

        <ul class="paywall-features">
          <li><span class="pf-check">✓</span> 3 AI-generated reels per week</li>
          <li><span class="pf-check">✓</span> HD MP4 download (1080×1920)</li>
          <li><span class="pf-check">✓</span> GPT-4o script + 6 AI voices</li>
          <li><span class="pf-check">✓</span> Auto captions &amp; hashtags</li>
          <li><span class="pf-check">✓</span> Stock footage sourced automatically</li>
        </ul>

        <button class="paywall-btn" id="pw-pay-btn" onclick="startPayment()">
          ⚡ Subscribe Now — ₹199/month
        </button>
        <p class="paywall-note">Secure · Razorpay · Cancel anytime</p>
      </div>

    </div>
    <% } %>

  </div>
</div>

<script>
function copyText(text) {
  navigator.clipboard.writeText(text).then(() => {
    const toast = document.getElementById('toast');
    toast.style.display = 'block';
    setTimeout(() => { toast.style.display = 'none'; }, 2500);
  });
}
</script>

<% if (!isSubscribed) { %>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  const RZP_KEY = '<%= razorpayKey %>';

  function showPayToast(msg, err) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.style.display = 'block';
    t.style.borderColor = err ? 'rgba(239,68,68,0.4)' : 'rgba(34,197,94,0.3)';
    t.style.color = err ? '#fca5a5' : '#86efac';
    setTimeout(() => { t.style.display = 'none'; }, 3500);
  }

  async function startPayment() {
    const btn = document.getElementById('pw-pay-btn');
    btn.disabled = true;
    btn.innerHTML = '<span class="pw-spinner"></span> Creating order…';

    let order;
    try {
      const res  = await fetch('/api/reels/payment/create-order', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      const data = await res.json();
      if (!res.ok) { showPayToast(data.error || 'Failed to create order.', true); reset(); return; }
      order = data;
    } catch (e) { showPayToast('Network error. Please try again.', true); reset(); return; }

    const options = {
      key:         RZP_KEY,
      amount:      order.amount,
      currency:    order.currency,
      name:        'SmrAI Studio',
      description: 'Reels Starter Plan — ₹199/month',
      order_id:    order.orderId,
      handler: async function(response) {
        btn.innerHTML = '<span class="pw-spinner"></span> Verifying…';
        try {
          const vRes  = await fetch('/api/reels/payment/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              razorpay_order_id:   response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature:  response.razorpay_signature,
            }),
          });
          const vData = await vRes.json();
          if (vRes.ok && vData.success) {
            showPayToast('🎉 Subscription activated! Loading your reel…');
            setTimeout(() => location.reload(), 1400);
          } else {
            showPayToast(vData.error || 'Verification failed.', true); reset();
          }
        } catch(e) { showPayToast('Verification error. Contact support.', true); reset(); }
      },
      prefill: {
        name:  '<%= currentUser ? (currentUser.name  || "") : "" %>',
        email: '<%= currentUser ? (currentUser.email || "") : "" %>',
      },
      theme: { color: '#7c3aed' },
      modal: { ondismiss: reset },
    };

    function reset() {
      btn.disabled = false;
      btn.textContent = '⚡ Subscribe Now — ₹199/month';
    }

    const rzp = new Razorpay(options);
    rzp.on('payment.failed', function(r) { showPayToast('Payment failed: ' + (r.error.description || ''), true); reset(); });
    rzp.open();
  }
</script>
<% } %>

<%- include('../partials/footer') %>
