<%- include('../partials/header', { title: 'Crafting Your Reel… — SmrAI Studio' }) %>
<script src="https://cdn.tailwindcss.com"></script>

<style>
  #reels-app {
    --accent:  #7c3aed;
    --accent2: #a855f7;
    --surface: rgba(255,255,255,0.04);
    --border:  rgba(255,255,255,0.08);
    min-height: 100vh;
    background: #09090b;
    color: #f4f4f5;
  }
  .glass-card {
    background: var(--surface);
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 16px;
  }
  .orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }

  /* NProgress-style top bar */
  #nprogress {
    position: fixed;
    top: 0; left: 0;
    width: 0%;
    height: 3px;
    background: linear-gradient(90deg, #7c3aed, #ec4899, #a855f7);
    z-index: 9999;
    transition: width 0.4s ease;
    border-radius: 0 2px 2px 0;
    box-shadow: 0 0 10px rgba(168,85,247,0.6);
  }

  /* Orbiting spinner */
  .spinner-wrap {
    position: relative;
    width: 80px; height: 80px;
    margin: 0 auto 28px;
  }
  .spinner-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid transparent;
    animation: orbit 1.4s linear infinite;
  }
  .spinner-ring:nth-child(1) { border-top-color: #7c3aed; animation-duration: 1.2s; }
  .spinner-ring:nth-child(2) { inset: 10px; border-right-color: #a855f7; animation-duration: 1.6s; animation-direction: reverse; }
  .spinner-ring:nth-child(3) { inset: 22px; border-bottom-color: #ec4899; animation-duration: 1s; }
  @keyframes orbit { to { transform: rotate(360deg); } }

  /* Steps */
  .step-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }
  .step-row:last-child { border-bottom: none; }
  .step-dot {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.12);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
    transition: all 0.4s;
  }
  .step-row.done   .step-dot { background: rgba(34,197,94,0.15); border-color: #22c55e; color: #22c55e; }
  .step-row.active .step-dot { border-color: var(--accent2); animation: pulse-ring 1.5s infinite; }
  .step-row.pending .step-dot { color: #3f3f46; }
  @keyframes pulse-ring {
    0%,100% { box-shadow: 0 0 0 0 rgba(168,85,247,0.4); }
    50%      { box-shadow: 0 0 0 6px rgba(168,85,247,0); }
  }
  .step-title   { font-size: 14px; font-weight: 500; color: #e4e4e7; }
  .step-sub     { font-size: 12px; color: #52525b; margin-top: 1px; }
  .step-row.done   .step-title { color: #a1a1aa; }
  .step-row.active .step-title { color: #c4b5fd; }

  /* Tip ticker */
  .tip-box { font-size: 13px; color: #52525b; text-align: center; min-height: 20px; transition: opacity 0.5s; }

  /* Failed state */
  .error-card {
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.25);
    border-radius: 16px;
    padding: 32px;
    text-align: center;
  }
  .btn-retry {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 24px;
    background: linear-gradient(135deg, #7c3aed, #a855f7);
    border-radius: 10px;
    color: white; font-weight: 600; font-size: 15px;
    text-decoration: none;
    margin-top: 16px;
    transition: opacity 0.2s;
  }
  .btn-retry:hover { opacity: 0.85; }

  /* Script approval card */
  .approval-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(34,197,94,0.12);
    border: 1px solid rgba(34,197,94,0.3);
    color: #86efac;
    font-size: 12px; font-weight: 600;
    padding: 4px 10px; border-radius: 20px;
    margin-bottom: 12px;
  }
  .script-textarea {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    color: #e4e4e7;
    font-size: 14px;
    line-height: 1.7;
    padding: 14px;
    resize: vertical;
    min-height: 200px;
    outline: none;
    transition: border-color 0.2s;
    font-family: inherit;
  }
  .script-textarea:focus { border-color: var(--accent2); }
  .script-textarea[readonly] { color: #a1a1aa; cursor: default; }
  .btn-approve {
    width: 100%;
    padding: 15px;
    background: linear-gradient(135deg, #7c3aed, #a855f7);
    border: none; border-radius: 12px;
    color: white; font-weight: 700; font-size: 16px;
    cursor: pointer; transition: opacity 0.2s;
  }
  .btn-approve:hover:not(:disabled) { opacity: 0.88; }
  .btn-approve:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-secondary {
    padding: 10px 18px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    color: #a1a1aa; font-size: 14px; font-weight: 500;
    cursor: pointer; transition: all 0.2s;
  }
  .btn-secondary:hover:not(:disabled) { background: rgba(255,255,255,0.1); color: #e4e4e7; }
  .btn-secondary:disabled { opacity: 0.4; cursor: not-allowed; }
  .cost-note {
    display: flex; align-items: center; gap: 8px;
    background: rgba(251,191,36,0.08);
    border: 1px solid rgba(251,191,36,0.2);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 13px; color: #fcd34d;
    margin-bottom: 16px;
  }
</style>

<!-- NProgress bar -->
<div id="nprogress"></div>

<div id="reels-app" style="padding-top: 70px; padding-bottom: 60px;">

  <div class="orb" style="width:400px;height:400px;background:#7c3aed;opacity:0.10;top:-80px;left:-100px;"></div>
  <div class="orb" style="width:350px;height:350px;background:#a855f7;opacity:0.08;bottom:0;right:-80px;"></div>

  <div style="position:relative;z-index:1;max-width:520px;margin:0 auto;padding:40px 16px;">

    <!-- Failed state -->
    <div id="failedState" style="display:none;">
      <div class="error-card">
        <div style="font-size:48px;margin-bottom:12px;">😔</div>
        <h2 style="font-size:22px;font-weight:700;color:#fca5a5;margin-bottom:8px;">Generation Failed</h2>
        <p id="failedMsg" style="color:#71717a;font-size:14px;line-height:1.6;margin-bottom:16px;">Something went wrong during reel generation.</p>
        <div id="refundNotice" style="display:none;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.25);border-radius:12px;padding:14px 16px;margin-bottom:16px;text-align:left;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
            <span style="font-size:18px;">💰</span>
            <span id="refundMsg" style="font-size:14px;font-weight:600;color:#86efac;"></span>
          </div>
          <p style="font-size:12px;color:#4ade80;margin:0;">Your wallet has been credited. You can retry or request a refund from your dashboard.</p>
        </div>
        <a href="/reels/create" class="btn-retry">← Try Again</a>
      </div>
    </div>

    <!-- Processing state -->
    <div id="processingState">
      <div class="spinner-wrap">
        <div class="spinner-ring"></div>
        <div class="spinner-ring"></div>
        <div class="spinner-ring"></div>
        <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:22px;">🎬</div>
      </div>
      <div class="text-center mb-8">
        <h2 style="font-size:22px;font-weight:700;color:#f4f4f5;margin-bottom:6px;" id="processingTitle">Crafting Your Script…</h2>
        <p style="font-size:14px;color:#52525b;" id="processingSubtitle">Writing your story and generating metadata</p>
      </div>
      <div class="glass-card p-5 mb-6">
        <div class="step-row pending" id="step-0">
          <div class="step-dot">✍️</div>
          <div>
            <div class="step-title">Writing Script</div>
            <div class="step-sub">SmrAI Studio crafting your story</div>
          </div>
        </div>
        <div class="step-row pending" id="step-1">
          <div class="step-dot">🎙️</div>
          <div>
            <div class="step-title">Generating Voice</div>
            <div class="step-sub">Converting script to audio</div>
          </div>
        </div>
        <div class="step-row pending" id="step-2">
          <div class="step-dot">🎬</div>
          <div>
            <div class="step-title">Generating Video Clips</div>
            <div class="step-sub">SmrAI Studio generating cinematic scenes</div>
          </div>
        </div>
        <div class="step-row pending" id="step-3">
          <div class="step-dot">⚡</div>
          <div>
            <div class="step-title">Merging & Exporting</div>
            <div class="step-sub">Compiling your final reel</div>
          </div>
        </div>
      </div>
      <div class="tip-box" id="tipBox">💡 Tip: Specific topics produce better reels than generic ones</div>
    </div>

    <!-- Script approval state -->
    <div id="approvalState" style="display:none;">
      <div style="text-align:center;margin-bottom:24px;">
        <div style="font-size:40px;margin-bottom:10px;">📝</div>
        <div class="approval-badge">✓ Script Ready</div>
        <h2 id="approvalTitle" style="font-size:22px;font-weight:700;color:#f4f4f5;margin-bottom:8px;">Review Your Script</h2>
        <p style="font-size:14px;color:#71717a;line-height:1.6;">Review before we generate the video — edit or regenerate for free.</p>
      </div>

      <!-- Title -->
      <div id="metaTitle" style="display:none;margin-bottom:12px;padding:14px 16px;background:rgba(124,58,237,.08);border:1px solid rgba(124,58,237,.25);border-radius:12px;">
        <div style="font-size:11px;font-weight:600;color:#71717a;letter-spacing:.06em;margin-bottom:4px;">TITLE</div>
        <div id="metaTitleText" style="font-size:15px;font-weight:700;color:#f4f4f5;"></div>
      </div>

      <!-- Description -->
      <div id="metaDesc" style="display:none;margin-bottom:12px;padding:14px 16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;">
        <div style="font-size:11px;font-weight:600;color:#71717a;letter-spacing:.06em;margin-bottom:6px;">DESCRIPTION</div>
        <div id="metaDescText" style="font-size:13px;color:#a1a1aa;line-height:1.7;"></div>
      </div>

      <!-- Caption -->
      <div id="metaCaption" style="display:none;margin-bottom:12px;padding:14px 16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;">
        <div style="font-size:11px;font-weight:600;color:#71717a;letter-spacing:.06em;margin-bottom:6px;">CAPTION</div>
        <div id="metaCaptionText" style="font-size:13px;color:#d4d4d8;font-style:italic;line-height:1.6;"></div>
      </div>

      <!-- Hashtags -->
      <div id="metaHashtags" style="display:none;margin-bottom:16px;padding:14px 16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;">
        <div style="font-size:11px;font-weight:600;color:#71717a;letter-spacing:.06em;margin-bottom:8px;">HASHTAGS</div>
        <div id="metaHashtagsList" style="display:flex;flex-wrap:wrap;gap:6px;"></div>
      </div>

      <!-- Script -->
      <div class="glass-card p-5 mb-4">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <span style="font-size:13px;font-weight:600;color:#a1a1aa;text-transform:uppercase;letter-spacing:0.05em;">Script</span>
          <button class="btn-secondary" id="editToggleBtn" onclick="toggleEdit()">✏️ Edit</button>
        </div>
        <textarea id="scriptTextarea" class="script-textarea" readonly></textarea>
      </div>

      <div style="display:flex;gap:10px;margin-bottom:16px;">
        <button class="btn-secondary" id="regenBtn" onclick="regenScript()" style="flex:1;">
          🔄 Regenerate Script
        </button>
      </div>

      <!-- Person Photo Upload (optional — for image-to-video) -->
      <div id="personPhotoBox" style="margin-bottom:16px;padding:16px;background:rgba(124,58,237,.06);border:1.5px dashed rgba(124,58,237,.35);border-radius:14px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
          <span style="font-size:20px;">🖼️</span>
          <div>
            <div style="font-size:14px;font-weight:700;color:#e4e4e7;">Add a Person Photo <span style="font-size:12px;font-weight:400;color:#71717a;">(optional)</span></div>
            <div style="font-size:12px;color:#71717a;margin-top:2px;">Upload a photo of the person and Veo will animate them in the video</div>
          </div>
        </div>
        <label id="photoLabel" style="display:flex;align-items:center;gap:8px;cursor:pointer;">
          <input type="file" id="personPhotoInput" accept="image/jpeg,image/png,image/webp" style="display:none;" onchange="onPhotoSelected(this)" />
          <span id="photoBtn" style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:#27272a;border:1px solid #3f3f46;border-radius:8px;font-size:13px;font-weight:600;color:#d4d4d8;">📁 Choose Photo</span>
          <span id="photoName" style="font-size:12px;color:#71717a;">No file chosen</span>
        </label>
        <div id="photoPreviewWrap" style="display:none;margin-top:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <img id="photoPreview" style="width:60px;height:60px;object-fit:cover;border-radius:10px;border:2px solid rgba(124,58,237,.4);" />
          <div style="flex:1;min-width:0;">
            <div id="photoPreviewName" style="font-size:13px;color:#e4e4e7;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
            <button onclick="clearPhoto()" style="font-size:12px;color:#f87171;background:none;border:none;cursor:pointer;padding:0;margin-top:2px;">✕ Remove</button>
          </div>
        </div>
        <p style="font-size:11px;color:#52525b;margin-top:8px;">Best results: clear face, good lighting, front-facing. JPG/PNG/WebP, max 10MB.</p>
      </div>

      <button class="btn-approve" id="approveBtn" onclick="approveScript()">
        Generate Video →
      </button>
    </div>

  </div>
</div>

<script>
const REEL_ID  = <%= reelId %>;
const POLL_MS  = 3000;
let pollTimer, tipTimer, ticks = 0;
let phase2Started = false;

const TIPS = [
  '💡 Tip: Short, punchy scripts perform best on TikTok and Reels',
  '🎙️ Try "Nova" or "Shimmer" voices for lifestyle content',
  '📈 Reels under 45 seconds get 3x more views on average',
  '🔥 Posting 3–5 reels per week grows channels 10x faster',
  '🎯 Niche content outperforms broad content every time',
];
let tipIndex = 0;

function rotateTip() {
  const el = document.getElementById('tipBox');
  el.style.opacity = '0';
  setTimeout(() => {
    tipIndex = (tipIndex + 1) % TIPS.length;
    el.textContent = TIPS[tipIndex];
    el.style.opacity = '1';
  }, 500);
}

function setStepState(index, state) {
  const el = document.getElementById(`step-${index}`);
  if (!el) return;
  el.className = `step-row ${state}`;
  if (state === 'done') el.querySelector('.step-dot').innerHTML = '✓';
}

function animateSteps() {
  if (phase2Started) {
    // Phase 2: step 0 done, animate steps 1-3
    setStepState(0, 'done');
    const step = Math.min(1 + Math.floor(ticks / 8), 3);
    for (let i = 1; i < 4; i++) {
      if (i < step)       setStepState(i, 'done');
      else if (i === step) setStepState(i, 'active');
      else                 setStepState(i, 'pending');
    }
  } else {
    // Phase 1: only step 0 active
    setStepState(0, 'active');
  }
}

function animateProgress() {
  const bar = document.getElementById('nprogress');
  const pct = phase2Started
    ? Math.min(25 + ticks * 3, 85)
    : Math.min(5 + ticks * 3, 18);
  bar.style.width = pct + '%';
}

async function poll() {
  ticks++;
  animateSteps();
  animateProgress();

  try {
    const res  = await fetch(`/reels/${REEL_ID}/status`);
    const data = await res.json();

    if (data.status === 'script_ready') {
      clearInterval(pollTimer);
      clearInterval(tipTimer);
      showApprovalUI(data);
      return;
    }

    if (data.status === 'completed') {
      clearInterval(pollTimer);
      clearInterval(tipTimer);
      document.getElementById('nprogress').style.width = '100%';
      setTimeout(() => { window.location.href = `/reels/result/${REEL_ID}`; }, 400);
      return;
    }

    if (data.status === 'failed') {
      clearInterval(pollTimer);
      clearInterval(tipTimer);
      document.getElementById('nprogress').style.background = '#ef4444';
      document.getElementById('processingState').style.display = 'none';
      document.getElementById('approvalState').style.display = 'none';
      document.getElementById('failedState').style.display = 'block';
      document.getElementById('failedMsg').textContent = data.error_message || 'An unexpected error occurred.';
      if (data.refunded_amount) {
        document.getElementById('refundNotice').style.display = 'block';
        document.getElementById('refundMsg').textContent = `₹${data.refunded_amount} refunded to your wallet`;
      }
    }
  } catch (e) {
    console.warn('[Poll] error:', e.message);
  }
}

function showApprovalUI(data) {
  document.getElementById('processingState').style.display = 'none';
  // Don't overwrite textarea if user is actively editing
  if (!_editing) {
    document.getElementById('scriptTextarea').value = data.script || '';
  }
  document.getElementById('approvalState').style.display = 'block';
  document.getElementById('nprogress').style.width = '20%';

  // Title
  if (data.title) {
    document.getElementById('approvalTitle').textContent = data.title;
    document.getElementById('metaTitleText').textContent = data.title;
    document.getElementById('metaTitle').style.display = 'block';
  }

  // Description
  if (data.description) {
    document.getElementById('metaDescText').textContent = data.description;
    document.getElementById('metaDesc').style.display = 'block';
  }

  // Caption
  if (data.caption) {
    document.getElementById('metaCaptionText').textContent = data.caption;
    document.getElementById('metaCaption').style.display = 'block';
  }

  // Hashtags
  if (Array.isArray(data.hashtags) && data.hashtags.length) {
    const list = document.getElementById('metaHashtagsList');
    list.innerHTML = data.hashtags.map(h =>
      `<span style="background:rgba(168,85,247,0.12);border:1px solid rgba(168,85,247,0.3);color:#c4b5fd;font-size:12px;font-weight:600;padding:3px 10px;border-radius:20px;">${h}</span>`
    ).join('');
    document.getElementById('metaHashtags').style.display = 'block';
  }
}

let _editing = false;
function toggleEdit() {
  const ta  = document.getElementById('scriptTextarea');
  const btn = document.getElementById('editToggleBtn');
  _editing = !_editing;
  if (_editing) {
    ta.removeAttribute('readonly');
    ta.style.color = '#f4f4f5';
    ta.focus();
    btn.textContent = '✓ Done';
    btn.style.color = '#4ade80';
  } else {
    ta.setAttribute('readonly', '');
    ta.style.color = '';
    btn.textContent = '✏️ Edit';
    btn.style.color = '';
  }
}

async function regenScript() {
  const btn = document.getElementById('regenBtn');
  btn.disabled = true;
  btn.textContent = 'Regenerating…';
  try {
    const res  = await fetch(`/reels/${REEL_ID}/regenerate-script`, { method: 'POST' });
    const data = await res.json();
    if (data.script) {
      document.getElementById('scriptTextarea').value = data.script;
      // Reset to read-only after regeneration
      document.getElementById('scriptTextarea').setAttribute('readonly', '');
      document.getElementById('editToggleBtn').textContent = '✏️ Edit';
    } else {
      alert(data.error || 'Failed to regenerate. Please try again.');
    }
  } catch (e) {
    alert('Network error. Please try again.');
  } finally {
    btn.disabled = false;
    btn.textContent = '🔄 Regenerate Script';
  }
}

function onPhotoSelected(input) {
  const file = input.files[0];
  if (!file) return;
  document.getElementById('photoName').textContent = file.name;
  document.getElementById('photoPreviewName').textContent = file.name;
  document.getElementById('photoPreviewWrap').style.display = 'flex';
  const reader = new FileReader();
  reader.onload = e => document.getElementById('photoPreview').src = e.target.result;
  reader.readAsDataURL(file);
}

function clearPhoto() {
  document.getElementById('personPhotoInput').value = '';
  document.getElementById('photoName').textContent = 'No file chosen';
  document.getElementById('photoPreviewWrap').style.display = 'none';
  document.getElementById('photoPreview').src = '';
}

async function approveScript() {
  const btn    = document.getElementById('approveBtn');
  const script = document.getElementById('scriptTextarea').value.trim();
  const photoFile = document.getElementById('personPhotoInput').files[0];
  btn.disabled = true;
  btn.textContent = photoFile ? 'Uploading photo…' : 'Starting video generation…';

  try {
    let res;
    if (photoFile) {
      // Send as multipart/form-data so the image is uploaded with the approval
      const fd = new FormData();
      fd.append('script', script);
      fd.append('personPhoto', photoFile);
      res = await fetch(`/reels/${REEL_ID}/approve`, { method: 'POST', body: fd });
    } else {
      res = await fetch(`/reels/${REEL_ID}/approve`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ script }),
      });
    }
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || 'Approval failed');

    // Switch back to processing state and resume polling
    phase2Started = true;
    ticks = 0;
    _editing = false;
    document.getElementById('approvalState').style.display = 'none';
    document.getElementById('processingState').style.display = 'block';
    document.getElementById('processingTitle').textContent = 'Generating Your Reel…';
    document.getElementById('processingSubtitle').textContent = 'This usually takes 3–5 minutes';
    document.getElementById('nprogress').style.width = '22%';
    setStepState(0, 'done');

    pollTimer = setInterval(poll, POLL_MS);
    tipTimer  = setInterval(rotateTip, 8000);
  } catch (e) {
    btn.disabled = false;
    btn.textContent = 'Generate Video →';
    alert(e.message);
  }
}


// Kick off
setStepState(0, 'active');
document.getElementById('nprogress').style.width = '8%';
poll();
pollTimer = setInterval(poll, POLL_MS);
tipTimer  = setInterval(rotateTip, 8000);
</script>

