<div id="ytModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:9999;align-items:center;justify-content:center;flex-direction:column;gap:12px">
  <button onclick="closeYT()" style="position:absolute;top:16px;right:20px;background:rgba(255,255,255,0.15);border:none;color:#fff;font-size:1.4rem;width:38px;height:38px;border-radius:50%;cursor:pointer;">✕</button>
  <div style="width:min(360px,92vw);aspect-ratio:9/16;border-radius:14px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,0.6);">
    <iframe id="ytFrame" src="" frameborder="0" allow="autoplay;encrypted-media" allowfullscreen style="width:100%;height:100%;border:none;"></iframe>
  </div>
</div>

<script>
function ytVideoId(url) {
  if (!url) return null;
  const m = url.match(/shorts\/([^?&/]+)/) || url.match(/youtu\.be\/([^?&/]+)/) || url.match(/[?&]v=([^&]+)/);
  return m ? m[1] : null;
}
function playYT(url) {
  const id = ytVideoId(url);
  if (!id) return;
  document.getElementById('ytFrame').src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
  document.getElementById('ytModal').style.display = 'flex';
}
function closeYT() {
  document.getElementById('ytFrame').src = '';
  document.getElementById('ytModal').style.display = 'none';
}
document.getElementById('ytModal').addEventListener('click', function(e) {
  if (e.target === this) closeYT();
});

let currentSlide = 0;
const slides = document.querySelectorAll('.carousel-slide');

function goToSlide(index) {
  slides.forEach(s => s.style.display = 'none');
  slides[index].style.display = 'block';
  currentSlide = index;
  document.querySelectorAll('.carousel-dot').forEach((d, i) => {
    d.style.background = i === index ? '#7c3aed' : '#e5e7eb';
  });
}
function nextSlide() { goToSlide((currentSlide + 1) % slides.length); }
function prevSlide() { goToSlide((currentSlide - 1 + slides.length) % slides.length); }
</script>

