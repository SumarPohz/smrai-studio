<%- include('../partials/header', { title: 'AI Reel Generator — SmrAI Studio' }) %>
<script src="https://cdn.tailwindcss.com"></script>

<style>
  #reels-landing {
    background: #ffffff;
    color: #111827;
    min-height: 100vh;
  }
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #7c3aed;
    color: #fff;
    font-size: 17px;
    font-weight: 600;
    padding: 16px 36px;
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.2s, transform 0.1s;
    box-shadow: 0 4px 24px rgba(124,58,237,0.35);
  }
  .btn-cta:hover { background: #6d28d9; transform: translateY(-2px); }

  /* Niche marquee */
  .niche-marquee-wrap {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
    padding: 8px 0 16px;
  }
  .niche-marquee-track {
    display: flex;
    gap: 14px;
    width: max-content;
    animation: nicheScroll 22s linear infinite;
  }
  .niche-marquee-wrap:hover .niche-marquee-track { animation-play-state: paused; }
  @keyframes nicheScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  .niche-card {
    flex-shrink: 0;
    width: 150px;
    aspect-ratio: 9/16;
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .niche-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.2); }
  .niche-label {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 28px 10px 12px;
    background: linear-gradient(to top, rgba(0,0,0,0.75), transparent);
    color: white;
    font-size: 12px;
    font-weight: 600;
    text-align: center;
    letter-spacing: 0.02em;
  }
  /* Platform icon badges */
  .platform-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #f3f4f6;
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 500;
    color: #374151;
  }
  /* Testimonial marquee — always visible */
  .reels-testi-desktop { display: none; }
  .reels-testi-marquee-wrap { display: block; overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%); mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%); }
  .reels-testi-track { display: flex; gap: 16px; width: max-content; animation: reelsTestiScroll 36s linear infinite; }
  .reels-testi-card { flex-shrink: 0; width: 280px; background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.05); }
  @keyframes reelsTestiScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* Stat cards */
  .stat-card {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 24px;
    text-align: center;
  }

  @media (max-width: 640px) {
    #reels-landing { padding-top: 0 !important; }
    .reels-hero-section { padding: 18px 14px 16px !important; }
    .reels-hero-section h1 { font-size: 1.55rem !important; margin-bottom: 8px !important; }
    .reels-hero-section p  { font-size: 12px !important; margin-bottom: 12px !important; }
    .reels-hero-section .reels-platform-row { margin-bottom: 14px !important; gap: 6px !important; }
    .platform-badge { font-size: 11px; padding: 4px 10px; }
    .btn-cta { font-size: 13px; padding: 10px 20px; }

    /* Niche cards smaller on mobile */
    .niche-card { width: 80px; border-radius: 10px; }
    .niche-label { font-size: 9px; padding: 14px 4px 7px; }
    .niche-marquee-track { gap: 8px !important; animation-duration: 16s !important; }
    .reels-niche-section { padding: 0 12px 24px !important; }

    /* Stat cards — always 3 col, compact */
    .reels-stats-section { padding: 22px 12px !important; }
    .stat-card { padding: 10px 6px; border-radius: 10px; }
    .stat-card .stat-num { font-size: 1.2rem !important; }
    .stat-card .stat-lbl { font-size: 10px !important; margin-top: 2px !important; }

    /* Reduce section dead space */
    #reels-landing section { padding-bottom: 24px !important; }
    .reels-testimonials-section { padding: 0 12px 24px !important; }
    .reels-testimonials-section > div:first-child { margin-bottom: 16px !important; }
    .reels-testimonials-section h2 { font-size: 1.3rem !important; margin-bottom: 4px !important; }
    .reels-testimonials-section p { font-size: 12px !important; }
    /* Testimonials: compact cards on mobile */
    .reels-testi-track { gap: 10px !important; animation-duration: 24s !important; }
    .reels-testi-card { width: 200px !important; border-radius: 12px !important; padding: 12px !important; }

    /* Why creators — 3-col compact grid */
    .reels-why-section { padding: 0 12px 24px !important; }
    .reels-why-section h2 { font-size: 1.3rem !important; margin-bottom: 6px !important; }
    .reels-why-section > div > p { font-size: 12px !important; margin-bottom: 14px !important; }
    .reels-why-grid { display: grid !important; grid-template-columns: 1fr 1fr 1fr !important; gap: 8px !important; flex-wrap: unset; overflow: visible !important; }
    .reels-why-card { width: auto !important; padding: 10px !important; border-radius: 10px !important; }
    .reels-why-card > div:first-child { margin-bottom: 6px !important; }
    .reels-why-card > div:first-child span:first-child { font-size: 10px !important; font-weight: 700; }
    .reels-why-card > div:first-child span:last-child { font-size: 14px !important; }
    .reels-why-card p { font-size: 10px !important; line-height: 1.45 !important; margin: 0 !important; }

    /* How it works — always 3 col, compact */
    .reels-how-section { padding: 28px 12px 36px !important; }
    .reels-how-section > div > p { font-size: 12px !important; margin-bottom: 24px !important; }
    .reels-how-grid { gap: 8px !important; margin-bottom: 28px !important; }
    .reels-how-step { gap: 6px !important; }
    .reels-how-step .step-num { width: 36px !important; height: 36px !important; font-size: 14px !important; }
    .reels-how-step .step-title { font-size: 11px !important; }
    .reels-how-step .step-desc  { font-size: 10px !important; line-height: 1.5 !important; }
  }
  /* Avatar stack */
  .avatar-stack { display: flex; }
  .avatar-stack img,
  .avatar-item {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 2px solid white;
    margin-left: -8px;
    object-fit: cover;
  }
  .avatar-stack > *:first-child { margin-left: 0; }
  .avatar-item {
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700;
    color: white;
  }
</style>

<div id="reels-landing" style="padding-top: 70px; box-sizing: border-box;">

  <!-- ── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="reels-hero-section" style="text-align:center; padding: 60px 16px 48px; max-width: 680px; margin: 0 auto;">

    <!-- Trusted row -->
    <div style="display:flex; align-items:center; justify-content:center; gap:10px; margin-bottom:28px;">
      <div class="avatar-stack">
        <div class="avatar-item" style="background:#7c3aed;">A</div>
        <div class="avatar-item" style="background:#db2777;">B</div>
        <div class="avatar-item" style="background:#0891b2;">C</div>
        <div class="avatar-item" style="background:#d97706;">D</div>
      </div>
      <span style="font-size:14px; color:#6b7280; font-weight:500;">Trusted by creators</span>
    </div>

    <!-- Headline -->
    <h1 style="font-size:clamp(2.2rem,5vw,3.6rem); font-weight:800; line-height:1.1; letter-spacing:-0.03em; color:#111827; margin-bottom:16px;">
      Create viral faceless<br>reels on auto-pilot
    </h1>

    <!-- Subtitle -->
    <p style="font-size:16px; color:#6b7280; line-height:1.7; max-width:480px; margin:0 auto 24px;">
      The only AI that writes scripts, records voice & builds reels for you automatically — even while you sleep.
    </p>

    <!-- Platform badges -->
    <div class="reels-platform-row" style="display:flex; align-items:center; justify-content:center; gap:8px; flex-wrap:wrap; margin-bottom:32px;">
      <span style="font-size:13px; color:#9ca3af;">Perfect for</span>
      <span class="platform-badge">▶️ YouTube</span>
      <span class="platform-badge">📸 Instagram</span>
      <span class="platform-badge">🎵 TikTok</span>
    </div>

    <!-- CTA -->
    <a href="/reels/create" class="btn-cta">
      ⚡ Create your first video
    </a>
    <p style="font-size:13px; color:#9ca3af; margin-top:12px;">Get your reel in less than 2 minutes.</p>

  </section>

  <!-- ── NICHE SHOWCASE ─────────────────────────────────────────────────────── -->
  <section class="reels-niche-section" style="padding: 0 24px 64px; max-width: 1100px; margin: 0 auto;">

    <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px; font-size:15px; font-weight:600; color:#374151;">
      Creates reels for any niche
      <svg width="18" height="18" fill="none" stroke="#7c3aed" stroke-width="2.5" viewBox="0 0 24 24" style="transform:rotate(15deg)">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>

    <%
      const niches = [
        { label: 'Act of Kindness',  g: 'linear-gradient(160deg,#bae6fd,#7dd3fc,#38bdf8)', emoji: '🤝', emoji2: '❤️' },
        { label: 'Biblical Stories', g: 'linear-gradient(160deg,#1e1b4b,#4338ca,#312e81)', emoji: '✝️', emoji2: '📖' },
        { label: 'Anime Stories',    g: 'linear-gradient(160deg,#2d1b69,#7c3aed,#a855f7)', emoji: '⚔️', emoji2: '🌸' },
        { label: 'Heist',            g: 'linear-gradient(160deg,#111827,#1f2937,#374151)', emoji: '🕵️', emoji2: '💰' },
        { label: 'Mythology',        g: 'linear-gradient(160deg,#451a03,#92400e,#b45309)', emoji: '⚡', emoji2: '🏛️' },
        { label: 'Horror',           g: 'linear-gradient(160deg,#0c0a09,#1c1917,#292524)', emoji: '👻', emoji2: '🩸' },
        { label: 'Finance Tips',     g: 'linear-gradient(160deg,#052e16,#166534,#15803d)', emoji: '💹', emoji2: '💵' },
        { label: 'Motivation',       g: 'linear-gradient(160deg,#4a044e,#a21caf,#c026d3)', emoji: '🔥', emoji2: '💪' },
      ];
    %>
    <div class="niche-marquee-wrap">
      <div class="niche-marquee-track">
        <% [...niches, ...niches].forEach(n => { %>
          <% const nicheDb = locals.nicheMap && locals.nicheMap[n.label]; %>
          <% const nicheVideo = nicheDb && nicheDb.video_url ? nicheDb.video_url : ''; %>
          <a class="niche-card" href="<%= nicheVideo ? '#' : '/reels/create?topic=' + encodeURIComponent(n.label) %>"
             title="<%= n.label %>"
             <% if (nicheVideo) { %>onclick="playYT('<%= nicheVideo %>');return false;"<% } %>>
            <div style="width:100%;height:100%;background:<%= n.g %>;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;">
              <% if (nicheVideo) { %>
              <div style="width:44px;height:44px;background:rgba(255,255,255,0.25);border-radius:50%;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </div>
              <% } else { %>
              <span style="font-size:2rem;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.4));"><%= n.emoji %></span>
              <span style="font-size:1.3rem;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.3));"><%= n.emoji2 %></span>
              <% } %>
            </div>
            <div class="niche-label"><%= n.label %></div>
          </a>
        <% }) %>
      </div>
    </div>

  </section>

  <!-- ── STATS STRIP ───────────────────────────────────────────────────────── -->
  <section class="reels-stats-section" style="background:#f9fafb; border-top:1px solid #e5e7eb; border-bottom:1px solid #e5e7eb; padding:48px 24px;">
    <div style="max-width:760px; margin:0 auto; text-align:center;">
      <h2 style="font-size:clamp(1.6rem,4vw,2.4rem); font-weight:800; color:#111827; margin-bottom:6px;">
        We actually get views
      </h2>
      <p style="color:#7c3aed; font-size:15px; margin-bottom:36px;">Real creators getting results with SmrAI Reels.</p>

      <div class="grid grid-cols-3 gap-3">
        <div class="stat-card">
          <div class="stat-num" style="font-size:2rem; font-weight:800; color:#7c3aed;">10K+</div>
          <div class="stat-lbl" style="font-size:13px; color:#6b7280; margin-top:4px;">Reels Generated</div>
        </div>
        <div class="stat-card">
          <div class="stat-num" style="font-size:2rem; font-weight:800; color:#7c3aed;">6</div>
          <div class="stat-lbl" style="font-size:13px; color:#6b7280; margin-top:4px;">AI Voice Options</div>
        </div>
        <div class="stat-card">
          <div class="stat-num" style="font-size:2rem; font-weight:800; color:#7c3aed;">&lt;2 min</div>
          <div class="stat-lbl" style="font-size:13px; color:#6b7280; margin-top:4px;">Avg. Gen Time</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CHANNEL PROOF CAROUSEL ────────────────────────────────────────────── -->
  <section style="padding: 0 24px 72px; max-width: 760px; margin: 0 auto; text-align:center;">
    <h2 style="font-size:clamp(1.6rem,4vw,2.4rem); font-weight:800; color:#111827; margin-bottom:6px;">
      We actually get views
    </h2>
    <p style="font-size:15px; margin-bottom:28px;">
      <span style="color:#6b7280;">Real channels getting </span>
      <span style="color:#7c3aed; font-weight:600;">millions of views</span>
      <span style="color:#6b7280;"> with our AI tool.</span>
    </p>

    <!-- Carousel wrapper -->
    <div style="border:1px solid #e5e7eb; border-radius:16px; overflow:hidden; background:#fff; box-shadow:0 2px 16px rgba(0,0,0,0.06);">

      <!-- Arrows -->
      <div style="display:flex; justify-content:flex-end; gap:6px; padding:12px 16px 0;">
        <button onclick="prevSlide()" style="width:30px;height:30px;border-radius:6px;border:1px solid #e5e7eb;background:#fff;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;color:#374151;">‹</button>
        <button onclick="nextSlide()" style="width:30px;height:30px;border-radius:6px;border:1px solid #e5e7eb;background:#fff;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;color:#374151;">›</button>
      </div>

      <!-- Slides -->
      <div id="carouselTrack" style="display:flex; overflow:hidden; padding:12px 16px;">
        <%
          const gradients = [
            'linear-gradient(160deg,#4a044e,#a21caf,#c026d3)',
            'linear-gradient(160deg,#052e16,#166534,#15803d)',
            'linear-gradient(160deg,#451a03,#92400e,#b45309)',
            'linear-gradient(160deg,#111827,#1f2937,#374151)',
            'linear-gradient(160deg,#1e1b4b,#312e81,#4338ca)',
            'linear-gradient(160deg,#0c0a09,#1c1917,#292524)',
          ];
          const channelSlides = locals.channelProof && locals.channelProof.length ? locals.channelProof.map(r => ({
            channel: r.channel_name,
            handle: r.handle || '',
            videos: (typeof r.videos === 'string' ? JSON.parse(r.videos||'[]') : r.videos || []),
          })) : [];
        %>
        <% if (channelSlides.length === 0) { %>
        <div style="min-width:100%;padding:2rem;text-align:center;color:#9ca3af;font-size:14px;">
          No channels added yet. Add them from the admin panel.
        </div>
        <% } %>
        <% channelSlides.forEach((slide, si) => { %>
        <div class="carousel-slide" style="min-width:100%; display:<%= si===0 ? 'block' : 'none' %>;">
          <div style="display:flex; gap:8px; margin-bottom:14px;">
            <% slide.videos.slice(0,3).forEach((v, vi) => { %>
            <div onclick="<%= v.url ? 'playYT(\''+v.url+'\')' : '' %>"
                 style="flex:1; aspect-ratio:9/16; border-radius:10px; overflow:hidden; position:relative; background:<%= gradients[vi % gradients.length] %>; <%= v.url ? 'cursor:pointer;' : '' %>">
              <% if (si === 0) { %>
                <div style="position:absolute;top:8px;left:8px;background:#ef4444;color:white;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;">Pinned</div>
              <% } %>
              <div style="position:absolute;bottom:8px;left:8px;color:white;font-size:12px;font-weight:600;display:flex;align-items:center;gap:4px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                <%= v.views || '' %>
              </div>
            </div>
            <% }) %>
          </div>
          <div style="display:flex; align-items:center; justify-content:space-between; padding:0 4px 12px;">
            <div style="display:flex; align-items:center; gap:10px;">
              <div style="width:36px;height:36px;border-radius:50%;background:#7c3aed;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:14px;">
                <%= slide.channel[0].toUpperCase() %>
              </div>
              <div style="text-align:left;">
                <div style="font-size:14px;font-weight:600;color:#111827;display:flex;align-items:center;gap:4px;">
                  <%= slide.channel %>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#0ea5e9"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                </div>
                <div style="font-size:12px;color:#9ca3af;"><%= slide.handle %></div>
              </div>
            </div>
            <div style="display:flex;gap:5px;">
              <% channelSlides.forEach((_, di) => { %>
                <div class="carousel-dot" data-index="<%= di %>" style="width:7px;height:7px;border-radius:50%;background:<%= di===si ? '#7c3aed' : '#e5e7eb' %>;cursor:pointer;" onclick="goToSlide(<%= di %>)"></div>
              <% }) %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ── WHY CREATORS CHOOSE US ─────────────────────────────────────────────── -->
  <section class="reels-why-section" style="padding: 0 24px 80px; max-width: 860px; margin: 0 auto; text-align:center;">
    <h2 style="font-size:clamp(1.6rem,4vw,2.4rem); font-weight:800; color:#111827; margin-bottom:8px;">
      Why creators choose us
    </h2>
    <p style="font-size:15px; color:#6b7280; margin-bottom:36px;">
      See how SmrAI Reels compares to <span style="color:#7c3aed;">traditional content creation</span> methods.
    </p>

    <div class="reels-why-grid grid grid-cols-1 sm:grid-cols-3 gap-4">

      <!-- Card 1: Hiring editors (red) -->
      <div class="reels-why-card" style="border:1px solid #fecaca; border-radius:16px; padding:24px; text-align:left; background:#fff;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
          <span style="font-size:14px; font-weight:700; color:#111827;">Hiring video editors</span>
          <span style="color:#ef4444; font-size:18px; font-weight:700;">✕</span>
        </div>
        <p style="font-size:13px; color:#ef4444; line-height:1.6;">
          Expensive at $50–200 per video, requires management and coordination with freelancers.
        </p>
      </div>

      <!-- Card 2: DIY (orange) -->
      <div class="reels-why-card" style="border:1px solid #fed7aa; border-radius:16px; padding:24px; text-align:left; background:#fff;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
          <span style="font-size:14px; font-weight:700; color:#111827;">Creating videos yourself</span>
          <span style="color:#f97316; font-size:18px; font-weight:700;">✕</span>
        </div>
        <p style="font-size:13px; color:#f97316; line-height:1.6;">
          Time-consuming process of scripting, recording, editing, and publishing across multiple platforms.
        </p>
      </div>

      <!-- Card 3: SmrAI (green) -->
      <div class="reels-why-card" style="border:1px solid #bbf7d0; border-radius:16px; padding:24px; text-align:left; background:#f0fdf4;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
          <span style="font-size:14px; font-weight:700; color:#111827;">SmrAI Reels</span>
          <span style="color:#22c55e; font-size:18px; font-weight:700;">✓</span>
        </div>
        <p style="font-size:13px; color:#16a34a; line-height:1.6;">
          Create and publish high-quality faceless reels on autopilot across TikTok, Instagram, and YouTube.
        </p>
      </div>

    </div>
  </section>

  <!-- ── TESTIMONIALS ───────────────────────────────────────────────────────── -->
  <section class="reels-testimonials-section" style="padding: 0 24px 80px; max-width: 1100px; margin: 0 auto;">
    <div style="text-align:center; margin-bottom:36px;">
      <h2 style="font-size:clamp(1.6rem,4vw,2.4rem); font-weight:800; color:#111827; margin-bottom:8px;">
        Hear what they say about us
      </h2>
      <p style="font-size:15px; color:#6b7280;">Real creators sharing their experience with SmrAI Reels.</p>
    </div>

    <%
      const testimonials = [
        { name:'Nana Bandoh',              letter:'N', bg:'#7c3aed', quote:'I went from 0 to 50K followers in 3 months just using this tool. My faceless finance channel basically runs itself now.' },
        { name:'Cynthia Duncan',            letter:'C', bg:'#db2777', quote:'The AI script quality is insane — it actually sounds like a real person wrote it. My engagement tripled overnight.' },
        { name:'Third Eye Vision Pictures', letter:'T', bg:'#0891b2', quote:'We create 5 reels a day across 3 niches. SmrAI does all the heavy lifting — scripts, voice, video. Game changer.' },
        { name:'Marcus Owusu',              letter:'M', bg:'#d97706', quote:'Tried every tool out there. Nothing comes close to the speed and quality here. My YouTube Shorts are finally popping off.' },
