<%- include('../partials/header', { title: 'AI Reel Generator — SmrAI Studio' }) %>
<script src="https://cdn.tailwindcss.com"></script>

<style>
  #reels-landing {
    background: #ffffff;
    color: #111827;
    min-height: 100vh;
  }
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #7c3aed;
    color: #fff;
    font-size: 17px;
    font-weight: 600;
    padding: 16px 36px;
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.2s, transform 0.1s;
    box-shadow: 0 4px 24px rgba(124,58,237,0.35);
  }
  .btn-cta:hover { background: #6d28d9; transform: translateY(-2px); }

  /* Niche cards */
  .niche-scroll {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    padding: 8px 4px 16px;
    scrollbar-width: none;
  }
  .niche-scroll::-webkit-scrollbar { display: none; }
  .niche-card {
    flex-shrink: 0;
    width: 150px;
    aspect-ratio: 9/16;
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .niche-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.2); }
  .niche-label {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 28px 10px 12px;
    background: linear-gradient(to top, rgba(0,0,0,0.75), transparent);
    color: white;
    font-size: 12px;
    font-weight: 600;
    text-align: center;
    letter-spacing: 0.02em;
  }
  /* Platform icon badges */
  .platform-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #f3f4f6;
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 500;
    color: #374151;
  }
  /* Stat cards */
  .stat-card {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 24px;
    text-align: center;
  }
  /* Avatar stack */
  .avatar-stack { display: flex; }
  .avatar-stack img,
  .avatar-item {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 2px solid white;
    margin-left: -8px;
    object-fit: cover;
  }
  .avatar-stack > *:first-child { margin-left: 0; }
  .avatar-item {
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700;
    color: white;
  }
</style>

<div id="reels-landing" style="padding-top: 70px;">

  <!-- ── HERO ──────────────────────────────────────────────────────────────── -->
  <section style="text-align:center; padding: 60px 16px 48px; max-width: 680px; margin: 0 auto;">

    <!-- Trusted row -->
    <div style="display:flex; align-items:center; justify-content:center; gap:10px; margin-bottom:28px;">
      <div class="avatar-stack">
        <div class="avatar-item" style="background:#7c3aed;">A</div>
        <div class="avatar-item" style="background:#db2777;">B</div>
        <div class="avatar-item" style="background:#0891b2;">C</div>
        <div class="avatar-item" style="background:#d97706;">D</div>
      </div>
      <span style="font-size:14px; color:#6b7280; font-weight:500;">Trusted by creators</span>
    </div>

    <!-- Headline -->
    <h1 style="font-size:clamp(2.2rem,5vw,3.6rem); font-weight:800; line-height:1.1; letter-spacing:-0.03em; color:#111827; margin-bottom:16px;">
      Create viral faceless<br>reels on auto-pilot
    </h1>

    <!-- Subtitle -->
    <p style="font-size:16px; color:#6b7280; line-height:1.7; max-width:480px; margin:0 auto 24px;">
      The only AI that writes scripts, records voice & builds reels for you automatically — even while you sleep.
    </p>

    <!-- Platform badges -->
    <div style="display:flex; align-items:center; justify-content:center; gap:8px; flex-wrap:wrap; margin-bottom:32px;">
      <span style="font-size:13px; color:#9ca3af;">Perfect for</span>
      <span class="platform-badge">▶️ YouTube</span>
      <span class="platform-badge">📸 Instagram</span>
      <span class="platform-badge">🎵 TikTok</span>
    </div>

    <!-- CTA -->
    <a href="/reels/create" class="btn-cta">
      ⚡ Create your first video
    </a>
    <p style="font-size:13px; color:#9ca3af; margin-top:12px;">Get your reel in less than 2 minutes.</p>

  </section>

  <!-- ── NICHE SHOWCASE ─────────────────────────────────────────────────────── -->
  <section style="padding: 0 24px 64px; max-width: 1100px; margin: 0 auto;">

    <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px; font-size:15px; font-weight:600; color:#374151;">
      Creates reels for any niche
      <svg width="18" height="18" fill="none" stroke="#7c3aed" stroke-width="2.5" viewBox="0 0 24 24" style="transform:rotate(15deg)">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>

    <div class="niche-scroll">
      <%
        const niches = [
          { label: 'Act of Kindness',  g: 'linear-gradient(160deg,#bae6fd,#7dd3fc,#38bdf8)' },
          { label: 'Biblical Stories', g: 'linear-gradient(160deg,#1e1b4b,#4338ca,#312e81)' },
          { label: 'Anime Stories',    g: 'linear-gradient(160deg,#2d1b69,#7c3aed,#a855f7)' },
          { label: 'Heist',            g: 'linear-gradient(160deg,#111827,#1f2937,#374151)' },
          { label: 'Mythology',        g: 'linear-gradient(160deg,#451a03,#92400e,#b45309)' },
          { label: 'Horror',           g: 'linear-gradient(160deg,#0c0a09,#1c1917,#292524)' },
          { label: 'Finance Tips',     g: 'linear-gradient(160deg,#052e16,#166534,#15803d)' },
          { label: 'Motivation',       g: 'linear-gradient(160deg,#4a044e,#a21caf,#c026d3)' },
        ];
      %>
      <% niches.forEach(n => { %>
        <a class="niche-card" href="/reels/create?topic=<%= encodeURIComponent(n.label) %>" title="<%= n.label %>">
          <div style="width:100%;height:100%;background:<%= n.g %>;"></div>
          <div class="niche-label"><%= n.label %></div>
        </a>
      <% }) %>
    </div>

  </section>

  <!-- ── STATS STRIP ───────────────────────────────────────────────────────── -->
  <section style="background:#f9fafb; border-top:1px solid #e5e7eb; border-bottom:1px solid #e5e7eb; padding:48px 24px;">
    <div style="max-width:760px; margin:0 auto; text-align:center;">
      <h2 style="font-size:clamp(1.6rem,4vw,2.4rem); font-weight:800; color:#111827; margin-bottom:6px;">
        We actually get views
      </h2>
      <p style="color:#7c3aed; font-size:15px; margin-bottom:36px;">Real creators getting results with SmrAI Reels.</p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="stat-card">
          <div style="font-size:2rem; font-weight:800; color:#7c3aed;">10K+</div>
          <div style="font-size:13px; color:#6b7280; margin-top:4px;">Reels Generated</div>
        </div>
        <div class="stat-card">
          <div style="font-size:2rem; font-weight:800; color:#7c3aed;">6</div>
          <div style="font-size:13px; color:#6b7280; margin-top:4px;">AI Voice Options</div>
        </div>
        <div class="stat-card">
          <div style="font-size:2rem; font-weight:800; color:#7c3aed;">&lt;2 min</div>
          <div style="font-size:13px; color:#6b7280; margin-top:4px;">Average Generation Time</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CHANNEL PROOF CAROUSEL ────────────────────────────────────────────── -->
  <section style="padding: 0 24px 72px; max-width: 760px; margin: 0 auto; text-align:center;">
    <h2 style="font-size:clamp(1.6rem,4vw,2.4rem); font-weight:800; color:#111827; margin-bottom:6px;">
      We actually get views
    </h2>
    <p style="font-size:15px; margin-bottom:28px;">
      <span style="color:#6b7280;">Real channels getting </span>
      <span style="color:#7c3aed; font-weight:600;">millions of views</span>
      <span style="color:#6b7280;"> with our AI tool.</span>
    </p>

    <!-- Carousel wrapper -->
    <div style="border:1px solid #e5e7eb; border-radius:16px; overflow:hidden; background:#fff; box-shadow:0 2px 16px rgba(0,0,0,0.06);">

      <!-- Arrows -->
      <div style="display:flex; justify-content:flex-end; gap:6px; padding:12px 16px 0;">
        <button onclick="prevSlide()" style="width:30px;height:30px;border-radius:6px;border:1px solid #e5e7eb;background:#fff;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;color:#374151;">‹</button>
        <button onclick="nextSlide()" style="width:30px;height:30px;border-radius:6px;border:1px solid #e5e7eb;background:#fff;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;color:#374151;">›</button>
      </div>

      <!-- Slides -->
      <div id="carouselTrack" style="display:flex; overflow:hidden; padding:12px 16px;">
        <%
          const channelSlides = [
            {
              channel: 'darktruthdaily',
              handle: '@darktruthdaily1',
              videos: [
                { views:'1.4M', g:'linear-gradient(160deg,#111827,#1f2937,#374151)' },
                { views:'223K', g:'linear-gradient(160deg,#1e1b4b,#312e81,#4338ca)' },
                { views:'3,997', g:'linear-gradient(160deg,#0c0a09,#1c1917,#292524)' },
              ]
            },
            {
              channel: 'motivationhub',
              handle: '@motivationhub_ai',
              videos: [
                { views:'892K', g:'linear-gradient(160deg,#4a044e,#a21caf,#c026d3)' },
                { views:'541K', g:'linear-gradient(160deg,#052e16,#166534,#15803d)' },
                { views:'210K', g:'linear-gradient(160deg,#451a03,#92400e,#b45309)' },
              ]
            },
          ];
        %>
        <% channelSlides.forEach((slide, si) => { %>
        <div class="carousel-slide" style="min-width:100%; display:<%= si===0 ? 'block' : 'none' %>;">
          <!-- Video thumbnails row -->
          <div style="display:flex; gap:8px; margin-bottom:14px;">
            <% slide.videos.forEach(v => { %>
            <div style="flex:1; aspect-ratio:9/16; border-radius:10px; overflow:hidden; position:relative; background:<%= v.g %>;">
              <% if (si === 0) { %>
                <div style="position:absolute;top:8px;left:8px;background:#ef4444;color:white;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;">Pinned</div>
              <% } %>
              <div style="position:absolute;bottom:8px;left:8px;color:white;font-size:12px;font-weight:600;display:flex;align-items:center;gap:4px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                <%= v.views %>
              </div>
            </div>
            <% }) %>
          </div>
          <!-- Channel info -->
          <div style="display:flex; align-items:center; justify-content:space-between; padding:0 4px 12px;">
            <div style="display:flex; align-items:center; gap:10px;">
              <div style="width:36px;height:36px;border-radius:50%;background:#7c3aed;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:14px;">
                <%= slide.channel[0].toUpperCase() %>
              </div>
              <div style="text-align:left;">
                <div style="font-size:14px;font-weight:600;color:#111827;display:flex;align-items:center;gap:4px;">
                  <%= slide.channel %>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#0ea5e9"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                </div>
                <div style="font-size:12px;color:#9ca3af;"><%= slide.handle %></div>
              </div>
            </div>
            <!-- Dots -->
            <div style="display:flex;gap:5px;">
              <% channelSlides.forEach((_, di) => { %>
                <div class="carousel-dot" data-index="<%= di %>" style="width:7px;height:7px;border-radius:50%;background:<%= di===si ? '#7c3aed' : '#e5e7eb' %>;cursor:pointer;" onclick="goToSlide(<%= di %>)"></div>
              <% }) %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ── WHY CREATORS CHOOSE US ─────────────────────────────────────────────── -->
  <section style="padding: 0 24px 80px; max-width: 860px; margin: 0 auto; text-align:center;">
    <h2 style="font-size:clamp(1.6rem,4vw,2.4rem); font-weight:800; color:#111827; margin-bottom:8px;">
      Why creators choose us
    </h2>
    <p style="font-size:15px; color:#6b7280; margin-bottom:36px;">
      See how SmrAI Reels compares to <span style="color:#7c3aed;">traditional content creation</span> methods.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

      <!-- Card 1: Hiring editors (red) -->
      <div style="border:1px solid #fecaca; border-radius:16px; padding:24px; text-align:left; background:#fff;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
          <span style="font-size:14px; font-weight:700; color:#111827;">Hiring video editors</span>
          <span style="color:#ef4444; font-size:18px; font-weight:700;">✕</span>
        </div>
        <p style="font-size:13px; color:#ef4444; line-height:1.6;">
          Expensive at $50–200 per video, requires management and coordination with freelancers.
        </p>
      </div>

      <!-- Card 2: DIY (orange) -->
      <div style="border:1px solid #fed7aa; border-radius:16px; padding:24px; text-align:left; background:#fff;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
          <span style="font-size:14px; font-weight:700; color:#111827;">Creating videos yourself</span>
          <span style="color:#f97316; font-size:18px; font-weight:700;">✕</span>
        </div>
        <p style="font-size:13px; color:#f97316; line-height:1.6;">
          Time-consuming process of scripting, recording, editing, and publishing across multiple platforms.
        </p>
      </div>

      <!-- Card 3: SmrAI (green) -->
      <div style="border:1px solid #bbf7d0; border-radius:16px; padding:24px; text-align:left; background:#f0fdf4;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
          <span style="font-size:14px; font-weight:700; color:#111827;">SmrAI Reels</span>
          <span style="color:#22c55e; font-size:18px; font-weight:700;">✓</span>
        </div>
        <p style="font-size:13px; color:#16a34a; line-height:1.6;">
          Create and publish high-quality faceless reels on autopilot across TikTok, Instagram, and YouTube.
        </p>
      </div>

    </div>
  </section>

  <!-- ── TESTIMONIALS ───────────────────────────────────────────────────────── -->
  <section style="padding: 0 24px 80px; max-width: 1100px; margin: 0 auto;">
    <div style="text-align:center; margin-bottom:36px;">
      <h2 style="font-size:clamp(1.6rem,4vw,2.4rem); font-weight:800; color:#111827; margin-bottom:8px;">
        Hear what they say about us
      </h2>
      <p style="font-size:15px; color:#6b7280;">Real creators sharing their experience with SmrAI Reels.</p>
    </div>

    <%
      const testimonials = [
        [
          { name:'Nana Bandoh',               letter:'N', bg:'#7c3aed', quote:'I went from 0 to 50K followers in 3 months just using this tool. My faceless finance channel basically runs itself now.' },
          { name:'Cynthia Duncan',             letter:'C', bg:'#db2777', quote:'The AI script quality is insane — it actually sounds like a real person wrote it. My engagement tripled overnight.' },
          { name:'Third Eye Vision Pictures',  letter:'T', bg:'#0891b2', quote:'We create 5 reels a day across 3 niches. SmrAI does all the heavy lifting — scripts, voice, video. Game changer.' },
          { name:'Marcus Owusu',               letter:'M', bg:'#d97706', quote:'Tried every tool out there. Nothing comes close to the speed and quality here. My YouTube Shorts are finally popping off.' },
        ],
        [
          { name:'Loyal Earl',   letter:'L', bg:'#059669', quote:'I was skeptical at first but my first reel hit 200K views. Now I post daily without touching the camera at all.' },
          { name:'Agnes Chen',   letter:'A', bg:'#7c3aed', quote:'The voiceover quality is so realistic. Viewers keep asking what equipment I use — they have no idea it is 100% AI.' },
          { name:'Josh Wright (Bikr)', letter:'J', bg:'#dc2626', quote:'Running a horror niche channel used to take me 6 hours per video. Now it takes 2 minutes. My life has completely changed.' },
          { name:'Priya Sharma', letter:'P', bg:'#c026d3', quote:'SmrAI is the only reason I was able to quit my 9-5. Three channels, all fully automated. The income is real.' },
        ],
      ];
    %>

    <% testimonials.forEach((row, rowIdx) => { %>
    <div style="display:flex; gap:16px; overflow-x:auto; padding:4px 2px 12px; scrollbar-width:none; -webkit-overflow-scrolling:touch; margin-bottom:16px;" onmouseover="this.style.cursor='grab'" onmousedown="this.style.cursor='grabbing'" onmouseup="this.style.cursor='grab'">
      <% row.forEach(t => { %>
      <div style="flex-shrink:0; width:260px; background:#fff; border:1px solid #e5e7eb; border-radius:16px; padding:20px; box-shadow:0 1px 6px rgba(0,0,0,0.05);">
        <!-- Stars -->
        <div style="display:flex; gap:2px; margin-bottom:12px;">
          <% for(let i=0;i<5;i++) { %><span style="color:#f59e0b; font-size:15px;">★</span><% } %>
        </div>
        <!-- Quote -->
        <p style="font-size:13px; color:#374151; line-height:1.65; margin-bottom:16px;">"<%= t.quote %>"</p>
        <!-- Author -->
        <div style="display:flex; align-items:center; gap:10px;">
          <div style="width:36px;height:36px;border-radius:50%;background:<%= t.bg %>;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:14px;flex-shrink:0;">
            <%= t.letter %>
          </div>
          <div style="font-size:13px; font-weight:600; color:#111827;"><%= t.name %></div>
        </div>
      </div>
      <% }) %>
    </div>
    <% }) %>
  </section>

  <!-- ── HOW IT WORKS (FINAL CTA) ──────────────────────────────────────────── -->
  <section style="background:#f9fafb; border-top:1px solid #e5e7eb; padding: 72px 24px 80px; text-align:center;">
    <div style="max-width:760px; margin:0 auto;">
      <h2 style="font-size:clamp(1.6rem,4vw,2.4rem); font-weight:800; color:#111827; margin-bottom:8px;">
        How it works
      </h2>
      <p style="font-size:15px; color:#7c3aed; font-weight:600; margin-bottom:48px;">Create faceless videos in three simple steps</p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8" style="margin-bottom:52px;">
        <% [
          ['1','Enter your topic','Type any niche or idea — or choose from our quick-start templates.','#7c3aed'],
          ['2','AI builds everything','Script, voice recording, stock clips, captions — fully automated.','#a855f7'],
          ['3','Download & post','One-click MP4 download. Share anywhere in seconds.','#ec4899'],
        ].forEach(s => { %>
        <div style="display:flex; flex-direction:column; align-items:center; gap:14px;">
          <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,<%= s[3] %>20,<%= s[3] %>40);border:2px solid <%= s[3] %>50;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:800;color:<%= s[3] %>;">
            <%= s[0] %>
          </div>
          <div style="font-size:16px; font-weight:700; color:#111827;"><%= s[1] %></div>
          <div style="font-size:14px; color:#6b7280; line-height:1.65;"><%= s[2] %></div>
        </div>
        <% }) %>
      </div>

      <a href="/reels/create" class="btn-cta" style="font-size:18px; padding:18px 44px;">
        ⚡ Start Creating Now
      </a>
      <p style="font-size:13px; color:#9ca3af; margin-top:14px;">No camera. No editing skills. Just results.</p>
    </div>
  </section>

</div>

<script>
let currentSlide = 0;
const slides = document.querySelectorAll('.carousel-slide');

function goToSlide(index) {
  slides.forEach(s => s.style.display = 'none');
  slides[index].style.display = 'block';
  currentSlide = index;
  document.querySelectorAll('.carousel-dot').forEach((d, i) => {
    d.style.background = i === index ? '#7c3aed' : '#e5e7eb';
  });
}
function nextSlide() { goToSlide((currentSlide + 1) % slides.length); }
function prevSlide() { goToSlide((currentSlide - 1 + slides.length) % slides.length); }
</script>

<script>
// Pre-fill topic from ?topic= query param on the create page
