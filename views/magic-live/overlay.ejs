<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Magic Live Overlay</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    html, body { width:100vw; height:100vh; overflow:hidden; background:#0d0020; }
    canvas {
      position:fixed; top:0; left:0;
      width:1920px; height:1080px;
      pointer-events:none;
      transform-origin: top left;
    }
  </style>
  <script>
    (function scaleCanvas() {
      function resize() {
        var el = document.getElementById('c');
        if (!el) return;
        var CW = el.width || 1920, CH = el.height || 1080;
        var scale = Math.min(window.innerWidth / CW, window.innerHeight / CH);
        el.style.transform = 'scale(' + scale + ')';
        el.style.left = ((window.innerWidth  - CW * scale) / 2) + 'px';
        el.style.top  = ((window.innerHeight - CH * scale) / 2) + 'px';
      }
      window.addEventListener('resize', resize);
      window.addEventListener('load',   resize);
      document.addEventListener('DOMContentLoaded', resize);
    })();
  </script>
</head>
<body>
  <canvas id="c" width="<%= vertical ? 1080 : 1920 %>" height="<%= vertical ? 1920 : 1080 %>"></canvas>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const USER_ID = <%- userId %>;
    let   HEADER_TEXT = `<%- headerText %>`;

    const VERTICAL = <%- vertical ? 'true' : 'false' %>;

    const canvas = document.getElementById('c');
    const ctx    = canvas.getContext('2d');
    const W = canvas.width;
    const H = canvas.height;

    // ── Book layout constants (vertical-aware) ──────────────────────────────
    // Vertical: single centered column for phone/Shorts streams
    const FONT_FAMILY = '"Dancing Script", cursive';
    const FONT_SIZE   = VERTICAL ? 52  : 62;
    const BULLET_SIZE = VERTICAL ? 44  : 48;
    const COL_X       = VERTICAL ? [80] : [110, 1010];  // single column, left-aligned with margin
    const BULLET_OFF  = 52;
    const START_Y     = VERTICAL ? 200 : 178;
    const LINE_H      = VERTICAL ? 100 : 94;
    const MAX_ROWS    = VERTICAL ? 16  : 9;
    const MS_PER_CHAR = 85;

    // ── Book state ──────────────────────────────────────────────────────────
    let allPages    = [[]];
    let displayPage = 0;
    let livePageIdx = 0;
    let nextCol     = 0;
    let nextRow     = 0;
    let nameQueue   = [];
    let isWriting   = false;

    let animId      = null;
    let anim        = null;

    let flipAlpha   = 1;
    let isFlipping  = false;

    // ── Effects state ───────────────────────────────────────────────────────
    let burstParts  = [];   // sparkle burst when name finishes
    let confParts   = [];   // milestone confetti
    let recentGlow  = null; // { col, row, name, startTs }
    let totalNames  = 0;    // session total
    let lastTs      = 0;    // for physics delta
    let ambLoopId   = null; // idle ambient loop

    // ── Subscriber alert state ──────────────────────────────────────────────
    let subAlert   = null; // { name, startTs }
    let subParts   = [];   // explosion + glitter particles
    let shockwaves = [];   // expanding rings { startTs, maxR, color, delay }

    // ── Socket ──────────────────────────────────────────────────────────────
    const socket = io();
    socket.emit('join-magic', USER_ID);

    socket.on('show-name', ({ name }) => {
      document.fonts.ready.then(() => {
        nameQueue.push(name);
        if (!isWriting && !isFlipping) processNext();
      });
    });

    socket.on('clear-overlay', () => {
      nameQueue.length = 0;
      cancelAnim();
      resetPage();
    });

    socket.on('nav-page', ({ direction }) => {
      if (isFlipping) return;
      let target = displayPage;
      if      (direction === 'prev' && displayPage > 0)           target = displayPage - 1;
      else if (direction === 'next' && displayPage < livePageIdx) target = displayPage + 1;
      else if (direction === 'live')                               target = livePageIdx;
      if (target === displayPage) return;

      if (anim && displayPage === livePageIdx) {
        nameQueue.unshift(anim.name);
        if (animId) { cancelAnimationFrame(animId); animId = null; }
        anim = null; isWriting = false;
      }
      doNavPageFlip(target);
    });

    socket.on('update-header', ({ headerText }) => {
      HEADER_TEXT = headerText;
      drawFrame(performance.now());
    });

    socket.on('show-subscriber', ({ name }) => {
      document.fonts.ready.then(() => {
        doSubscriberAlert(name);
        // also queue in guestbook
        nameQueue.push(name);
        if (!isWriting && !isFlipping) processNext();
      });
    });

    // ── Helpers ─────────────────────────────────────────────────────────────
    function cancelAnim() {
      if (animId) { cancelAnimationFrame(animId); animId = null; }
      anim      = null;
      isWriting = false;
    }

    function resetPage() {
      allPages    = [[]];
      displayPage = 0;
      livePageIdx = 0;
      totalNames  = 0;
      nextCol = 0; nextRow = 0;
      isFlipping  = false; flipAlpha = 1;
      recentGlow  = null;
      burstParts.length = 0;
      confParts.length  = 0;
      cancelAnim();
      drawFrame(performance.now());
      ensureAmbientLoop();
    }

    function setFont(size, style) {
      ctx.font = (style || '700') + ' ' + size + 'px ' + FONT_FAMILY;
    }

    function charTipX(text, idx, size, startX) {
      setFont(size);
      let x = startX;
      for (let i = 0; i < idx; i++) x += ctx.measureText(text[i]).width;
      return x;
    }

    // ── Particle helpers ─────────────────────────────────────────────────────
    function updatePhysics(ts) {
      const dt = Math.min(50, ts - lastTs);
      lastTs = ts;

      for (let i = burstParts.length - 1; i >= 0; i--) {
        const p = burstParts[i];
        p.x  += p.vx * dt / 16;
        p.y  += p.vy * dt / 16;
        p.vy += 0.28 * dt / 16;
        p.vx *= Math.pow(0.97, dt / 16);
        p.rot += p.rotSpeed;
        p.life -= dt / (p.maxLife * 16);
        if (p.life <= 0) burstParts.splice(i, 1);
      }

      for (let i = confParts.length - 1; i >= 0; i--) {
        const p = confParts[i];
        p.x  += p.vx * dt / 16;
        p.y  += p.vy * dt / 16;
        p.vy += 0.18 * dt / 16;
        p.vx *= Math.pow(0.992, dt / 16);
        p.rot += p.rotSpeed;
        p.life -= dt / (p.maxLife * 16);
        if (p.life <= 0) confParts.splice(i, 1);
      }

      for (let i = subParts.length - 1; i >= 0; i--) {
        const p = subParts[i];
        p.x  += p.vx * dt / 16;
        p.y  += p.vy * dt / 16;
        if (p.kind === 'burst') {
          p.vy += 0.32 * dt / 16;
          p.vx *= Math.pow(0.965, dt / 16);
        } else {
          p.vy += 0.08 * dt / 16; // glitter falls gently
          p.vx += Math.sin(p.y / 60) * 0.04;
        }
        p.rot += p.rotSpeed;
        p.life -= dt / (p.maxLife * 16);
        if (p.life <= 0) subParts.splice(i, 1);
      }
    }

    function spawnBurst(x, y) {
      const COLS = ['#c4b5fd','#f9a8d4','#fde68a','#a5f3fc','#86efac','#fb923c'];
      for (let i = 0; i < 24; i++) {
        const angle = (Math.PI * 2 * i / 24) + (Math.random() - 0.5) * 0.5;
        const spd   = 5 + Math.random() * 11;
        burstParts.push({
          x, y,
          vx: Math.cos(angle) * spd,
          vy: Math.sin(angle) * spd - 5,
          life: 1,
          maxLife: 38 + Math.random() * 28,
          size: 3 + Math.random() * 4.5,
          rot: Math.random() * Math.PI,
          rotSpeed: (Math.random() - 0.5) * 0.28,
          color: COLS[Math.floor(Math.random() * COLS.length)],
        });
      }
    }

    function spawnMilestone() {
      const COLS = ['#f9a8d4','#fde68a','#a5f3fc','#c4b5fd','#86efac','#fb923c','#fff'];
      for (let i = 0; i < 90; i++) {
        confParts.push({
          x: 200 + Math.random() * (W - 400),
          y: -20,
          vx: (Math.random() - 0.5) * 20,
          vy: 7 + Math.random() * 16,
          life: 1,
          maxLife: 110 + Math.random() * 70,
          w: 9 + Math.random() * 14,
          h: 5 + Math.random() * 8,
          rot: Math.random() * Math.PI * 2,
          rotSpeed: (Math.random() - 0.5) * 0.2,
          color: COLS[Math.floor(Math.random() * COLS.length)],
        });
      }
    }

    // ── Subscriber alert engine ──────────────────────────────────────────────
    const SUB_DUR = 4000;

    function doSubscriberAlert(name) {
      subAlert = { name, startTs: null };
      subParts.length = 0;
      shockwaves.length = 0;

      // Radial burst from center
      const BCOLS = ['#fbbf24','#f59e0b','#c4b5fd','#f9a8d4','#fff','#67e8f9','#86efac'];
      for (let i = 0; i < 90; i++) {
        const angle = (Math.PI * 2 * i / 90) + (Math.random() - 0.5) * 0.25;
        const spd   = 9 + Math.random() * 22;
        subParts.push({
          x: W / 2, y: H / 2,
          vx: Math.cos(angle) * spd,
          vy: Math.sin(angle) * spd - 5,
          life: 1, maxLife: 55 + Math.random() * 45,
          size: 3 + Math.random() * 7,
          rot: Math.random() * Math.PI,
          rotSpeed: (Math.random() - 0.5) * 0.32,
          color: BCOLS[Math.floor(Math.random() * BCOLS.length)],
          kind: 'burst',
        });
      }

      // Glitter rain from top
      const GCOLS = ['#fbbf24','#fff','#c4b5fd','#f9a8d4','#67e8f9'];
      for (let i = 0; i < 70; i++) {
        subParts.push({
          x: Math.random() * W,
          y: -30 - Math.random() * 300,
          vx: (Math.random() - 0.5) * 2.5,
          vy: 3 + Math.random() * 7,
          life: 1, maxLife: 140 + Math.random() * 80,
          size: 2 + Math.random() * 5,
          rot: Math.random() * Math.PI * 2,
          rotSpeed: (Math.random() - 0.5) * 0.18,
          color: GCOLS[Math.floor(Math.random() * GCOLS.length)],
          kind: 'glitter',
        });
      }

      // Shockwaves
      shockwaves.push({ startTs: null, delay: 0,   maxR: 700, color: '#fbbf24', lw: 4 });
      shockwaves.push({ startTs: null, delay: 140, maxR: 960, color: '#a78bfa', lw: 2.5 });
      shockwaves.push({ startTs: null, delay: 280, maxR: 560, color: '#f9a8d4', lw: 2 });
    }

    function rRekt(x, y, w, h, r) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + w - r, y);
      ctx.arcTo(x + w, y, x + w, y + r, r);
      ctx.lineTo(x + w, y + h - r);
      ctx.arcTo(x + w, y + h, x + w - r, y + h, r);
      ctx.lineTo(x + r, y + h);
      ctx.arcTo(x, y + h, x, y + h - r, r);
      ctx.lineTo(x, y + r);
      ctx.arcTo(x, y, x + r, y, r);
      ctx.closePath();
    }

    function drawLightning(x1, y1, x2, y2, alpha) {
      const SEG = 10;
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.lineWidth   = 2.5;
      ctx.lineCap     = 'round';
      ctx.shadowBlur  = 18;
      ctx.shadowColor = '#c4b5fd';
      ctx.strokeStyle = '#a78bfa';
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      for (let i = 1; i < SEG; i++) {
        const px = x1 + (x2 - x1) * (i / SEG) + (Math.random() - 0.5) * 80;
        const py = y1 + (y2 - y1) * (i / SEG) + (Math.random() - 0.5) * 80;
        ctx.lineTo(px, py);
      }
      ctx.lineTo(x2, y2);
      ctx.stroke();
      ctx.lineWidth   = 1;
      ctx.strokeStyle = '#fff';
      ctx.shadowBlur  = 6;
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      for (let i = 1; i < SEG; i++) {
        const px = x1 + (x2 - x1) * (i / SEG) + (Math.random() - 0.5) * 80;
        const py = y1 + (y2 - y1) * (i / SEG) + (Math.random() - 0.5) * 80;
        ctx.lineTo(px, py);
      }
      ctx.lineTo(x2, y2);
      ctx.stroke();
      ctx.restore();
    }

    function drawSubscriberAlert(ts) {
      if (!subAlert) return;
      if (!subAlert.startTs) { subAlert.startTs = ts; return; }

      const age = ts - subAlert.startTs;
      if (age > SUB_DUR) { subAlert = null; subParts.length = 0; shockwaves.length = 0; return; }

      const t = age / SUB_DUR;
      const alpha = t < 0.12 ? t / 0.12 : t > 0.78 ? (1 - t) / 0.22 : 1;

      // ── Screen dim ────────────────────────────────────────────────────────
      ctx.save();
      ctx.globalAlpha = alpha * 0.52;
      ctx.fillStyle   = 'rgba(5,0,15,0.7)';
      ctx.fillRect(0, 0, W, H);
      ctx.restore();

      // ── Edge glow ─────────────────────────────────────────────────────────
      const pulse = 0.55 + 0.45 * Math.sin(age / 160);
      const eSize = 110;
      [[0,0,0,eSize,'#fbbf24','down'],[0,H-eSize,0,H,'#a78bfa','up'],
       [0,0,eSize,0,'#fbbf24','right'],[W-eSize,0,W,0,'#a78bfa','left']
      ].forEach(([x,y,x2,y2,col,dir]) => {
        let g;
        if (dir==='down')  g = ctx.createLinearGradient(0,y,0,y+eSize);
        else if (dir==='up') g = ctx.createLinearGradient(0,y,0,y+eSize);
        else if (dir==='right') g = ctx.createLinearGradient(x,0,x+eSize,0);
        else g = ctx.createLinearGradient(W-eSize,0,W,0);
        const a = alpha * pulse * 0.55;
        if (dir==='down'||dir==='right') { g.addColorStop(0,col.replace(')',`,${a})`).replace('rgb','rgba')||`rgba(251,191,36,${a})`); g.addColorStop(1,'rgba(0,0,0,0)'); }
        else                             { g.addColorStop(0,'rgba(0,0,0,0)'); g.addColorStop(1,col.replace(')',`,${a})`).replace('rgb','rgba')||`rgba(167,139,250,${a})`); }
        ctx.fillStyle = g;
        if (dir==='down')  ctx.fillRect(0,0,W,eSize);
        else if (dir==='up') ctx.fillRect(0,H-eSize,W,eSize);
        else if (dir==='right') ctx.fillRect(0,0,eSize,H);
        else ctx.fillRect(W-eSize,0,eSize,H);
      });

      // ── Simplified edge glow ──────────────────────────────────────────────
      ctx.save();
      ctx.globalAlpha = alpha * pulse * 0.5;
      const eg1 = ctx.createLinearGradient(0,0,0,eSize);
      eg1.addColorStop(0,`rgba(251,191,36,0.6)`); eg1.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle = eg1; ctx.fillRect(0,0,W,eSize);
      const eg2 = ctx.createLinearGradient(0,H-eSize,0,H);
      eg2.addColorStop(0,'rgba(0,0,0,0)'); eg2.addColorStop(1,'rgba(167,139,250,0.6)');
      ctx.fillStyle = eg2; ctx.fillRect(0,H-eSize,W,eSize);
      const eg3 = ctx.createLinearGradient(0,0,eSize,0);
      eg3.addColorStop(0,`rgba(251,191,36,0.6)`); eg3.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle = eg3; ctx.fillRect(0,0,eSize,H);
      const eg4 = ctx.createLinearGradient(W-eSize,0,W,0);
      eg4.addColorStop(0,'rgba(0,0,0,0)'); eg4.addColorStop(1,'rgba(167,139,250,0.6)');
      ctx.fillStyle = eg4; ctx.fillRect(W-eSize,0,eSize,H);
      ctx.restore();

      // ── Lightning bolts (first 1.2s) ──────────────────────────────────────
      if (age < 1200) {
        const la = alpha * Math.max(0, 1 - age / 1200) * 0.9;
        const cx = W / 2, cy = H / 2, sp = 120;
        drawLightning(0,   0,   cx - sp, cy - sp, la);
        drawLightning(W,   0,   cx + sp, cy - sp, la);
        drawLightning(0,   H,   cx - sp, cy + sp, la);
        drawLightning(W,   H,   cx + sp, cy + sp, la);
      }

      // ── Shockwaves ────────────────────────────────────────────────────────
      shockwaves.forEach((s, i) => {
        if (!s.startTs) { s.startTs = ts + (s.delay || 0); return; }
        if (ts < s.startTs) return;
        const a2 = ts - s.startTs;
        if (a2 > 900) return;
        const st = a2 / 900;
        const r  = st * s.maxR;
        ctx.save();
        ctx.globalAlpha  = (1 - st) * 0.75 * alpha;
        ctx.strokeStyle  = s.color;
        ctx.lineWidth    = s.lw * (1 - st * 0.6);
        ctx.shadowBlur   = 24;
        ctx.shadowColor  = s.color;
        ctx.beginPath(); ctx.arc(W / 2, H / 2, r, 0, Math.PI * 2); ctx.stroke();
        ctx.restore();
      });

      // ── Banner ────────────────────────────────────────────────────────────
      const BW = 900, BH = 230;
      const BX = W / 2 - BW / 2, BY = H / 2 - BH / 2;

      // Bounce-in scale
      let sc = 1;
      if (t < 0.2) {
        const et = t / 0.2;
        sc = et < 0.65 ? (et / 0.65) * 1.12 : 1.12 - ((et - 0.65) / 0.35) * 0.12;
      }

      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.translate(W / 2, H / 2);
      ctx.scale(sc, sc);
      ctx.translate(-W / 2, -H / 2);

      // Banner background
      const bgGrad = ctx.createLinearGradient(BX, BY, BX + BW, BY + BH);
      bgGrad.addColorStop(0,   'rgba(8,0,20,0.97)');
      bgGrad.addColorStop(0.5, 'rgba(20,0,45,0.97)');
      bgGrad.addColorStop(1,   'rgba(8,0,20,0.97)');
      ctx.shadowBlur  = 70;
      ctx.shadowColor = '#7c3aed';
      ctx.fillStyle   = bgGrad;
      rRekt(BX, BY, BW, BH, 22);
      ctx.fill();
      ctx.shadowBlur  = 0;

      // Animated border
      const shimP = (age % 1600) / 1600;
      const bGrad = ctx.createLinearGradient(BX + shimP * BW * 2 - BW, BY, BX + shimP * BW * 2, BY + BH);
      bGrad.addColorStop(0,    '#fbbf24');
      bGrad.addColorStop(0.25, '#c4b5fd');
      bGrad.addColorStop(0.5,  '#f9a8d4');
      bGrad.addColorStop(0.75, '#67e8f9');
      bGrad.addColorStop(1,    '#fbbf24');
      ctx.strokeStyle = bGrad;
      ctx.lineWidth   = 3.5;
      ctx.shadowBlur  = 18;
      ctx.shadowColor = '#fbbf24';
      rRekt(BX, BY, BW, BH, 22);
      ctx.stroke();
      ctx.shadowBlur  = 0;

      // Inner glow line
      ctx.strokeStyle = 'rgba(251,191,36,0.15)';
      ctx.lineWidth   = 1;
      rRekt(BX + 6, BY + 6, BW - 12, BH - 12, 18);
      ctx.stroke();

      // ✦ corner accents
      const cp = 0.6 + 0.4 * Math.sin(age / 180);
      ctx.font         = '700 30px ' + FONT_FAMILY;
      ctx.textBaseline = 'middle';
      ctx.textAlign    = 'center';
      ctx.fillStyle    = `rgba(251,191,36,${cp})`;
      ctx.shadowBlur   = 12; ctx.shadowColor = '#fbbf24';
      ctx.fillText('✦', BX + 34, H / 2);
      ctx.fillText('✦', BX + BW - 34, H / 2);
      ctx.shadowBlur   = 0;

      // "NEW SUBSCRIBER" label
      ctx.font         = '700 20px "Inter",sans-serif';
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'alphabetic';
      ctx.fillStyle    = '#fbbf24';
      ctx.shadowBlur   = 14; ctx.shadowColor = '#fbbf24';
      ctx.fillText('✦   N E W   S U B S C R I B E R   ✦', W / 2, BY + 72);
      ctx.shadowBlur   = 0;

      // Divider line
      const dlG = ctx.createLinearGradient(BX + 60, 0, BX + BW - 60, 0);
      dlG.addColorStop(0, 'rgba(251,191,36,0)');
      dlG.addColorStop(0.5, 'rgba(251,191,36,0.4)');
      dlG.addColorStop(1, 'rgba(251,191,36,0)');
      ctx.strokeStyle = dlG; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(BX + 60, BY + 85); ctx.lineTo(BX + BW - 60, BY + 85); ctx.stroke();

      // Name — golden metallic gradient
      const nLen    = subAlert.name.length;
      const nSize   = Math.min(90, Math.max(52, 90 - Math.max(0, nLen - 10) * 3));
      const nGrad   = ctx.createLinearGradient(W/2 - 360, 0, W/2 + 360, 0);
      nGrad.addColorStop(0,    '#fff4c2');
      nGrad.addColorStop(0.2,  '#f5c518');
      nGrad.addColorStop(0.5,  '#fde68a');
      nGrad.addColorStop(0.8,  '#c8960c');
      nGrad.addColorStop(1,    '#fff4c2');
      ctx.font         = '700 ' + nSize + 'px ' + FONT_FAMILY;
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'alphabetic';
      ctx.shadowBlur   = 28; ctx.shadowColor = '#fbbf24';
      ctx.fillStyle    = nGrad;
      ctx.fillText(subAlert.name, W / 2, BY + BH - 46);
      ctx.shadowBlur   = 0;

      // Shimmer sweep
      const swP  = (age % 900) / 900;
      const swG  = ctx.createLinearGradient(BX + swP * (BW + 200) - 120, BY, BX + swP * (BW + 200), BY + BH);
      swG.addColorStop(0, 'rgba(255,255,255,0)');
      swG.addColorStop(0.5, 'rgba(255,255,255,0.22)');
      swG.addColorStop(1, 'rgba(255,255,255,0)');
      ctx.fillStyle = swG;
      rRekt(BX, BY, BW, BH, 22);
      ctx.fill();

      ctx.restore();

      // ── Sub particles (drawn after banner so they're on top) ───────────────
      subParts.forEach(p => {
        if (p.life <= 0) return;
        ctx.save();
        ctx.globalAlpha = p.life * 0.92;
        ctx.fillStyle   = p.color;
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        const s = p.size * Math.sqrt(p.life);
        if (p.kind === 'glitter') {
          // 4-pointed star shape
          ctx.beginPath();
          ctx.moveTo(0, -s * 1.6); ctx.lineTo(s * 0.4, -s * 0.4);
          ctx.lineTo(s * 1.6, 0);  ctx.lineTo(s * 0.4,  s * 0.4);
          ctx.lineTo(0,  s * 1.6); ctx.lineTo(-s * 0.4, s * 0.4);
          ctx.lineTo(-s * 1.6, 0); ctx.lineTo(-s * 0.4, -s * 0.4);
          ctx.closePath(); ctx.fill();
        } else {
          ctx.shadowBlur  = 6;
          ctx.shadowColor = p.color;
          ctx.fillRect(-s / 2, -s / 2, s, s);
        }
        ctx.restore();
      });
    }

    // ── Drawing helpers ──────────────────────────────────────────────────────
    function drawHeader(alpha) {
      ctx.save();
      ctx.globalAlpha  = alpha;
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'alphabetic';

      // glow pass
      const hSize = VERTICAL ? 38 : 66;
      ctx.font        = '700 ' + hSize + 'px ' + FONT_FAMILY;
      ctx.shadowBlur  = 40;
      ctx.shadowColor = 'rgba(167,139,250,0.9)';
      ctx.fillStyle   = '#c084fc';
      ctx.fillText('✨  ' + HEADER_TEXT + '  ✨', W / 2, 82);

      // sharp pass
      ctx.shadowBlur  = 12;
      ctx.shadowColor = 'rgba(216,180,254,0.7)';
      ctx.fillStyle   = '#e879f9';
      ctx.fillText('✨  ' + HEADER_TEXT + '  ✨', W / 2, 82);

      // decorative rule
      const rg = ctx.createLinearGradient(W / 2 - 360, 0, W / 2 + 360, 0);
      rg.addColorStop(0,   'rgba(139,92,246,0)');
      rg.addColorStop(0.5, 'rgba(139,92,246,0.38)');
      rg.addColorStop(1,   'rgba(139,92,246,0)');
      ctx.strokeStyle = rg;
      ctx.lineWidth   = 1.5;
      ctx.beginPath();
      ctx.moveTo(W / 2 - 360, 96);
      ctx.lineTo(W / 2 + 360, 96);
      ctx.stroke();

      ctx.textAlign = 'left';
      ctx.restore();
    }

    function drawAmbientParticles(ts) {
      const t = ts * 0.001;
      for (let i = 0; i < 42; i++) {
        const seed  = i * 7919;
        const baseX = (seed * 13.7) % W;
        const baseY = (seed * 7.3)  % H;
        const speed = 0.032 + (seed % 100) / 2900;
        const drift = ((seed % 50) - 25) / 6500;
        const phase = (seed % 628) / 100;
        const x     = ((baseX + drift * t * W)  % W + W) % W;
        const y     = ((baseY - speed * t * H)  % H + H) % H;
        const alpha = Math.max(0, 0.07 + 0.09 * Math.sin(t * 0.75 + phase));
        const size  = 1 + (seed % 22) / 13;
        ctx.save();
        ctx.globalAlpha = alpha;
        ctx.fillStyle   = i % 3 === 0 ? '#c4b5fd' : i % 3 === 1 ? '#f9a8d4' : '#fde68a';
        ctx.beginPath();
        ctx.arc(x, y, size, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }
    }

    function drawBurstParticles() {
      burstParts.forEach(p => {
        if (p.life <= 0) return;
        ctx.save();
        ctx.globalAlpha = p.life * 0.92;
        ctx.fillStyle   = p.color;
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        const s = p.size * Math.sqrt(p.life);
        ctx.fillRect(-s / 2, -s / 2, s, s);
        ctx.restore();
      });
    }

    function drawConfettiParticles() {
      confParts.forEach(p => {
        if (p.life <= 0) return;
        ctx.save();
        ctx.globalAlpha = Math.min(1, p.life * 1.6);
        ctx.fillStyle   = p.color;
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
        ctx.restore();
      });
    }

    function drawRecentGlow(ts) {
      if (!recentGlow) return;
      if (!recentGlow.startTs) { recentGlow.startTs = ts; return; }
      const age = ts - recentGlow.startTs;
      const DUR = 4800;
      if (age > DUR) { recentGlow = null; return; }
      const t     = age / DUR;
      const pulse = 0.55 + 0.45 * Math.sin(age / 250);
      const alpha = (1 - t) * (1 - t) * pulse * 0.68;
      ctx.save();
      ctx.globalAlpha  = alpha;
      ctx.shadowBlur   = 40;
      ctx.shadowColor  = '#a78bfa';
      setFont(FONT_SIZE);
      ctx.textBaseline = 'alphabetic';
      ctx.fillStyle    = '#ddd6fe';
      ctx.fillText(recentGlow.name,
        COL_X[recentGlow.col],
        START_Y + recentGlow.row * LINE_H);
      ctx.restore();
    }

    function drawNameCounter(alpha) {
      const count = allPages.reduce((s, p) => s + p.length, 0);
      if (count === 0) return;
      ctx.save();
      ctx.globalAlpha  = alpha * 0.52;
      ctx.font         = 'italic 400 26px ' + FONT_FAMILY;
      ctx.textBaseline = 'alphabetic';
      ctx.textAlign    = 'right';
      ctx.fillStyle    = 'rgba(251,191,36,0.8)';
      ctx.fillText(count + ' guests featured tonight', W - 36, H - 52);
      ctx.textAlign    = 'left';
      ctx.restore();
    }

    // ── Draw already-written names ───────────────────────────────────────────
    function drawStaticNames() {
      (allPages[displayPage] || []).forEach(({ name, col, row }) => {
        const x = COL_X[col];
        const y = START_Y + row * LINE_H;
        drawNameAt(name, name.length, 1, x, y);
        drawBullet(col, row, 1);
      });
    }

    function drawNameAt(text, count, alpha, x, y) {
      if (count <= 0) return;
      ctx.save();
      ctx.globalAlpha  = alpha;
      setFont(FONT_SIZE);
      ctx.textBaseline = 'alphabetic';
      // golden glow halo
      ctx.shadowBlur   = 24;
      ctx.shadowColor  = 'rgba(251,191,36,0.65)';
      ctx.fillStyle    = '#fde68a';
      ctx.fillText(text.slice(0, count), x, y);
      // bright gold crisp pass
      ctx.shadowBlur   = 8;
      ctx.shadowColor  = 'rgba(245,197,24,0.5)';
      ctx.fillStyle    = '#fff4c2';
      ctx.fillText(text.slice(0, count), x, y);
      ctx.restore();
    }

    function drawBullet(col, row, alpha) {
      const x = COL_X[col] - BULLET_OFF;
      const y = START_Y + row * LINE_H;
      ctx.save();
      ctx.globalAlpha  = alpha;
      setFont(BULLET_SIZE);
      ctx.textBaseline = 'alphabetic';
      ctx.fillStyle    = 'rgba(251,191,36,0.88)';
      ctx.fillText('✦', x, y);
      ctx.restore();
    }

    // ── Page decorations ─────────────────────────────────────────────────────
    function drawPageNum(alpha) {
      ctx.save();
      ctx.globalAlpha  = alpha;
      ctx.font         = 'italic 400 32px ' + FONT_FAMILY;
      ctx.textBaseline = 'alphabetic';
      ctx.textAlign    = 'center';
      const onLive  = displayPage === livePageIdx;
      ctx.fillStyle = onLive ? 'rgba(192,132,252,0.85)' : 'rgba(250,100,100,0.9)';
      const label   = onLive
        ? `— Page ${displayPage + 1} —`
        : `— Page ${displayPage + 1}  ·  Live: Pg ${livePageIdx + 1} —`;
      ctx.fillText(label, W / 2, H - 52);
      ctx.textAlign = 'left';
      ctx.restore();
    }

    function drawDivider(alpha) {
      if (COL_X.length === 1) return; // no divider in single-column mode
      ctx.save();
      ctx.globalAlpha  = alpha * 0.18;
      ctx.strokeStyle  = '#7c3aed';
      ctx.lineWidth    = 1.5;
      ctx.setLineDash([6, 8]);
      ctx.beginPath();
      ctx.moveTo(W / 2, START_Y - 55);
      ctx.lineTo(W / 2, START_Y + MAX_ROWS * LINE_H - 10);
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.restore();
    }

    // ── Golden fountain pen ──────────────────────────────────────────────────
    function drawPen(tx, ty, alpha) {
      if (alpha <= 0) return;
      ctx.save();
      ctx.globalAlpha = alpha;
      const ANGLE  = -Math.PI / 5;
      const LENGTH = 180;
      const bx = tx - Math.cos(ANGLE) * LENGTH;
      const by = ty - Math.sin(ANGLE) * LENGTH;

      const bodyGrad = ctx.createLinearGradient(bx, by, tx, ty);
      bodyGrad.addColorStop(0,    '#fff4c2');
      bodyGrad.addColorStop(0.15, '#f5c518');
      bodyGrad.addColorStop(0.45, '#c8960c');
      bodyGrad.addColorStop(0.7,  '#f5c518');
      bodyGrad.addColorStop(0.88, '#8b6914');
      bodyGrad.addColorStop(1,    '#3a2a00');

      ctx.lineWidth   = 24; ctx.lineCap = 'round'; ctx.strokeStyle = bodyGrad;
      ctx.beginPath();
      ctx.moveTo(bx, by);
      ctx.lineTo(tx + Math.cos(ANGLE) * 14, ty + Math.sin(ANGLE) * 14);
      ctx.stroke();

      ctx.lineWidth   = 9; ctx.strokeStyle = '#1a1200';
      ctx.beginPath();
      ctx.moveTo(tx + Math.cos(ANGLE) * 14, ty + Math.sin(ANGLE) * 14);
      ctx.lineTo(tx, ty);
      ctx.stroke();

      const inkGrad = ctx.createRadialGradient(tx, ty, 0, tx, ty, 8);
      inkGrad.addColorStop(0, 'rgba(80,30,120,0.9)');
      inkGrad.addColorStop(1, 'rgba(80,30,120,0)');
      ctx.fillStyle = inkGrad;
      ctx.beginPath(); ctx.arc(tx, ty, 8, 0, Math.PI * 2); ctx.fill();

      const bandX = bx + Math.cos(ANGLE) * (LENGTH * 0.82);
      const bandY = by + Math.sin(ANGLE) * (LENGTH * 0.82);
      ctx.lineWidth = 30; ctx.strokeStyle = 'rgba(200,150,10,0.45)'; ctx.lineCap = 'butt';
      ctx.beginPath();
      ctx.moveTo(bandX - Math.cos(ANGLE)*8, bandY - Math.sin(ANGLE)*8);
      ctx.lineTo(bandX + Math.cos(ANGLE)*8, bandY + Math.sin(ANGLE)*8);
      ctx.stroke();

      ctx.fillStyle = '#f5c518';
      ctx.beginPath(); ctx.arc(bx, by, 13, 0, Math.PI * 2); ctx.fill();
      ctx.restore();
    }

    // ── Master render ────────────────────────────────────────────────────────
    function drawFrame(ts) {
      const now   = ts || performance.now();
      const alpha = flipAlpha;
      ctx.clearRect(0, 0, W, H);

      // back-to-front layering
      drawAmbientParticles(now);
      drawHeader(alpha);
      drawDivider(alpha);
      drawPageNum(alpha);
      drawNameCounter(alpha);
      drawStaticNames();
      drawRecentGlow(now);

      if (anim && displayPage === livePageIdx) {
        const { name, col, row, revealed } = anim;
        const x = COL_X[col];
        const y = START_Y + row * LINE_H;
        if (revealed > 0) drawBullet(col, row, anim.fading ? anim.fadeAlpha : 1);
        drawNameAt(name, revealed, anim.fading ? anim.fadeAlpha : 1, x, y);
        if (!anim.fading && revealed > 0) {
          const tipX  = charTipX(name, revealed, FONT_SIZE, x);
          const tipY  = y - FONT_SIZE * 0.18;
          const bounce = (revealed < name.length && now)
            ? 5 * Math.abs(Math.sin((now - anim.lastCharTs) / MS_PER_CHAR * Math.PI))
            : 0;
          drawPen(tipX, tipY + bounce, anim.penAlpha !== undefined ? anim.penAlpha : 1);
        }
      }

      // particles always on top
      drawBurstParticles();
      drawConfettiParticles();

      // subscriber alert — topmost layer
      drawSubscriberAlert(now);
    }

    // ── Animation loop ───────────────────────────────────────────────────────
    function animLoop(ts) {
      if (!anim) return;
      updatePhysics(ts);

      const { name, col, row } = anim;

      if (!anim.fading) {
        if (!anim.lastCharTs) anim.lastCharTs = ts;
        if (ts - anim.lastCharTs >= MS_PER_CHAR && anim.revealed < name.length) {
          anim.revealed++;
          anim.lastCharTs = ts;
        }

        if (anim.revealed >= name.length) {
          if (!anim.holdStart) anim.holdStart = ts;
          const held = ts - anim.holdStart;
          anim.penAlpha = held < 600 ? 1 : Math.max(0, 1 - (held - 600) / 400);

          if (held > 2000) {
            // Commit name
            allPages[livePageIdx].push({ name, col, row });
            totalNames++;

            // Sparkle burst at pen tip
            const tipX = charTipX(name, name.length, FONT_SIZE, COL_X[col]);
            const tipY = START_Y + row * LINE_H - FONT_SIZE * 0.18;
            spawnBurst(tipX, tipY);

            // Recent name glow
            recentGlow = { col, row, name, startTs: null };

            // Milestone every 10th name
            if (totalNames % 10 === 0) spawnMilestone();

            anim      = null;
            isWriting = false;
            animId    = null;
            drawFrame(ts);
            advancePosition();
            if (!isFlipping && nameQueue.length > 0) setTimeout(processNext, 100);
            else ensureAmbientLoop();
            return;
          }
        }
      }

      drawFrame(ts);
      animId = requestAnimationFrame(animLoop);
    }

    function advancePosition() {
      if (COL_X.length === 1) {
        // single column (vertical mode)
        nextRow++;
        if (nextRow >= MAX_ROWS) doPageFlip();
      } else if (nextCol === 0) {
        nextRow++;
        if (nextRow >= MAX_ROWS) { nextCol = 1; nextRow = 0; }
      } else {
        nextRow++;
        if (nextRow >= MAX_ROWS) doPageFlip();
      }
    }

    function processNext() {
      if (!nameQueue.length || isWriting || isFlipping) return;
      isWriting = true;
      const name = nameQueue.shift();
      if (animId) { cancelAnimationFrame(animId); animId = null; }
      anim = {
        name, col: nextCol, row: nextRow,
        revealed: 0, lastCharTs: null, holdStart: null,
        fading: false, fadeAlpha: 1, penAlpha: 1,
      };
      animId = requestAnimationFrame(animLoop);
    }

    // ── Idle ambient loop ────────────────────────────────────────────────────
    function ensureAmbientLoop() {
      if (ambLoopId) return;
      function loop(ts) {
        if (isWriting || isFlipping) { ambLoopId = null; return; }
        updatePhysics(ts);
        drawFrame(ts);
        ambLoopId = requestAnimationFrame(loop);
      }
      ambLoopId = requestAnimationFrame(loop);
    }

    // ── Core book-turn engine ─────────────────────────────────────────────────
    function doBookFlip(snapOld, drawNew, forward, onDone) {
      const FLIP_MS  = 820;
      const BEND_W   = 160;
      const SHADOW_W = 220;
      let   start    = null;

      function frame(ts) {
        if (!start) start = ts;
        updatePhysics(ts);
        const raw  = Math.min(1, (ts - start) / FLIP_MS);
        const ease = raw < 0.5
          ? 4 * raw * raw * raw
          : 1 - Math.pow(-2 * raw + 2, 3) / 2;

        const foldX = forward ? W * (1 - ease) : W * ease;

        ctx.clearRect(0, 0, W, H);

        // ambient particles still visible during flip
        drawAmbientParticles(ts);

        // Layer 1: new page
        drawNew();

        // Layer 2: cast shadow
        const shadowAlpha = 0.5 * Math.sin(ease * Math.PI);
        if (shadowAlpha > 0.01) {
          if (forward) {
            const x0 = Math.max(0, foldX - SHADOW_W);
            const sg = ctx.createLinearGradient(x0, 0, foldX, 0);
            sg.addColorStop(0, 'rgba(0,0,0,0)');
            sg.addColorStop(1, `rgba(0,0,0,${shadowAlpha})`);
            ctx.fillStyle = sg;
            ctx.fillRect(x0, 0, foldX - x0, H);
          } else {
            const x1 = Math.min(W, foldX + SHADOW_W);
            const sg = ctx.createLinearGradient(foldX, 0, x1, 0);
            sg.addColorStop(0, `rgba(0,0,0,${shadowAlpha})`);
            sg.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.fillStyle = sg;
            ctx.fillRect(foldX, 0, x1 - foldX, H);
          }
        }

        // Layer 3: old page clipped to unturned side
        ctx.save();
        ctx.beginPath();
        forward ? ctx.rect(foldX, 0, W - foldX, H) : ctx.rect(0, 0, foldX, H);
        ctx.clip();
        ctx.drawImage(snapOld, 0, 0);
        if (forward) {
          const bg = ctx.createLinearGradient(foldX, 0, foldX + BEND_W, 0);
          bg.addColorStop(0, `rgba(0,0,0,${0.65 * ease})`);
          bg.addColorStop(1, 'rgba(0,0,0,0)');
          ctx.fillStyle = bg;
          ctx.fillRect(foldX, 0, Math.min(BEND_W, W - foldX), H);
        } else {
          const bg = ctx.createLinearGradient(foldX - BEND_W, 0, foldX, 0);
          bg.addColorStop(0, 'rgba(0,0,0,0)');
          bg.addColorStop(1, `rgba(0,0,0,${0.65 * (1 - ease)})`);
          ctx.fillStyle = bg;
          ctx.fillRect(Math.max(0, foldX - BEND_W), 0, Math.min(BEND_W, foldX), H);
        }
        ctx.restore();

        // Layer 4: fold crease highlight
        const creaseAlpha = 0.65 * Math.sin(ease * Math.PI);
        if (creaseAlpha > 0.02 && foldX > 4 && foldX < W - 4) {
          const cg = ctx.createLinearGradient(foldX - 18, 0, foldX + 18, 0);
          cg.addColorStop(0,    'rgba(255,255,255,0)');
          cg.addColorStop(0.45, `rgba(255,255,255,${creaseAlpha})`);
          cg.addColorStop(0.55, `rgba(200,180,255,${creaseAlpha * 0.8})`);
          cg.addColorStop(1,    'rgba(255,255,255,0)');
          ctx.fillStyle = cg;
          ctx.fillRect(foldX - 18, 0, 36, H);
        }

        // burst/confetti still visible during flip
        drawBurstParticles();
        drawConfettiParticles();

        if (raw < 1) {
          animId = requestAnimationFrame(frame);
        } else {
          animId = null;
          onDone();
        }
      }

      animId = requestAnimationFrame(frame);
    }

    // ── Automatic page flip (page fills up) ───────────────────────────────────
    function doPageFlip() {
      isFlipping = true;
      isWriting  = false;
      if (animId) { cancelAnimationFrame(animId); animId = null; }
      anim = null;

      const snap = document.createElement('canvas');
      snap.width = W; snap.height = H;
      snap.getContext('2d').drawImage(canvas, 0, 0);

      livePageIdx++;
      allPages.push([]);
      displayPage = livePageIdx;
      nextCol = 0; nextRow = 0;

      doBookFlip(snap, () => {
        drawHeader(1); drawDivider(1); drawPageNum(1);
      }, true, () => {
        flipAlpha  = 1;
        isFlipping = false;
        drawFrame(performance.now());
        if (nameQueue.length > 0) setTimeout(processNext, 100);
        else ensureAmbientLoop();
      });
    }

    // ── Manual page navigation ────────────────────────────────────────────────
    function doNavPageFlip(targetIdx) {
      isFlipping = true;
      if (animId) { cancelAnimationFrame(animId); animId = null; }

      const snap = document.createElement('canvas');
      snap.width = W; snap.height = H;
      snap.getContext('2d').drawImage(canvas, 0, 0);

      const forward = targetIdx > displayPage;
      displayPage   = targetIdx;

      doBookFlip(snap, () => {
        drawHeader(1); drawStaticNames(); drawDivider(1); drawPageNum(1);
      }, forward, () => {
        isFlipping = false;
        drawFrame(performance.now());
        if (displayPage === livePageIdx && !isWriting && nameQueue.length > 0)
          setTimeout(processNext, 100);
        else ensureAmbientLoop();
      });
    }

    // ── Boot ─────────────────────────────────────────────────────────────────
    document.fonts.ready.then(() => {
      drawFrame(performance.now());
      ensureAmbientLoop();
    });
  </script>
</body>
</html>
