<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Magic Live Overlay</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    html, body { width:100vw; height:100vh; overflow:hidden; background:#0d0020; }
    canvas {
      position:fixed; top:0; left:0;
      width:1920px; height:1080px;
      pointer-events:none;
      transform-origin: top left;
    }
  </style>
  <script>
    (function scaleCanvas() {
      function resize() {
        var el = document.getElementById('c');
        if (!el) return;
        var CW = el.width || 1920, CH = el.height || 1080;
        // Sync CSS layout size to drawing surface size before scaling
        el.style.width  = CW + 'px';
        el.style.height = CH + 'px';
        var scale = Math.min(window.innerWidth / CW, window.innerHeight / CH);
        el.style.transform = 'scale(' + scale + ')';
        el.style.left = ((window.innerWidth  - CW * scale) / 2) + 'px';
        el.style.top  = ((window.innerHeight - CH * scale) / 2) + 'px';
      }
      window.addEventListener('resize', resize);
      window.addEventListener('load',   resize);
      document.addEventListener('DOMContentLoaded', resize);
    })();
  </script>
</head>
<body>
  <!-- Standby screen (shown when session is OFF) -->
  <div id="standby" style="display:<%- sessionActive ? 'none' : 'flex' %>;position:fixed;inset:0;background:#000;z-index:9999;align-items:center;justify-content:center;flex-direction:column;gap:16px;">
    <div style="width:64px;height:64px;border-radius:50%;background:#18181b;border:2px solid #27272a;display:flex;align-items:center;justify-content:center;font-size:28px;">✨</div>
    <div style="color:#3f3f46;font-family:sans-serif;font-size:18px;font-weight:600;letter-spacing:.08em;">STANDBY</div>
  </div>
  <!-- Audio unlock hint — fades out after first interaction -->
  <div id="audioHint" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);
    background:rgba(0,0,0,0.72);border:1px solid rgba(255,255,255,0.12);
    color:rgba(255,255,255,0.7);font-family:sans-serif;font-size:13px;font-weight:600;
    padding:8px 20px;border-radius:999px;letter-spacing:.04em;z-index:99998;
    pointer-events:none;transition:opacity 1.2s ease;white-space:nowrap;">
    🔊 Tap / click anywhere to activate audio
  </div>
  <canvas id="c" width="1920" height="1080"></canvas>
  <audio id="bgMusic" loop style="display:none;"></audio>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const USER_ID = <%- userId %>;
    let   HEADER_TEXT = `<%- headerText %>`;

    // ── Vertical mode (single column for phone/Shorts) ──────────────────────
    const VERTICAL = new URLSearchParams(window.location.search).get('mode') === 'vertical';
    const canvas = document.getElementById('c');
    canvas.width  = VERTICAL ? 1080 : 1920;
    canvas.height = VERTICAL ? 1920 : 1080;
    const ctx = canvas.getContext('2d');
    const W = canvas.width;
    const H = canvas.height;

    // ── Book layout constants ───────────────────────────────────────────────
    const FONT_FAMILY = '"Dancing Script", cursive';
    const FONT_SIZE   = VERTICAL ? 52  : 62;
    const BULLET_SIZE = VERTICAL ? 42  : 48;
    const COL_X       = VERTICAL ? [80] : [110, 1010];
    const BULLET_OFF  = 52;
    const START_Y     = VERTICAL ? 296 : 178; // extra top clearance in vertical for YouTube UI
    const LINE_H      = VERTICAL ? 100 : 94;
    const MAX_ROWS    = VERTICAL ? 12  : 9;
    const MS_PER_CHAR = 85;

    // ── Book state ──────────────────────────────────────────────────────────
    let allPages    = [[]];
    let displayPage = 0;
    let livePageIdx = 0;
    let nextCol     = 0;
    let nextRow     = 0;
    let nameQueue   = [];
    let isWriting   = false;

    let animId      = null;
    let anim        = null;

    let flipAlpha   = 1;
    let isFlipping  = false;

    // ── Effects state ───────────────────────────────────────────────────────
    let burstParts  = [];   // sparkle burst when name finishes
    let confParts   = [];   // milestone confetti
    let recentGlow  = null; // { col, row, name, startTs }
    let totalNames  = 0;    // session total
    let lastTs      = 0;    // for physics delta
    let ambLoopId   = null; // idle ambient loop

    // ── Subscriber alert state ──────────────────────────────────────────────
    let subAlert   = null; // { name, startTs }
    let subParts   = [];   // explosion + glitter particles
    let shockwaves = [];   // expanding rings { startTs, maxR, color, delay }

    // ── Shoutout card state ──────────────────────────────────────────────────
    let shoutAlert = null; // { name, startTs }
    const SHOUT_DUR = 4700; // total ms the card is visible

    // ── Live poll state ──────────────────────────────────────────────────────
    let pollData      = null;   // { question, options, votes, total, endTs }
    let pollAlpha     = 0;      // fade progress 0–1
    let pollFadingIn  = false;
    let pollFadeTs    = null;   // timestamp when fade started
    let pollDisplay   = [];     // smoothed vote values for animation
    let pollAnswer    = null;   // correct answer letter, set on reveal
    let pollStartTs   = null;   // set on first draw frame
    let pollRevealing = false;  // answer reveal phase
    let pollRevealTs  = null;   // when reveal animation started
    let pollPaused    = false;  // blocks name queue while poll is active
    let pollAutoRevealSent = false; // guard so fetch only fires once
    let pollBurstFired = false;  // sparkle burst fires once on reveal
    const POLL_FADE = 400;
    let   POLL_DURATION = 60_000;  // updated dynamically from poll-start event
    const REVEAL_DUR    = 7_000;   // answer stays visible 7s then fades

    // ── Sound effects (Web Audio API) ───────────────────────────────────────
    let audioCtx = null;
    function getAudioCtx() {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      return audioCtx;
    }

    // ── Audio unlock (browsers block audio until first user gesture) ─────────
    let audioUnlocked = false;
    function unlockAudio() {
      if (audioUnlocked) return;
      try {
        const ctx2 = getAudioCtx();
        if (ctx2.state === 'suspended') ctx2.resume();
        audioUnlocked = true;
        // Retry background music if it was blocked at startup
        const bgAudio = document.getElementById('bgMusic');
        if (pendingMusicId && bgAudio.paused) {
          if (!bgAudio.src || bgAudio.src === location.href) {
            bgAudio.src = `/music/${pendingMusicId}.mp3`;
          }
          bgAudio.play().catch(() => {});
        }
        // Hide the hint
        const hint = document.getElementById('audioHint');
        if (hint) { hint.style.opacity = '0'; setTimeout(() => hint.remove(), 1300); }
      } catch(e) {}
    }
    // Listen for any interaction — fires once then removes itself
    ['click','touchstart','keydown'].forEach(ev =>
      document.addEventListener(ev, unlockAudio, { once: false })
    );

    let lastTickSec = -1; // track second changes for tick sound

    function playTick(urgent = false) {
      try {
        const ctx2 = getAudioCtx();
        if (ctx2.state === 'suspended') { ctx2.resume(); }
        const o = ctx2.createOscillator();
        const g = ctx2.createGain();
        o.connect(g); g.connect(ctx2.destination);
        o.type = 'sine';
        o.frequency.value = urgent ? 1100 : 820;
        const now = ctx2.currentTime;
        g.gain.setValueAtTime(urgent ? 0.35 : 0.2, now);
        g.gain.exponentialRampToValueAtTime(0.001, now + 0.07);
        o.start(now); o.stop(now + 0.07);
        // Retry bg music after AudioContext unlocks
        const bgAudio = document.getElementById('bgMusic');
        if (pendingMusicId && bgAudio.paused && bgAudio.src) {
          bgAudio.play().catch(() => {});
        }
      } catch(e) {}
    }

    function playCorrectSound() {
      try {
        const ctx2 = getAudioCtx();
        // Ascending C-E-G-C arpeggio (C5, E5, G5, C6)
        [523, 659, 784, 1047].forEach((freq, i) => {
          setTimeout(() => {
            const o = ctx2.createOscillator();
            const g = ctx2.createGain();
            o.connect(g); g.connect(ctx2.destination);
            o.type = 'sine';
            o.frequency.value = freq;
            const now = ctx2.currentTime;
            g.gain.setValueAtTime(0.45, now);
            g.gain.exponentialRampToValueAtTime(0.001, now + 0.35);
            o.start(now); o.stop(now + 0.35);
          }, i * 130);
        });
      } catch(e) {}
    }

    // ── Socket ──────────────────────────────────────────────────────────────
    const socket = io();
    socket.emit('join-magic', USER_ID);

    socket.on('show-name', ({ name }) => {
      document.fonts.ready.then(() => {
        nameQueue.push(name);
        if (!isWriting && !isFlipping) processNext();
      });
    });

    socket.on('clear-overlay', () => {
      nameQueue.length = 0;
      cancelAnim();
      resetPage();
    });

    socket.on('nav-page', ({ direction }) => {
      if (isFlipping) return;
      let target = displayPage;
      if      (direction === 'prev' && displayPage > 0)           target = displayPage - 1;
      else if (direction === 'next' && displayPage < livePageIdx) target = displayPage + 1;
      else if (direction === 'live')                               target = livePageIdx;
      if (target === displayPage) return;

      if (anim && displayPage === livePageIdx) {
        nameQueue.unshift(anim.name);
        if (animId) { cancelAnimationFrame(animId); animId = null; }
        anim = null; isWriting = false;
      }
      doNavPageFlip(target);
    });

    socket.on('update-header', ({ headerText }) => {
      HEADER_TEXT = headerText;
      drawFrame(performance.now());
    });

    socket.on('show-subscriber', ({ name }) => {
      document.fonts.ready.then(() => {
        doSubscriberAlert(name);
        // also queue in guestbook
        nameQueue.push(name);
        if (!isWriting && !isFlipping) processNext();
      });
    });

    socket.on('show-shoutout', ({ name }) => {
      document.fonts.ready.then(() => { doShoutoutAlert(name); });
    });

    socket.on('poll-start', ({ question, options, duration }) => {
      POLL_DURATION = ((duration && [30,45,60].includes(duration)) ? duration : 60) * 1000;
      pollData      = { question, options, votes: new Array(options.length).fill(0), total: 0, endTs: null };
      pollDisplay   = new Array(options.length).fill(0);
      pollAnswer    = null;
      pollStartTs   = null;
      pollRevealing = false; pollRevealTs = null;
      pollAutoRevealSent = false;
      lastTickSec = -1;
      pollBurstFired = false;
      pollFadingIn  = true; pollFadeTs = null; pollAlpha = 0;
      pollPaused    = true;
      ensureAmbientLoop();
    });

    socket.on('poll-update', ({ votes, total }) => {
      if (pollData) { pollData.votes = votes; pollData.total = total; }
    });

    socket.on('poll-reveal', ({ answer, votes, total }) => {
      if (!pollData) return;
      if (votes) pollData.votes = votes;
      if (total !== undefined) pollData.total = total;
      pollAnswer    = answer;
      pollRevealing = true;
      pollRevealTs  = null;
      pollData.endTs = performance.now();
      lastTickSec = -1; // reset tick tracker
      playCorrectSound();
    });

    socket.on('poll-end', ({ votes, total }) => {
      if (pollData) {
        if (votes) pollData.votes = votes;
        if (total !== undefined) pollData.total = total;
        pollData.endTs = pollData.endTs || performance.now();
      }
    });

    socket.on('session-toggle', ({ active }) => {
      document.getElementById('standby').style.display = active ? 'none' : 'flex';
      if (!active) {
        playBgMusic(null);
      }
    });

    let pendingMusicId = null;

    function playBgMusic(musicId) {
      const a = document.getElementById('bgMusic');
      if (!musicId) { a.pause(); a.src = ''; pendingMusicId = null; return; }
      pendingMusicId = musicId;
      if (a.src !== location.origin + `/music/${musicId}.mp3`) {
        a.src = `/music/${musicId}.mp3`;
      }
      a.volume = 0.08;
      a.loop   = true;
      const p  = a.play();
      if (p) p.catch(() => {
        // Autoplay blocked — will retry on first tick/interaction
      });
    }

    socket.on('loop-music', ({ musicId }) => playBgMusic(musicId));

    // ── Helpers ─────────────────────────────────────────────────────────────
    function cancelAnim() {
      if (animId) { cancelAnimationFrame(animId); animId = null; }
      anim      = null;
      isWriting = false;
    }

    function resetPage() {
      allPages    = [[]];
      displayPage = 0;
      livePageIdx = 0;
      totalNames  = 0;
      nextCol = 0; nextRow = 0;
      isFlipping  = false; flipAlpha = 1;
      recentGlow  = null;
      burstParts.length = 0;
      confParts.length  = 0;
      cancelAnim();
      drawFrame(performance.now());
      ensureAmbientLoop();
    }

    function setFont(size, style) {
      ctx.font = (style || '700') + ' ' + size + 'px ' + FONT_FAMILY;
    }

    function charTipX(text, idx, size, startX) {
      setFont(size);
      let x = startX;
      for (let i = 0; i < idx; i++) x += ctx.measureText(text[i]).width;
      return x;
    }

    // ── Particle helpers ─────────────────────────────────────────────────────
    function updatePhysics(ts) {
      const dt = Math.min(50, ts - lastTs);
      lastTs = ts;

      for (let i = burstParts.length - 1; i >= 0; i--) {
        const p = burstParts[i];
        p.x  += p.vx * dt / 16;
        p.y  += p.vy * dt / 16;
        p.vy += 0.28 * dt / 16;
        p.vx *= Math.pow(0.97, dt / 16);
        p.rot += p.rotSpeed;
        p.life -= dt / (p.maxLife * 16);
        if (p.life <= 0) burstParts.splice(i, 1);
      }

      for (let i = confParts.length - 1; i >= 0; i--) {
        const p = confParts[i];
        p.x  += p.vx * dt / 16;
        p.y  += p.vy * dt / 16;
        p.vy += 0.18 * dt / 16;
        p.vx *= Math.pow(0.992, dt / 16);
        p.rot += p.rotSpeed;
        p.life -= dt / (p.maxLife * 16);
        if (p.life <= 0) confParts.splice(i, 1);
      }

      for (let i = subParts.length - 1; i >= 0; i--) {
        const p = subParts[i];
        p.x  += p.vx * dt / 16;
        p.y  += p.vy * dt / 16;
        if (p.kind === 'burst') {
          p.vy += 0.32 * dt / 16;
          p.vx *= Math.pow(0.965, dt / 16);
        } else {
          p.vy += 0.08 * dt / 16; // glitter falls gently
          p.vx += Math.sin(p.y / 60) * 0.04;
        }
        p.rot += p.rotSpeed;
        p.life -= dt / (p.maxLife * 16);
        if (p.life <= 0) subParts.splice(i, 1);
      }
    }

    function spawnBurst(x, y) {
      const COLS = ['#c4b5fd','#f9a8d4','#fde68a','#a5f3fc','#86efac','#fb923c'];
      for (let i = 0; i < 24; i++) {
        const angle = (Math.PI * 2 * i / 24) + (Math.random() - 0.5) * 0.5;
        const spd   = 5 + Math.random() * 11;
        burstParts.push({
          x, y,
          vx: Math.cos(angle) * spd,
          vy: Math.sin(angle) * spd - 5,
          life: 1,
          maxLife: 38 + Math.random() * 28,
          size: 3 + Math.random() * 4.5,
          rot: Math.random() * Math.PI,
          rotSpeed: (Math.random() - 0.5) * 0.28,
          color: COLS[Math.floor(Math.random() * COLS.length)],
        });
      }
    }

    function spawnMilestone() {
      const COLS = ['#f9a8d4','#fde68a','#a5f3fc','#c4b5fd','#86efac','#fb923c','#fff'];
      for (let i = 0; i < 90; i++) {
        confParts.push({
          x: 200 + Math.random() * (W - 400),
          y: -20,
          vx: (Math.random() - 0.5) * 20,
          vy: 7 + Math.random() * 16,
          life: 1,
          maxLife: 110 + Math.random() * 70,
          w: 9 + Math.random() * 14,
          h: 5 + Math.random() * 8,
          rot: Math.random() * Math.PI * 2,
          rotSpeed: (Math.random() - 0.5) * 0.2,
          color: COLS[Math.floor(Math.random() * COLS.length)],
        });
      }
    }

    // ── Subscriber alert engine ──────────────────────────────────────────────
    const SUB_DUR = 4000;

    function doSubscriberAlert(name) {
      subAlert = { name, startTs: null };
      subParts.length = 0;
      shockwaves.length = 0;

      // Radial burst from center
      const BCOLS = ['#fbbf24','#f59e0b','#c4b5fd','#f9a8d4','#fff','#67e8f9','#86efac'];
      for (let i = 0; i < 90; i++) {
        const angle = (Math.PI * 2 * i / 90) + (Math.random() - 0.5) * 0.25;
        const spd   = 9 + Math.random() * 22;
        subParts.push({
          x: W / 2, y: H / 2,
          vx: Math.cos(angle) * spd,
          vy: Math.sin(angle) * spd - 5,
          life: 1, maxLife: 55 + Math.random() * 45,
          size: 3 + Math.random() * 7,
          rot: Math.random() * Math.PI,
          rotSpeed: (Math.random() - 0.5) * 0.32,
          color: BCOLS[Math.floor(Math.random() * BCOLS.length)],
          kind: 'burst',
        });
      }

      // Glitter rain from top
      const GCOLS = ['#fbbf24','#fff','#c4b5fd','#f9a8d4','#67e8f9'];
      for (let i = 0; i < 70; i++) {
        subParts.push({
          x: Math.random() * W,
          y: -30 - Math.random() * 300,
          vx: (Math.random() - 0.5) * 2.5,
          vy: 3 + Math.random() * 7,
          life: 1, maxLife: 140 + Math.random() * 80,
          size: 2 + Math.random() * 5,
          rot: Math.random() * Math.PI * 2,
          rotSpeed: (Math.random() - 0.5) * 0.18,
          color: GCOLS[Math.floor(Math.random() * GCOLS.length)],
          kind: 'glitter',
        });
      }

      // Shockwaves
      shockwaves.push({ startTs: null, delay: 0,   maxR: 700, color: '#fbbf24', lw: 4 });
      shockwaves.push({ startTs: null, delay: 140, maxR: 960, color: '#a78bfa', lw: 2.5 });
      shockwaves.push({ startTs: null, delay: 280, maxR: 560, color: '#f9a8d4', lw: 2 });
    }

    // ── Shoutout card engine ─────────────────────────────────────────────────
    function doShoutoutAlert(name) {
      shoutAlert = { name, startTs: null };
      // Burst particles at card center (bottom-third of screen)
      spawnBurst(W / 2, H * 0.62);
    }

    function drawShoutoutAlert(ts) {
      if (!shoutAlert) return;
      if (!shoutAlert.startTs) { shoutAlert.startTs = ts; return; }

      const age = ts - shoutAlert.startTs;
      if (age > SHOUT_DUR) { shoutAlert = null; return; }

      const SLIDE_IN  = 380;
      const SLIDE_OUT = 320;
      const HOLD_END  = SHOUT_DUR - SLIDE_OUT;

      // slide progress: 0 = fully off right, 1 = fully on screen
      let slide, alpha;
      if (age < SLIDE_IN) {
        const p  = age / SLIDE_IN;
        // ease-out cubic
        slide = 1 - Math.pow(1 - p, 3);
        alpha = p;
      } else if (age > HOLD_END) {
        const p  = (age - HOLD_END) / SLIDE_OUT;
        // ease-in cubic
        slide = 1 - Math.pow(p, 3);
        alpha = 1 - p;
      } else {
        slide = 1;
        alpha = 1;
      }

      const CW = VERTICAL ? W * 0.88 : 820;
      const CH = VERTICAL ? 200 : 210;
      const CX = W / 2 - CW / 2 + (1 - slide) * (W / 2 + CW); // slides from right
      const CY = H * 0.52 - CH / 2;

      ctx.save();
      ctx.globalAlpha = alpha;

      // Card background — cyan-to-teal gradient
      const bg = ctx.createLinearGradient(CX, CY, CX + CW, CY + CH);
      bg.addColorStop(0,   '#083344');
      bg.addColorStop(0.4, '#0e7490');
      bg.addColorStop(1,   '#083344');
      ctx.shadowBlur  = 60;
      ctx.shadowColor = 'rgba(6,182,212,0.55)';
      ctx.fillStyle   = bg;
      rRekt(CX, CY, CW, CH, 20);
      ctx.fill();
      ctx.shadowBlur  = 0;

      // Animated border shimmer
      const shimP = (age % 1200) / 1200;
      const bGrad = ctx.createLinearGradient(CX + shimP * (CW + 300) - 200, CY, CX + shimP * (CW + 300), CY + CH);
      bGrad.addColorStop(0,    '#06b6d4');
      bGrad.addColorStop(0.3,  '#67e8f9');
      bGrad.addColorStop(0.6,  '#a5f3fc');
      bGrad.addColorStop(1,    '#06b6d4');
      ctx.strokeStyle = bGrad;
      ctx.lineWidth   = 3;
      ctx.shadowBlur  = 14; ctx.shadowColor = '#06b6d4';
      rRekt(CX, CY, CW, CH, 20);
      ctx.stroke();
      ctx.shadowBlur  = 0;

      // Shimmer sweep
      const swP = (age % 700) / 700;
      const swG = ctx.createLinearGradient(CX + swP * (CW + 160) - 100, CY, CX + swP * (CW + 160), CY + CH);
      swG.addColorStop(0, 'rgba(255,255,255,0)');
      swG.addColorStop(0.5, 'rgba(255,255,255,0.18)');
      swG.addColorStop(1, 'rgba(255,255,255,0)');
      ctx.fillStyle = swG;
      rRekt(CX, CY, CW, CH, 20);
      ctx.fill();

      // "✨ SHOUTOUT TO" label
      ctx.font         = '700 ' + (VERTICAL ? 20 : 24) + 'px "Inter",sans-serif';
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'alphabetic';
      ctx.fillStyle    = 'rgba(255,255,255,0.9)';
      ctx.shadowBlur   = 10; ctx.shadowColor = 'rgba(6,182,212,0.8)';
      ctx.fillText('✨  S H O U T O U T  T O  ✨', W / 2, CY + (VERTICAL ? 52 : 60));
      ctx.shadowBlur   = 0;

      // Divider
      const dg = ctx.createLinearGradient(CX + 40, 0, CX + CW - 40, 0);
      dg.addColorStop(0, 'rgba(6,182,212,0)');
      dg.addColorStop(0.5, 'rgba(6,182,212,0.5)');
      dg.addColorStop(1, 'rgba(6,182,212,0)');
      ctx.strokeStyle = dg; ctx.lineWidth = 1;
      const dy = CY + (VERTICAL ? 62 : 72);
      ctx.beginPath(); ctx.moveTo(CX + 40, dy); ctx.lineTo(CX + CW - 40, dy); ctx.stroke();

      // Name
      const nLen   = shoutAlert.name.length;
      const nSize  = VERTICAL ? Math.min(70, Math.max(44, 70 - Math.max(0, nLen - 12) * 2.5))
                               : Math.min(82, Math.max(52, 82 - Math.max(0, nLen - 12) * 3));
      const nGrad  = ctx.createLinearGradient(W / 2 - 300, 0, W / 2 + 300, 0);
      nGrad.addColorStop(0,   '#fff4c2');
      nGrad.addColorStop(0.2, '#f5c518');
      nGrad.addColorStop(0.5, '#fde68a');
      nGrad.addColorStop(0.8, '#c8960c');
      nGrad.addColorStop(1,   '#fff4c2');
      ctx.font         = '700 ' + nSize + 'px ' + FONT_FAMILY;
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'alphabetic';
      ctx.shadowBlur   = 24; ctx.shadowColor = 'rgba(251,191,36,0.75)';
      ctx.fillStyle    = nGrad;
      ctx.fillText(shoutAlert.name, W / 2, CY + CH - (VERTICAL ? 28 : 36));
      ctx.shadowBlur   = 0;

      ctx.textAlign = 'left';
      ctx.restore();
    }

    // ── Live poll bar chart ───────────────────────────────────────────────────
    const POLL_COLORS = ['#06b6d4','#a78bfa','#f9a8d4','#fbbf24'];
    const POLL_LABELS = ['A','B','C','D'];

    function drawPoll(ts) {
      if (!pollData) return;

      // Set start timestamp on first frame
      if (!pollStartTs) pollStartTs = ts;

      // Fade in
      if (pollFadingIn) {
        if (!pollFadeTs) pollFadeTs = ts;
        pollAlpha = Math.min(1, (ts - pollFadeTs) / POLL_FADE);
        if (pollAlpha >= 1) { pollFadingIn = false; pollFadeTs = null; }
      }

      // Auto-reveal when countdown hits zero
      const elapsed   = ts - pollStartTs;
      const remaining = Math.max(0, POLL_DURATION - elapsed);

      // Tick sound every second during countdown
      if (!pollRevealing && remaining > 0) {
        const secNow = Math.ceil(remaining / 1000);
        if (secNow !== lastTickSec) {
          lastTickSec = secNow;
          playTick(secNow <= 10);
        }
      }

      if (remaining <= 0 && !pollRevealing && !pollAutoRevealSent) {
        pollAutoRevealSent = true;
        fetch('/magic-live/api/poll/reveal', { method: 'POST' }).catch(() => {});
      }

      // Reveal phase: set reveal timestamp, then fade out after REVEAL_DUR
      if (pollRevealing) {
        if (!pollRevealTs) pollRevealTs = ts;
        const sinceReveal = ts - pollRevealTs;
        if (sinceReveal > REVEAL_DUR) {
          if (!pollFadeTs) pollFadeTs = ts;
          pollAlpha = Math.max(0, 1 - (ts - pollFadeTs) / POLL_FADE);
          if (pollAlpha <= 0) {
            pollData = null; pollAlpha = 0; pollFadeTs = null;
            pollBurstFired = false; pollPaused = false;
            if (nameQueue.length) processNext();
            return;
          }
        }
      }

      if (pollAlpha <= 0) return;

      // Smooth display values toward actual votes (lerp)
      const totalVotes = pollData.votes.reduce((s, v) => s + v, 0);
      for (let i = 0; i < pollData.options.length; i++) {
        const target = pollData.votes[i] || 0;
        if (pollDisplay[i] === undefined) pollDisplay[i] = 0;
        pollDisplay[i] += (target - pollDisplay[i]) * 0.08;
      }

      // ── Layout: large centered engagement panel ──────────────────────────────
      const nOpts    = pollData.options.length;
      const HDR_SIZE = VERTICAL ? 17 : 19;
      const Q_SIZE   = VERTICAL ? 36 : 44;
      const L_SIZE   = VERTICAL ? 30 : 36;
      const OPT_SIZE = VERTICAL ? 22 : 28;
      const PCT_SIZE = VERTICAL ? 22 : 26;
      const BAR_H    = VERTICAL ? 48 : 58;
      const ROW_GAP  = VERTICAL ? 66 : 80;
      const PAD_X    = VERTICAL ? 52 : 64;
      const PAD_TOP  = VERTICAL ? 22 : 26;
      const PAD_BOT  = VERTICAL ? 32 : 40;
      const LABEL_W  = VERTICAL ? 38 : 46;
      const PCT_W    = VERTICAL ? 68 : 80;
      const GAP      = 12;
      const ARC_R    = VERTICAL ? 34 : 40;
      const HDR_H    = Math.max(ARC_R * 2 + 8, HDR_SIZE + 20);

      // Panel: 80-84% width, vertically centered on canvas
      const PW = Math.round(W * (VERTICAL ? 0.84 : 0.80));
      const PX = Math.round(W / 2 - PW / 2);
      const PH = PAD_TOP + HDR_H + 14 + Q_SIZE + 20 + nOpts * ROW_GAP + PAD_BOT;
      const PY = Math.round(H / 2 - PH / 2);

      const BAR_X = PX + PAD_X + LABEL_W + GAP;
      const BAR_W = PW - PAD_X * 2 - LABEL_W - GAP * 2 - PCT_W;

      // Correct answer index (-1 during voting)
      const correctIdx = (pollRevealing && pollAnswer)
        ? ['A','B','C','D'].indexOf(pollAnswer) : -1;

      ctx.save();
      ctx.globalAlpha = pollAlpha;

      // Screen dim — poll takes over the canvas
      ctx.fillStyle = 'rgba(0,0,0,0.62)';
      ctx.fillRect(0, 0, W, H);

      // Panel background
      const panBg = ctx.createLinearGradient(PX, PY, PX, PY + PH);
      panBg.addColorStop(0, 'rgba(10,3,28,0.97)');
      panBg.addColorStop(1, 'rgba(5,1,16,0.99)');
      ctx.shadowBlur  = 70;
      ctx.shadowColor = 'rgba(124,58,237,0.55)';
      ctx.fillStyle   = panBg;
      rRekt(PX, PY, PW, PH, 24);
      ctx.fill();
      ctx.shadowBlur  = 0;

      // Panel border
      const borderG = ctx.createLinearGradient(PX, PY, PX + PW, PY + PH);
      borderG.addColorStop(0,   'rgba(124,58,237,0.7)');
      borderG.addColorStop(0.5, 'rgba(167,139,250,0.9)');
      borderG.addColorStop(1,   'rgba(124,58,237,0.7)');
      ctx.strokeStyle = borderG;
      ctx.lineWidth   = 2;
      rRekt(PX, PY, PW, PH, 24);
      ctx.stroke();

      // ── Header: "LIVE POLL" label + countdown arc ────────────────────────────
      const HDR_CY = PY + PAD_TOP + HDR_H / 2;

      ctx.font         = '700 ' + HDR_SIZE + 'px "Inter",sans-serif';
      ctx.textAlign    = 'left';
      ctx.textBaseline = 'middle';
      ctx.fillStyle    = '#a78bfa';
      ctx.shadowBlur   = 14; ctx.shadowColor = 'rgba(167,139,250,0.65)';
      ctx.fillText('\uD83D\uDCCA  LIVE POLL', PX + PAD_X, HDR_CY);
      ctx.shadowBlur   = 0;

      // Countdown arc (hidden during reveal)
      if (!pollRevealing) {
        const arcCX   = PX + PW - PAD_X - ARC_R;
        const secLeft = Math.ceil(remaining / 1000);
        const progress = 1 - remaining / POLL_DURATION;
        const urgColor = secLeft <= 10 ? '#ef4444' : secLeft <= 20 ? '#f97316' : '#a78bfa';

        // Track ring
        ctx.beginPath();
        ctx.arc(arcCX, HDR_CY, ARC_R, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgba(255,255,255,0.1)';
        ctx.lineWidth   = VERTICAL ? 5 : 6;
        ctx.stroke();

        // Progress arc (fills clockwise from top as time passes)
        const arcG = ctx.createLinearGradient(arcCX - ARC_R, HDR_CY - ARC_R, arcCX + ARC_R, HDR_CY + ARC_R);
        arcG.addColorStop(0, urgColor);
        arcG.addColorStop(1, secLeft <= 10 ? '#fca5a5' : '#fde68a');
        ctx.beginPath();
        ctx.arc(arcCX, HDR_CY, ARC_R, -Math.PI / 2, -Math.PI / 2 + progress * Math.PI * 2);
        ctx.strokeStyle = arcG;
        ctx.lineWidth   = VERTICAL ? 5 : 6;
        ctx.lineCap     = 'round';
        ctx.stroke();
        ctx.lineCap     = 'butt';

        // Seconds number inside arc
        ctx.font         = '700 ' + (VERTICAL ? 19 : 23) + 'px "Inter",sans-serif';
        ctx.textAlign    = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillStyle    = secLeft <= 10 ? '#ef4444' : '#fde68a';
        ctx.shadowBlur   = 10; ctx.shadowColor = urgColor;
        ctx.fillText(String(secLeft), arcCX, HDR_CY);
        ctx.shadowBlur   = 0;
      }

      // ── Question ─────────────────────────────────────────────────────────────
      const Q_Y = PY + PAD_TOP + HDR_H + 14 + Q_SIZE;
      ctx.font         = '700 ' + Q_SIZE + 'px "Inter",sans-serif';
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'alphabetic';
      ctx.fillStyle    = '#ffffff';
      ctx.shadowBlur   = 16; ctx.shadowColor = 'rgba(124,58,237,0.55)';
      ctx.fillText(pollData.question, W / 2, Q_Y);
      ctx.shadowBlur   = 0;

      // Divider
      const dg = ctx.createLinearGradient(PX + 36, 0, PX + PW - 36, 0);
      dg.addColorStop(0, 'rgba(124,58,237,0)');
      dg.addColorStop(0.5, 'rgba(167,139,250,0.5)');
      dg.addColorStop(1, 'rgba(124,58,237,0)');
      ctx.strokeStyle = dg; ctx.lineWidth = 1;
      const divY = Q_Y + 16;
      ctx.beginPath(); ctx.moveTo(PX + 36, divY); ctx.lineTo(PX + PW - 36, divY); ctx.stroke();

      const BARS_Y = divY + 20;

      // ── Vote bars ─────────────────────────────────────────────────────────────
      for (let i = 0; i < nOpts; i++) {
        const rowY    = BARS_Y + i * ROW_GAP;
        const isRight = correctIdx >= 0 && i === correctIdx;
        const isWrong = correctIdx >= 0 && i !== correctIdx;
        const col     = isRight ? '#4ade80' : POLL_COLORS[i];
        const pct     = totalVotes > 0 ? pollDisplay[i] / totalVotes : 0;
        const barW    = Math.round(BAR_W * pct);
        const actual  = pollData.votes[i] || 0;
        const pctTxt  = totalVotes > 0 ? Math.round(actual / totalVotes * 100) + '%' : '\u2013';
        const textY   = rowY + BAR_H - (VERTICAL ? 11 : 13);

        ctx.save();

        // Dim wrong options during reveal
        if (isWrong) ctx.globalAlpha = pollAlpha * 0.22;

        // Correct option: bounce scale from row centre
        if (isRight) {
          const sinceRev = pollRevealTs ? ts - pollRevealTs : 0;
          const bounce   = sinceRev < 500 ? 1 + Math.sin((sinceRev / 500) * Math.PI) * 0.05 : 1;
          const cx2 = BAR_X + BAR_W / 2;
          const cy2 = rowY + BAR_H / 2;
          ctx.translate(cx2, cy2); ctx.scale(bounce, bounce); ctx.translate(-cx2, -cy2);

          // Fire sparkle burst once on reveal
          if (!pollBurstFired && pollRevealTs && ts - pollRevealTs < 80) {
            pollBurstFired = true;
            spawnBurst(BAR_X + Math.min(barW, BAR_W) / 2, rowY + BAR_H / 2);
          }
        }

        // Letter label
        ctx.font         = '700 ' + L_SIZE + 'px "Inter",sans-serif';
        ctx.textAlign    = 'center';
        ctx.textBaseline = 'alphabetic';
        ctx.fillStyle    = col;
        ctx.shadowBlur   = isRight ? 16 : 8; ctx.shadowColor = col;
        ctx.fillText(POLL_LABELS[i], PX + PAD_X + LABEL_W / 2, textY);
        ctx.shadowBlur   = 0;

        // Track
        ctx.fillStyle = isRight ? 'rgba(74,222,128,0.12)' : 'rgba(255,255,255,0.07)';
        rRekt(BAR_X, rowY, BAR_W, BAR_H, BAR_H / 2);
        ctx.fill();

        // Filled bar
        if (barW > 0) {
          const bg2 = ctx.createLinearGradient(BAR_X, 0, BAR_X + Math.max(barW, BAR_H), 0);
          if (isRight) {
            bg2.addColorStop(0, '#22c55ebb'); bg2.addColorStop(1, '#4ade80');
          } else {
            bg2.addColorStop(0, col + 'bb'); bg2.addColorStop(1, col);
          }
          ctx.fillStyle  = bg2;
          ctx.shadowBlur = isRight ? 22 : 10; ctx.shadowColor = col;
          rRekt(BAR_X, rowY, Math.max(barW, BAR_H), BAR_H, BAR_H / 2);
          ctx.fill();
          ctx.shadowBlur = 0;
        }

        // Option text clipped inside bar track
        ctx.save();
        ctx.font         = OPT_SIZE + 'px "Inter",sans-serif';
        ctx.textAlign    = 'left'; ctx.textBaseline = 'alphabetic';
        ctx.fillStyle    = barW > 80 ? 'rgba(255,255,255,0.9)' : 'rgba(255,255,255,0.5)';
        ctx.beginPath(); rRekt(BAR_X, rowY, BAR_W, BAR_H, BAR_H / 2); ctx.clip();
        ctx.fillText(pollData.options[i], BAR_X + 16, textY);
        ctx.restore();

        // Percentage
        ctx.font         = '700 ' + PCT_SIZE + 'px "Inter",sans-serif';
        ctx.textAlign    = 'right'; ctx.textBaseline = 'alphabetic';
        ctx.fillStyle    = isRight ? '#4ade80' : '#fde68a';
        ctx.shadowBlur   = 5;
        ctx.shadowColor  = isRight ? 'rgba(74,222,128,0.5)' : 'rgba(251,191,36,0.5)';
        ctx.fillText(pctTxt, PX + PW - PAD_X + 4, textY);
        ctx.shadowBlur   = 0;

        ctx.restore();
      }

      // ── Footer ────────────────────────────────────────────────────────────────
      const footerY = PY + PH - (VERTICAL ? 12 : 16);
      ctx.font         = (VERTICAL ? 14 : 16) + 'px "Inter",sans-serif';
      ctx.textAlign    = 'center'; ctx.textBaseline = 'alphabetic';
      ctx.fillStyle    = 'rgba(156,163,175,0.55)';
      ctx.fillText(
        pollData.endTs !== null
          ? '\u2736 Final Results  \u00B7  ' + pollData.total + ' vote' + (pollData.total !== 1 ? 's' : '')
          : pollData.total + ' vote' + (pollData.total !== 1 ? 's' : ''),
        W / 2, footerY
      );

      // ── Reveal badge ──────────────────────────────────────────────────────────
      if (pollRevealing && pollRevealTs && pollAnswer && correctIdx >= 0) {
        const sinceRev    = ts - pollRevealTs;
        const badgeAlpha  = Math.min(1, sinceRev / 280);
        const badgeBounce = sinceRev < 600 ? 1 + Math.sin((sinceRev / 600) * Math.PI) * 0.10 : 1;
        const correctOpt  = pollData.options[correctIdx] || '';

        const BDG_W  = Math.min(PW - 80, VERTICAL ? 680 : 740);
        const BDG_H  = VERTICAL ? 86 : 100;
        const BDG_X  = Math.round(W / 2 - BDG_W / 2);
        // Position badge in the centre of the bars zone — below question + divider
        const BDG_CY = BARS_Y + Math.round((nOpts * ROW_GAP) / 2);
        const BDG_Y  = Math.round(BDG_CY - BDG_H / 2);

        ctx.save();
        ctx.globalAlpha = pollAlpha * badgeAlpha;
        ctx.translate(W / 2, BDG_CY);
        ctx.scale(badgeBounce, badgeBounce);
        ctx.translate(-W / 2, -BDG_CY);

        // Badge background
        const bdgG = ctx.createLinearGradient(BDG_X, BDG_Y, BDG_X + BDG_W, BDG_Y + BDG_H);
        bdgG.addColorStop(0, '#14532d');
        bdgG.addColorStop(1, '#166534');
        ctx.shadowBlur  = 36; ctx.shadowColor = 'rgba(74,222,128,0.65)';
        ctx.fillStyle   = bdgG;
        rRekt(BDG_X, BDG_Y, BDG_W, BDG_H, 18);
        ctx.fill();

        ctx.strokeStyle = '#4ade80'; ctx.lineWidth = 2.5; ctx.shadowBlur = 0;
        rRekt(BDG_X, BDG_Y, BDG_W, BDG_H, 18);
        ctx.stroke();

        // "Correct Answer!" line
        ctx.font         = '700 ' + (VERTICAL ? 17 : 20) + 'px "Inter",sans-serif';
        ctx.textAlign    = 'center'; ctx.textBaseline = 'middle';
        ctx.fillStyle    = '#bbf7d0';
        ctx.shadowBlur   = 8; ctx.shadowColor = '#4ade80';
        ctx.fillText('\u2713  Correct Answer!', W / 2, BDG_Y + BDG_H * 0.32);

        // Answer letter + option text
        ctx.font         = '700 ' + (VERTICAL ? 24 : 28) + 'px "Inter",sans-serif';
        ctx.fillStyle    = '#ffffff';
        ctx.shadowBlur   = 12;
        ctx.fillText(pollAnswer + ':  ' + correctOpt, W / 2, BDG_Y + BDG_H * 0.72);
        ctx.shadowBlur   = 0;

        ctx.restore();
      }

      ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
      ctx.restore();
    }

    function rRekt(x, y, w, h, r) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + w - r, y);
      ctx.arcTo(x + w, y, x + w, y + r, r);
      ctx.lineTo(x + w, y + h - r);
      ctx.arcTo(x + w, y + h, x + w - r, y + h, r);
      ctx.lineTo(x + r, y + h);
      ctx.arcTo(x, y + h, x, y + h - r, r);
      ctx.lineTo(x, y + r);
      ctx.arcTo(x, y, x + r, y, r);
      ctx.closePath();
    }

    function drawLightning(x1, y1, x2, y2, alpha) {
      const SEG = 10;
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.lineWidth   = 2.5;
      ctx.lineCap     = 'round';
      ctx.shadowBlur  = 18;
      ctx.shadowColor = '#c4b5fd';
      ctx.strokeStyle = '#a78bfa';
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      for (let i = 1; i < SEG; i++) {
        const px = x1 + (x2 - x1) * (i / SEG) + (Math.random() - 0.5) * 80;
        const py = y1 + (y2 - y1) * (i / SEG) + (Math.random() - 0.5) * 80;
        ctx.lineTo(px, py);
      }
      ctx.lineTo(x2, y2);
      ctx.stroke();
      ctx.lineWidth   = 1;
      ctx.strokeStyle = '#fff';
      ctx.shadowBlur  = 6;
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      for (let i = 1; i < SEG; i++) {
        const px = x1 + (x2 - x1) * (i / SEG) + (Math.random() - 0.5) * 80;
        const py = y1 + (y2 - y1) * (i / SEG) + (Math.random() - 0.5) * 80;
        ctx.lineTo(px, py);
      }
      ctx.lineTo(x2, y2);
      ctx.stroke();
      ctx.restore();
    }

    function drawSubscriberAlert(ts) {
      if (!subAlert) return;
      if (!subAlert.startTs) { subAlert.startTs = ts; return; }

      const age = ts - subAlert.startTs;
      if (age > SUB_DUR) { subAlert = null; subParts.length = 0; shockwaves.length = 0; return; }

      const t = age / SUB_DUR;
      const alpha = t < 0.12 ? t / 0.12 : t > 0.78 ? (1 - t) / 0.22 : 1;

      // ── Screen dim ────────────────────────────────────────────────────────
      ctx.save();
      ctx.globalAlpha = alpha * 0.52;
      ctx.fillStyle   = 'rgba(5,0,15,0.7)';
      ctx.fillRect(0, 0, W, H);
      ctx.restore();

      // ── Edge glow ─────────────────────────────────────────────────────────
      const pulse = 0.55 + 0.45 * Math.sin(age / 160);
      const eSize = 110;
      [[0,0,0,eSize,'#fbbf24','down'],[0,H-eSize,0,H,'#a78bfa','up'],
       [0,0,eSize,0,'#fbbf24','right'],[W-eSize,0,W,0,'#a78bfa','left']
      ].forEach(([x,y,x2,y2,col,dir]) => {
        let g;
        if (dir==='down')  g = ctx.createLinearGradient(0,y,0,y+eSize);
        else if (dir==='up') g = ctx.createLinearGradient(0,y,0,y+eSize);
        else if (dir==='right') g = ctx.createLinearGradient(x,0,x+eSize,0);
        else g = ctx.createLinearGradient(W-eSize,0,W,0);
        const a = alpha * pulse * 0.55;
        if (dir==='down'||dir==='right') { g.addColorStop(0,col.replace(')',`,${a})`).replace('rgb','rgba')||`rgba(251,191,36,${a})`); g.addColorStop(1,'rgba(0,0,0,0)'); }
        else                             { g.addColorStop(0,'rgba(0,0,0,0)'); g.addColorStop(1,col.replace(')',`,${a})`).replace('rgb','rgba')||`rgba(167,139,250,${a})`); }
        ctx.fillStyle = g;
        if (dir==='down')  ctx.fillRect(0,0,W,eSize);
        else if (dir==='up') ctx.fillRect(0,H-eSize,W,eSize);
        else if (dir==='right') ctx.fillRect(0,0,eSize,H);
        else ctx.fillRect(W-eSize,0,eSize,H);
      });

      // ── Simplified edge glow ──────────────────────────────────────────────
      ctx.save();
      ctx.globalAlpha = alpha * pulse * 0.5;
      const eg1 = ctx.createLinearGradient(0,0,0,eSize);
      eg1.addColorStop(0,`rgba(251,191,36,0.6)`); eg1.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle = eg1; ctx.fillRect(0,0,W,eSize);
      const eg2 = ctx.createLinearGradient(0,H-eSize,0,H);
      eg2.addColorStop(0,'rgba(0,0,0,0)'); eg2.addColorStop(1,'rgba(167,139,250,0.6)');
      ctx.fillStyle = eg2; ctx.fillRect(0,H-eSize,W,eSize);
      const eg3 = ctx.createLinearGradient(0,0,eSize,0);
      eg3.addColorStop(0,`rgba(251,191,36,0.6)`); eg3.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle = eg3; ctx.fillRect(0,0,eSize,H);
      const eg4 = ctx.createLinearGradient(W-eSize,0,W,0);
      eg4.addColorStop(0,'rgba(0,0,0,0)'); eg4.addColorStop(1,'rgba(167,139,250,0.6)');
      ctx.fillStyle = eg4; ctx.fillRect(W-eSize,0,eSize,H);
      ctx.restore();

      // ── Lightning bolts (first 1.2s) ──────────────────────────────────────
      if (age < 1200) {
        const la = alpha * Math.max(0, 1 - age / 1200) * 0.9;
        const cx = W / 2, cy = H / 2, sp = 120;
        drawLightning(0,   0,   cx - sp, cy - sp, la);
        drawLightning(W,   0,   cx + sp, cy - sp, la);
        drawLightning(0,   H,   cx - sp, cy + sp, la);
        drawLightning(W,   H,   cx + sp, cy + sp, la);
      }

      // ── Shockwaves ────────────────────────────────────────────────────────
      shockwaves.forEach((s, i) => {
        if (!s.startTs) { s.startTs = ts + (s.delay || 0); return; }
        if (ts < s.startTs) return;
        const a2 = ts - s.startTs;
        if (a2 > 900) return;
        const st = a2 / 900;
        const r  = st * s.maxR;
        ctx.save();
        ctx.globalAlpha  = (1 - st) * 0.75 * alpha;
        ctx.strokeStyle  = s.color;
        ctx.lineWidth    = s.lw * (1 - st * 0.6);
        ctx.shadowBlur   = 24;
        ctx.shadowColor  = s.color;
        ctx.beginPath(); ctx.arc(W / 2, H / 2, r, 0, Math.PI * 2); ctx.stroke();
        ctx.restore();
      });

      // ── Banner ────────────────────────────────────────────────────────────
      const BW = 900, BH = 230;
      const BX = W / 2 - BW / 2, BY = H / 2 - BH / 2;

      // Bounce-in scale
      let sc = 1;
      if (t < 0.2) {
        const et = t / 0.2;
        sc = et < 0.65 ? (et / 0.65) * 1.12 : 1.12 - ((et - 0.65) / 0.35) * 0.12;
      }

      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.translate(W / 2, H / 2);
      ctx.scale(sc, sc);
      ctx.translate(-W / 2, -H / 2);

      // Banner background
      const bgGrad = ctx.createLinearGradient(BX, BY, BX + BW, BY + BH);
      bgGrad.addColorStop(0,   'rgba(8,0,20,0.97)');
      bgGrad.addColorStop(0.5, 'rgba(20,0,45,0.97)');
      bgGrad.addColorStop(1,   'rgba(8,0,20,0.97)');
      ctx.shadowBlur  = 70;
      ctx.shadowColor = '#7c3aed';
      ctx.fillStyle   = bgGrad;
      rRekt(BX, BY, BW, BH, 22);
      ctx.fill();
      ctx.shadowBlur  = 0;

      // Animated border
      const shimP = (age % 1600) / 1600;
      const bGrad = ctx.createLinearGradient(BX + shimP * BW * 2 - BW, BY, BX + shimP * BW * 2, BY + BH);
      bGrad.addColorStop(0,    '#fbbf24');
      bGrad.addColorStop(0.25, '#c4b5fd');
      bGrad.addColorStop(0.5,  '#f9a8d4');
      bGrad.addColorStop(0.75, '#67e8f9');
      bGrad.addColorStop(1,    '#fbbf24');
      ctx.strokeStyle = bGrad;
      ctx.lineWidth   = 3.5;
      ctx.shadowBlur  = 18;
      ctx.shadowColor = '#fbbf24';
      rRekt(BX, BY, BW, BH, 22);
      ctx.stroke();
      ctx.shadowBlur  = 0;

      // Inner glow line
      ctx.strokeStyle = 'rgba(251,191,36,0.15)';
      ctx.lineWidth   = 1;
      rRekt(BX + 6, BY + 6, BW - 12, BH - 12, 18);
      ctx.stroke();

      // ✦ corner accents
      const cp = 0.6 + 0.4 * Math.sin(age / 180);
      ctx.font         = '700 30px ' + FONT_FAMILY;
      ctx.textBaseline = 'middle';
      ctx.textAlign    = 'center';
      ctx.fillStyle    = `rgba(251,191,36,${cp})`;
      ctx.shadowBlur   = 12; ctx.shadowColor = '#fbbf24';
      ctx.fillText('✦', BX + 34, H / 2);
      ctx.fillText('✦', BX + BW - 34, H / 2);
      ctx.shadowBlur   = 0;

      // "NEW SUBSCRIBER" label
      ctx.font         = '700 20px "Inter",sans-serif';
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'alphabetic';
      ctx.fillStyle    = '#fbbf24';
      ctx.shadowBlur   = 14; ctx.shadowColor = '#fbbf24';
      ctx.fillText('✦   N E W   S U B S C R I B E R   ✦', W / 2, BY + 72);
      ctx.shadowBlur   = 0;

      // Divider line
      const dlG = ctx.createLinearGradient(BX + 60, 0, BX + BW - 60, 0);
      dlG.addColorStop(0, 'rgba(251,191,36,0)');
      dlG.addColorStop(0.5, 'rgba(251,191,36,0.4)');
      dlG.addColorStop(1, 'rgba(251,191,36,0)');
      ctx.strokeStyle = dlG; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(BX + 60, BY + 85); ctx.lineTo(BX + BW - 60, BY + 85); ctx.stroke();

      // Name — golden metallic gradient
      const nLen    = subAlert.name.length;
      const nSize   = Math.min(90, Math.max(52, 90 - Math.max(0, nLen - 10) * 3));
      const nGrad   = ctx.createLinearGradient(W/2 - 360, 0, W/2 + 360, 0);
      nGrad.addColorStop(0,    '#fff4c2');
      nGrad.addColorStop(0.2,  '#f5c518');
      nGrad.addColorStop(0.5,  '#fde68a');
      nGrad.addColorStop(0.8,  '#c8960c');
      nGrad.addColorStop(1,    '#fff4c2');
      ctx.font         = '700 ' + nSize + 'px ' + FONT_FAMILY;
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'alphabetic';
      ctx.shadowBlur   = 28; ctx.shadowColor = '#fbbf24';
      ctx.fillStyle    = nGrad;
      ctx.fillText(subAlert.name, W / 2, BY + BH - 46);
      ctx.shadowBlur   = 0;

      // Shimmer sweep
      const swP  = (age % 900) / 900;
      const swG  = ctx.createLinearGradient(BX + swP * (BW + 200) - 120, BY, BX + swP * (BW + 200), BY + BH);
      swG.addColorStop(0, 'rgba(255,255,255,0)');
      swG.addColorStop(0.5, 'rgba(255,255,255,0.22)');
      swG.addColorStop(1, 'rgba(255,255,255,0)');
      ctx.fillStyle = swG;
      rRekt(BX, BY, BW, BH, 22);
      ctx.fill();

      ctx.restore();

      // ── Sub particles (drawn after banner so they're on top) ───────────────
      subParts.forEach(p => {
        if (p.life <= 0) return;
        ctx.save();
        ctx.globalAlpha = p.life * 0.92;
        ctx.fillStyle   = p.color;
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        const s = p.size * Math.sqrt(p.life);
        if (p.kind === 'glitter') {
          // 4-pointed star shape
          ctx.beginPath();
          ctx.moveTo(0, -s * 1.6); ctx.lineTo(s * 0.4, -s * 0.4);
          ctx.lineTo(s * 1.6, 0);  ctx.lineTo(s * 0.4,  s * 0.4);
          ctx.lineTo(0,  s * 1.6); ctx.lineTo(-s * 0.4, s * 0.4);
          ctx.lineTo(-s * 1.6, 0); ctx.lineTo(-s * 0.4, -s * 0.4);
          ctx.closePath(); ctx.fill();
        } else {
          ctx.shadowBlur  = 6;
          ctx.shadowColor = p.color;
          ctx.fillRect(-s / 2, -s / 2, s, s);
        }
        ctx.restore();
      });
    }

    // ── Drawing helpers ──────────────────────────────────────────────────────
    function drawHeader(alpha) {
      ctx.save();
      ctx.globalAlpha  = alpha;
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'alphabetic';

      // glow pass
      ctx.font        = '700 ' + (VERTICAL ? 44 : 66) + 'px ' + FONT_FAMILY;
      ctx.shadowBlur  = 40;
      ctx.shadowColor = 'rgba(167,139,250,0.9)';
      ctx.fillStyle   = '#c084fc';
      // vertical needs more top clearance — YouTube UI covers ~120px at top
      const HDR_Y  = VERTICAL ? 196 : 82;
      const RULE_Y = VERTICAL ? 212 : 96;

      ctx.fillText('✨  ' + HEADER_TEXT + '  ✨', W / 2, HDR_Y);

      // sharp pass
      ctx.shadowBlur  = 12;
      ctx.shadowColor = 'rgba(216,180,254,0.7)';
      ctx.fillStyle   = '#e879f9';
      ctx.fillText('✨  ' + HEADER_TEXT + '  ✨', W / 2, HDR_Y);

      // decorative rule
      const rg = ctx.createLinearGradient(W / 2 - 360, 0, W / 2 + 360, 0);
      rg.addColorStop(0,   'rgba(139,92,246,0)');
      rg.addColorStop(0.5, 'rgba(139,92,246,0.38)');
      rg.addColorStop(1,   'rgba(139,92,246,0)');
      ctx.strokeStyle = rg;
      ctx.lineWidth   = 1.5;
      ctx.beginPath();
      ctx.moveTo(W / 2 - 360, RULE_Y);
      ctx.lineTo(W / 2 + 360, RULE_Y);
      ctx.stroke();

      ctx.textAlign = 'left';
      ctx.restore();
    }

    function drawAmbientParticles(ts) {
      const t = ts * 0.001;
      for (let i = 0; i < 42; i++) {
        const seed  = i * 7919;
        const baseX = (seed * 13.7) % W;
        const baseY = (seed * 7.3)  % H;
        const speed = 0.032 + (seed % 100) / 2900;
        const drift = ((seed % 50) - 25) / 6500;
        const phase = (seed % 628) / 100;
        const x     = ((baseX + drift * t * W)  % W + W) % W;
        const y     = ((baseY - speed * t * H)  % H + H) % H;
        const alpha = Math.max(0, 0.07 + 0.09 * Math.sin(t * 0.75 + phase));
        const size  = 1 + (seed % 22) / 13;
        ctx.save();
        ctx.globalAlpha = alpha;
        ctx.fillStyle   = i % 3 === 0 ? '#c4b5fd' : i % 3 === 1 ? '#f9a8d4' : '#fde68a';
        ctx.beginPath();
        ctx.arc(x, y, size, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }
    }

    function drawBurstParticles() {
      burstParts.forEach(p => {
        if (p.life <= 0) return;
        ctx.save();
        ctx.globalAlpha = p.life * 0.92;
        ctx.fillStyle   = p.color;
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        const s = p.size * Math.sqrt(p.life);
        ctx.fillRect(-s / 2, -s / 2, s, s);
        ctx.restore();
      });
    }

    function drawConfettiParticles() {
      confParts.forEach(p => {
        if (p.life <= 0) return;
        ctx.save();
        ctx.globalAlpha = Math.min(1, p.life * 1.6);
        ctx.fillStyle   = p.color;
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
        ctx.restore();
      });
    }

    function drawRecentGlow(ts) {
      if (!recentGlow) return;
      if (!recentGlow.startTs) { recentGlow.startTs = ts; return; }
      const age = ts - recentGlow.startTs;
      const DUR = 4800;
      if (age > DUR) { recentGlow = null; return; }
      const t     = age / DUR;
      const pulse = 0.55 + 0.45 * Math.sin(age / 250);
      const alpha = (1 - t) * (1 - t) * pulse * 0.68;
      ctx.save();
      ctx.globalAlpha  = alpha;
      ctx.shadowBlur   = 40;
      ctx.shadowColor  = '#a78bfa';
      setFont(FONT_SIZE);
      ctx.textBaseline = 'alphabetic';
      ctx.fillStyle    = '#ddd6fe';
      ctx.fillText(recentGlow.name,
        COL_X[recentGlow.col],
        START_Y + recentGlow.row * LINE_H);
      ctx.restore();
    }

    function drawNameCounter(alpha) {
      const count = allPages.reduce((s, p) => s + p.length, 0);
      if (count === 0) return;
      ctx.save();
      ctx.globalAlpha  = alpha * 0.52;
      ctx.font         = 'italic 400 26px ' + FONT_FAMILY;
      ctx.textBaseline = 'alphabetic';
      ctx.textAlign    = 'right';
      ctx.fillStyle    = 'rgba(251,191,36,0.8)';
      ctx.fillText(count + ' guests featured tonight', W - 36, VERTICAL ? H - 140 : H - 52);
      ctx.textAlign    = 'left';
      ctx.restore();
    }

    // ── Draw already-written names ───────────────────────────────────────────
    function drawStaticNames() {
      (allPages[displayPage] || []).forEach(({ name, col, row }) => {
        const x = COL_X[col];
        const y = START_Y + row * LINE_H;
        drawNameAt(name, name.length, 1, x, y);
        drawBullet(col, row, 1);
      });
    }

    function drawNameAt(text, count, alpha, x, y) {
      if (count <= 0) return;
      ctx.save();
      ctx.globalAlpha  = alpha;
      setFont(FONT_SIZE);
      ctx.textBaseline = 'alphabetic';
      // golden glow halo
      ctx.shadowBlur   = 24;
      ctx.shadowColor  = 'rgba(251,191,36,0.65)';
      ctx.fillStyle    = '#fde68a';
      ctx.fillText(text.slice(0, count), x, y);
      // bright gold crisp pass
      ctx.shadowBlur   = 8;
      ctx.shadowColor  = 'rgba(245,197,24,0.5)';
      ctx.fillStyle    = '#fff4c2';
      ctx.fillText(text.slice(0, count), x, y);
      ctx.restore();
    }

    function drawBullet(col, row, alpha) {
      const x = COL_X[col] - BULLET_OFF;
      const y = START_Y + row * LINE_H;
      ctx.save();
      ctx.globalAlpha  = alpha;
      setFont(BULLET_SIZE);
      ctx.textBaseline = 'alphabetic';
      ctx.fillStyle    = 'rgba(251,191,36,0.88)';
      ctx.fillText('✦', x, y);
      ctx.restore();
    }

    // ── Page decorations ─────────────────────────────────────────────────────
    function drawPageNum(alpha) {
      ctx.save();
      ctx.globalAlpha  = alpha;
      ctx.font         = 'italic 400 32px ' + FONT_FAMILY;
      ctx.textBaseline = 'alphabetic';
      ctx.textAlign    = 'center';
      const onLive  = displayPage === livePageIdx;
      ctx.fillStyle = onLive ? 'rgba(192,132,252,0.85)' : 'rgba(250,100,100,0.9)';
      const label   = onLive
        ? `— Page ${displayPage + 1} —`
        : `— Page ${displayPage + 1}  ·  Live: Pg ${livePageIdx + 1} —`;
      ctx.fillText(label, W / 2, VERTICAL ? H - 140 : H - 52);
      ctx.textAlign = 'left';
      ctx.restore();
    }

    function drawDivider(alpha) {
      if (VERTICAL) return;
      ctx.save();
      ctx.globalAlpha  = alpha * 0.18;
      ctx.strokeStyle  = '#7c3aed';
      ctx.lineWidth    = 1.5;
      ctx.setLineDash([6, 8]);
      ctx.beginPath();
      ctx.moveTo(W / 2, START_Y - 55);
      ctx.lineTo(W / 2, START_Y + MAX_ROWS * LINE_H - 10);
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.restore();
    }

    // ── Golden fountain pen ──────────────────────────────────────────────────
    function drawPen(tx, ty, alpha) {
      if (alpha <= 0) return;
      ctx.save();
      ctx.globalAlpha = alpha;
      const ANGLE  = -Math.PI / 5;
      const LENGTH = 180;
      const bx = tx - Math.cos(ANGLE) * LENGTH;
      const by = ty - Math.sin(ANGLE) * LENGTH;

      const bodyGrad = ctx.createLinearGradient(bx, by, tx, ty);
      bodyGrad.addColorStop(0,    '#fff4c2');
      bodyGrad.addColorStop(0.15, '#f5c518');
      bodyGrad.addColorStop(0.45, '#c8960c');
      bodyGrad.addColorStop(0.7,  '#f5c518');
      bodyGrad.addColorStop(0.88, '#8b6914');
      bodyGrad.addColorStop(1,    '#3a2a00');

      ctx.lineWidth   = 24; ctx.lineCap = 'round'; ctx.strokeStyle = bodyGrad;
      ctx.beginPath();
      ctx.moveTo(bx, by);
      ctx.lineTo(tx + Math.cos(ANGLE) * 14, ty + Math.sin(ANGLE) * 14);
      ctx.stroke();

      ctx.lineWidth   = 9; ctx.strokeStyle = '#1a1200';
      ctx.beginPath();
      ctx.moveTo(tx + Math.cos(ANGLE) * 14, ty + Math.sin(ANGLE) * 14);
      ctx.lineTo(tx, ty);
      ctx.stroke();

      const inkGrad = ctx.createRadialGradient(tx, ty, 0, tx, ty, 8);
      inkGrad.addColorStop(0, 'rgba(80,30,120,0.9)');
      inkGrad.addColorStop(1, 'rgba(80,30,120,0)');
      ctx.fillStyle = inkGrad;
      ctx.beginPath(); ctx.arc(tx, ty, 8, 0, Math.PI * 2); ctx.fill();

      const bandX = bx + Math.cos(ANGLE) * (LENGTH * 0.82);
      const bandY = by + Math.sin(ANGLE) * (LENGTH * 0.82);
      ctx.lineWidth = 30; ctx.strokeStyle = 'rgba(200,150,10,0.45)'; ctx.lineCap = 'butt';
      ctx.beginPath();
      ctx.moveTo(bandX - Math.cos(ANGLE)*8, bandY - Math.sin(ANGLE)*8);
      ctx.lineTo(bandX + Math.cos(ANGLE)*8, bandY + Math.sin(ANGLE)*8);
      ctx.stroke();

      ctx.fillStyle = '#f5c518';
      ctx.beginPath(); ctx.arc(bx, by, 13, 0, Math.PI * 2); ctx.fill();
      ctx.restore();
    }

    // ── Master render ────────────────────────────────────────────────────────
    function drawFrame(ts) {
      const now   = ts || performance.now();
      const alpha = flipAlpha;
      ctx.clearRect(0, 0, W, H);

      // back-to-front layering
      drawAmbientParticles(now);
      drawHeader(alpha);
      drawDivider(alpha);
      drawPageNum(alpha);
      drawNameCounter(alpha);
      drawStaticNames();
      drawRecentGlow(now);

      if (anim && displayPage === livePageIdx) {
        const { name, col, row, revealed } = anim;
        const x = COL_X[col];
        const y = START_Y + row * LINE_H;
        if (revealed > 0) drawBullet(col, row, anim.fading ? anim.fadeAlpha : 1);
        drawNameAt(name, revealed, anim.fading ? anim.fadeAlpha : 1, x, y);
        if (!anim.fading && revealed > 0) {
          const tipX  = charTipX(name, revealed, FONT_SIZE, x);
          const tipY  = y - FONT_SIZE * 0.18;
          const bounce = (revealed < name.length && now)
            ? 5 * Math.abs(Math.sin((now - anim.lastCharTs) / MS_PER_CHAR * Math.PI))
            : 0;
          drawPen(tipX, tipY + bounce, anim.penAlpha !== undefined ? anim.penAlpha : 1);
        }
      }

      // particles always on top
      drawBurstParticles();
      drawConfettiParticles();

      // live poll — above guestbook, below subscriber/shoutout
      drawPoll(now);

      // subscriber alert
      drawSubscriberAlert(now);

      // shoutout card — topmost layer
      drawShoutoutAlert(now);
    }

    // ── Animation loop ───────────────────────────────────────────────────────
    function animLoop(ts) {
      if (!anim) return;
      updatePhysics(ts);

      const { name, col, row } = anim;

      if (!anim.fading) {
        if (!anim.lastCharTs) anim.lastCharTs = ts;
        if (ts - anim.lastCharTs >= MS_PER_CHAR && anim.revealed < name.length) {
          anim.revealed++;
          anim.lastCharTs = ts;
        }

        if (anim.revealed >= name.length) {
          if (!anim.holdStart) anim.holdStart = ts;
          const held = ts - anim.holdStart;
          anim.penAlpha = held < 600 ? 1 : Math.max(0, 1 - (held - 600) / 400);

          if (held > 2000) {
            // Commit name
            allPages[livePageIdx].push({ name, col, row });
            totalNames++;

            // Sparkle burst at pen tip
            const tipX = charTipX(name, name.length, FONT_SIZE, COL_X[col]);
            const tipY = START_Y + row * LINE_H - FONT_SIZE * 0.18;
            spawnBurst(tipX, tipY);

            // Recent name glow
            recentGlow = { col, row, name, startTs: null };

            // Milestone every 10th name
            if (totalNames % 10 === 0) spawnMilestone();

            anim      = null;
            isWriting = false;
            animId    = null;
            drawFrame(ts);
            advancePosition();
            if (!isFlipping && nameQueue.length > 0) setTimeout(processNext, 100);
            else ensureAmbientLoop();
            return;
          }
        }
      }

      drawFrame(ts);
      animId = requestAnimationFrame(animLoop);
    }

    function advancePosition() {
      if (VERTICAL) {
        nextRow++;
        if (nextRow >= MAX_ROWS) doPageFlip();
      } else if (nextCol === 0) {
        nextRow++;
        if (nextRow >= MAX_ROWS) { nextCol = 1; nextRow = 0; }
      } else {
        nextRow++;
        if (nextRow >= MAX_ROWS) doPageFlip();
      }
    }

    function processNext() {
      if (!nameQueue.length || isWriting || isFlipping || pollPaused) return;
      isWriting = true;
      const name = nameQueue.shift();
      if (animId) { cancelAnimationFrame(animId); animId = null; }
      anim = {
        name, col: nextCol, row: nextRow,
        revealed: 0, lastCharTs: null, holdStart: null,
        fading: false, fadeAlpha: 1, penAlpha: 1,
      };
      animId = requestAnimationFrame(animLoop);
    }

    // ── Idle ambient loop ────────────────────────────────────────────────────
    function ensureAmbientLoop() {
      if (ambLoopId) return;
      function loop(ts) {
        const pollActive = pollData !== null || shoutAlert !== null;
        if (isWriting || isFlipping) {
          // keep running if poll/shoutout still need drawing
          if (!pollActive) { ambLoopId = null; return; }
        }
        updatePhysics(ts);
        drawFrame(ts);
        ambLoopId = requestAnimationFrame(loop);
      }
      ambLoopId = requestAnimationFrame(loop);
    }

    // ── Core book-turn engine ─────────────────────────────────────────────────
    function doBookFlip(snapOld, drawNew, forward, onDone) {
      const FLIP_MS  = 820;
      const BEND_W   = 160;
      const SHADOW_W = 220;
      let   start    = null;

      function frame(ts) {
        if (!start) start = ts;
        updatePhysics(ts);
        const raw  = Math.min(1, (ts - start) / FLIP_MS);
        const ease = raw < 0.5
          ? 4 * raw * raw * raw
          : 1 - Math.pow(-2 * raw + 2, 3) / 2;

        const foldX = forward ? W * (1 - ease) : W * ease;

        ctx.clearRect(0, 0, W, H);

        // ambient particles still visible during flip
        drawAmbientParticles(ts);

        // Layer 1: new page
        drawNew();

        // Layer 2: cast shadow
        const shadowAlpha = 0.5 * Math.sin(ease * Math.PI);
        if (shadowAlpha > 0.01) {
          if (forward) {
            const x0 = Math.max(0, foldX - SHADOW_W);
            const sg = ctx.createLinearGradient(x0, 0, foldX, 0);
            sg.addColorStop(0, 'rgba(0,0,0,0)');
            sg.addColorStop(1, `rgba(0,0,0,${shadowAlpha})`);
            ctx.fillStyle = sg;
            ctx.fillRect(x0, 0, foldX - x0, H);
          } else {
            const x1 = Math.min(W, foldX + SHADOW_W);
            const sg = ctx.createLinearGradient(foldX, 0, x1, 0);
            sg.addColorStop(0, `rgba(0,0,0,${shadowAlpha})`);
            sg.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.fillStyle = sg;
            ctx.fillRect(foldX, 0, x1 - foldX, H);
          }
        }

        // Layer 3: old page clipped to unturned side
        ctx.save();
        ctx.beginPath();
        forward ? ctx.rect(foldX, 0, W - foldX, H) : ctx.rect(0, 0, foldX, H);
        ctx.clip();
        ctx.drawImage(snapOld, 0, 0);
        if (forward) {
          const bg = ctx.createLinearGradient(foldX, 0, foldX + BEND_W, 0);
          bg.addColorStop(0, `rgba(0,0,0,${0.65 * ease})`);
          bg.addColorStop(1, 'rgba(0,0,0,0)');
          ctx.fillStyle = bg;
          ctx.fillRect(foldX, 0, Math.min(BEND_W, W - foldX), H);
        } else {
          const bg = ctx.createLinearGradient(foldX - BEND_W, 0, foldX, 0);
          bg.addColorStop(0, 'rgba(0,0,0,0)');
          bg.addColorStop(1, `rgba(0,0,0,${0.65 * (1 - ease)})`);
          ctx.fillStyle = bg;
          ctx.fillRect(Math.max(0, foldX - BEND_W), 0, Math.min(BEND_W, foldX), H);
        }
        ctx.restore();

        // Layer 4: fold crease highlight
        const creaseAlpha = 0.65 * Math.sin(ease * Math.PI);
        if (creaseAlpha > 0.02 && foldX > 4 && foldX < W - 4) {
          const cg = ctx.createLinearGradient(foldX - 18, 0, foldX + 18, 0);
          cg.addColorStop(0,    'rgba(255,255,255,0)');
          cg.addColorStop(0.45, `rgba(255,255,255,${creaseAlpha})`);
          cg.addColorStop(0.55, `rgba(200,180,255,${creaseAlpha * 0.8})`);
          cg.addColorStop(1,    'rgba(255,255,255,0)');
          ctx.fillStyle = cg;
          ctx.fillRect(foldX - 18, 0, 36, H);
        }

        // burst/confetti still visible during flip
        drawBurstParticles();
        drawConfettiParticles();

        if (raw < 1) {
          animId = requestAnimationFrame(frame);
        } else {
          animId = null;
          onDone();
        }
      }

      animId = requestAnimationFrame(frame);
    }

    // ── Automatic page flip (page fills up) ───────────────────────────────────
    function doPageFlip() {
      isFlipping = true;
      isWriting  = false;
      if (animId) { cancelAnimationFrame(animId); animId = null; }
      anim = null;

      const snap = document.createElement('canvas');
      snap.width = W; snap.height = H;
      snap.getContext('2d').drawImage(canvas, 0, 0);

      livePageIdx++;
      allPages.push([]);
      displayPage = livePageIdx;
      nextCol = 0; nextRow = 0;

      doBookFlip(snap, () => {
        drawHeader(1); drawDivider(1); drawPageNum(1);
      }, true, () => {
        flipAlpha  = 1;
        isFlipping = false;
        drawFrame(performance.now());
        if (nameQueue.length > 0) setTimeout(processNext, 100);
        else ensureAmbientLoop();
      });
    }

    // ── Manual page navigation ────────────────────────────────────────────────
    function doNavPageFlip(targetIdx) {
      isFlipping = true;
      if (animId) { cancelAnimationFrame(animId); animId = null; }

      const snap = document.createElement('canvas');
      snap.width = W; snap.height = H;
      snap.getContext('2d').drawImage(canvas, 0, 0);

      const forward = targetIdx > displayPage;
      displayPage   = targetIdx;

      doBookFlip(snap, () => {
        drawHeader(1); drawStaticNames(); drawDivider(1); drawPageNum(1);
      }, forward, () => {
        isFlipping = false;
        drawFrame(performance.now());
        if (displayPage === livePageIdx && !isWriting && nameQueue.length > 0)
          setTimeout(processNext, 100);
        else ensureAmbientLoop();
      });
    }

    // ── Boot ─────────────────────────────────────────────────────────────────
    document.fonts.ready.then(() => {
      drawFrame(performance.now());
      ensureAmbientLoop();
    });
  </script>
</body>
</html>
