<%- include("partials/header") %>

<style>
.about-page { min-height: 100vh; background: #e2e5ea; position: relative; overflow: hidden; padding: 80px 20px 60px; font-family: 'Segoe UI', system-ui, sans-serif; }

/* ── Animated BG ── */
.contact-bg { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
.contact-bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); animation: orbFloat 8s ease-in-out infinite; }
.contact-bg-orb:nth-child(1) { width: 500px; height: 500px; background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%); top: -100px; left: -100px; animation-delay: 0s; }
.contact-bg-orb:nth-child(2) { width: 400px; height: 400px; background: radial-gradient(circle, rgba(168,85,247,0.14) 0%, transparent 70%); top: 30%; right: -80px; animation-delay: -3s; }
.contact-bg-orb:nth-child(3) { width: 350px; height: 350px; background: radial-gradient(circle, rgba(236,72,153,0.1) 0%, transparent 70%); bottom: -50px; left: 30%; animation-delay: -5s; }
.contact-bg-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(99,102,241,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,0.05) 1px, transparent 1px); background-size: 50px 50px; }
@keyframes orbFloat { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-30px) scale(1.05)} }

/* ── Wrapper ── */
.about-wrapper { max-width: 1000px; margin: 0 auto; position: relative; z-index: 1; }

/* ── Header ── */
.about-header { text-align: center; margin-bottom: 48px; }
.about-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.25); border-radius: 50px; padding: 6px 16px; font-size: 13px; color: #4f46e5; margin-bottom: 20px; }
.about-header h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; color: #111827; margin: 0 0 16px; line-height: 1.1; }
.about-header p { color: #4b5563; font-size: 1.05rem; max-width: 560px; margin: 0 auto; line-height: 1.7; }

/* ── Stats Row ── */
.about-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
.stat-card { background: #1e2030; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 20px 16px; text-align: center; box-shadow: 0 2px 12px rgba(0,0,0,0.15); transition: all 0.3s; }
.stat-card:hover { background: #252840; border-color: rgba(99,102,241,0.4); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(99,102,241,0.15); }
.stat-number { font-size: 1.8rem; font-weight: 800; background: linear-gradient(135deg, #6366f1, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.stat-label { color: #64748b; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.8px; margin-top: 4px; }
@media(max-width:640px){ .about-stats { grid-template-columns: repeat(2, 1fr); } }

/* ── Main Grid ── */
.about-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 24px; margin-bottom: 24px; align-items: stretch; }
.about-grid > * { align-self: stretch; }
@media(max-width:768px){ .about-grid { grid-template-columns: 1fr; } }

/* ── Cards ── */
.about-card { background: #1e2030; border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 28px; box-shadow: 0 2px 12px rgba(0,0,0,0.15); display: flex; flex-direction: column; }
.about-card .feature-list { flex: 1; }
.about-card .serve-grid { flex: 1; }
.about-card h2 { font-size: 1.1rem; font-weight: 700; color: #f1f5f9; margin: 0 0 16px; display: flex; align-items: center; gap: 10px; }
.about-card h2 .card-icon { width: 32px; height: 32px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
.card-icon.purple { background: rgba(99,102,241,0.2); }
.card-icon.pink   { background: rgba(236,72,153,0.2); }
.card-icon.blue   { background: rgba(59,130,246,0.2); }
.card-icon.green  { background: rgba(34,197,94,0.2); }
.card-icon.orange { background: rgba(251,146,60,0.2); }

/* ── Mission text ── */
.about-card p { color: #94a3b8; font-size: 0.9rem; line-height: 1.7; margin: 0; }

/* ── Feature list ── */
.feature-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 3px; }
.feature-list li { display: flex; align-items: center; gap: 8px; color: #94a3b8; font-size: 0.78rem; padding: 5px 8px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 7px; }
.feature-list li::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: linear-gradient(135deg, #6366f1, #a855f7); flex-shrink: 0; }

/* ── Who We Serve ── */
.serve-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; align-content: start; }
.serve-item { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 10px 14px; color: #94a3b8; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; }

/* ── Full-width mission ── */
.about-mission { background: #1e2030; border: 1px solid rgba(99,102,241,0.2); border-radius: 20px; padding: 28px 32px; box-shadow: 0 2px 12px rgba(0,0,0,0.15); margin-bottom: 24px; text-align: center; }
.about-mission h2 { font-size: 1.1rem; font-weight: 700; color: #f1f5f9; margin: 0 0 12px; }
.about-mission p { color: #94a3b8; font-size: 0.92rem; line-height: 1.75; max-width: 680px; margin: 0 auto; }

/* ── Values row ── */
.values-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
@media(max-width:640px){ .values-row { grid-template-columns: 1fr; } }
.value-card { background: #1e2030; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.15); transition: all 0.3s; }
.value-card:hover { background: #252840; border-color: rgba(99,102,241,0.3); transform: translateY(-2px); }
.value-card .v-icon { font-size: 24px; margin-bottom: 10px; }
.value-card h3 { color: #e2e8f0; font-size: 0.95rem; font-weight: 700; margin: 0 0 6px; }
.value-card p { color: #64748b; font-size: 0.82rem; line-height: 1.6; margin: 0; }

@media(max-width:768px){
  .about-page { padding: 50px 12px 30px; }
  .about-header { margin-bottom: 28px; }
  .about-card { padding: 18px; }
  .about-mission { padding: 20px; }
  .serve-grid { grid-template-columns: 1fr 1fr; }
  .value-card { padding: 16px; }
}
</style>

<!-- Animated Background -->
<div class="contact-bg">
  <div class="contact-bg-grid"></div>
  <div class="contact-bg-orb"></div>
  <div class="contact-bg-orb"></div>
  <div class="contact-bg-orb"></div>
</div>

