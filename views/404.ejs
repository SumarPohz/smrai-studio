<%- include("partials/header") %>

<style>
  .err-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  .err-card {
    text-align: center;
    max-width: 420px;
    width: 100%;
  }
  .err-code-wrap {
    position: relative;
    display: inline-block;
    margin-bottom: 8px;
  }
  .err-code {
    font-size: 96px;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, #1e4db7 0%, #2563eb 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -4px;
  }
  .err-icon {
    font-size: 48px;
    display: block;
    margin-bottom: 4px;
  }
  .err-title {
    font-size: 22px;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 10px;
  }
  .err-desc {
    font-size: 15px;
    color: #64748b;
    line-height: 1.6;
    margin-bottom: 28px;
  }
  .err-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .err-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 24px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.15s;
    cursor: pointer;
    border: none;
  }
  .err-btn:hover { opacity: 0.88; transform: translateY(-1px); }
  .err-btn.primary { background: #1e4db7; color: #fff; }
  .err-btn.ghost   { background: #f1f5f9; color: #334155; }
  .err-divider {
    width: 48px; height: 3px;
    background: linear-gradient(90deg, #1e4db7, #3b82f6);
    border-radius: 3px;
    margin: 0 auto 24px;
  }
</style>

<div class="err-page">
  <div class="err-card">
    <span class="err-icon">🔍</span>
    <div class="err-code">404</div>
    <div class="err-divider"></div>
    <div class="err-title">Page Not Found</div>
    <div class="err-desc">
      The page you're looking for doesn't exist or has been moved.<br>
      Let's get you back on track.
    </div>
    <div class="err-actions">
      <a class="err-btn primary" href="/">← Go Home</a>
      <a class="err-btn ghost"   href="javascript:history.back()">Go Back</a>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
