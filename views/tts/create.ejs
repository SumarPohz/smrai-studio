<%- include('../partials/header', { title: 'Text to Voice — SmrAI Studio' }) %>

<style>
#tts-page {
  min-height: 100vh;
  background: #09090b;
  color: #f4f4f5;
  padding-top: 80px;
  padding-bottom: 60px;
}
.tts-card {
  max-width: 600px;
  margin: 0 auto;
  padding: 0 16px;
}
.tts-label {
  font-size: 13px;
  font-weight: 600;
  color: #71717a;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 10px;
  display: block;
}
.tts-textarea {
  width: 100%;
  background: rgba(255,255,255,0.05);
  border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  color: #f4f4f5;
  font-size: 15px;
  line-height: 1.75;
  padding: 16px;
  resize: vertical;
  min-height: 200px;
  outline: none;
  transition: border-color 0.2s;
  font-family: inherit;
  box-sizing: border-box;
}
.tts-textarea:focus { border-color: #7c3aed; }
.tts-textarea::placeholder { color: #52525b; }
.char-row { display:flex; justify-content:space-between; margin-top:6px; font-size:12px; color:#52525b; }

/* Voice picker */
.voice-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; }
@media(min-width:480px){ .voice-grid{ grid-template-columns:repeat(3,1fr); } }
.v-chip {
  display:flex; align-items:center; gap:10px;
  padding:12px 14px;
  border:1.5px solid rgba(255,255,255,0.1);
  border-radius:12px;
  background:rgba(255,255,255,0.04);
  cursor:pointer;
  transition:all .15s;
}
.v-chip:hover { border-color:rgba(124,58,237,.5); background:rgba(124,58,237,.08); }
.v-chip.selected { border-color:#7c3aed; background:rgba(124,58,237,.15); }
.v-chip-dot { width:10px;height:10px;border-radius:50%;border:2px solid #52525b;flex-shrink:0; transition:all .15s; }
.v-chip.selected .v-chip-dot { background:#7c3aed;border-color:#7c3aed; }
.v-chip-name { font-size:14px;font-weight:600;color:#e4e4e7; }
.v-chip-tag  { font-size:11px;color:#71717a; }
.play-btn {
  margin-left:auto;
  width:28px;height:28px;border-radius:6px;
  border:1px solid rgba(255,255,255,0.12);
  background:rgba(255,255,255,0.06);
  color:#a1a1aa;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:all .15s;
}
.play-btn:hover { border-color:#7c3aed;color:#c4b5fd; }

/* Generate button */
.btn-generate {
  width:100%;height:54px;
  background:linear-gradient(135deg,#7c3aed,#a855f7);
  border:none;border-radius:14px;
  color:#fff;font-size:16px;font-weight:700;
  cursor:pointer;transition:opacity .15s,transform .1s;
  display:flex;align-items:center;justify-content:center;gap:8px;
}
.btn-generate:hover:not(:disabled) { opacity:.9;transform:translateY(-1px); }
.btn-generate:disabled { opacity:.5;cursor:not-allowed;transform:none; }

/* Result */
.result-box {
  background:rgba(124,58,237,.08);
  border:1.5px solid rgba(124,58,237,.3);
  border-radius:16px;
  padding:24px;
  display:none;
}
.result-box.show { display:block; }
audio { width:100%;border-radius:10px;margin:14px 0; }
.btn-dl {
  display:inline-flex;align-items:center;gap:8px;
  padding:11px 22px;
  background:linear-gradient(135deg,#7c3aed,#a855f7);
  border:none;border-radius:10px;
  color:#fff;font-size:14px;font-weight:700;
  cursor:pointer;text-decoration:none;
  transition:opacity .15s;
}
.btn-dl:hover { opacity:.88; }
.btn-dl:disabled { opacity:.45;cursor:not-allowed; }

/* Error */
.err-box {
  display:none;
  background:rgba(239,68,68,.08);
  border:1px solid rgba(239,68,68,.25);
  border-radius:10px;
  padding:12px 16px;
  color:#fca5a5;
  font-size:14px;
  margin-bottom:16px;
}

@keyframes spin { to { transform:rotate(360deg); } }
@keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
</style>

<div id="tts-page">
  <div class="tts-card">

    <!-- Header -->
    <div style="text-align:center;margin-bottom:36px;">
      <div style="font-size:2.5rem;margin-bottom:10px;">🎙️</div>
      <h1 style="font-size:1.8rem;font-weight:800;color:#f4f4f5;letter-spacing:-0.02em;margin-bottom:6px;">Text to Voice</h1>
      <p style="font-size:14px;color:#71717a;">Type or paste any text and get an AI voiceover instantly</p>
    </div>

    <!-- Error -->
    <div id="errBox" class="err-box"></div>

    <!-- Text input -->
    <div style="margin-bottom:24px;">
      <label class="tts-label">Your Text</label>
      <textarea id="scriptTxt" class="tts-textarea" maxlength="5000"
        placeholder="Type or paste your script here…&#10;&#10;e.g. &quot;In 1969, humanity took its greatest leap forward when Neil Armstrong stepped onto the moon...&quot;"
        oninput="updateCount()"></textarea>
      <div class="char-row">
        <span>AI will voice exactly what you write</span>
        <span id="charCount">0 / 5000</span>
      </div>
    </div>

    <!-- Voice picker -->
    <div style="margin-bottom:28px;">
      <label class="tts-label">Voice</label>
      <div class="voice-grid">
        <% [
          ['alloy',   'Alloy',   'Neutral'],
          ['echo',    'Echo',    'Male'],
          ['fable',   'Fable',   'Male'],
          ['onyx',    'Onyx',    'Deep'],
          ['nova',    'Nova',    'Female'],
          ['shimmer', 'Shimmer', 'Soft'],
        ].forEach((v, vi) => { %>
        <div class="v-chip <%= vi===0?'selected':'' %>" onclick="pickVoice('<%= v[0] %>')" data-voice="<%= v[0] %>">
          <div class="v-chip-dot"></div>
          <div>
            <div class="v-chip-name"><%= v[1] %></div>
            <div class="v-chip-tag"><%= v[2] %></div>
          </div>
          <button class="play-btn" onclick="event.stopPropagation();playVoice('<%= v[0] %>',this)" title="Preview">
            <svg width="9" height="9" fill="currentColor" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </button>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- Generate button -->
    <button id="genBtn" class="btn-generate" onclick="generate()">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072M12 18.364A8.5 8.5 0 013.636 7m16.728 0A8.5 8.5 0 0112 18.364"/></svg>
      Generate Audio
    </button>

    <!-- Result -->
    <div id="resultBox" class="result-box" style="margin-top:24px;">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px;">
        <span style="font-size:1.2rem;">✅</span>
        <span style="font-size:15px;font-weight:700;color:#a78bfa;">Your audio is ready!</span>
      </div>
      <audio id="resultAudio" controls></audio>
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <button class="btn-dl" id="dlBtn" onclick="handleDownload()">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download MP3
        </button>
        <button onclick="reset()" style="padding:11px 18px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#a1a1aa;font-size:14px;font-weight:500;cursor:pointer;">
          New Audio
        </button>
      </div>
    </div>

  </div>
</div>

<script>
let voice = 'alloy';
let ttsId = null;
let _pollTimer = null;
let _activeAudio = null, _activeBtn = null;

const PLAY_ICON  = `<svg width="9" height="9" fill="currentColor" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>`;
const PAUSE_ICON = `<svg width="9" height="9" fill="currentColor" viewBox="0 0 24 24"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>`;
const SPIN_ICON  = `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:spin 1s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`;

function updateCount() {
  const len = document.getElementById('scriptTxt').value.length;
  document.getElementById('charCount').textContent = len + ' / 5000';
}

function pickVoice(v) {
  document.querySelectorAll('.v-chip').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-voice="'+v+'"]').classList.add('selected');
  voice = v;
}

function playVoice(v, btn) {
  if (_activeAudio && _activeBtn === btn) {
    _activeAudio.pause(); _activeAudio = null; _activeBtn = null;
    btn.innerHTML = PLAY_ICON; return;
  }
  if (_activeAudio) { _activeAudio.pause(); if (_activeBtn) _activeBtn.innerHTML = PLAY_ICON; }
  btn.innerHTML = SPIN_ICON; _activeBtn = btn;
  const audio = new Audio(`/reels/voice-preview/${v}`);
  _activeAudio = audio;
  audio.oncanplaythrough = () => { btn.innerHTML = PAUSE_ICON; audio.play(); };
  audio.onended  = () => { btn.innerHTML = PLAY_ICON; _activeAudio = null; _activeBtn = null; };
  audio.onerror  = () => { btn.innerHTML = PLAY_ICON; _activeAudio = null; _activeBtn = null; };
  audio.load();
}

function showErr(msg) {
  const el = document.getElementById('errBox');
  el.textContent = msg; el.style.display = 'block';
  el.scrollIntoView({ behavior:'smooth', block:'nearest' });
}
function hideErr() { document.getElementById('errBox').style.display = 'none'; }

async function generate() {
  const script = document.getElementById('scriptTxt').value.trim();
  if (!script || script.length < 5) { showErr('Please enter some text first.'); return; }
  hideErr();

  const btn = document.getElementById('genBtn');
  btn.disabled = true;
  btn.innerHTML = SPIN_ICON + ' Generating…';
  document.getElementById('resultBox').classList.remove('show');

  try {
    const res  = await fetch('/tts/generate-audio', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ script, voice }),
    });
    const data = await res.json();
    if (!res.ok || data.error) throw new Error(data.error || 'Failed to start audio generation.');
    ttsId = data.tts_id;
    startPolling();
  } catch (err) {
    showErr(err.message);
    btn.disabled = false;
    btn.innerHTML = `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072M12 18.364A8.5 8.5 0 013.636 7m16.728 0A8.5 8.5 0 0112 18.364"/></svg> Generate Audio`;
  }
}

function startPolling() {
  const btn = document.getElementById('genBtn');
  const dots = ['Generating.', 'Generating..', 'Generating...'];
  let tick = 0;
  _pollTimer = setInterval(async () => {
    tick++;
    btn.innerHTML = SPIN_ICON + ' ' + dots[tick % 3];
    try {
      const res  = await fetch(`/tts/status/${ttsId}`);
      const data = await res.json();
      if (data.status === 'completed') {
        clearInterval(_pollTimer);
        showResult(data.audio_url);
      } else if (data.status === 'failed') {
        clearInterval(_pollTimer);
        showErr('Audio generation failed. Please try again.');
        btn.disabled = false;
        btn.innerHTML = `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072M12 18.364A8.5 8.5 0 013.636 7m16.728 0A8.5 8.5 0 0112 18.364"/></svg> Generate Audio`;
      }
    } catch {}
  }, 3000);
}

function showResult(audioUrl) {
  const btn = document.getElementById('genBtn');
  btn.disabled = false;
  btn.innerHTML = `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072M12 18.364A8.5 8.5 0 013.636 7m16.728 0A8.5 8.5 0 0112 18.364"/></svg> Generate Audio`;
  const audio = document.getElementById('resultAudio');
  audio.src = audioUrl;
  const box = document.getElementById('resultBox');
  box.classList.add('show');
  box.style.animation = 'fadeIn .4s ease';
  box.scrollIntoView({ behavior:'smooth', block:'nearest' });
}

async function handleDownload() {
  if (!ttsId) return;
  const btn = document.getElementById('dlBtn');
  btn.disabled = true;
  try {
    const res = await fetch(`/tts/audio/${ttsId}/download`);
    if (res.status === 403) { alert('Download requires a subscription.'); return; }
    if (!res.ok) throw new Error('Download failed.');
    const blob = await res.blob();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = `smrai-voice-${ttsId}.mp3`; a.click();
    URL.revokeObjectURL(url);
  } catch (err) {
    alert(err.message);
  } finally {
    btn.disabled = false;
  }
}

function reset() {
  ttsId = null;
  document.getElementById('resultBox').classList.remove('show');
  document.getElementById('resultAudio').src = '';
  document.getElementById('scriptTxt').value = '';
  updateCount();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>

<%- include('../partials/footer') %>
