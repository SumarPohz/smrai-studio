<%- include('../partials/header', { title: 'Text to Voice — SmrAI Studio' }) %>
<script src="https://cdn.tailwindcss.com"></script>

<style>
#tts-wizard {
  background: #fff;
  min-height: 100vh;
  color: #111827;
}
.wiz-progress { display:flex; gap:6px; margin-bottom:32px; }
.wiz-seg { height:5px; flex:1; border-radius:999px; background:#e5e7eb; transition:background 0.3s; }
.wiz-seg.done { background:#7c3aed; }
.step-badge { display:inline-block; padding:3px 12px; border-radius:999px; border:1.5px solid #7c3aed; color:#7c3aed; font-size:13px; font-weight:600; margin-left:10px; vertical-align:middle; }
.opt-badge  { display:inline-block; padding:3px 10px; border-radius:999px; border:1.5px solid #7c3aed; color:#7c3aed; font-size:12px; font-weight:600; margin-left:8px; vertical-align:middle; }
.step-title { font-size:1.65rem; font-weight:800; color:#111827; margin-bottom:6px; }
.step-sub   { font-size:14px; color:#6b7280; margin-bottom:22px; }

/* Tabs */
.wiz-tabs { display:flex; border-bottom:1.5px solid #e5e7eb; margin-bottom:20px; }
.wiz-tab  { padding:10px 18px; font-size:14px; font-weight:500; color:#6b7280; cursor:pointer; border:none; border-bottom:2.5px solid transparent; margin-bottom:-1.5px; background:none; display:flex; align-items:center; gap:6px; }
.wiz-tab.active { color:#7c3aed; border-bottom-color:#7c3aed; }

/* Niche presets */
.niche-item { border:1.5px solid #e5e7eb; border-radius:12px; padding:14px 18px; cursor:pointer; margin-bottom:10px; transition:border-color .15s,background .15s; }
.niche-item:hover,.niche-item.selected { border-color:#7c3aed; background:#faf5ff; }
.niche-item-title { font-size:15px; font-weight:600; color:#111827; }
.niche-item-desc  { font-size:13px; color:#9ca3af; margin-top:2px; }

/* Voice */
.wiz-card { border:1.5px solid #e5e7eb; border-radius:14px; overflow:hidden; }
.voice-item { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid #f3f4f6; cursor:pointer; transition:background .12s; }
.voice-item:last-child { border-bottom:none; }
.voice-item.selected { background:#faf5ff; }
.v-radio { width:18px; height:18px; border-radius:50%; border:2px solid #d1d5db; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.voice-item.selected .v-radio { border-color:#7c3aed; }
.v-dot { width:9px; height:9px; border-radius:50%; background:#7c3aed; display:none; }
.voice-item.selected .v-dot { display:block; }
.v-badge { display:inline-block; padding:2px 9px; border-radius:999px; background:#dbeafe; color:#1d4ed8; font-size:11px; font-weight:700; margin-left:6px; }
.v-badge.female { background:#fce7f3; color:#9d174d; }

/* Scrollable step body */
.wiz-body { max-height: calc(100vh - 320px); overflow-y: auto; padding-right: 4px; }

/* Nav */
.wiz-nav { display:flex; justify-content:space-between; align-items:center; padding-top:24px; border-top:1px solid #f3f4f6; margin-top:32px; }
.btn-back { display:flex; align-items:center; gap:6px; padding:12px 22px; border:1.5px solid #e5e7eb; border-radius:10px; background:#fff; color:#374151; font-size:15px; font-weight:500; cursor:pointer; transition:border-color .15s; }
.btn-back:hover { border-color:#6b7280; }
.btn-next { display:flex; align-items:center; gap:6px; padding:12px 26px; border-radius:10px; background:#7c3aed; color:#fff; font-size:15px; font-weight:600; cursor:pointer; border:none; transition:background .15s; }
.btn-next:hover { background:#6d28d9; }
.btn-next:disabled { opacity:.5; cursor:not-allowed; }
.err-box { display:none; background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.25); border-radius:10px; padding:12px 16px; color:#dc2626; font-size:14px; margin-bottom:16px; }

/* Inputs */
.wiz-input,.wiz-select,.wiz-textarea { width:100%; border:1.5px solid #e5e7eb; border-radius:10px; padding:12px 14px; font-size:15px; color:#111827; background:#fff; outline:none; transition:border-color .15s; box-sizing:border-box; }
.wiz-input:focus,.wiz-select:focus,.wiz-textarea:focus { border-color:#7c3aed; }
.wiz-textarea { resize:vertical; min-height:180px; font-family:inherit; line-height:1.7; }
.wiz-label { font-size:14px; font-weight:600; color:#111827; margin-bottom:8px; display:block; }
.char-count { font-size:12px; color:#9ca3af; }

/* Confirmation modal */
.tts-modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:1000; display:flex; align-items:center; justify-content:center; padding:20px; }
.tts-modal-box { background:#fff; border-radius:20px; padding:32px 28px; max-width:380px; width:100%; box-shadow:0 20px 60px rgba(0,0,0,0.2); text-align:center; }

/* Result player */
.audio-card { background:#faf5ff; border:1.5px solid #e9d5ff; border-radius:16px; padding:28px 24px; text-align:center; }
audio { width:100%; border-radius:10px; margin:16px 0; }
.btn-download { display:inline-flex; align-items:center; gap:8px; padding:12px 28px; background:linear-gradient(135deg,#7c3aed,#a855f7); color:#fff; border:none; border-radius:10px; font-size:15px; font-weight:700; cursor:pointer; text-decoration:none; transition:opacity .15s; }
.btn-download:hover { opacity:.88; }
.btn-download:disabled { opacity:.45; cursor:not-allowed; }
.paywall-msg { background:#fef3c7; border:1px solid #fde68a; border-radius:10px; padding:12px 16px; font-size:13px; color:#92400e; margin-top:12px; display:none; }

@keyframes spin { to { transform:rotate(360deg); } }
</style>

<!-- Confirmation modal -->
<div id="ttsModal" class="tts-modal-overlay" style="display:none;">
  <div class="tts-modal-box">
    <div style="font-size:2.5rem;margin-bottom:10px;">🎙️</div>
    <h3 style="font-size:1.2rem;font-weight:800;color:#111827;margin-bottom:8px;">Generate Voice?</h3>
    <p style="font-size:14px;color:#6b7280;line-height:1.6;margin-bottom:24px;">Your script is ready! Proceed to voice selection or keep editing.</p>
    <div style="display:flex;gap:12px;justify-content:center;">
      <button onclick="closeModal()" style="padding:11px 22px;border:1.5px solid #e5e7eb;border-radius:10px;background:#fff;color:#374151;font-size:14px;font-weight:600;cursor:pointer;">✏️ Keep Editing</button>
      <button onclick="confirmGenerate()" style="padding:11px 22px;border:none;border-radius:10px;background:#7c3aed;color:#fff;font-size:14px;font-weight:700;cursor:pointer;">✅ Yes, Continue</button>
    </div>
  </div>
</div>

<div id="tts-wizard" style="padding-top:80px;padding-bottom:60px;">
  <div style="max-width:560px;margin:0 auto;padding:0 16px;">

    <!-- Progress bar (4 steps) -->
    <div class="wiz-progress" id="wizProg">
      <div class="wiz-seg" id="seg0"></div>
      <div class="wiz-seg" id="seg1"></div>
      <div class="wiz-seg" id="seg2"></div>
      <div class="wiz-seg" id="seg3"></div>
    </div>

    <!-- ── STEP 1: Topic ──────────────────────────────────────────── -->
    <div id="step-1" class="wiz-step">
      <h2 class="step-title">Choose Your Topic <span class="step-badge">Step 1 of 4</span></h2>
      <p class="step-sub">Select a preset niche or describe your own topic</p>
      <div id="s1err" class="err-box"></div>

      <div class="wiz-tabs">
        <button class="wiz-tab active" id="t1a" onclick="sTab('a')">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          Presets
        </button>
        <button class="wiz-tab" id="t1b" onclick="sTab('b')">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/></svg>
          Custom
        </button>
      </div>

      <div id="p1a" class="wiz-body">
        <% [
          ['Scary Stories','Scary stories that give you goosebumps'],
          ['History','Viral videos about history spanning from ancient times to the modern day.'],
          ['True Crime','Viral videos about true crime stories.'],
          ['Stoic Motivation','Viral videos about stoic philosophy and life lessons.'],
          ['Finance Tips','Smart money habits and financial freedom strategies.'],
          ['Motivation','Inspirational content to push people to their limits.'],
          ['Biblical Stories','Timeless stories from the Bible brought to life.'],
          ['Mythology','Ancient myths and legends from around the world.'],
          ['Anime Stories','Epic anime-inspired story arcs and character arcs.'],
          ['Act of Kindness','Heartwarming stories of humans helping each other.'],
          ['Tech Tips','Quick and useful technology tips for everyday life.'],
          ['Health Hacks','Simple daily habits for a healthier and longer life.'],
        ].forEach(n => { %>
        <div class="niche-item" onclick="pickTopic('<%= n[0] %>')" data-niche="<%= n[0] %>">
          <div class="niche-item-title"><%= n[0] %></div>
          <div class="niche-item-desc"><%= n[1] %></div>
        </div>
        <% }) %>
      </div>

      <div id="p1b" class="wiz-body" style="display:none;">
        <label class="wiz-label">Your Topic</label>
        <textarea id="customTopic" class="wiz-textarea" style="min-height:120px;" maxlength="300"
          placeholder="e.g.: The story of Nikola Tesla and how he was betrayed by the world..."
          oninput="cc('customTopic','cc1',300)"></textarea>
        <div style="display:flex;justify-content:space-between;margin-top:4px;">
          <span style="font-size:13px;color:#7c3aed;">AI will generate a script from this topic</span>
          <span class="char-count" id="cc1">0/300</span>
        </div>
      </div>

      <div class="wiz-nav">
        <div></div>
        <button class="btn-next" id="genScriptBtn" onclick="generateScript()">
          <span id="genScriptTxt">Generate Script</span>
          <span id="genScriptIco"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
        </button>
      </div>
    </div>

    <!-- ── STEP 2: Script Editor ───────────────────────────────────── -->
    <div id="step-2" class="wiz-step" style="display:none;">
      <h2 class="step-title">Edit Script <span class="step-badge">Step 2 of 4</span></h2>
      <p class="step-sub">Review and refine the AI-generated script before creating your voiceover</p>
      <div id="s2err" class="err-box"></div>

      <div class="wiz-body">
        <label class="wiz-label">Your Script</label>
        <textarea id="scriptTxt" class="wiz-textarea" style="min-height:260px;"
          maxlength="5000"
          placeholder="Your AI-generated script will appear here…"
          oninput="cc('scriptTxt','cc2',5000)"></textarea>
        <div style="display:flex;justify-content:space-between;margin-top:6px;">
          <span style="font-size:13px;color:#7c3aed;">Edit freely — AI will voice exactly what you write</span>
          <span class="char-count" id="cc2">0/5000</span>
        </div>
      </div>

      <div class="wiz-nav">
        <button class="btn-back" onclick="go(1)"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg> Back</button>
        <button class="btn-next" onclick="openModal()">
          Generate Voice
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <!-- ── STEP 3: Voice Selection ────────────────────────────────── -->
    <div id="step-3" class="wiz-step" style="display:none;">
      <h2 class="step-title">Select Voice <span class="step-badge">Step 3 of 4</span></h2>
      <p class="step-sub">Choose the AI voice that will narrate your script</p>

      <div class="wiz-body">
        <div class="wiz-card">
          <% [
            ['alloy',   'Alloy',   'Neutral', false, 'Neutral &amp; balanced — great for any content.'],
            ['echo',    'Echo',    'Male',    false, 'Deep &amp; authoritative — the well known voice of TikTok.'],
            ['fable',   'Fable',   'Male',    false, 'British &amp; storytelling — ideal for narratives.'],
            ['onyx',    'Onyx',    'Male',    false, 'Rich &amp; powerful — perfect for storytelling.'],
            ['nova',    'Nova',    'Female',  true,  'Warm &amp; friendly — great for lifestyle content.'],
            ['shimmer', 'Shimmer', 'Female',  true,  'Soft &amp; calm — ideal for relaxing content.'],
          ].forEach((v, vi) => { %>
          <div class="voice-item <%= vi===0?'selected':'' %>" onclick="pickVoice('<%= v[0] %>')" data-voice="<%= v[0] %>">
            <div style="display:flex;align-items:center;gap:12px;flex:1;">
              <div class="v-radio"><div class="v-dot"></div></div>
              <div>
                <div style="display:flex;align-items:center;">
                  <span style="font-size:15px;font-weight:700;color:#111827;"><%= v[1] %></span>
                  <span class="v-badge <%= v[3]?'female':'' %>"><%= v[2] %></span>
                </div>
                <div style="font-size:13px;color:#6b7280;margin-top:2px;"><%- v[4] %></div>
              </div>
            </div>
            <button class="play-btn" onclick="event.stopPropagation();playVoice('<%= v[0] %>',this)" title="Preview voice"
              style="width:34px;height:34px;border-radius:8px;border:1.5px solid #e5e7eb;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#374151;flex-shrink:0;">
              <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </button>
          </div>
          <% }) %>
        </div>
      </div><!-- /wiz-body -->

      <div class="wiz-nav">
        <button class="btn-back" onclick="go(2)"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg> Back</button>
        <button class="btn-next" id="genAudioBtn" onclick="generateAudio()">
          <span id="genAudioTxt">Generate Audio</span>
          <span id="genAudioIco"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
        </button>
      </div>
    </div>

    <!-- ── STEP 4: Result ─────────────────────────────────────────── -->
    <div id="step-4" class="wiz-step" style="display:none;">
      <h2 class="step-title">Your Voiceover is Ready! <span class="step-badge">Step 4 of 4</span></h2>
      <p class="step-sub">Listen to your AI-generated voiceover below</p>

      <div class="audio-card">
        <div style="font-size:3rem;margin-bottom:8px;">🎙️</div>
        <div style="font-size:15px;font-weight:700;color:#111827;margin-bottom:4px;" id="resultTopic">Your Voiceover</div>
        <div style="font-size:13px;color:#9ca3af;margin-bottom:16px;" id="resultVoiceLabel">AI Voice</div>
        <audio id="resultAudio" controls style="width:100%;border-radius:10px;margin-bottom:20px;"></audio>

        <button class="btn-download" id="downloadBtn" onclick="downloadAudio()">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download MP3
        </button>

        <div id="paywallMsg" class="paywall-msg">
          🔒 Download requires a Pro subscription.
          <a href="/subscription" style="color:#92400e;font-weight:700;text-decoration:underline;margin-left:4px;">Upgrade to Pro →</a>
        </div>
      </div>

      <div style="text-align:center;margin-top:28px;">
        <a href="/tts" style="font-size:14px;color:#7c3aed;font-weight:600;text-decoration:none;">
          + Create Another Voiceover
        </a>
      </div>
    </div>

  </div><!-- /max-width -->
</div><!-- /tts-wizard -->

<script>
let S = { step: 1, topic: '', voice: 'alloy', ttsId: null };

// ── Icon constants ─────────────────────────────────────────────────────────
const PLAY_ICON  = `<svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>`;
const PAUSE_ICON = `<svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>`;
const SPIN_ICON  = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:spin 1s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`;

// ── Voice preview player ────────────────────────────────────────────────────
let _activeAudio = null, _activeBtn = null;
function _resetBtn(btn) { if (btn) btn.innerHTML = PLAY_ICON; }

function playVoice(voice, btn) {
  if (_activeAudio && _activeBtn === btn) {
    _activeAudio.pause(); _activeAudio = null; _activeBtn = null; _resetBtn(btn); return;
  }
  if (_activeAudio) { _activeAudio.pause(); _resetBtn(_activeBtn); }
  btn.innerHTML = SPIN_ICON; _activeBtn = btn;
  const audio = new Audio(`/reels/voice-preview/${voice}`);
  _activeAudio = audio;
  audio.oncanplaythrough = () => { if (_activeAudio !== audio) return; btn.innerHTML = PAUSE_ICON; audio.play(); };
  audio.onended  = () => { _resetBtn(btn); _activeAudio = null; _activeBtn = null; };
  audio.onerror  = () => { _resetBtn(btn); _activeAudio = null; _activeBtn = null; };
  audio.load();
}

// ── Navigation ──────────────────────────────────────────────────────────────
function updProg(n) {
  for (let i = 0; i < 4; i++)
    document.getElementById('seg' + i).classList.toggle('done', i < n);
}

function go(n) {
  document.getElementById('step-' + S.step).style.display = 'none';
  S.step = n;
  document.getElementById('step-' + n).style.display = 'block';
  updProg(n);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── Step 1 helpers ──────────────────────────────────────────────────────────
function sTab(panel) {
  document.getElementById('p1a').style.display = panel === 'a' ? 'block' : 'none';
  document.getElementById('p1b').style.display = panel === 'b' ? 'block' : 'none';
  document.getElementById('t1a').classList.toggle('active', panel === 'a');
  document.getElementById('t1b').classList.toggle('active', panel === 'b');
}

function pickTopic(t) {
  document.querySelectorAll('.niche-item').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-niche="' + t + '"]').classList.add('selected');
  S.topic = t; hideErr('s1err');
}

function pickVoice(v) {
  document.querySelectorAll('.voice-item').forEach(el => el.classList.remove('selected'));
  document.querySelector('[data-voice="' + v + '"]').classList.add('selected');
  S.voice = v;
}

function cc(inputId, countId, max) {
  document.getElementById(countId).textContent = document.getElementById(inputId).value.length + '/' + max;
}

function showErr(id, msg) { const el = document.getElementById(id); el.textContent = msg; el.style.display = 'block'; }
function hideErr(id)       { const el = document.getElementById(id); if (el) el.style.display = 'none'; }

// ── Modal ───────────────────────────────────────────────────────────────────
function openModal() {
  const script = document.getElementById('scriptTxt').value.trim();
  if (!script || script.length < 10) { showErr('s2err', 'Script is too short. Please write or generate a script first.'); return; }
  hideErr('s2err');
  document.getElementById('ttsModal').style.display = 'flex';
}
function closeModal() { document.getElementById('ttsModal').style.display = 'none'; }
function confirmGenerate() { closeModal(); go(3); }

// ── Generate Script (Step 1 → 2) ────────────────────────────────────────────
async function generateScript() {
  const isCustom = document.getElementById('p1b').style.display !== 'none';
  if (isCustom) {
    S.topic = document.getElementById('customTopic').value.trim();
    if (!S.topic || S.topic.length < 3) { showErr('s1err', 'Please describe your topic (at least 3 characters).'); return; }
  } else if (!S.topic) {
    showErr('s1err', 'Please select a topic to continue.'); return;
  }
  hideErr('s1err');

  const btn = document.getElementById('genScriptBtn');
  document.getElementById('genScriptTxt').textContent = 'Generating…';
  document.getElementById('genScriptIco').innerHTML = SPIN_ICON;
  btn.disabled = true;

  try {
    const res  = await fetch('/tts/generate-script', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ topic: S.topic }),
    });
    const data = await res.json();
    if (!res.ok || data.error) throw new Error(data.error || 'Failed to generate script.');

    document.getElementById('scriptTxt').value = data.script;
    cc('scriptTxt', 'cc2', 5000);
    go(2);
  } catch (err) {
    showErr('s1err', err.message);
  } finally {
    document.getElementById('genScriptTxt').textContent = 'Generate Script';
    document.getElementById('genScriptIco').innerHTML = `<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>`;
    btn.disabled = false;
  }
}

// ── Generate Audio (Step 3 → 4) ─────────────────────────────────────────────
async function generateAudio() {
  const script = document.getElementById('scriptTxt').value.trim();
  if (!script) { return; }

  const btn = document.getElementById('genAudioBtn');
  document.getElementById('genAudioTxt').textContent = 'Generating…';
  document.getElementById('genAudioIco').innerHTML = SPIN_ICON;
  btn.disabled = true;

  try {
    const res  = await fetch('/tts/generate-audio', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ script, voice: S.voice }),
    });
    const data = await res.json();
    if (!res.ok || data.error) throw new Error(data.error || 'Failed to generate audio.');

    S.ttsId = data.tts_id;
    document.getElementById('resultAudio').src   = data.audio_url;
    document.getElementById('resultTopic').textContent = S.topic || 'Your Voiceover';
    document.getElementById('resultVoiceLabel').textContent = 'Voice: ' + S.voice.charAt(0).toUpperCase() + S.voice.slice(1);
    go(4);
  } catch (err) {
    showErr('s2err', err.message);
    go(2);
  } finally {
    document.getElementById('genAudioTxt').textContent = 'Generate Audio';
    document.getElementById('genAudioIco').innerHTML = `<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>`;
    btn.disabled = false;
  }
}

// ── Download ─────────────────────────────────────────────────────────────────
async function downloadAudio() {
  if (!S.ttsId) return;
  const btn = document.getElementById('downloadBtn');
  btn.disabled = true;
  document.getElementById('paywallMsg').style.display = 'none';

  try {
    const res = await fetch(`/tts/audio/${S.ttsId}/download`);
    if (res.status === 403) {
      document.getElementById('paywallMsg').style.display = 'block';
      return;
    }
    if (!res.ok) throw new Error('Download failed.');
    // Trigger browser download
    const blob = await res.blob();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = `smrai-voice-${S.ttsId}.mp3`; a.click();
    URL.revokeObjectURL(url);
  } catch (err) {
    alert(err.message);
  } finally {
    btn.disabled = false;
  }
}

// Init
updProg(1);
</script>

