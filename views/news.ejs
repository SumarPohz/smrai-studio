<%- include("partials/header") %>

<style>
.news-page { min-height: 100vh; background: #e2e5ea; position: relative; overflow: hidden; padding: 80px 20px 60px; font-family: 'Segoe UI', system-ui, sans-serif; }

/* ── Animated BG ── */
.contact-bg { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
.contact-bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); animation: orbFloat 8s ease-in-out infinite; }
.contact-bg-orb:nth-child(1) { width: 500px; height: 500px; background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%); top: -100px; left: -100px; animation-delay: 0s; }
.contact-bg-orb:nth-child(2) { width: 400px; height: 400px; background: radial-gradient(circle, rgba(168,85,247,0.14) 0%, transparent 70%); top: 30%; right: -80px; animation-delay: -3s; }
.contact-bg-orb:nth-child(3) { width: 350px; height: 350px; background: radial-gradient(circle, rgba(236,72,153,0.1) 0%, transparent 70%); bottom: -50px; left: 30%; animation-delay: -5s; }
.contact-bg-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(99,102,241,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,0.05) 1px, transparent 1px); background-size: 50px 50px; }
@keyframes orbFloat { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-30px) scale(1.05)} }

/* ── Wrapper ── */
.news-wrapper { max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }

/* ── Header ── */
.news-header { text-align: center; margin-bottom: 44px; }
.news-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.25); border-radius: 50px; padding: 6px 16px; font-size: 13px; color: #4f46e5; margin-bottom: 20px; }
.news-header h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; color: #111827; margin: 0 0 16px; line-height: 1.1; }
.news-header p { color: #4b5563; font-size: 1.05rem; max-width: 500px; margin: 0 auto; }

/* ── Timeline ── */
.news-timeline { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px; }
.news-item { background: #1e2030; border: 1px solid rgba(255,255,255,0.08); border-radius: 18px; padding: 22px 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.15); display: flex; gap: 18px; align-items: flex-start; transition: all 0.3s; }
.news-item:hover { background: #252840; border-color: rgba(99,102,241,0.35); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(99,102,241,0.12); }
.news-dot { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; margin-top: 2px; }
.news-dot.purple { background: rgba(99,102,241,0.2); }
.news-dot.green  { background: rgba(34,197,94,0.2); }
.news-dot.blue   { background: rgba(59,130,246,0.2); }
.news-dot.pink   { background: rgba(236,72,153,0.2); }
.news-dot.orange { background: rgba(251,146,60,0.2); }
.news-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; flex-wrap: wrap; }
.news-date { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #64748b; font-weight: 600; }
.news-tag { font-size: 10px; padding: 2px 10px; border-radius: 20px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; }
.news-tag.launch  { background: rgba(99,102,241,0.15); color: #818cf8; border: 1px solid rgba(99,102,241,0.25); }
.news-tag.feature { background: rgba(34,197,94,0.12); color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
.news-tag.update  { background: rgba(59,130,246,0.12); color: #60a5fa; border: 1px solid rgba(59,130,246,0.25); }
.news-tag.coming  { background: rgba(251,146,60,0.12); color: #fb923c; border: 1px solid rgba(251,146,60,0.25); }
.news-item h3 { font-size: 1rem; font-weight: 700; color: #f1f5f9; margin: 0 0 6px; }
.news-item p  { color: #94a3b8; font-size: 0.87rem; line-height: 1.6; margin: 0; }

/* ── Upcoming Card ── */
.upcoming-card { background: #1e2030; border: 1px solid rgba(99,102,241,0.2); border-radius: 20px; padding: 24px 28px; box-shadow: 0 2px 12px rgba(0,0,0,0.15); margin-bottom: 24px; }
.upcoming-card h2 { font-size: 1.05rem; font-weight: 700; color: #f1f5f9; margin: 0 0 16px; display: flex; align-items: center; gap: 8px; }
.upcoming-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
.upcoming-item { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 10px; padding: 10px 14px; color: #94a3b8; font-size: 0.83rem; display: flex; align-items: center; gap: 8px; }
@media(max-width:600px){ .upcoming-grid { grid-template-columns: 1fr 1fr; } }
@media(max-width:400px){ .upcoming-grid { grid-template-columns: 1fr; } }

/* ── Follow Strip ── */
.follow-strip { background: #1e2030; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 18px 22px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; box-shadow: 0 2px 12px rgba(0,0,0,0.15); }
.follow-strip p { color: #94a3b8; font-size: 0.88rem; margin: 0; }
.follow-links { display: flex; gap: 8px; flex-wrap: wrap; }
.follow-link { display: flex; align-items: center; gap: 7px; padding: 6px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: #94a3b8; text-decoration: none; font-size: 12px; transition: all 0.25s; }
.follow-link:hover { color: #fff; border-color: rgba(99,102,241,0.5); background: rgba(99,102,241,0.12); }

@media(max-width:768px){
  .news-page { padding: 50px 12px 30px; }
  .news-header { margin-bottom: 28px; }
  .news-item { padding: 12px 10px; gap: 8px; }
  .news-dot { width: 28px; height: 28px; font-size: 13px; border-radius: 8px; flex-shrink: 0; }
  .news-meta { gap: 6px; margin-bottom: 4px; }
  .news-date { font-size: 9px; }
  .news-tag { font-size: 9px; padding: 2px 7px; }
  .news-item h3 { font-size: 0.82rem; margin-bottom: 4px; }
  .news-item p { font-size: 0.76rem; line-height: 1.5; }
  .upcoming-card { padding: 14px; }
  .follow-strip { flex-direction: column; align-items: flex-start; }
}
@media(max-width:480px){ .news-timeline { grid-template-columns: 1fr 1fr; gap: 10px; } }
</style>

