    <!-- Pro -->
    <div class="pricing-card featured">
      <div class="featured-badge">Most Popular</div>
      <div class="card-icon">⚡</div>
      <div class="card-name">Magic Live Pro</div>
      <div class="card-tagline">For serious streamers & creators</div>
      <div class="card-price"><sup>₹</sup>99<span class="per">/month</span></div>
      <div class="card-note">or ₹149 for 30 days — billed via wallet</div>
      <ul class="card-features">
        <li><span class="chk">✓</span> Everything in Free</li>
        <li><span class="chk">✓</span> All 6 premium font styles</li>
        <li><span class="chk">✓</span> All 4 animation styles (incl. Handwriting)</li>
        <li><span class="chk">✓</span> Auto-show mode (no clicks needed)</li>
        <li><span class="chk">✓</span> Priority name queue</li>
        <li><span class="chk">✓</span> Custom animation speed</li>
        <li><span class="chk">✓</span> Remove "Powered by SmrAI" branding</li>
      </ul>
      <a href="/subscription" class="card-btn primary">Upgrade to Pro →</a>
    </div>

  </div>



</div>

<%- include("partials/footer") %>
