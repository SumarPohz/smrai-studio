<%- include("partials/header") %>

<style>
/* ── Reset & Base ── */
.contact-page { min-height: 100vh; background: #f1f3f6; position: relative; overflow: hidden; padding: 80px 20px 60px; font-family: 'Segoe UI', system-ui, sans-serif; }

/* ── Animated BG ── */
.contact-bg { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
.contact-bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); animation: orbFloat 8s ease-in-out infinite; }
.contact-bg-orb:nth-child(1) { width: 500px; height: 500px; background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%); top: -100px; left: -100px; animation-delay: 0s; }
.contact-bg-orb:nth-child(2) { width: 400px; height: 400px; background: radial-gradient(circle, rgba(168,85,247,0.14) 0%, transparent 70%); top: 30%; right: -80px; animation-delay: -3s; }
.contact-bg-orb:nth-child(3) { width: 350px; height: 350px; background: radial-gradient(circle, rgba(236,72,153,0.1) 0%, transparent 70%); bottom: -50px; left: 30%; animation-delay: -5s; }
.contact-bg-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(99,102,241,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,0.05) 1px, transparent 1px); background-size: 50px 50px; }
@keyframes orbFloat { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-30px) scale(1.05)} }

/* ── Layout ── */
.contact-wrapper { max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }

/* ── Header ── */
.contact-header { text-align: center; margin-bottom: 60px; }
.contact-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(99,102,241,0.15); border: 1px solid rgba(99,102,241,0.3); border-radius: 50px; padding: 6px 16px; font-size: 13px; color: #a5b4fc; margin-bottom: 20px; }
.contact-header h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; background: linear-gradient(135deg, #fff 0%, #a5b4fc 50%, #e879f9 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin: 0 0 16px; line-height: 1.1; }
.contact-header p { color: #94a3b8; font-size: 1.1rem; max-width: 500px; margin: 0 auto; }

/* ── Grid ── */
.contact-grid { display: grid; grid-template-columns: 1fr 1.6fr; gap: 32px; align-items: start; }
@media(max-width:768px){ .contact-grid { grid-template-columns: 1fr; } }

/* ── Info Cards ── */
.contact-info { display: flex; flex-direction: column; gap: 16px; }
.info-cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.info-card { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 16px; padding: 16px; display: flex; align-items: flex-start; gap: 12px; transition: all 0.3s; }
.info-card:hover { background: rgba(99,102,241,0.1); border-color: rgba(99,102,241,0.3); transform: translateY(-2px); }
.info-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
.info-icon.purple { background: rgba(99,102,241,0.2); }
.info-icon.pink { background: rgba(236,72,153,0.2); }
.info-icon.blue { background: rgba(59,130,246,0.2); }
.info-icon.green { background: rgba(34,197,94,0.2); }
.info-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #64748b; margin-bottom: 3px; }
.info-value { color: #e2e8f0; font-size: 0.85rem; font-weight: 500; line-height: 1.3; }
.info-sub { color: #64748b; font-size: 0.75rem; margin-top: 2px; }
@media(max-width:768px){ .info-cards-grid { grid-template-columns: 1fr 1fr; } }
@media(max-width:400px){ .info-cards-grid { grid-template-columns: 1fr; } }

/* ── Social Strip ── */
.social-strip { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 20px; }
.social-strip h4 { color: #94a3b8; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 14px; }
.social-links { display: flex; gap: 10px; flex-wrap: wrap; }
.social-link { display: flex; align-items: center; gap: 8px; padding: 8px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); color: #94a3b8; text-decoration: none; font-size: 13px; transition: all 0.25s; }
.social-link:hover { color: #fff; border-color: rgba(99,102,241,0.5); background: rgba(99,102,241,0.12); transform: translateY(-1px); }

/* ── Form Card ── */
.form-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 24px; padding: 40px; backdrop-filter: blur(12px); }
.form-card h2 { font-size: 1.5rem; font-weight: 700; color: #f1f5f9; margin: 0 0 8px; }
.form-card p { color: #64748b; font-size: 0.9rem; margin: 0 0 28px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media(max-width:500px){ .form-row { grid-template-columns: 1fr; } }

.form-group { margin-bottom: 18px; }
.form-group label { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.8px; color: #64748b; margin-bottom: 8px; font-weight: 600; }
.form-group input,
.form-group select,
.form-group textarea { width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; padding: 12px 16px; color: #f1f5f9; font-size: 0.95rem; outline: none; transition: all 0.25s; box-sizing: border-box; font-family: inherit; }
.form-group input::placeholder,
.form-group textarea::placeholder { color: #475569; }
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { border-color: rgba(99,102,241,0.6); background: rgba(99,102,241,0.06); box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
.form-group select option { background: #1e1e2e; color: #f1f5f9; }
.form-group textarea { resize: vertical; min-height: 120px; }

/* ── Submit Button ── */
.btn-send { width: 100%; padding: 14px 24px; border: none; border-radius: 12px; background: linear-gradient(135deg, #6366f1, #a855f7); color: #fff; font-size: 1rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; transition: all 0.3s; position: relative; overflow: hidden; letter-spacing: 0.3px; }
.btn-send::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, #818cf8, #c084fc); opacity: 0; transition: opacity 0.3s; }
.btn-send:hover::before { opacity: 1; }
.btn-send:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(99,102,241,0.4); }
.btn-send:active { transform: translateY(0); }
.btn-send span, .btn-send svg { position: relative; z-index: 1; }
.btn-send.loading { pointer-events: none; opacity: 0.8; }

/* ── Toast ── */
.contact-toast { position: fixed; bottom: 30px; right: 30px; z-index: 9999; padding: 14px 22px; border-radius: 14px; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 10px; transform: translateY(100px); opacity: 0; transition: all 0.4s cubic-bezier(0.34,1.56,0.64,1); max-width: 340px; box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
.contact-toast.show { transform: translateY(0); opacity: 1; }
.contact-toast.success { background: linear-gradient(135deg, #059669, #10b981); color: #fff; }
.contact-toast.error { background: linear-gradient(135deg, #dc2626, #ef4444); color: #fff; }

/* ── Flash Messages ── */
.contact-flash { padding: 14px 20px; border-radius: 12px; margin-bottom: 20px; font-size: 0.9rem; display: flex; align-items: center; gap: 10px; }
.contact-flash.success { background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3); color: #6ee7b7; }
.contact-flash.error { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
</style>

<!-- Animated Background -->
<div class="contact-bg">
  <div class="contact-bg-grid"></div>
  <div class="contact-bg-orb"></div>
  <div class="contact-bg-orb"></div>
  <div class="contact-bg-orb"></div>
</div>

<div class="contact-page">
  <div class="contact-wrapper">

    <!-- Header -->
    <div class="contact-header">
      <div class="contact-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Get in touch
      </div>
      <h1>We'd love to hear<br>from you</h1>
      <p>Have a question, feedback, or partnership idea? Drop us a message and we'll get back to you.</p>
    </div>

    <!-- Grid -->
    <div class="contact-grid">

      <!-- Left: Info -->
      <div class="contact-info">

        <div class="info-cards-grid">
          <div class="info-card">
            <div class="info-icon purple">📧</div>
            <div>
              <div class="info-label">Email</div>
              <div class="info-value">tech@sumarpohz.com</div>
              <div class="info-sub">Reply within 24h</div>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon blue">🕐</div>
            <div>
              <div class="info-label">Office Hours</div>
              <div class="info-value">Mon – Fri 10AM–6PM</div>
              <div class="info-sub">IST</div>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon green">📍</div>
            <div>
              <div class="info-label">Location</div>
              <div class="info-value">India</div>
              <div class="info-sub">Remote-first team</div>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon pink">⚡</div>
            <div>
              <div class="info-label">Response Time</div>
              <div class="info-value">Within 24h</div>
              <div class="info-sub">Business days only</div>
            </div>
          </div>
        </div>

        <div class="social-strip">
          <h4>Find us online</h4>
          <div class="social-links">
            <a href="#" class="social-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
              Twitter
            </a>
            <a href="#" class="social-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
            <a href="#" class="social-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              Instagram
            </a>
          </div>
        </div>

      </div>

      <!-- Right: Form -->
      <div class="form-card">
        <h2>Send us a message</h2>
        <p>Fill out the form below and our team will respond promptly.</p>

        <% if (locals.contactSuccess) { %>
          <div class="contact-flash success">✅ Message sent! We'll get back to you within 24 hours.</div>
        <% } %>
        <% if (locals.contactError) { %>
          <div class="contact-flash error">❌ <%= locals.contactError %></div>
        <% } %>

        <form id="contactForm" action="/contact" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label>Your Name</label>
              <input type="text" name="name" placeholder="John Doe" required value="<%= locals.user ? locals.user.name || '' : '' %>">
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" name="email" placeholder="john@example.com" required value="<%= locals.user ? locals.user.email || '' : '' %>">
            </div>
          </div>

          <div class="form-group">
            <label>Subject</label>
            <select name="subject">
              <option value="General Inquiry">General Inquiry</option>
              <option value="Technical Support">Technical Support</option>
              <option value="Billing & Payments">Billing & Payments</option>
              <option value="Partnership / Business">Partnership / Business</option>
              <option value="Bug Report">Bug Report</option>
              <option value="Feature Request">Feature Request</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label>Message</label>
            <textarea name="message" placeholder="Tell us how we can help you..." required></textarea>
          </div>

          <button type="submit" class="btn-send" id="sendBtn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            <span>Send Message</span>
          </button>
        </form>
      </div>

    </div>
  </div>
</div>

<!-- Toast -->
<div class="contact-toast" id="contactToast"></div>

<script>
// Auto-show flash toast
(function(){
  <% if (locals.contactSuccess) { %>
    showContactToast('Message sent! We\'ll reply within 24 hours.', 'success');
  <% } else if (locals.contactError) { %>
    showContactToast('<%= locals.contactError %>', 'error');
  <% } %>

  function showContactToast(msg, type) {
    const t = document.getElementById('contactToast');
    t.textContent = (type === 'success' ? '✅ ' : '❌ ') + msg;
    t.className = 'contact-toast ' + type + ' show';
    setTimeout(() => t.classList.remove('show'), 4000);
  }

  // Loading state on submit
  document.getElementById('contactForm').addEventListener('submit', function(){
    const btn = document.getElementById('sendBtn');
    btn.classList.add('loading');
    btn.querySelector('span').textContent = 'Sending...';
  });
})();
</script>

<%- include("partials/footer") %>
