    gap: 1.5rem;
    align-items: flex-start;
  }

  .builder-left {
    flex: 1.2;
    min-width: 0;
  }

  .builder-right {
    flex: 1;
    min-width: 280px;
    position: sticky;
    top: 5.5rem;
  }

  .rb-step {
    display: none;
    background: #ffffff;
    padding: 1.8rem 2.2rem;
    border-radius: 18px;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.12);
    margin: 0 auto 0;
  }

  .rb-step + .rb-step {
    margin-top: 1.8rem;
  }

  .rb-step.active {
    display: block;
    animation: rbFadeIn 0.18s ease-out;
  }

  @keyframes rbFadeIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .rb-step-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 0.5rem;
    text-align: left;
  }

