    margin-bottom: 1.1rem;
    line-height: 1.6;
    text-align: left;
  }

  .rb-grid-2 {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem 1.25rem;
  }

  .rb-field {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .rb-field-full {
    grid-column: 1 / -1;
  }

  .rb-field-hint {
    font-size: 0.78rem;
