}

/* ── Field-level mic button ──────────────────────────────────── */
.ai-mic-field-btn {
  border: 1px solid #e5e7eb;
  background: #f9fafb;
  color: #6b7280;
  font-size: 0.78rem;
  padding: 0.22rem 0.42rem;
  border-radius: 999px;
  cursor: pointer;
  line-height: 1;
  transition: background 0.15s, color 0.15s, border-color 0.15s, box-shadow 0.15s;
