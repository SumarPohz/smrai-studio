<%- include("partials/header") %>
<%
  // For admin-created templates: check if a section is enabled.
  // templateSections is array of {section_key, is_enabled} passed from GET /resume-builder.
  // If null/undefined (static template), all sections are enabled.
  function isSectionEnabled(key) {
    if (!templateSections || !Array.isArray(templateSections)) return true;
    const sec = templateSections.find(s => s.section_key === key);
    return sec ? sec.is_enabled : false;
  }
%>

<section class="builder-section">
  <div class="builder-header-row">
    <div>
      <h1>Resume Builder</h1>
      <p class="section-subtitle">
        Using template: <strong><%= template %></strong>
        &nbsp;·&nbsp;
        <a href="/resume-templates">Change template</a>
      </p>
    </div>
    <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">
      <button type="button" id="aiInterviewBtn" class="btn-ai-interview">
        🎤 AI Interview Mode
      </button>
      <div class="builder-hint-pill">
        Step <span id="rbStepCounter">1</span> of 4
      </div>
    </div>
  </div>

  <!-- ===== AI INTERVIEW MODAL ===== -->
  <div id="aiInterviewModal" class="ai-modal-overlay" style="display:none;" aria-modal="true" role="dialog">
    <div class="ai-modal">
      <div class="ai-modal-header">
        <div>
          <h2 class="ai-modal-title">🎤 AI Interview Mode</h2>
          <p class="ai-modal-subtitle">Answer a few questions and we'll build your resume automatically.</p>
        </div>
        <button type="button" id="aiModalClose" class="ai-modal-close" aria-label="Close">&times;</button>
      </div>

      <!-- Chat area -->
      <div id="aiChatArea" class="ai-chat-area"></div>

      <!-- Input row -->
      <div id="aiInputRow" class="ai-input-row">
        <div class="ai-input-wrapper">
          <input type="text" id="aiAnswerInput" class="ai-answer-input" placeholder="Type your answer..." autocomplete="off" />
          <button type="button" id="aiMicBtn" class="ai-mic-btn" title="Speak your answer" aria-label="Speak your answer">🎤</button>
        </div>
        <button type="button" id="aiSendBtn" class="btn-primary">Send →</button>
      </div>
      <div id="aiMicStatus" class="ai-mic-listening"></div>

      <!-- Generate button (shown after Q&A for non-photo templates) -->
      <div id="aiGenerateRow" class="ai-generate-row" style="display:none;">
        <button type="button" id="aiGenerateBtn" class="btn-primary ai-generate-btn">
          ✨ Generate My Resume
        </button>
      </div>

      <!-- Photo step (shown after Q&A for photo-supporting templates) -->
      <div id="aiPhotoStep" class="ai-photo-step" style="display:none;">
        <input type="file" id="aiPhotoInput" accept="image/*" style="display:none;" />

        <!-- Initial: choose or skip -->
        <div id="aiPhotoInitial" class="ai-photo-initial">
          <button type="button" id="aiPhotoChooseBtn" class="btn-primary ai-photo-choose-btn">
            📷 Upload Photo
          </button>
          <button type="button" id="aiPhotoSkipBtn" class="ai-photo-skip-link">
            Skip — no photo
          </button>
        </div>

        <!-- Cropper panel (shown after file selected) -->
        <div id="aiCropPanel" class="ai-crop-panel" style="display:none;">
          <div class="ai-crop-frame">
            <img id="aiCropImg" src="" alt="Crop preview" />
          </div>
          <div class="ai-crop-actions">
            <button type="button" id="aiCropConfirmBtn" class="btn-primary">✓ Use This Photo</button>
            <button type="button" id="aiCropRetryBtn" class="ai-photo-skip-link">↩ Choose Different</button>
          </div>
        </div>

        <!-- After crop confirmed: thumbnail + generate -->
        <div id="aiPhotoDoneArea" style="display:none;">
          <div class="ai-photo-done-row">
            <img id="aiPhotoThumb" src="" class="ai-photo-thumb" alt="Profile photo" />
            <span class="ai-photo-done-label">Photo ready ✓</span>
            <button type="button" id="aiPhotoRedo" class="ai-photo-skip-link">Change</button>
          </div>
          <button type="button" id="aiPhotoGenBtn" class="btn-primary ai-generate-btn">
            ✨ Generate My Resume
          </button>
        </div>
      </div>

      <!-- Status -->
      <div id="aiModalStatus" class="ai-modal-status"></div>
    </div>
  </div>

  <div class="builder-main">
    <!-- LEFT: FORM -->
    <div class="builder-left">
      <form
          id="resumeBuilderForm"
          action="/resume-builder/preview"
          method="POST"
          novalidate
        >
        <input type="hidden" name="template" value="<%= template %>">
          <input
            type="hidden"
            name="resumeId"
            id="resumeId"
            value="<%= typeof resumeId !== 'undefined' && resumeId ? resumeId : '' %>"
          >
          <input type="hidden" name="experienceLevel" id="experienceLevelInput" value="experienced">

        <!-- STEP 1: YOUR DETAILS -->
        <div class="rb-step active" data-step="1">
          <h2 class="rb-step-title">Your Details</h2>
          <p class="rb-step-subtitle">
            Start with your basic information. We’ll reuse these details across all templates.
          </p>

          <div class="rb-grid-2">
            <div class="rb-field">
              <label for="fullName">Full Name<span class="req">*</span></label>
              <input
                type="text"
                id="fullName"
                name="fullName"
                required
                value="<%= (draft && draft.fullName) || (profile && profile.full_name) || '' %>"
              />
            </div>

            <div class="rb-field">
              <label for="roleTitle">Job Title<span class="req">*</span></label>
              <input
                type="text"
                id="roleTitle"
                name="roleTitle"
                placeholder="e.g. Account Support Coordinator"
                value="<%= (draft && draft.roleTitle) || (profile && profile.role_title) || '' %>"
              />
            </div>

            <div class="rb-field">
              <label for="email">Email Address<span class="req">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                value="<%= (draft && draft.email) || (profile && profile.email) || (user && user.email) || '' %>"
              />
            </div>

            <div class="rb-field">
              <label for="phone">Mobile No.<span class="req">*</span></label>
              <input
                type="text"
                id="phone"
                name="phone"
                required
                value="<%= (draft && draft.phone) || (profile && profile.phone) || '' %>"
              />
            </div>


            <div class="rb-field">
              <label for="location">Location<span class="req">*</span></label>
              <input
                type="text"
                id="location"
                name="location"
                placeholder="Bangalore, Karnataka"
                value="<%= (draft && draft.location) || (profile && profile.location) || '' %>"
              />
            </div>

            <div class="rb-field">
              <label for="zipCode">ZIP / Postal Code</label>
              <input
                type="text"
                id="zipCode"
                name="zipCode"
                placeholder="560001"
                value="<%= (draft && draft.zipCode) || '' %>"
              />
            </div>

<% const _existingPhoto = (draft && draft.profileImageUrl) || (profile && profile.profile_image_url) || ''; %>
<% if (isPhotoTpl) { %>
            <!-- Photo upload widget (photo-supporting templates only) -->
            <div class="rb-field rb-photo-field">
              <label>Profile Photo <span class="rb-photo-badge">Recommended</span></label>
              <input type="file" id="photoFileInput" accept="image/*" style="display:none;" />
              <input type="hidden" name="profileImageUrl" id="profileImageUrl"
                     value="<%= _existingPhoto %>" />
              <div class="photo-preview-wrap">
                <img id="photoPreviewImg"
                     src="<%= _existingPhoto %>"
                     class="photo-preview-img<%= _existingPhoto ? '' : ' ph-hidden' %>"
                     alt="Profile photo" />
                <div id="photoPlaceholder"
                     class="photo-preview-placeholder<%= _existingPhoto ? ' ph-hidden' : '' %>">
                  <span>No photo</span>
                </div>
              </div>
              <div class="photo-upload-btns">
                <button type="button" id="photoUploadTrigger" class="btn-photo-action">
                  📷 Upload Photo
                </button>
                <button type="button" id="photoRemoveBtn"
                        class="btn-photo-action btn-photo-remove<%= _existingPhoto ? '' : ' ph-hidden' %>">
                  Remove
                </button>
              </div>
              <p class="rb-field-hint">Square photo · JPG or PNG · min 200×200px</p>
            </div>
<% } %>
          </div>
        </div>

        <!-- STEP 2: SUMMARY -->
        <% if (isSectionEnabled('summary')) { %>
        <div class="rb-step" data-step="2">
          <h2 class="rb-step-title">Professional Summary</h2>
          <p class="rb-step-subtitle">
            Write 3–5 lines about your professional background, strengths, and the value you bring.
            This section appears at the top of your resume.
          </p> 

          <div class="rb-field rb-field-full ai-field-wrap">
            <div class="ai-field-label">
              <label for="summary">Professional Summary</label>
              <div class="ai-btn-group">
                <span class="fmic-status" aria-live="polite"></span>
                <button type="button" class="ai-mic-field-btn" data-mic-target="summary" title="Voice input" aria-label="Start voice input for Professional Summary">🎤</button>
                <button type="button" class="ai-btn" data-field="summary">✨ AI Suggest</button>
                <button type="button" class="ai-undo-btn" data-field="summary" disabled>↩ Undo</button>
              </div>
            </div>
            <textarea
              id="summary"
              name="summary"
              rows="7"
              placeholder="Example: A highly motivated and results-oriented professional..."
            ><%= (draft && draft.summary) || (profile && profile.summary) || '' %></textarea>
          </div>
        </div>
        <% } %>

        <!-- STEP 3: EXPERIENCE -->
        <% if (isSectionEnabled('experience')) { %>
        <div class="rb-step" data-step="3">
          <h2 class="rb-step-title">Experience</h2>

          <p class="rb-step-subtitle">
            Describe your roles in your own words — or use 🎤 to speak them.
            Click ✨ AI Suggest and we’ll detect each position and structure them automatically.
          </p>

          <div class="rb-field rb-field-full ai-field-wrap">
            <div class="ai-field-label">
              <label for="experience">Experience</label>
              <div class="ai-btn-group">
                <span class="fmic-status" aria-live="polite"></span>
                <button type="button" class="ai-mic-field-btn" data-mic-target="experience" title="Voice input" aria-label="Start voice input for Experience">🎤</button>
                <button type="button" class="ai-btn" data-field="experience">✨ AI Suggest</button>
                <button type="button" class="ai-undo-btn" data-field="experience" disabled>↩ Undo</button>
              </div>
            </div>
            <textarea
              id="experience"
              name="experience"
              rows="10"
              placeholder="e.g. I worked as a Security Supervisor at ACPS, Delhi, India from 2020 to present. I managed a team of 10 officers and reduced incidents by 30%..."
><% {
              var _rawExp = (draft && draft.experience) || (profile && profile.experience) || '';
              var _expText = '';
              if (Array.isArray(_rawExp)) {
                _expText = _rawExp.map(function(e){
                  var parts = [];
                  if (e.title || e.company) parts.push((e.title||'') + (e.company?' at '+e.company:'') + (e.dates?' ('+e.dates+')':''));
                  if (e.description) parts.push(e.description);
                  return parts.join('\n');
                }).join('\n\n');
              } else {
                _expText = String(_rawExp || '');
              }
            } %><%= _expText %></textarea>
            <% if (Array.isArray(draft && draft.experience)) { %>
            <input type="hidden" name="experienceJson" id="experienceJson" value="<%= JSON.stringify(draft.experience) %>">
            <% } %>
          </div>
        </div>
        <% } %>

        <!-- STEP 4: EDUCATION, LANGUAGES, SKILLS -->
        <% if (isSectionEnabled('education') || isSectionEnabled('skills') || isSectionEnabled('languages')) { %>
        <div class="rb-step" data-step="4">
          <h2 class="rb-step-title">Education, Languages &amp; Skills</h2>
          <p class="rb-step-subtitle">
            Add your education details, languages, and key skills. For skills you can again
            use one line per skill – we’ll show them as bullet points.
          </p>

          <div class="rb-grid-2">
            <div class="rb-field rb-field-full ai-field-wrap">
              <div class="ai-field-label">
                <label for="education">Education</label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-mic-field-btn" data-mic-target="education" title="Voice input" aria-label="Start voice input for Education">🎤</button>
                  <button type="button" class="ai-btn" data-field="education">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="education" disabled>↩ Undo</button>
                </div>
              </div>
              <textarea
                id="education"
                name="education"
                rows="4"
              ><%= (draft && draft.education) || '' %></textarea>
            </div>

            <div class="rb-field ai-field-wrap">
              <div class="ai-field-label">
                <label for="languages">Languages</label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-mic-field-btn" data-mic-target="languages" title="Voice input" aria-label="Start voice input for Languages">🎤</button>
                  <button type="button" class="ai-btn" data-field="languages">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="languages" disabled>↩ Undo</button>
                </div>
              </div>
              <textarea
                id="languages"
                name="languages"
                rows="4"
              ><%= (draft && draft.languages) || '' %></textarea>
            </div>

            <% if (template === 'bold-sidebar' || template === 'creative-gradient' || (template !== 'photo-resume' && isSectionEnabled('references'))) { %>
            <div class="rb-field ai-field-wrap">
              <div class="ai-field-label">
                <label for="references">References <span style="font-weight:400;color:#6b7280;font-size:0.85em;">(optional)</span></label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-mic-field-btn" data-mic-target="references" title="Voice input" aria-label="Start voice input for References">🎤</button>
                  <button type="button" class="ai-btn" data-field="references">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="references" disabled>↩ Undo</button>
                </div>
              </div>
              <p class="rb-field-hint" style="margin:0.2rem 0 0.4rem;font-size:0.82rem;color:#6b7280;">
                Up to 3 referees. Separate each with <code>---</code> on its own line.<br>
                Format per referee: Name → Institution → Phone → Website (one per line).
              </p>
              <textarea
                id="references"
                name="references"
                rows="7"
                placeholder="Rufus Stewart&#10;Borcelle University&#10;+123-456-7890&#10;www.example.com&#10;---&#10;Lorna Alvarado&#10;Borcelle University"
              ><%= (draft && draft.references) || '' %></textarea>
            </div>
            <% } %>

            <div class="rb-field ai-field-wrap">
              <div class="ai-field-label">
                <label for="skills">Skills</label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-mic-field-btn" data-mic-target="skills" title="Voice input" aria-label="Start voice input for Skills">🎤</button>
                  <button type="button" class="ai-btn" data-field="skills">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="skills" disabled>↩ Undo</button>
                </div>
              </div>
              <textarea
                id="skills"
                name="skills"
                rows="4"
              ><%= (draft && draft.skills) || '' %></textarea>
            </div>

            <% if (template === 'tech-focused' || template === 'ats-friendly' || isSectionEnabled('technologies') || isSectionEnabled('projects') || isSectionEnabled('certifications')) { %>

            <% if (template !== 'photo-resume') { %>
            <div class="rb-field ai-field-wrap">
              <div class="ai-field-label">
                <label for="technologies">Technologies / Stack</label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-btn" data-field="technologies">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="technologies" disabled>↩ Undo</button>
                </div>
              </div>
              <p class="rb-field-hint">One category per line — e.g. <em>Frontend: React, TypeScript, Tailwind</em></p>
              <textarea
                id="technologies"
                name="technologies"
                rows="5"
                placeholder="Frontend: React, TypeScript, Tailwind CSS&#10;Backend: Node.js, Python, Express.js&#10;Database: PostgreSQL, MongoDB, Redis&#10;DevOps: Docker, AWS, GitHub Actions&#10;Tools: Git, Postman, Figma"
              ><%= (draft && draft.technologies) || '' %></textarea>
            </div>
            <% } %>

            <% if (template !== 'photo-resume') { %>
            <div class="rb-field ai-field-wrap">
              <div class="ai-field-label">
                <label for="projects">Projects</label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-btn" data-field="projects">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="projects" disabled>↩ Undo</button>
                </div>
              </div>
              <p class="rb-field-hint">Format: <em>Project Name | Tech: React, Node | https://link.com</em> then description on next lines. Blank line to separate projects.</p>
              <textarea
                id="projects"
                name="projects"
                rows="8"
                placeholder="Portfolio Website | Tech: React, Tailwind | github.com/user/portfolio&#10;Built a responsive portfolio with dark mode and animations.&#10;• Deployed on Vercel with CI/CD pipeline&#10;&#10;API Service | Tech: Python, FastAPI | api.myproject.com&#10;REST API for ML sentiment analysis."
              ><%= (draft && draft.projects) || '' %></textarea>
            </div>

            <div class="rb-field">
              <label for="portfolioUrl">Portfolio or LinkedIn URL <span class="rb-badge-qr">→ QR Code</span></label>
              <p class="rb-field-hint">This URL will be converted to a QR code on your resume.</p>
              <input
                type="url"
                id="portfolioUrl"
                name="portfolioUrl"
                placeholder="https://yourportfolio.com  or  https://linkedin.com/in/yourname"
                value="<%= (draft && draft.portfolioUrl) || '' %>"
              />
            </div>

            <div class="rb-field">
              <label for="githubUrl">GitHub Profile URL</label>
              <input
                type="url"
                id="githubUrl"
                name="githubUrl"
                placeholder="https://github.com/yourusername"
                value="<%= (draft && draft.githubUrl) || '' %>"
              />
            </div>
            <% } %>

            <div class="rb-field">
              <label for="linkedinUrl">LinkedIn Profile URL</label>
              <input
                type="url"
                id="linkedinUrl"
                name="linkedinUrl"
                placeholder="https://linkedin.com/in/yourname"
                value="<%= (draft && draft.linkedinUrl) || '' %>"
              />
            </div>

            <div class="rb-field ai-field-wrap">
              <div class="ai-field-label">
                <label for="certifications">Certifications &amp; Achievements <span style="font-weight:400;color:#6b7280;font-size:0.85em;">(optional)</span></label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-mic-field-btn" data-mic-target="certifications" title="Voice input" aria-label="Start voice input for Certifications">🎤</button>
                  <button type="button" class="ai-btn" data-field="certifications">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="certifications" disabled>↩ Undo</button>
                </div>
              </div>
              <textarea
                id="certifications"
                name="certifications"
                rows="4"
                placeholder="AWS Certified Solutions Architect — 2024&#10;Google Professional Cloud Developer — 2023&#10;Meta React Developer Certificate — 2022"
              ><%= (draft && draft.certifications) || '' %></textarea>
            </div>

            <% if (template === 'ats-friendly' || isSectionEnabled('achievements') || isSectionEnabled('awards') || isSectionEnabled('training') || isSectionEnabled('volunteering')) { %>

            <div class="rb-field ai-field-wrap">
              <div class="ai-field-label">
                <label for="achievements">Key Achievements <span style="font-weight:400;color:#6b7280;font-size:0.85em;">(optional)</span></label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-mic-field-btn" data-mic-target="achievements" title="Voice input" aria-label="Start voice input for Achievements">🎤</button>
                  <button type="button" class="ai-btn" data-field="achievements">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="achievements" disabled>↩ Undo</button>
                </div>
              </div>
              <p class="rb-field-hint">One achievement per line. ATS scanners rank resumes higher when key wins are listed.</p>
              <textarea
                id="achievements"
                name="achievements"
                rows="4"
                placeholder="Led migration to microservices, reducing load time by 40%&#10;Open-source library with 2k+ GitHub stars&#10;Promoted to Senior Engineer within 18 months"
              ><%= (draft && draft.achievements) || '' %></textarea>
            </div>

            <% if (template !== 'photo-resume') { %>
            <div class="rb-field ai-field-wrap">
              <div class="ai-field-label">
                <label for="awards">Awards <span style="font-weight:400;color:#6b7280;font-size:0.85em;">(optional)</span></label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-btn" data-field="awards">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="awards" disabled>↩ Undo</button>
                </div>
              </div>
              <p class="rb-field-hint">One award per line — e.g. <em>Dean's List — Cornell 2022</em></p>
              <textarea
                id="awards"
                name="awards"
                rows="3"
                placeholder="Dean's List — Cornell School of Engineering&#10;Hackathon Winner — Google DevFest 2023&#10;Best Final Year Project Award"
              ><%= (draft && draft.awards) || '' %></textarea>
            </div>

            <div class="rb-field ai-field-wrap">
              <div class="ai-field-label">
                <label for="training">Training &amp; Courses <span style="font-weight:400;color:#6b7280;font-size:0.85em;">(optional)</span></label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-btn" data-field="training">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="training" disabled>↩ Undo</button>
                </div>
              </div>
              <p class="rb-field-hint">One course per line — e.g. <em>Machine Learning — Stanford Online, 2023</em></p>
              <textarea
                id="training"
                name="training"
                rows="3"
                placeholder="Full-Stack Web Development — freeCodeCamp, 2023&#10;Machine Learning Specialization — Coursera, 2022&#10;Introduction to Cloud Computing — AWS Training"
              ><%= (draft && draft.training) || '' %></textarea>
            </div>

            <div class="rb-field ai-field-wrap">
              <div class="ai-field-label">
                <label for="volunteering">Volunteering <span style="font-weight:400;color:#6b7280;font-size:0.85em;">(optional)</span></label>
                <div class="ai-btn-group">
                  <span class="fmic-status" aria-live="polite"></span>
                  <button type="button" class="ai-btn" data-field="volunteering">✨ AI Suggest</button>
                  <button type="button" class="ai-undo-btn" data-field="volunteering" disabled>↩ Undo</button>
                </div>
              </div>
              <textarea
                id="volunteering"
                name="volunteering"
                rows="3"
                placeholder="Tech Mentor — Google Developer Student Club (2022–Present)&#10;Open Source Contributor — Mozilla Firefox, reported 3 critical bugs&#10;Code instructor — weekend coding bootcamp for underprivileged youth"
              ><%= (draft && draft.volunteering) || '' %></textarea>
            </div>
            <% } %>

            <% } %>

            <% } %>

            <% if (template !== 'photo-resume' && isSectionEnabled('hobbies')) { %>
            <div class="rb-field">
